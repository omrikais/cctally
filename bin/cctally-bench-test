#!/usr/bin/env bash
# Structural / determinism self-test for the backend benchmark harness
# (issue #276, M3 / Session B). Runs bin/cctally-bench at --scale small and
# asserts the --json schema (all 14 benchmark families, finite ordered
# medians) + isolation (the real ~/.local/share/cctally and ~/.claude are
# untouched). It NEVER asserts wall-clock timings — the only committed
# timings live in bench/baselines/backend.json as advisory data.
#
# Auto-discovered by bin/cctally-test-all via its bin/cctally-*-test glob once
# `chmod +x`'d (no registration needed). Emits the standard `PASS <name>` /
# `FAIL <name>` lines + a final `passed: N   failed: M` summary the aggregator
# parses.
set -uo pipefail

# Shared dev-autodetect suppressor preamble (exports
# CCTALLY_DISABLE_DEV_AUTODETECT=1); coverage enforced by
# tests/test_harness_dev_autodetect_coverage.py.
. "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_lib-harness-env.sh"

REPO_ROOT=$(cd "$(dirname "$0")/.." && pwd)
BENCH="$REPO_ROOT/bin/cctally-bench"

pass_count=0
fail_count=0

report() {
    local status="$1" name="$2" detail="${3:-}"
    if [ "$status" = PASS ]; then
        printf 'PASS %s\n' "$name"
        pass_count=$((pass_count + 1))
    else
        printf 'FAIL %s%s\n' "$name" "${detail:+: $detail}"
        fail_count=$((fail_count + 1))
    fi
}

# True iff the path exists (any type).
exists() { [ -e "$1" ] && echo yes || echo no; }

# Isolation is asserted POSITIVELY — the bench must write its cache.db into the
# scratch CCTALLY_DATA_DIR, which only happens when CCTALLY_DATA_DIR is honored
# (an un-pinned bench would write the REAL ~/.local/share/cctally/cache.db and
# the scratch cache.db would never appear). This is robust against a live
# cctally instance concurrently writing the real dir (statusline / hook-tick),
# which a strict "real dir byte-frozen" assertion would false-flag. As a
# clean-machine backstop we also check the real dirs were not CREATED from
# absent.
REAL_CACHE="$HOME/.local/share/cctally"
REAL_CLAUDE="$HOME/.claude/projects"
cache_existed=$(exists "$REAL_CACHE")
claude_existed=$(exists "$REAL_CLAUDE")

SCRATCH=$(mktemp -d -t cctally-bench-selftest-XXXXXX)
trap 'rm -rf "$SCRATCH"' EXIT

# Pin BOTH env axes (Codex-P1 isolation) + TZ + dev-autodetect off, and pass an
# explicit scratch --root so the trap cleans everything the run wrote.
out=$(CCTALLY_DATA_DIR="$SCRATCH/data" \
      CLAUDE_CONFIG_DIR="$SCRATCH/claude" \
      CCTALLY_DISABLE_DEV_AUTODETECT=1 \
      TZ=Etc/UTC \
      "$BENCH" --scale small --iterations 2 --json --root "$SCRATCH" \
      2>"$SCRATCH/err")
rc=$?

if [ $rc -ne 0 ]; then
    report FAIL bench-run "cctally-bench exited $rc"
    echo "---- bench stderr ----" >&2
    sed -n '1,40p' "$SCRATCH/err" >&2
else
    report PASS bench-run
    # Schema + benchmark-name assertions (no timing thresholds). The JSON is
    # passed via BENCH_JSON (not stdin) because the here-doc already redirects
    # stdin to feed python3 its program text.
    if BENCH_JSON="$out" python3 - <<'PY'
import json, os
d = json.loads(os.environ["BENCH_JSON"])
assert d["schemaVersion"] == 1, f"schemaVersion={d.get('schemaVersion')}"
for k in ("cctally_version", "machine_label", "scale", "seed",
          "dataset_counts", "benchmarks"):
    assert k in d, f"missing top-level key {k!r}"
need = {
    "snapshot.cold", "snapshot.warm", "snapshot.idle",
    "sync.noop", "sync.delta",
    "conversations.page1", "conversations.sorted", "conversations.filtered",
    "search.cross_session", "find.in_conversation",
    "payload.assemble", "outline.build",
    "reconcile.cache_report", "reconcile.projects_env",
}
missing = need - set(d["benchmarks"])
assert not missing, f"missing benchmarks: {sorted(missing)}"
for name, b in d["benchmarks"].items():
    for k in ("median_ms", "min_ms", "max_ms", "count", "bytes", "phases"):
        assert k in b, f"{name} missing meta key {k!r}"
    m, lo, hi = b["median_ms"], b["min_ms"], b["max_ms"]
    assert lo <= m <= hi, f"{name} unordered: min={lo} median={m} max={hi}"
    assert m >= 0, f"{name} negative median {m}"
PY
    then
        report PASS json-schema
    else
        report FAIL json-schema "schema assertion failed"
    fi
fi

# Isolation (positive): the bench wrote its cache.db into the scratch
# CCTALLY_DATA_DIR — proving CCTALLY_DATA_DIR was honored, so it did NOT write
# the real ~/.local/share/cctally/cache.db.
if [ -s "$SCRATCH/data/cache.db" ]; then
    report PASS isolation-scratch-cache-db
else
    report FAIL isolation-scratch-cache-db "scratch cache.db missing/empty — CCTALLY_DATA_DIR not honored?"
fi
# Isolation (positive): the generator wrote synthetic JSONL under the scratch
# Claude root — proving CLAUDE_CONFIG_DIR was the ingest source, not real ~/.claude.
if [ -n "$(find "$SCRATCH/claude/projects" -name '*.jsonl' -print -quit 2>/dev/null)" ]; then
    report PASS isolation-scratch-claude-root
else
    report FAIL isolation-scratch-claude-root "no synthetic JSONL under scratch Claude root"
fi
# Isolation (clean-machine backstop): the real dirs must not be CREATED from
# absent by the run. On a machine where they already exist (a live cctally
# install), a concurrent statusline/hook-tick write is not the bench's doing,
# so we don't compare mtimes — the scratch checks above are the real guard.
if [ "$cache_existed" = no ] && [ "$(exists "$REAL_CACHE")" = yes ]; then
    report FAIL isolation-real-cache-dir "$REAL_CACHE was created by the run"
else
    report PASS isolation-real-cache-dir
fi
if [ "$claude_existed" = no ] && [ "$(exists "$REAL_CLAUDE")" = yes ]; then
    report FAIL isolation-real-claude-root "$REAL_CLAUDE was created by the run"
else
    report PASS isolation-real-claude-root
fi

echo "passed: $pass_count   failed: $fail_count"
[ "$fail_count" -eq 0 ] || exit 1
