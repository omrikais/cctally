#!/usr/bin/env python3
"""cctally-release — maintainer-only release driver. Not shipped to end users.

Six idempotent phases:
  1. Stamp CHANGELOG.md (move [Unreleased] entries under [X.Y.Z]).
  2. Annotated tag vX.Y.Z + push --follow-tags.
  3. Mirror push (replay private → push public branch + tag).
  4. GitHub Release create on the public mirror.
  5. npm publish via OIDC trusted publisher (observed).
  6. Homebrew formula bump.

See docs/RELEASE.md for the full operator manual.
"""

from __future__ import annotations

import sys

__min_python_version__ = (3, 13)

if sys.version_info < __min_python_version__:
    print(
        f"cctally-release requires Python {'.'.join(map(str, __min_python_version__))}+, "
        f"but {sys.version.split()[0]} is in use.",
        file=sys.stderr,
    )
    sys.exit(2)

import argparse
import importlib.machinery
import importlib.util
import pathlib
import textwrap

_BIN = pathlib.Path(__file__).resolve().parent


def _load(name: str, path: pathlib.Path):
    # `bin/cctally` has no `.py` suffix, so spec_from_file_location()
    # returns None; an explicit SourceFileLoader handles that case
    # uniformly with the `.py` siblings.
    loader = importlib.machinery.SourceFileLoader(name, str(path))
    spec = importlib.util.spec_from_loader(name, loader)
    mod = importlib.util.module_from_spec(spec)
    sys.modules[name] = mod
    loader.exec_module(mod)
    return mod


# Load bin/cctally as a regular module under the canonical name "cctally" so
# `_cctally_release`'s `_cctally()` accessor finds it via sys.modules. The
# `if __name__ == "__main__":` guard in bin/cctally prevents its main() from
# firing on load. We then load `_cctally_release.py` so its `cmd_release`
# entry-point is available.
cctally = _load("cctally", _BIN / "cctally")
_release = _load("_cctally_release", _BIN / "_cctally_release.py")


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        prog="cctally-release",
        formatter_class=cctally.CLIHelpFormatter,
        description=textwrap.dedent(
            """\
            Maintainer release driver. Six idempotent phases:
              1. Stamp CHANGELOG.md (move [Unreleased] entries under [X.Y.Z]).
              2. Annotated tag vX.Y.Z + push --follow-tags.
              3. Mirror push (replay private → push public branch + tag).
              4. GitHub Release create on the public mirror.
              5. npm publish via OIDC trusted publisher (observed).
              6. Homebrew formula bump.

            See docs/RELEASE.md for full reference.
            """
        ),
    )
    parser.add_argument(
        "kind",
        nargs="?",
        choices=["patch", "minor", "major", "prerelease", "finalize"],
        help="Bump kind (omit only with --resume)",
    )
    parser.add_argument(
        "--resume",
        action="store_true",
        help="Continue an in-progress release (infers vX.Y.Z from latest CHANGELOG header)",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print phase plan with diff/tag/release; mutate nothing; exit 0",
    )
    parser.add_argument(
        "--no-publish",
        action="store_true",
        help="Stop after Phase 2 (tag); skip Phases 3-6 (mirror, gh release, npm, brew)",
    )
    parser.add_argument(
        "--prerelease-id",
        default="rc",
        help="Override 'rc' for prerelease bumps (default 'rc')",
    )
    parser.add_argument(
        "--bump",
        choices=["patch", "minor", "major"],
        help="REQUIRED with `prerelease` when current is stable; REFUSED when current is prerelease",
    )
    parser.add_argument(
        "--remote",
        default="origin",
        help="Default 'origin' (private remote)",
    )
    parser.add_argument(
        "--allow-branch",
        default=None,
        help="Override the on-main refusal (escape hatch)",
    )
    parser.add_argument(
        "--public-clone",
        default=None,
        help="Override public-clone discovery (default: git config 'release.publicClone' or marker file)",
    )
    parser.add_argument(
        "--skip-npm",
        action="store_true",
        help="Skip Phase 5 (npm publish). Idempotent: re-running --resume without it picks the channel back up.",
    )
    parser.add_argument(
        "--brew-clone",
        default=None,
        help="Override brew tap discovery (default: git config 'release.brewClone' or marker file)",
    )
    parser.add_argument(
        "--skip-brew",
        action="store_true",
        help="Skip Phase 6 (brew formula bump). Idempotent: re-running --resume without it picks the channel back up.",
    )
    parser.add_argument(
        "--allow-formula-downgrade",
        action="store_true",
        help="Override Phase 6's monotonic-version gate (issue #30). Use only for intentional yank/revert cases — Phase 6 normally refuses to write a formula whose URL pins a lower SemVer than the on-disk formula.",
    )

    args = parser.parse_args(argv)
    rc = _release.cmd_release(args)
    return int(rc) if rc is not None else 0


if __name__ == "__main__":
    sys.exit(main())
