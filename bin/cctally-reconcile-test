# ─── Invariant PROJBUDGET1: per-project budget spend + fired consumption_pct ──
# (Task 3, spec §9.4) TWO independent paths reconcile within 1e-9 over the
# seeded `per-project` window:
#   (A) Σ `budget --json .projects[].spent_usd` ≡ the SAME per-project costs
#       `project --json .projects[].costUsd` reports for the matching
#       projectPath. Two different commands, two different aggregation entry
#       points, one underlying `_sum_cost_by_project` truth — so a drift in
#       either consumer is caught.
#   (B) The alert-fire `consumption_pct` (written into `project_budget_milestones`
#       by the ACTUAL reconcile path `_reconcile_project_budget_milestones_on_write`)
#       ≡ the displayed `budget --json .projects[].consumption_pct` for the same
#       project. We DRIVE the real reconcile (not a re-derivation) so the fired
#       value is bound to the displayed value by construction — exactly how the
#       PROJECTED1 invariant binds the projected detector to the displayed
#       week-avg field.
# Mirrors the BUDGET1 / PROJECTED1 structure (load `bin/cctally`, drive the real
# path, assert against the published JSON within 1e-9).
PROJBUDGET1_PY='
import json, os, sys, importlib.util
from importlib.machinery import SourceFileLoader

budget = json.loads(os.environ["RECONCILE_A"])   # budget --json
project = json.loads(os.environ["RECONCILE_B"])   # project --json

# ── (A) per-project spend reconciliation: budget.projects[].spent_usd ≡
#        project.projects[].costUsd for the matching projectPath ─────────────
proj_cost = {p["projectPath"]: p["costUsd"] for p in project["projects"]}
bproj = {p["project_key"]: p for p in budget.get("projects", [])}
assert bproj, "PROJBUDGET1 vacuous: budget --json carried no projects[]"
matched = 0
for key, row in bproj.items():
    spent_budget = row["spent_usd"]
    # A configured project with no spend this window is absent from project
    # --json (it renders a $0 budget row); skip it from the spend-equality leg.
    if key not in proj_cost:
        assert abs(spent_budget) < 1e-9, (
            f"PROJBUDGET1: {key} has budget spent_usd={spent_budget} but no "
            f"project --json row"
        )
        continue
    matched += 1
    assert abs(spent_budget - proj_cost[key]) < 1e-9, (
        f"PROJBUDGET1 (A): budget.spent_usd={spent_budget} != "
        f"project.costUsd={proj_cost[key]} for {key}"
    )
assert matched > 0, "PROJBUDGET1 (A) vacuous: no configured project matched a project --json row"

# ── (B) fired consumption_pct ≡ displayed consumption_pct ──────────────────
bin_dir = os.environ["PROJBUDGET_BIN_DIR"]
sys.path.insert(0, bin_dir)
loader = SourceFileLoader("cctally", os.path.join(bin_dir, "cctally"))
spec = importlib.util.spec_from_loader("cctally", loader)
c = importlib.util.module_from_spec(spec); sys.modules["cctally"] = c
loader.exec_module(c)

# Drive the REAL reconcile path (record without dispatch) with project alerts
# forced active over the SAME projects + thresholds the displayed status used.
thresholds = list(budget.get("alert_thresholds") or [90, 100])
validated = {
    "projects": {row["project_key"]: row["budget_usd"] for row in budget["projects"]},
    "project_alerts_enabled": True,
    "alert_thresholds": thresholds,
}
c._reconcile_project_budget_milestones_on_write(validated)

conn = c.open_db()
fired = {}
for r in conn.execute(
    "SELECT project_key, consumption_pct FROM project_budget_milestones"
):
    fired[r["project_key"]] = float(r["consumption_pct"])
conn.close()

# Non-vacuity: at least one project must be over a threshold so a row was fired.
assert fired, "PROJBUDGET1 (B) vacuous: no project_budget_milestones rows were fired"
displayed = {p["project_key"]: p["consumption_pct"] for p in budget["projects"]}
for key, fired_pct in fired.items():
    disp = displayed.get(key)
    assert disp is not None, f"PROJBUDGET1 (B): fired {key} not in displayed projects[]"
    assert abs(fired_pct - disp) < 1e-9, (
        f"PROJBUDGET1 (B): fired consumption_pct={fired_pct} != "
        f"displayed consumption_pct={disp} for {key}"
    )
'
pb_home="$FIXTURES/budget/per-project"
if [ -f "$pb_home/input.env" ]; then
    AS_OF=""
    # shellcheck disable=SC1091
    . "$pb_home/input.env"
    pb_budget=$(HOME="$pb_home" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
        "$BIN" budget --json 2>/dev/null); rc_b=$?
    pb_project=$(HOME="$pb_home" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
        "$BIN" project --json 2>/dev/null); rc_p=$?
    if [ $rc_b -ne 0 ] || [ $rc_p -ne 0 ]; then
        echo "RECONCILE FAIL project_budget_spend_and_fired_pct budget/per-project: budget rc=$rc_b project rc=$rc_p"
        fail_count=$((fail_count + 1))
    else
        result=$(RECONCILE_A="$pb_budget" RECONCILE_B="$pb_project" \
            PROJBUDGET_BIN_DIR="$REPO_ROOT/bin" \
            HOME="$pb_home" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
            CCTALLY_DISABLE_DEV_AUTODETECT=1 \
            python3 -c "$PROJBUDGET1_PY" 2>&1); rc_py=$?
        if [ $rc_py -ne 0 ]; then
            echo "RECONCILE FAIL project_budget_spend_and_fired_pct budget/per-project: $result"
            fail_count=$((fail_count + 1))
        else
            echo "PASS project_budget_spend_and_fired_pct budget/per-project"
            pass_count=$((pass_count + 1))
        fi
    fi
else
    echo "RECONCILE FAIL project_budget_spend_and_fired_pct budget/per-project: fixture missing"
    fail_count=$((fail_count + 1))
fi

# ─── Invariant TRANSCRIPT1: /api/data.transcriptsEnabled == the gate ────
# Conversation viewer (Plan 2, spec §5/§6.9). The dashboard injects a
# per-request `transcriptsEnabled` into `/api/data` via
# `_transcripts_visible_to_request`, whose body is exactly
#
#     transcripts_allowed(bind, expose)
#         AND host_allowed_for_transcripts(Host, expose)
#
# over the two pure predicates in `bin/_lib_transcript_access.py`. The same
# composition gates the three conversation GET routes (403 on false), so a
# request that would 403 must show `transcriptsEnabled=false`, never
# enabled-then-403. This invariant locks the injected value to the kernel
# predicates DIRECTLY across the (bind, expose, Host) truth-table:
#
#   bind       expose  Host                  expected
#   loopback   off     loopback              True
#   loopback   off     LAN-hostname          False   (Host not loopback)
#   LAN        off     *                     False   (bind gate closed)
#   LAN        on      IP-literal            True    (can't be DNS-rebound)
#   LAN        on      hostname              False   (rebinding vector)
#
# The dashboard glue (`_cctally_dashboard.py`) keeps a SINGLE definition of
# this composition (`_transcripts_visible_to_request`) that both the GET-route
# 403 gate and the `/api/data` client signal route through — so locking the
# composition to the kernel predicates here pins both surfaces.
transcripts_enabled_eq_gate_invariant () {
    local name="transcripts_enabled_eq_gate"
    local result rc_py
    result=$(REPO_ROOT="$REPO_ROOT" python3 -c '
import os
import sys

repo_root = os.environ["REPO_ROOT"]
sys.path.insert(0, os.path.join(repo_root, "bin"))

import _lib_transcript_access as ta


def visible(bind, expose, host):
    """Re-derivation of the endpoint composition (see
    `_cctally_dashboard.DashboardHTTPHandler._transcripts_visible_to_request`):
    the bind gate AND the per-request Host allowlist."""
    return (ta.transcripts_allowed(bind, expose)
            and ta.host_allowed_for_transcripts(host, expose))


# (bind, expose, Host) -> expected transcriptsEnabled
truth_table = [
    ("127.0.0.1", False, "127.0.0.1:8789", True),
    ("127.0.0.1", False, "dashboard.lan:8789", False),
    ("0.0.0.0",   False, "192.168.0.9:8789", False),
    ("0.0.0.0",   False, "127.0.0.1:8789",   False),
    ("0.0.0.0",   True,  "192.168.0.9:8789", True),
    ("0.0.0.0",   True,  "[fe80::1]:8789",   True),
    ("0.0.0.0",   True,  "evil.attacker.com", False),
    ("0.0.0.0",   True,  "machine.local:8789", False),
]
for bind, expose, host, expected in truth_table:
    got = visible(bind, expose, host)
    if bool(got) is not bool(expected):
        sys.exit(
            f"transcriptsEnabled mismatch for bind={bind!r} expose={expose} "
            f"Host={host!r}: gate={got} expected={expected}"
        )
' 2>&1); rc_py=$?
    if [ $rc_py -ne 0 ]; then
        echo "RECONCILE FAIL $name: $result"
        fail_count=$((fail_count + 1))
    else
        echo "PASS $name (transcriptsEnabled == gate truth-table)"
        pass_count=$((pass_count + 1))
    fi
}
transcripts_enabled_eq_gate_invariant

# ─── Invariant CODEXBUDGET1: Codex budget spend ≡ Σ codex-daily costUSD ──────
# (calendar-period + Codex budgets, spec §7.2) TWO independent paths reconcile
# within 1e-9 over the seeded `both-vendors` Codex calendar-month window:
#   (A) `budget --json .codex.spent_usd` (computed via _sum_codex_cost_for_range
#       over the cache DB) ≡ Σ `codex-daily --json .daily[].costUSD` for the
#       days inside the resolved Codex period window [period_start_at, as_of).
#   Two different commands, two different aggregation entry points, one
#   underlying _calculate_codex_entry_cost truth — so a drift in either consumer
#   is caught. Mirrors the codex_weekly_eq_sum_codex_daily structure.
CODEXBUDGET1_PY='
import json, os, datetime as dt
b = json.loads(os.environ["RECONCILE_A"])   # budget --json
d = json.loads(os.environ["RECONCILE_B"])   # codex-daily --json

codex = b.get("codex")
assert codex is not None, "CODEXBUDGET1 vacuous: budget --json carried no codex block"
spent_budget = codex["spent_usd"]
ps = dt.datetime.fromisoformat(codex["period_start_at"].replace("Z", "+00:00"))
now = dt.datetime.fromisoformat(codex["as_of"].replace("Z", "+00:00"))
ps_date = ps.date()
now_date = now.date()

def parse_date(s):
    return dt.datetime.strptime(s, "%b %d, %Y").date()

# Σ codex-daily costUSD for bucket-days inside [period_start, as_of]. The
# fixture seeds all Codex entries on one day strictly inside the window, so the
# whole-history codex-daily sum equals the budget spend; the date filter keeps
# the invariant correct if the fixture ever spans the boundary.
daily_sum = sum(
    r["costUSD"] for r in d.get("daily", [])
    if ps_date <= parse_date(r["date"]) <= now_date
)
assert daily_sum > 0, "CODEXBUDGET1 vacuous: codex-daily sum is 0 (no Codex spend seeded)"
assert abs(spent_budget - daily_sum) < 1e-9, (
    f"CODEXBUDGET1: budget.codex.spent_usd={spent_budget} != "
    f"Σcodex_daily.costUSD={daily_sum}"
)
'
reconcile_invariant "codex_budget_spend_eq_sum_codex_daily" \
    "$FIXTURES/budget/both-vendors" \
    "budget --json" \
    "codex-daily --json" \
    "$CODEXBUDGET1_PY"

# ─── Invariant CODEXBUDGET2: codex_budget latching == displayed Codex spend ──
# (calendar-period + Codex budgets, spec §6; unified vendor-tagged table #143)
# Parallels PROJBUDGET1 (B) for the Codex axis: DRIVE the REAL
# forward-only-from-set reconcile against the merged table
# (`_reconcile_budget_milestones_on_set(vendor="codex", …)`) and assert the
# fired `consumption_pct` row binds — by construction, not re-derivation — to the
# displayed `budget --json .codex.spent_usd` over the same resolved period
# window. We force a small Codex target so the seeded Codex spend ($15) crosses
# the 90/100 thresholds (the seeded `both-vendors` Codex budget is at 7.5%, far
# below any threshold), then assert (reading `budget_milestones WHERE
# vendor='codex'`):
#   (A) each fired row's consumption_pct == displayed_spent / forced_target * 100
#       within 1e-9 (binds the reconcile path's _sum_codex_cost_for_range to the
#       displayed .codex.spent_usd);
#   (B) every row carries alerted_at SET (forward-only-from-set: recorded WITHOUT
#       dispatch — no instant popup on a mid-period set already over);
#   (C) a SECOND reconcile run inserts NO new rows (fire-once / latching via
#       UNIQUE(vendor, period_start_at, period, threshold) + the alerted_at IS
#       NULL UPDATE guard);
#   (D) every row carries the CONFIGURED period (#137 period-row consistency).
# Non-vacuity: assert at least one row fired (the forced target guarantees a
# crossing) — a regression that stopped recording would trip (A)'s row-count or
# the explicit `fired` guard.
CODEXBUDGET2_PY='
import json, os, sys, importlib.util
from importlib.machinery import SourceFileLoader

budget = json.loads(os.environ["RECONCILE_A"])   # budget --json
# Vendor passed in via env (sibling PROJECTED3 convention) so the SQL value
# binds as a parameter and this body needs no nested shell-quote escaping.
vendor = os.environ["RECONCILE_VENDOR"]
codex = budget.get("codex")
assert codex is not None, "CODEXBUDGET2 vacuous: budget --json carried no codex block"
displayed_spent = float(codex["spent_usd"])
assert displayed_spent > 0, "CODEXBUDGET2 vacuous: displayed Codex spend is 0"
period = codex["period"]
thresholds = list(codex.get("alert_thresholds") or [90, 100])

bin_dir = os.environ["CODEXBUDGET_BIN_DIR"]
sys.path.insert(0, bin_dir)
loader = SourceFileLoader("cctally", os.path.join(bin_dir, "cctally"))
spec = importlib.util.spec_from_loader("cctally", loader)
c = importlib.util.module_from_spec(spec); sys.modules["cctally"] = c
loader.exec_module(c)

import argparse
config = c.load_config()
tz = c.resolve_display_tz(argparse.Namespace(tz=None), config)
now_utc = c._command_as_of()

# Force a small target so the seeded $15 Codex spend crosses 90 AND 100.
forced_target = 15.0
expected_pct = displayed_spent / forced_target * 100.0

def run_reconcile():
    conn = c.open_db()
    try:
        c._reconcile_budget_milestones_on_set(
            conn, vendor="codex", target=forced_target, thresholds=thresholds,
            now_utc=now_utc, period=period, config=config, tz=tz,
        )
    finally:
        conn.close()

run_reconcile()
conn = c.open_db()
rows = conn.execute(
    "SELECT vendor, threshold, period, consumption_pct, alerted_at "
    "FROM budget_milestones WHERE vendor = ? ORDER BY threshold",
    (vendor,),
).fetchall()
n_after_first = len(rows)
conn.close()

assert rows, "CODEXBUDGET2 (non-vacuity): no codex budget_milestones rows fired"
# (A) fired consumption_pct binds to the displayed Codex spend / forced target.
for r in rows:
    # Every fired row carries the Codex vendor tag in the unified table (#143).
    assert r["vendor"] == vendor, (
        "CODEXBUDGET2 (vendor): threshold %s tagged vendor=%r != %r"
        % (r["threshold"], r["vendor"], vendor)
    )
    fired_pct = float(r["consumption_pct"])
    assert abs(fired_pct - expected_pct) < 1e-9, (
        f"CODEXBUDGET2 (A): fired consumption_pct={fired_pct} != "
        f"displayed_spent/target*100={expected_pct}"
    )
    # (B) forward-only-from-set: recorded WITH alerted_at, never dispatched.
    assert r["alerted_at"] is not None, (
        "CODEXBUDGET2 (B): threshold %s recorded without alerted_at" % r["threshold"]
    )
    # (D) period-row consistency (#137): the reconcile path stamps the
    # CONFIGURED period into every fired row (never NULL, never a stale noun).
    assert r["period"] == period, (
        "CODEXBUDGET2 (D): threshold %s stored period=%r != configured %r"
        % (r["threshold"], r["period"], period)
    )

# (C) fire-once / latching: a second reconcile inserts no new rows.
run_reconcile()
conn = c.open_db()
n_after_second = conn.execute(
    "SELECT COUNT(*) FROM budget_milestones WHERE vendor = ?", (vendor,)
).fetchone()[0]
conn.close()
assert n_after_second == n_after_first, (
    f"CODEXBUDGET2 (C): re-run inserted rows ({n_after_first} -> {n_after_second}) "
    f"— latching/fire-once broken"
)
'
cb_home="$FIXTURES/budget/both-vendors"
if [ -f "$cb_home/input.env" ]; then
    AS_OF=""
    # shellcheck disable=SC1091
    . "$cb_home/input.env"
    cb_budget=$(HOME="$cb_home" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
        "$BIN" budget --json 2>/dev/null); rc_b=$?
    if [ $rc_b -ne 0 ]; then
        echo "RECONCILE FAIL codex_budget_latching_eq_displayed_spend budget/both-vendors: budget rc=$rc_b"
        fail_count=$((fail_count + 1))
    else
        result=$(RECONCILE_A="$cb_budget" RECONCILE_VENDOR="codex" \
            CODEXBUDGET_BIN_DIR="$REPO_ROOT/bin" \
            HOME="$cb_home" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
            CCTALLY_DISABLE_DEV_AUTODETECT=1 \
            python3 -c "$CODEXBUDGET2_PY" 2>&1); rc_py=$?
        if [ $rc_py -ne 0 ]; then
            echo "RECONCILE FAIL codex_budget_latching_eq_displayed_spend budget/both-vendors: $result"
            fail_count=$((fail_count + 1))
        else
            echo "PASS codex_budget_latching_eq_displayed_spend budget/both-vendors"
            pass_count=$((pass_count + 1))
        fi
    fi
else
    echo "RECONCILE FAIL codex_budget_latching_eq_displayed_spend budget/both-vendors: fixture missing"
    fail_count=$((fail_count + 1))
fi

# ─── Invariant BUDGETCOEXIST: claude + codex coexist on an IDENTICAL key (#143) ─
# The vendor-tagged merge's defining invariant — and the SOLE reason `vendor`
# leads the UNIQUE(vendor, period_start_at, period, threshold) key: a Claude
# crossing and a Codex crossing that land on an IDENTICAL
# (period_start_at, period, threshold) must BOTH survive in the merged table.
# Without `vendor` in the key the INSERT OR IGNORE would drop the second writer's
# row (3-tuple collision). The earlier form of this test only fired the seeded
# `both-vendors` budgets (Claude subscription-week vs Codex calendar-month) —
# whose keys differ on BOTH period_start_at AND period independently, so they
# could never collide even WITHOUT the vendor column: the coexistence assertion
# was tautological and never exercised the vendor-in-key requirement.
#
# We now FORCE the collision: drive BOTH vendors through the SAME calendar-month
# period over the `both-vendors` fixture. `_resolve_budget_window` then yields the
# IDENTICAL period_start_at (2026-05-01T00:00:00+00:00) and the same
# period='calendar-month' for each vendor, and both seeded spends (Claude $72,
# Codex $15) cross the same forced 90/100 thresholds — so each (90, 100) threshold
# is written ONCE per vendor on a byte-identical 3-tuple. We fire both vendors'
# REAL forward-only-from-set reconcile
# (`_reconcile_budget_milestones_on_set(vendor=…, period='calendar-month', …)`)
# into one DB, then assert:
#   (1) each fired row's `vendor` matches its writer (claude rows tagged
#       'claude', codex rows tagged 'codex') — the row-level split that lets one
#       physical table serve both axes;
#   (2) SAME-KEY COEXISTENCE (load-bearing): for every (period_start_at, period,
#       threshold) 3-tuple that BOTH vendors crossed, EXACTLY 2 rows exist — one
#       vendor='claude' and one vendor='codex'. Drop `vendor` from the UNIQUE key
#       and the second INSERT OR IGNORE is dropped → 1 row → this assertion goes
#       RED (proven non-vacuous below);
#   (3) non-vacuity: claude_count > 0 AND codex_count > 0 (both writers fired) AND
#       at least one shared 3-tuple actually collided across vendors.
BUDGETCOEXIST_PY='
import json, os, sys, importlib.util
from collections import Counter
from importlib.machinery import SourceFileLoader

budget = json.loads(os.environ["RECONCILE_A"])   # budget --json
# Claude budget is top-level; Codex budget nests under .codex. We re-resolve both
# vendors over a SHARED calendar-month window below (NOT the displayed periods) so
# the keys genuinely collide; the displayed spends only gate non-vacuity.
codex = budget.get("codex")
assert codex is not None, "BUDGETCOEXIST vacuous: budget --json carried no codex block"
assert float(budget["spent_usd"]) > 0, "BUDGETCOEXIST vacuous: displayed Claude spend is 0"
assert float(codex["spent_usd"]) > 0, "BUDGETCOEXIST vacuous: displayed Codex spend is 0"
thresholds = [90, 100]
# Force BOTH vendors onto the SAME period so their resolved keys collide.
shared_period = "calendar-month"

bin_dir = os.environ["CODEXBUDGET_BIN_DIR"]
sys.path.insert(0, bin_dir)
loader = SourceFileLoader("cctally", os.path.join(bin_dir, "cctally"))
spec = importlib.util.spec_from_loader("cctally", loader)
c = importlib.util.module_from_spec(spec); sys.modules["cctally"] = c
loader.exec_module(c)

import argparse
config = c.load_config()
tz = c.resolve_display_tz(argparse.Namespace(tz=None), config)
now_utc = c._command_as_of()

# Resolve the SHARED calendar-month window per vendor + its real spend over that
# window (the costly leg), so we can force a target that crosses both thresholds.
conn = c.open_db()
try:
    spend = {}
    for vendor in ("claude", "codex"):
        win = c._cctally_milestones._resolve_budget_window(
            conn, vendor=vendor, now_utc=now_utc, period=shared_period,
            config=config, tz=tz,
        )
        assert win is not None, (
            "BUDGETCOEXIST: %s resolved no calendar-month window" % vendor
        )
        spend[vendor] = (
            win,
            c._cctally_milestones._budget_spend_for_vendor(
                conn, vendor=vendor, start_at=win, now_utc=now_utc
            ),
        )
finally:
    conn.close()

# Both vendors MUST resolve the IDENTICAL period-start instant on calendar-month
# — that identity is the whole premise of the collision test.
claude_start, claude_spend = spend["claude"]
codex_start, codex_spend = spend["codex"]
assert claude_start == codex_start, (
    "BUDGETCOEXIST: calendar-month period-start diverged across vendors "
    "(claude=%s codex=%s) — same-key collision premise broken"
    % (claude_start.isoformat(), codex_start.isoformat())
)
assert claude_spend > 0 and codex_spend > 0, (
    "BUDGETCOEXIST vacuous: a vendor has $0 spend over the shared calendar-month "
    "window (claude=%s codex=%s)" % (claude_spend, codex_spend)
)
shared_key = claude_start.isoformat(timespec="seconds")

# Force a small per-vendor target so each vendor crosses BOTH 90 and 100
# (~150% consumption against its real shared-window spend).
claude_target = claude_spend / 1.5
codex_target = codex_spend / 1.5

# Fire BOTH vendors REAL forward-only-from-set reconcile on the SAME period into
# ONE DB. Each (90, 100) threshold is now a byte-identical
# (period_start_at, period, threshold) 3-tuple differing ONLY by vendor.
conn = c.open_db()
try:
    c._reconcile_budget_milestones_on_set(
        conn, vendor="claude", target=claude_target, thresholds=thresholds,
        now_utc=now_utc, period=shared_period, config=config, tz=tz,
    )
    c._reconcile_budget_milestones_on_set(
        conn, vendor="codex", target=codex_target, thresholds=thresholds,
        now_utc=now_utc, period=shared_period, config=config, tz=tz,
    )
finally:
    conn.close()

conn = c.open_db()
rows = conn.execute(
    "SELECT vendor, period_start_at, period, threshold FROM budget_milestones"
).fetchall()
conn.close()

claude_rows = [r for r in rows if r["vendor"] == "claude"]
codex_rows = [r for r in rows if r["vendor"] == "codex"]
claude_count = len(claude_rows)
codex_count = len(codex_rows)

# (3) non-vacuity: both writers fired.
assert claude_count > 0, "BUDGETCOEXIST: no claude rows fired (forced target should cross)"
assert codex_count > 0, "BUDGETCOEXIST: no codex rows fired (forced target should cross)"
# (1) every row carries the vendor tag of its writer (no foreign-vendor rows).
assert all(r["vendor"] in ("claude", "codex") for r in rows), (
    "BUDGETCOEXIST: a fired row carries an unexpected vendor tag"
)

# (2) SAME-KEY COEXISTENCE (load-bearing). For every (period_start_at, period,
# threshold) 3-tuple, count the surviving rows by vendor. Each tuple that BOTH
# vendors crossed must hold EXACTLY 2 rows — one claude, one codex. WITHOUT
# `vendor` in the UNIQUE key the second INSERT OR IGNORE is dropped → 1 row →
# this assertion goes RED (see the non-vacuity proof in the commit body).
by_tuple = {}
for r in rows:
    key = (r["period_start_at"], r["period"], r["threshold"])
    by_tuple.setdefault(key, Counter())[r["vendor"]] += 1

shared_tuples = [
    (st, pd, th) for st in (shared_key,) for pd in (shared_period,)
    for th in thresholds
]
collided = 0
for key in shared_tuples:
    vendors = by_tuple.get(key)
    assert vendors is not None, (
        "BUDGETCOEXIST: expected both vendors at %r but found no rows" % (key,)
    )
    assert vendors.get("claude", 0) == 1 and vendors.get("codex", 0) == 1 \
        and sum(vendors.values()) == 2, (
        "BUDGETCOEXIST (same-key): %r holds %r rows != exactly one claude + one "
        "codex — a cross-vendor UNIQUE collision dropped a row (the vendor column "
        "is what keeps both)" % (key, dict(vendors))
    )
    collided += 1
# Non-vacuity for (2): at least one shared 3-tuple actually had a cross-vendor
# collision to resolve (otherwise the EXACTLY-2 assertion never ran).
assert collided > 0, (
    "BUDGETCOEXIST (same-key) vacuous: no shared (period_start_at, period, "
    "threshold) tuple was crossed by BOTH vendors"
)
'
co_home="$FIXTURES/budget/both-vendors"
if [ -f "$co_home/input.env" ]; then
    AS_OF=""
    # shellcheck disable=SC1091
    . "$co_home/input.env"
    co_budget=$(HOME="$co_home" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
        "$BIN" budget --json 2>/dev/null); rc_b=$?
    if [ $rc_b -ne 0 ]; then
        echo "RECONCILE FAIL budget_vendors_coexist budget/both-vendors: budget rc=$rc_b"
        fail_count=$((fail_count + 1))
    else
        result=$(RECONCILE_A="$co_budget" \
            CODEXBUDGET_BIN_DIR="$REPO_ROOT/bin" \
            HOME="$co_home" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
            CCTALLY_DISABLE_DEV_AUTODETECT=1 \
            python3 -c "$BUDGETCOEXIST_PY" 2>&1); rc_py=$?
        if [ $rc_py -ne 0 ]; then
            echo "RECONCILE FAIL budget_vendors_coexist budget/both-vendors: $result"
            fail_count=$((fail_count + 1))
        else
            echo "PASS budget_vendors_coexist budget/both-vendors"
            pass_count=$((pass_count + 1))
        fi
    fi
else
    echo "RECONCILE FAIL budget_vendors_coexist budget/both-vendors: fixture missing"
    fail_count=$((fail_count + 1))
fi

# ============================================================================
# U-PCT: usage-% cross-surface invariants (#281 S6 / #280 R5, spec §2)
# ----------------------------------------------------------------------------
# The usage-% chain (statusline 7d <-> weekly Used % <-> report/forecast p_now
# <-> dashboard envelope <-> project) has per-surface pytest coverage but no
# CROSS-surface reconcile invariant. This group pins that every surface reads
# the SAME reset-aware value in three scenarios.
#
# THREE per-scenario HOMEs (not one shared DB): `report`'s current-week pick,
# the statusline DB fallback, and record-usage's reset detection all compare
# against the GLOBALLY-latest snapshot, so a shared three-week DB cannot be
# scenario-selected by CCTALLY_AS_OF alone (spec §2.1 / Codex finding 3).
# CCTALLY_AS_OF is pinned inside each scenario's week.
#
# Fixture week: [2026-06-25T10:00:00Z, 2026-07-02T10:00:00Z), wsd 2026-06-25.
#   W-CTRL   ramp 10 -> 20 -> 30                                    expect 30
#   W-RESET  pre-peak 41; reset eff 06-27T10:00Z; post 3,5,7        expect 7
#   W-CREDIT pre-peak 46; credit-floor eff 06-27T10:00Z; 33,37      expect 37
#
# Six read-only surfaces, two families:
#   latest-row  : forecast.current.weekly_percent, weekly.usedPct,
#                 report.weeklyPercent, envelope.current_week.used_pct
#   floored-MAX : project.totals.usedPercent, statusline 7d
# Both families read the SAME expected value under correct (floored) behavior:
# the post-reset/post-credit ramp is the latest AND the floored MAX. Surface 7
# (record-credit --dry-run) pins the reset/credit --from resolution. An
# un-floored clamp site snaps its floored-MAX surface to the stale peak
# (41 / 46) while the latest-row surfaces stay put — the disjoint
# belt-and-suspenders design (spec §3 wired-verification pass, §5 evidence).
# ============================================================================
UPCT_WSD="2026-06-25"
UPCT_WS_AT="2026-06-25T10:00:00Z"
UPCT_WE_AT="2026-07-02T10:00:00Z"
UPCT_WE_DATE="2026-07-02"
UPCT_AS_OF="2026-06-29T12:00:00Z"

# Seed one scenario HOME's stats.db + cache.db. Inline heredoc (self-contained,
# deterministic) using the _fixture_builders seed helpers; the
# weekly_credit_floors row is raw SQL naming all four required columns
# (week_start_date, effective_at_utc, observed_pre_credit_pct, applied_at_utc —
# no shared helper exists, YAGNI for one consumer; spec §2.1 / Codex finding 13).
upct_seed_reader () {
    local scenario="$1" datadir="$2"
    mkdir -p "$datadir"
    UPCT_SCENARIO="$scenario" UPCT_DATADIR="$datadir" \
    UPCT_WSD="$UPCT_WSD" UPCT_WS_AT="$UPCT_WS_AT" \
    UPCT_WE_AT="$UPCT_WE_AT" UPCT_WE_DATE="$UPCT_WE_DATE" \
    PYTHONPATH="$REPO_ROOT/bin" TZ=Etc/UTC python3 - <<'PYSEED'
import datetime as dt, os, pathlib, sqlite3
import _fixture_builders as fb

scenario = os.environ["UPCT_SCENARIO"]
datadir = pathlib.Path(os.environ["UPCT_DATADIR"])
wsd = os.environ["UPCT_WSD"]
ws_at = os.environ["UPCT_WS_AT"]
we_at = os.environ["UPCT_WE_AT"]
we_date = os.environ["UPCT_WE_DATE"]

stats = datadir / "stats.db"
cache = datadir / "cache.db"
fb.create_stats_db(stats)
fb.create_cache_db(cache)

fhr = "2026-06-29T15:00:00Z"
fhr_epoch = int(dt.datetime.fromisoformat(fhr.replace("Z", "+00:00")).timestamp())
fhk = fhr_epoch // 600 * 600
common = dict(
    week_start_date=wsd, week_end_date=we_date,
    week_start_at=ws_at, week_end_at=we_at,
    five_hour_percent=8.0, five_hour_resets_at=fhr, five_hour_window_key=fhk,
    source="upct-fixture",
)

if scenario == "ctrl":
    ramp = [("2026-06-26T09:00:00Z", 10.0),
            ("2026-06-27T09:00:00Z", 20.0),
            ("2026-06-28T09:00:00Z", 30.0)]
elif scenario == "reset":
    # Pre-reset peak 41 is captured BEFORE the 10:00Z reset effective; the
    # post-reset ramp 3->5->7 is captured after. Un-floored MAX snaps to 41.
    ramp = [("2026-06-26T08:00:00Z", 15.0),
            ("2026-06-27T09:00:00Z", 41.0),
            ("2026-06-27T11:00:00Z", 3.0),
            ("2026-06-28T09:00:00Z", 5.0),
            ("2026-06-28T15:00:00Z", 7.0)]
elif scenario == "credit":
    # Pre-credit peak 46 before the 10:00Z floor; post-credit 33->37 after.
    ramp = [("2026-06-26T08:00:00Z", 20.0),
            ("2026-06-27T09:00:00Z", 46.0),
            ("2026-06-27T11:00:00Z", 33.0),
            ("2026-06-28T09:00:00Z", 37.0)]
else:
    raise SystemExit(f"unknown scenario {scenario}")

with sqlite3.connect(stats) as c:
    for cap, pct in ramp:
        fb.seed_weekly_usage_snapshot(c, captured_at_utc=cap, weekly_percent=pct, **common)
    # One cost snapshot so `report`'s usage-cost join emits a current-week row.
    fb.seed_weekly_cost_snapshot(
        c, captured_at_utc="2026-06-28T12:00:00Z",
        week_start_date=wsd, week_end_date=we_date,
        week_start_at=ws_at, week_end_at=we_at, cost_usd=5.0)
    if scenario == "reset":
        # Mixed +00:00 (event) vs Z (snapshots) offset spellings; new_week_end_at
        # matches week_end_at's instant so forecast's midweek-reset override + the
        # subscription-week re-anchor both fire. effective inside [ws_at, we_at).
        fb.seed_week_reset_event(
            c, detected_at_utc="2026-06-27T10:05:00Z",
            old_week_end_at="2026-06-30T10:00:00+00:00",
            new_week_end_at="2026-07-02T10:00:00+00:00",
            effective_reset_at_utc="2026-06-27T10:00:00+00:00")
    if scenario == "credit":
        c.execute(
            "INSERT INTO weekly_credit_floors "
            "(week_start_date, effective_at_utc, observed_pre_credit_pct, "
            " applied_at_utc) VALUES (?,?,?,?)",
            (wsd, "2026-06-27T10:00:00+00:00", 46.0, "2026-06-27T10:05:00Z"))
    c.commit()

# One in-window cache session entry (after the reset/credit effective) so
# `weekly`'s _aggregate_weekly emits a current-week bucket (spec §2.1 finding 4).
with sqlite3.connect(cache) as c:
    fb.seed_session_file(
        c, path="/upct/session.jsonl", session_id="upct-sid",
        project_path="/upct/proj")
    fb.seed_session_entry(
        c, source_path="/upct/session.jsonl", line_offset=0,
        timestamp_utc="2026-06-28T12:00:00Z", model="claude-sonnet-4-5",
        input_tokens=100000, output_tokens=10000,
        msg_id="upct-msg", req_id="upct-req")
    c.commit()
PYSEED
}

# Run all six read-only surfaces (+ optional record-credit surface 7) against a
# seeded HOME and assert every one reports `expected` within 1e-9.
#   $1 name  $2 expected  $3 home  $4 rc_mode(none|hwm|prior_credit)  $5 rc_from
upct_reader_run () {
    local name="$1" expected="$2" h="$3" rc_mode="$4" rc_from="$5"
    local as_of="$UPCT_AS_OF" wsd="$UPCT_WSD" datadir="$h/.local/share/cctally"
    local FC WK RP PJ SL ENVPCT RC=""
    FC=$(HOME="$h" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$as_of" "$BIN" forecast --json 2>/dev/null)
    WK=$(HOME="$h" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$as_of" "$BIN" weekly --json 2>/dev/null)
    RP=$(HOME="$h" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$as_of" "$BIN" report --json 2>/dev/null)
    PJ=$(HOME="$h" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$as_of" "$BIN" project --json 2>/dev/null)
    # Feed `{}` on stdin so statusline exercises the DB-fallback + HWM-clamp
    # path (spec §2.2 surface 6 / Codex finding 10), not the stdin rate_limits.
    SL=$(printf '{}' | HOME="$h" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$as_of" "$BIN" statusline 2>/dev/null)
    # Dashboard envelope via the pure-Python in-process path (spec §2.2 surface
    # 4): _tui_build_snapshot(now_utc=..., skip_sync=True) -> snapshot_to_envelope.
    ENVPCT=$(CCTALLY_DATA_DIR="$datadir" REPO_ROOT_RESOLVED="$REPO_ROOT" \
             UPCT_NOW="$as_of" CCTALLY_AS_OF="$as_of" TZ=Etc/UTC python3 - <<'PYENV' 2>/dev/null)
import datetime as dt, os, pathlib, sys, types
repo_root = pathlib.Path(os.environ["REPO_ROOT_RESOLVED"])
script_path = repo_root / "bin" / "cctally"
mod = types.ModuleType("cctally"); mod.__file__ = str(script_path)
sys.modules["cctally"] = mod
exec(compile(script_path.read_text(), str(script_path), "exec"), mod.__dict__)
sys.path.insert(0, str(repo_root / "bin"))
import _cctally_tui as T
import _cctally_dashboard_envelope as E
NOW = dt.datetime.fromisoformat(os.environ["UPCT_NOW"].replace("Z", "+00:00"))
snap = T._tui_build_snapshot(now_utc=NOW, skip_sync=True)
env = E.snapshot_to_envelope(snap, now_utc=NOW)
cw = env.get("current_week")
print(cw["used_pct"] if cw and cw.get("used_pct") is not None else "None")
PYENV
    if [ "$rc_mode" != "none" ]; then
        RC=$(HOME="$h" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$as_of" "$BIN" \
             record-credit --to 1 --dry-run --json 2>/dev/null)
    fi
    local result rc_py
    result=$(UPCT_NAME="$name" UPCT_EXPECTED="$expected" UPCT_WSD="$wsd" \
             UPCT_RC_MODE="$rc_mode" UPCT_RC_FROM="$rc_from" \
             UPCT_FC="$FC" UPCT_WK="$WK" UPCT_RP="$RP" UPCT_PJ="$PJ" \
             UPCT_SL="$SL" UPCT_ENV="$ENVPCT" UPCT_RC="$RC" \
             python3 - <<'PYCHK' 2>&1); rc_py=$?
import json, os, re, sys
name = os.environ["UPCT_NAME"]
exp = float(os.environ["UPCT_EXPECTED"])
wsd = os.environ["UPCT_WSD"]
TOL = 1e-9
errs = []
def near(v, label):
    if v is None:
        errs.append(f"{label}=None"); return
    if abs(float(v) - exp) >= TOL:
        errs.append(f"{label}={v} (want {exp})")
fc = json.loads(os.environ["UPCT_FC"])
near(fc["current"]["weekly_percent"], "forecast.current.weekly_percent")
wk = json.loads(os.environ["UPCT_WK"])
wrow = next((w for w in wk.get("weekly", []) if w.get("week") == wsd), None)
near(wrow["usedPct"] if wrow else None, "weekly.usedPct")
rp = json.loads(os.environ["UPCT_RP"])
rrow = next((r for r in rp.get("trend", []) if r.get("weekStartDate") == wsd), None)
near(rrow["weeklyPercent"] if rrow else None, "report.weeklyPercent")
pj = json.loads(os.environ["UPCT_PJ"])
near(pj["totals"]["usedPercent"], "project.totals.usedPercent")
m = re.search(r"7d (\d+(?:\.\d+)?)%", os.environ["UPCT_SL"])
near(float(m.group(1)) if m else None, "statusline.7d")
env = os.environ["UPCT_ENV"].strip()
near(float(env) if env not in ("", "None") else None, "envelope.current_week.used_pct")
rc_mode = os.environ["UPCT_RC_MODE"]
if rc_mode != "none":
    rc = json.loads(os.environ["UPCT_RC"])
    fs = rc["credit"]["fromSource"]
    fp = rc["credit"]["fromPct"]
    rc_from = float(os.environ["UPCT_RC_FROM"])
    if fs != rc_mode:
        errs.append(f"record-credit.fromSource={fs!r} (want {rc_mode!r})")
    if abs(float(fp) - rc_from) >= TOL:
        errs.append(f"record-credit.fromPct={fp} (want {rc_from})")
if errs:
    print("; ".join(errs), file=sys.stderr)
    sys.exit(1)
PYCHK
    if [ $rc_py -ne 0 ]; then
        echo "RECONCILE FAIL $name upct/$(basename "$h"): $result"
        fail_count=$((fail_count + 1))
    else
        echo "PASS $name upct/$(basename "$h")"
        pass_count=$((pass_count + 1))
    fi
}

UPCT_CTRL="$SCRATCH_DIR/upct-ctrl"
UPCT_RESET="$SCRATCH_DIR/upct-reset"
UPCT_CREDIT="$SCRATCH_DIR/upct-credit"
upct_seed_reader ctrl   "$UPCT_CTRL/.local/share/cctally"
upct_seed_reader reset  "$UPCT_RESET/.local/share/cctally"
upct_seed_reader credit "$UPCT_CREDIT/.local/share/cctally"
# U-PCT1 (W-CTRL): surfaces 1-6 agree at 30 (no reset/credit — surface 7 skipped).
upct_reader_run U-PCT1 30 "$UPCT_CTRL"   none         0
# U-PCT2 (W-RESET): surfaces 1-6 = post-reset 7, not the pre-reset peak 41;
# record-credit resolves --from via the reset-aware HWM (fromSource=hwm, 7).
upct_reader_run U-PCT2 7  "$UPCT_RESET"  hwm          7
# U-PCT3 (W-CREDIT): surfaces 1-6 = post-credit 37, not the pre-credit peak 46;
# record-credit pins the documented prior_credit precedence (fromSource, 46).
upct_reader_run U-PCT3 37 "$UPCT_CREDIT" prior_credit 46

# ----------------------------------------------------------------------------
# U-PCT4: write-site clamp accepts a real post-credit tick (the M2 linchpin).
# record-usage has NO --json (Codex finding 1), so the check queries the
# just-inserted weekly_usage_snapshots row directly. A fed post-credit tick 38
# is BELOW the stale peak (41 reset / 46 credit) but ABOVE the floored MAX
# (7 / 37). The reset-aware write clamp must ACCEPT it -> the newest row (MAX
# id) reads 38. An un-floored clamp would MAX to 41/46 and suppress the tick
# (should_insert=False) -> the newest row would stay at the prior post value
# (7 / 37), never storing 38 (spec §4a; the "real post-credit 37<46 tick not
# suppressed" linchpin).
#
# Wall-clock-anchored HOMEs, isolated from the pinned reader HOMEs above:
# record-usage ignores CCTALLY_AS_OF for the plausibility band AND stamps the
# inserted row with real now_utc_iso() (Codex finding 9), so the fixture week
# is built relative to real now. The fed tick 38 is a RISE from 7/37, so it
# never trips the >=25pp / reset-to-zero auto-credit detector (which fires on
# DROPS). alerts.notifier=none suppresses the milestone-crossing dispatch.
upct_seed_writeclamp () {
    # Seed one wall-clock W4 HOME; echo the derived week_reset epoch on stdout.
    local scenario="$1" datadir="$2"
    mkdir -p "$datadir"
    UPCT4_SCENARIO="$scenario" UPCT4_DATADIR="$datadir" \
    PYTHONPATH="$REPO_ROOT/bin" TZ=Etc/UTC python3 - <<'PYSEED4'
import datetime as dt, json, os, pathlib, sqlite3
import _fixture_builders as fb
scenario = os.environ["UPCT4_SCENARIO"]
datadir = pathlib.Path(os.environ["UPCT4_DATADIR"])
# Current subscription week contains real now: week_end 3d ahead (within the
# [now-30d, now+8d] plausibility band), week_start 4d behind. record-usage
# derives week_start_date from --resets-at as (fromtimestamp(resets) - 7d).date,
# so the seeded rows must carry that exact wsd.
now = dt.datetime.now(dt.timezone.utc).replace(minute=0, second=0, microsecond=0)
week_end = now + dt.timedelta(days=3)
week_start = week_end - dt.timedelta(days=7)
resets_epoch = int(week_end.timestamp())
wsd = week_start.date().isoformat()
we_date = week_end.date().isoformat()
ws_at = week_start.isoformat(timespec="seconds").replace("+00:00", "Z")
we_at = week_end.isoformat(timespec="seconds").replace("+00:00", "Z")
# Floor effective ~26h ago (mixed +00:00 spelling vs the Z captures). The
# pre-reset/pre-credit peak is captured 48h ago (before the floor); the post
# ramp is captured after, so the floored MAX drops the stale peak.
floor_eff = (now - dt.timedelta(hours=26)).isoformat(timespec="seconds")
def cap(hours_ago):
    return (now - dt.timedelta(hours=hours_ago)).isoformat(timespec="seconds").replace("+00:00", "Z")
stats = datadir / "stats.db"
cache = datadir / "cache.db"
fb.create_stats_db(stats)
fb.create_cache_db(cache)
(datadir / "config.json").write_text(json.dumps({"alerts": {"notifier": "none"}}))
common = dict(week_start_date=wsd, week_end_date=we_date,
              week_start_at=ws_at, week_end_at=we_at, source="upct4-fixture")
if scenario == "reset":
    ramp = [(48, 41.0), (20, 3.0), (10, 5.0), (1, 7.0)]  # (hours_ago, pct)
else:
    ramp = [(48, 46.0), (20, 33.0), (1, 37.0)]
with sqlite3.connect(stats) as c:
    for hrs, pct in ramp:
        fb.seed_weekly_usage_snapshot(c, captured_at_utc=cap(hrs), weekly_percent=pct, **common)
    if scenario == "reset":
        fb.seed_week_reset_event(
            c, detected_at_utc=cap(26),
            old_week_end_at=(week_end - dt.timedelta(days=2)).isoformat(timespec="seconds"),
            new_week_end_at=we_at, effective_reset_at_utc=floor_eff)
    else:
        c.execute(
            "INSERT INTO weekly_credit_floors "
            "(week_start_date, effective_at_utc, observed_pre_credit_pct, "
            " applied_at_utc) VALUES (?,?,?,?)",
            (wsd, floor_eff, 46.0, cap(25)))
    c.commit()
print(resets_epoch)
PYSEED4
}

# Feed the tick into a freshly-seeded W4 HOME and assert the newest row is 38.
upct_writeclamp_run_scn () {
    # $1 name  $2 scenario(reset|credit)  $3 home  $4 stale_peak
    local name="$1" scenario="$2" h="$3" stale="$4"
    local datadir="$h/.local/share/cctally" resets latest diff
    resets=$(upct_seed_writeclamp "$scenario" "$datadir")
    HOME="$h" TZ=Etc/UTC "$BIN" record-usage --percent 38 --resets-at "$resets" >/dev/null 2>&1
    latest=$(sqlite3 "$datadir/stats.db" \
        "SELECT weekly_percent FROM weekly_usage_snapshots ORDER BY id DESC LIMIT 1" 2>/dev/null)
    diff=$(awk -v a="$latest" -v b=38 'BEGIN{d=a-b; if(d<0)d=-d; print d}')
    if awk -v d="$diff" 'BEGIN{exit !(d < 1e-9)}'; then
        echo "PASS $name upct/$(basename "$h")"
        pass_count=$((pass_count + 1))
    else
        echo "RECONCILE FAIL $name upct/$(basename "$h"): newest weekly_percent=$latest (want 38; un-floored clamp would suppress it to the stale peak $stale)"
        fail_count=$((fail_count + 1))
    fi
}

upct_writeclamp_run_scn U-PCT4a reset  "$SCRATCH_DIR/upct-w4-reset"  41
upct_writeclamp_run_scn U-PCT4b credit "$SCRATCH_DIR/upct-w4-credit" 46

echo "----"
echo "passed: $pass_count   failed: $fail_count"
[ "$fail_count" -eq 0 ]
