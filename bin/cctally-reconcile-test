#!/usr/bin/env bash
# Cross-command reconciliation harness.
#
# Each invariant asserts that two subcommands, given the same fixture HOME
# and CCTALLY_AS_OF, emit JSON fields that agree within a 1e-9 USD
# tolerance. Tolerance absorbs IEEE-754 summation ULPs across different
# aggregation paths (both paths use identical pricing dicts but sum in
# different orders).
#
# All reader-side fixture trees (generated by 4 builder scripts) are
# rebuilt at the top so the harness is self-contained for standalone
# invocation on a fresh clone.
#
# Failure format: RECONCILE FAIL <invariant> <fixture>: <diagnostic>
# Exits 0 on all-pass, non-zero on any failure.

set -uo pipefail

# Dev-instance isolation: force prod data-dir layout under fake HOME.
. "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_lib-harness-env.sh"

REPO_ROOT=$(cd "$(dirname "$0")/.." && pwd)
BIN="$REPO_ROOT/bin/cctally"

# Per-run scratch dir for the regenerated fixture DBs and any test-process
# SQLite writes — same pattern as bin/cctally-*-test wrappers. The builders
# are host-deterministic but produce different bytes on different hosts/
# SQLite versions, so writing into the in-tree fixture dirs would dirty
# the tree on every run. FIXTURES points at the scratch dir so each
# reconcile_invariant call resolves $FIXTURES/<cmd>/<scenario> to the
# freshly-built scratch copy (input.env is written by each builder).
SCRATCH_DIR=$(mktemp -d -t cctally-reconcile-fixtures-XXXXXX)
trap 'rm -rf "$SCRATCH_DIR"' EXIT
FIXTURES="$SCRATCH_DIR"

# Rebuild every fixture tree this harness reads into the scratch dir.
# ~3s total; makes standalone invocation self-contained on a fresh clone
# without dirtying the in-tree fixtures.
. "$REPO_ROOT/bin/_lib-fixture-cache.sh"
build_fixtures_cached "$REPO_ROOT/bin/build-weekly-fixtures.py" "$SCRATCH_DIR/weekly"
build_fixtures_cached "$REPO_ROOT/bin/build-session-fixtures.py" "$SCRATCH_DIR/session"
build_fixtures_cached "$REPO_ROOT/bin/build-cache-report-fixtures.py" "$SCRATCH_DIR/cache-report"
"$REPO_ROOT/bin/build-codex-fixtures.py"        --out "$SCRATCH_DIR"              >/dev/null
build_fixtures_cached "$REPO_ROOT/bin/build-diff-fixtures.py" "$SCRATCH_DIR/diff"
build_fixtures_cached "$REPO_ROOT/bin/build-mode-fixtures.py" "$SCRATCH_DIR/mode"
build_fixtures_cached "$REPO_ROOT/bin/build-speed-fixtures.py" "$SCRATCH_DIR/speed"
"$REPO_ROOT/bin/build-daily-instances-fixtures.py" --out "$SCRATCH_DIR/daily-instances" >/dev/null
build_fixtures_cached "$REPO_ROOT/bin/build-budget-fixtures.py" "$SCRATCH_DIR/budget"
build_fixtures_cached "$REPO_ROOT/bin/build-forecast-fixtures.py" "$SCRATCH_DIR/forecast"

pass_count=0
fail_count=0

# reconcile_invariant NAME FIXTURE_HOME CMD_A CMD_B PY_ASSERTION
#   NAME          : short invariant identifier, e.g. "weekly_eq_sum_daily"
#   FIXTURE_HOME  : absolute path to the fixture dir (input.env is sourced
#                   to pick up AS_OF; FLAGS in input.env is NOT used —
#                   per-invariant flags live in CMD_A / CMD_B strings).
#   CMD_A         : full argv after the binary, e.g. "weekly --json"
#   CMD_B         : same, e.g. "daily --json"
#   PY_ASSERTION  : python3 source run via `python3 -c`. Reads two env
#                   vars — RECONCILE_A (JSON from CMD_A) and RECONCILE_B
#                   (JSON from CMD_B). Must non-zero-exit on failure with
#                   a diagnostic message; on success either print nothing
#                   or print "OK".
reconcile_invariant () {
    local name="$1"
    local fixture_home="$2"
    local cmd_a="$3"
    local cmd_b="$4"
    local py="$5"
    local fixture_label
    fixture_label=$(basename "$(dirname "$fixture_home")")/$(basename "$fixture_home")

    local FAKE_HOME="${fixture_home%/}"
    local AS_OF=""
    local FLAGS=""

    if [ ! -f "$fixture_home/input.env" ]; then
        echo "RECONCILE FAIL $name $fixture_label: no input.env"
        fail_count=$((fail_count + 1))
        return 1
    fi
    # shellcheck disable=SC1091
    . "$fixture_home/input.env"
    if [ -z "$AS_OF" ]; then
        echo "RECONCILE FAIL $name $fixture_label: input.env missing AS_OF"
        fail_count=$((fail_count + 1))
        return 1
    fi

    local json_a json_b rc_a rc_b
    # shellcheck disable=SC2086
    json_a=$(HOME="$FAKE_HOME" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
             "$BIN" $cmd_a 2>/dev/null); rc_a=$?
    # shellcheck disable=SC2086
    json_b=$(HOME="$FAKE_HOME" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
             "$BIN" $cmd_b 2>/dev/null); rc_b=$?
    if [ $rc_a -ne 0 ] || [ $rc_b -ne 0 ]; then
        echo "RECONCILE FAIL $name $fixture_label: subcommand exit rc_a=$rc_a rc_b=$rc_b"
        fail_count=$((fail_count + 1))
        return 1
    fi

    local result rc_py
    result=$(RECONCILE_A="$json_a" RECONCILE_B="$json_b" python3 -c "$py" 2>&1); rc_py=$?
    if [ $rc_py -ne 0 ]; then
        echo "RECONCILE FAIL $name $fixture_label: $result"
        fail_count=$((fail_count + 1))
        return 1
    fi

    echo "PASS $name $fixture_label"
    pass_count=$((pass_count + 1))
    return 0
}

# Invariant 1: weekly.totalCost == Σ daily.totalCost for dates in the week.
INVARIANT_1_PY='
import json, os
w = json.loads(os.environ["RECONCILE_A"])
d = json.loads(os.environ["RECONCILE_B"])
diffs = []
for week in w.get("weekly", []):
    ws = week["weekStartAt"][:10]
    we = week["weekEndAt"][:10]
    daily_sum = sum(r["totalCost"] for r in d.get("daily", []) if ws <= r["date"] < we)
    wcost = week["totalCost"]
    if abs(wcost - daily_sum) >= 1e-9:
        diffs.append(f"week={ws} weekly.totalCost={wcost} daily_sum={daily_sum}")
assert not diffs, "; ".join(diffs)
'
for fx in weekly/multi-week-anchored weekly/current-week-partial; do
    reconcile_invariant "weekly_eq_sum_daily" "$FIXTURES/$fx" \
        "weekly --json" \
        "daily --json" \
        "$INVARIANT_1_PY"
done

# Invariant DI1: grouping by project conserves cost. Σ over projects Σ over
# dates of projects[*][*].totalCost (daily --instances) == Σ daily[*].totalCost
# (default, same fixture/window). Uses the daily-instances fixture, whose two
# same-basename git-roots (app (work) / app (personal)) + a NULL-project
# (unknown) bucket stress the disambiguation + (unknown)-collection paths.
INVARIANT_DI1_PY='
import json, os
inst = json.loads(os.environ["RECONCILE_A"])
base = json.loads(os.environ["RECONCILE_B"])
inst_sum = sum(r["totalCost"] for rows in inst["projects"].values() for r in rows)
base_sum = sum(r["totalCost"] for r in base.get("daily", []))
assert abs(inst_sum - base_sum) < 1e-9, f"Σprojects.totalCost={inst_sum} Σdaily.totalCost={base_sum}"
'
reconcile_invariant "daily_instances_sum_eq_daily" \
    "$FIXTURES/daily-instances/multi-project" \
    "daily --instances --json --since 20260520 --until 20260521" \
    "daily --json --since 20260520 --until 20260521" \
    "$INVARIANT_DI1_PY"

# Invariant DI2: {projects}.totals == default {daily}.totals per field (1e-9).
# The grouped path's footer aggregate must match the ungrouped daily totals
# field-for-field (input/output/cache/total tokens + totalCost).
INVARIANT_DI2_PY='
import json, os
inst = json.loads(os.environ["RECONCILE_A"])["totals"]
base = json.loads(os.environ["RECONCILE_B"])["totals"]
diffs = []
for k in base:
    if abs(inst[k] - base[k]) >= 1e-9:
        diffs.append(f"{k}: instances={inst[k]} daily={base[k]}")
assert not diffs, "; ".join(diffs)
'
reconcile_invariant "daily_instances_totals_eq_daily" \
    "$FIXTURES/daily-instances/multi-project" \
    "daily --instances --json --since 20260520 --until 20260521" \
    "daily --json --since 20260520 --until 20260521" \
    "$INVARIANT_DI2_PY"

# Invariant 2: Σ session.totalCost == Σ daily.totalCost for the full range.
INVARIANT_2_PY='
import json, os
s = json.loads(os.environ["RECONCILE_A"])
d = json.loads(os.environ["RECONCILE_B"])
s_sum = sum(r["totalCost"] for r in s.get("sessions", []))
d_sum = sum(r["totalCost"] for r in d.get("daily", []))
assert abs(s_sum - d_sum) < 1e-9, f"Σsession={s_sum} Σdaily={d_sum}"
'
for fx in session/single-session-single-file session/resumed-across-files; do
    reconcile_invariant "session_eq_sum_daily" "$FIXTURES/$fx" \
        "session --json" \
        "daily --json" \
        "$INVARIANT_2_PY"
done

# Invariant 3: cache-report.days[*].totalCost == daily.totalCost per-date.
# Iterates cache-report's days (which honor --days/--since/--until windowing)
# and looks up the corresponding daily row by date. Does NOT assert the
# reverse (daily ⊆ cache-report) because daily is unscoped here — the
# days-flag-trailing-window fixture deliberately seeds an out-of-window
# entry that cache-report is expected to filter.
INVARIANT_3_PY='
import json, os
c = json.loads(os.environ["RECONCILE_A"])
d = json.loads(os.environ["RECONCILE_B"])
d_by_date = {r["date"]: r["totalCost"] for r in d.get("daily", [])}
diffs = []
for row in c.get("days", []):
    date = row["date"]
    ccost = row.get("totalCost")
    if ccost is None:
        diffs.append(f"{date}: cache-report has no totalCost field")
        continue
    if date not in d_by_date:
        diffs.append(f"{date}: missing from daily")
        continue
    dcost = d_by_date[date]
    if abs(ccost - dcost) >= 1e-9:
        diffs.append(f"{date}: cache-report={ccost} daily={dcost}")
assert not diffs, "; ".join(diffs)
'
# healthy-cache-hit: default window (--days 7 is the subcommand default).
reconcile_invariant "cache_report_eq_daily_per_date" "$FIXTURES/cache-report/healthy-cache-hit" \
    "cache-report --json" \
    "daily --json" \
    "$INVARIANT_3_PY"
# days-flag-trailing-window: explicit --days 7 passed to cache-report.
# (We hardcode the flag here — the helper ignores FLAGS from input.env.)
reconcile_invariant "cache_report_eq_daily_per_date" "$FIXTURES/cache-report/days-flag-trailing-window" \
    "cache-report --json --days 7" \
    "daily --json" \
    "$INVARIANT_3_PY"

# ── Cache-report snapshot invariants (R-CR1..R-CR4) ────────────────────
# Spec §7.9: assertions over the dashboard envelope built by
# ``build_cache_report_snapshot`` (the CLI's ``cache-report --json``
# emits per-row financials but not the envelope-level rollups —
# ``today.*``, ``seven_day_*``, ``fourteen_day_*`` — that the panel /
# modal consume). Each fixture spawns its own Python subprocess so the
# module-level ``APP_DIR`` / ``CACHE_DB_PATH`` constants in ``cctally``
# bind to the fixture's HOME at import time (the credit_invariants
# pattern below this block uses the same recipe for the same reason).
#
# R-CR1: today.net_usd == today.saved_usd − today.wasted_usd (within 1e-9).
# R-CR2: Σ days[0..7].net_usd == seven_day_net_usd (within 1e-9).
# R-CR3: Σ days[0..14].saved_usd == fourteen_day_counterfactual_usd
#        (within 1e-9).
# R-CR4: fourteen_day_efficiency_ratio ==
#        Σsaved / (Σsaved + Σ|wasted|) within 1e-9 when denom > 0;
#        0.0 when denom == 0.
#
# Fixture coverage: cache-drop-anomaly carries one anomalous day +
# five clean baseline days so the invariants exercise both branches
# (anomaly_triggered=True/False rows interleave in the 14-day window).
# healthy-cache-hit covers the all-clean path. net-negative-anomaly
# stresses the wasted_usd-dominant path (R-CR4 denom path with a
# negative net total).
cache_report_snapshot_invariants () {
    local name="cache_report_snapshot_invariants"
    local fixture
    for fixture in cache-drop-anomaly healthy-cache-hit net-negative-anomaly; do
        local fixture_home="$FIXTURES/cache-report/$fixture"
        if [ ! -f "$fixture_home/input.env" ]; then
            echo "RECONCILE FAIL $name $fixture: no input.env"
            fail_count=$((fail_count + 1))
            continue
        fi
        local AS_OF=""
        # shellcheck disable=SC1091
        . "$fixture_home/input.env"
        if [ -z "$AS_OF" ]; then
            echo "RECONCILE FAIL $name $fixture: input.env missing AS_OF"
            fail_count=$((fail_count + 1))
            continue
        fi

        local result rc_py
        result=$(REPO_ROOT_RESOLVED="$REPO_ROOT" \
                 HOME="$fixture_home" TZ=Etc/UTC AS_OF="$AS_OF" \
                 FIXTURE_LABEL="$fixture" \
                 python3 - <<'PYCR' 2>&1)
import importlib.util, os, pathlib, sys, types, datetime as dt
from importlib.machinery import SourceFileLoader

repo_root = pathlib.Path(os.environ["REPO_ROOT_RESOLVED"])
script_path = repo_root / "bin" / "cctally"
mod = types.ModuleType("cctally")
mod.__file__ = str(script_path)
sys.modules["cctally"] = mod
code = compile(script_path.read_text(), str(script_path), "exec")
exec(code, mod.__dict__)

sys.path.insert(0, str(repo_root / "bin"))
import _cctally_dashboard as D

label = os.environ["FIXTURE_LABEL"]
as_of = os.environ["AS_OF"].rstrip("Z")
now_utc = dt.datetime.fromisoformat(as_of).replace(tzinfo=dt.timezone.utc)

# Build the snapshot exactly as the dashboard sync thread would, with
# the same hardcoded v1 anomaly knobs (spec §6.1). display_tz=None
# means "host-local" — under TZ=Etc/UTC + tzset that's UTC, matching
# the fixture builder's bucketing assumptions.
snap = D.build_cache_report_snapshot(
    now_utc=now_utc,
    anomaly_threshold_pp=15,
    anomaly_window_days=14,
    display_tz=None,
)

# Defensive: every fixture in this loop is expected to produce a
# non-empty snapshot. If a future fixture re-uses this slot with no
# entries, the invariants would silently pass (R-CR3/R-CR4 with
# empty sums are vacuously true). Fail loud so the maintainer
# notices.
assert not snap.is_empty, (
    f"R-CR ({label}) fail: snapshot is empty — fixture has no entries"
)

# R-CR1: today.net_usd == today.saved_usd − today.wasted_usd.
r_cr1 = abs(
    snap.today.net_usd - (snap.today.saved_usd - snap.today.wasted_usd)
)
assert r_cr1 < 1e-9, (
    f"R-CR1 ({label}) fail (spec §7.9): "
    f"today.net_usd={snap.today.net_usd} vs saved−wasted="
    f"{snap.today.saved_usd - snap.today.wasted_usd} "
    f"|diff|={r_cr1} >= 1e-9"
)

# R-CR2: Σ days[0..7].net_usd == seven_day_net_usd.
seven_day_rows = snap.days[:7]
seven_sum = sum(r.net_usd for r in seven_day_rows)
r_cr2 = abs(seven_sum - snap.seven_day_net_usd)
assert r_cr2 < 1e-9, (
    f"R-CR2 ({label}) fail (spec §7.9): "
    f"Σ days[0..7].net_usd={seven_sum} vs "
    f"seven_day_net_usd={snap.seven_day_net_usd} "
    f"|diff|={r_cr2} >= 1e-9"
)

# R-CR3: Σ days[0..14].saved_usd == fourteen_day_counterfactual_usd.
saved_sum = sum(r.saved_usd for r in snap.days)
r_cr3 = abs(saved_sum - snap.fourteen_day_counterfactual_usd)
assert r_cr3 < 1e-9, (
    f"R-CR3 ({label}) fail (spec §7.9): "
    f"Σ days[].saved_usd={saved_sum} vs "
    f"fourteen_day_counterfactual_usd="
    f"{snap.fourteen_day_counterfactual_usd} "
    f"|diff|={r_cr3} >= 1e-9"
)

# R-CR4: fourteen_day_efficiency_ratio matches sum(saved) / (sum(saved)
# + sum(|wasted|)) within 1e-9 when denom > 0; 0.0 when denom == 0.
wasted_abs_sum = sum(abs(r.wasted_usd) for r in snap.days)
denom = saved_sum + wasted_abs_sum
if denom > 1e-9:
    expected_ratio = saved_sum / denom
else:
    expected_ratio = 0.0
r_cr4 = abs(snap.fourteen_day_efficiency_ratio - expected_ratio)
assert r_cr4 < 1e-9, (
    f"R-CR4 ({label}) fail (spec §7.9): "
    f"fourteen_day_efficiency_ratio="
    f"{snap.fourteen_day_efficiency_ratio} vs expected="
    f"{expected_ratio} (Σsaved={saved_sum}, "
    f"Σ|wasted|={wasted_abs_sum}, denom={denom}) "
    f"|diff|={r_cr4} >= 1e-9"
)

print("OK")
PYCR
        rc_py=$?
        if [ $rc_py -ne 0 ]; then
            echo "RECONCILE FAIL $name $fixture: $result"
            fail_count=$((fail_count + 1))
        else
            echo "PASS $name $fixture (R-CR1..R-CR4)"
            pass_count=$((pass_count + 1))
        fi
    done
}
cache_report_snapshot_invariants

# Invariant 4: codex-monthly.costUSD == Σ codex-daily.costUSD for entries in
# the month. codex-daily's date format is "Mar 31, 2026"; codex-monthly's
# month format is "Mar 2026". Parse both to map daily entries to months.
INVARIANT_4_PY='
import json, os, datetime as dt
m = json.loads(os.environ["RECONCILE_A"])
d = json.loads(os.environ["RECONCILE_B"])

def parse_date(s): return dt.datetime.strptime(s, "%b %d, %Y").date()
def parse_month(s): return dt.datetime.strptime(s, "%b %Y").date()

diffs = []
for mrow in m.get("monthly", []):
    month = parse_month(mrow["month"])
    daily_sum = sum(
        r["costUSD"] for r in d.get("daily", [])
        if parse_date(r["date"]).year == month.year
        and parse_date(r["date"]).month == month.month
    )
    mcost = mrow["costUSD"]
    if abs(mcost - daily_sum) >= 1e-9:
        name = mrow["month"]
        diffs.append(f"month={name} monthly.costUSD={mcost} daily_sum={daily_sum}")
assert not diffs, "; ".join(diffs)
'
reconcile_invariant "codex_monthly_eq_sum_codex_daily" \
    "$FIXTURES/codex-daily/multi-week-rollup" \
    "codex-monthly --json" \
    "codex-daily --json" \
    "$INVARIANT_4_PY"

# Invariant 5: codex-weekly.costUSD == Σ codex-daily.costUSD for entries in
# the week [weekStart, weekStart + 7 days). Both commands use "Mar 31, 2026"
# date format (daily) and "Mar 30, 2026" week-start label (weekly).
INVARIANT_5_PY='
import json, os, datetime as dt
w = json.loads(os.environ["RECONCILE_A"])
d = json.loads(os.environ["RECONCILE_B"])

def parse_date(s): return dt.datetime.strptime(s, "%b %d, %Y").date()

diffs = []
for wrow in w.get("weekly", []):
    ws = parse_date(wrow["week"])
    we = ws + dt.timedelta(days=7)
    daily_sum = sum(
        r["costUSD"] for r in d.get("daily", [])
        if ws <= parse_date(r["date"]) < we
    )
    wcost = wrow["costUSD"]
    if abs(wcost - daily_sum) >= 1e-9:
        label = wrow["week"]
        diffs.append(f"week={label} weekly.costUSD={wcost} daily_sum={daily_sum}")
assert not diffs, "; ".join(diffs)
'
reconcile_invariant "codex_weekly_eq_sum_codex_daily" \
    "$FIXTURES/codex-daily/multi-week-rollup" \
    "codex-weekly --json" \
    "codex-daily --json" \
    "$INVARIANT_5_PY"

# Invariant 6: Σ codex-session.costUSD == Σ codex-daily.costUSD for the full
# range the fixture exposes. The cross-day-session fixture has one session
# spanning Apr 14 → Apr 15; both commands see the same JSONL data.
INVARIANT_6_PY='
import json, os
s = json.loads(os.environ["RECONCILE_A"])
d = json.loads(os.environ["RECONCILE_B"])
s_sum = sum(r["costUSD"] for r in s.get("sessions", []))
d_sum = sum(r["costUSD"] for r in d.get("daily", []))
assert abs(s_sum - d_sum) < 1e-9, f"Σcodex_session={s_sum} Σcodex_daily={d_sum}"
'
reconcile_invariant "codex_session_eq_sum_codex_daily" \
    "$FIXTURES/codex-session/cross-day-session" \
    "codex-session --json" \
    "codex-daily --json" \
    "$INVARIANT_6_PY"

# Invariants 4f/5f/6f: the same three Codex cross-command grouping-invariance
# checks, but with --speed fast on BOTH sides. Reuses the SAME assertion bodies
# (INVARIANT_4_PY / 5_PY / 6_PY) — proves grouping-invariance still holds under
# the fast-tier multiplier (the per-entry scale factor is identical across
# grouping paths, so monthly/weekly/Σsession == Σdaily must remain exact).
# Issue #86 Session D.
reconcile_invariant "codex_monthly_eq_sum_codex_daily_fast" \
    "$FIXTURES/codex-daily/multi-week-rollup" \
    "codex-monthly --speed fast --json" \
    "codex-daily --speed fast --json" \
    "$INVARIANT_4_PY"

reconcile_invariant "codex_weekly_eq_sum_codex_daily_fast" \
    "$FIXTURES/codex-daily/multi-week-rollup" \
    "codex-weekly --speed fast --json" \
    "codex-daily --speed fast --json" \
    "$INVARIANT_5_PY"

reconcile_invariant "codex_session_eq_sum_codex_daily_fast" \
    "$FIXTURES/codex-session/cross-day-session" \
    "codex-session --speed fast --json" \
    "codex-daily --speed fast --json" \
    "$INVARIANT_6_PY"

# Invariant 7: Codex token totals reconcile to Codex's OWN ground-truth cumulative
# counter. cctally dedups re-emitted token_count events (see CLAUDE.md "Intentional
# divergence from upstream on duplicate token_count events"); the authoritative
# per-session total is the FINAL info.total_token_usage.total_tokens that Codex
# itself maintains and does NOT advance on a UI re-emit. Summing that across
# sessions must equal codex-daily's reported totalTokens.
#
# The second path here is NOT another cctally subcommand — it is a raw, independent
# scan of the fixture JSONL (Σ per-file max total_token_usage.total_tokens), so the
# two paths share no aggregation code. Non-vacuity guard: the naive sum of ALL
# last_token_usage.total_tokens (the ccusage-codex method) must STRICTLY EXCEED the
# deduped ground truth — proving the fixture actually contains re-emitted events, so
# a regression that disabled the dedup guard (bin/_lib_jsonl.py "cumulative <=
# last_total_tokens: continue") would report the inflated naive sum and FAIL here.
# This codifies the manual ground-truth reconciliation that confirmed cctally — not
# upstream ccusage — matches Codex's internal bookkeeping to the token.
INVARIANT_7_PY='
import json, os, glob
a = json.loads(os.environ["RECONCILE_A"])
reported_total = (a.get("totals") or {}).get("totalTokens")

ground_truth = 0   # Σ per-session final total_token_usage.total_tokens (Codex truth)
naive_all = 0      # Σ last_token_usage.total_tokens over EVERY event (ccusage method)
sessions_dir = os.environ["RECONCILE_SESSIONS_DIR"]
jsonls = glob.glob(os.path.join(sessions_dir, "**", "*.jsonl"), recursive=True)
for f in jsonls:
    file_max = 0
    for line in open(f, encoding="utf-8"):
        line = line.strip()
        if not line:
            continue
        try:
            o = json.loads(line)
        except ValueError:
            continue
        p = o.get("payload") if isinstance(o.get("payload"), dict) else {}
        if p.get("type") != "token_count":
            continue
        info = p.get("info")
        if not isinstance(info, dict):
            continue
        ltu = info.get("last_token_usage")
        if isinstance(ltu, dict):
            naive_all += int(ltu.get("total_tokens") or 0)
        ttu = info.get("total_token_usage")
        if isinstance(ttu, dict) and ttu.get("total_tokens") is not None:
            file_max = max(file_max, int(ttu.get("total_tokens") or 0))
    ground_truth += file_max

errs = []
if not jsonls:
    errs.append("no fixture JSONL found under RECONCILE_SESSIONS_DIR")
if reported_total != ground_truth:
    errs.append(
        f"codex-daily.totalTokens={reported_total} != Codex ground truth "
        f"(Sigma final total_token_usage.total_tokens)={ground_truth}"
    )
if not (naive_all > ground_truth):
    errs.append(
        f"NON-VACUITY VIOLATION: naive all-events sum={naive_all} must exceed "
        f"deduped ground truth={ground_truth} (fixture has no re-emitted events?)"
    )
assert not errs, "; ".join(errs)
'
# Custom invariant (command-output vs raw-JSONL ground truth), mirroring the
# statusline_reconcile precedent below — reconcile_invariant only does
# command-vs-command, so this one is bespoke but shares the PASS/FAIL format
# and the pass_count / fail_count counters.
codex_ground_truth_invariant () {
    local name="codex_dedup_eq_codex_ground_truth"
    local fixture_home="$FIXTURES/codex-daily/token-count-dedup"
    local fixture_label
    fixture_label=$(basename "$(dirname "$fixture_home")")/$(basename "$fixture_home")
    local FAKE_HOME="${fixture_home%/}"
    local AS_OF=""
    if [ ! -f "$fixture_home/input.env" ]; then
        echo "RECONCILE FAIL $name $fixture_label: no input.env"
        fail_count=$((fail_count + 1)); return 1
    fi
    # shellcheck disable=SC1091
    . "$fixture_home/input.env"
    if [ -z "$AS_OF" ]; then
        echo "RECONCILE FAIL $name $fixture_label: input.env missing AS_OF"
        fail_count=$((fail_count + 1)); return 1
    fi
    local json_a rc_a
    json_a=$(HOME="$FAKE_HOME" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
             "$BIN" codex-daily --json 2>/dev/null); rc_a=$?
    if [ $rc_a -ne 0 ]; then
        echo "RECONCILE FAIL $name $fixture_label: subcommand exit rc=$rc_a"
        fail_count=$((fail_count + 1)); return 1
    fi
    local result rc_py
    result=$(RECONCILE_A="$json_a" RECONCILE_SESSIONS_DIR="$FAKE_HOME/.codex/sessions" \
             python3 -c "$INVARIANT_7_PY" 2>&1); rc_py=$?
    if [ $rc_py -ne 0 ]; then
        echo "RECONCILE FAIL $name $fixture_label: $result"
        fail_count=$((fail_count + 1)); return 1
    fi
    echo "PASS $name $fixture_label"
    pass_count=$((pass_count + 1)); return 0
}
codex_ground_truth_invariant

# Speed scalar-multiplier invariants (issue #86 Session D): on a single-model
# fixture, Σ(--speed fast) == Σ(--speed standard) × per-model multiplier. Two
# scenarios pin the override (gpt-5.5 → ×2.5) and fallback (gpt-5 → ×2.0)
# branches of _codex_fast_multiplier exactly. The fixture HOME carries no
# ~/.codex/config.toml, so the standard/fast values are unambiguous (auto would
# resolve to standard, but we force the tiers explicitly here).
reconcile_invariant "speed_override_2_5x" \
    "$FIXTURES/speed/override-model" \
    "codex-daily --speed fast --json" \
    "codex-daily --speed standard --json" \
    '
import json, os
fast = json.loads(os.environ["RECONCILE_A"])["totals"]["costUSD"]
std  = json.loads(os.environ["RECONCILE_B"])["totals"]["costUSD"]
assert std > 0, f"std={std}"
assert abs(fast - std * 2.5) < 1e-9, f"fast={fast} std*2.5={std*2.5}"
'

reconcile_invariant "speed_fallback_2_0x" \
    "$FIXTURES/speed/fallback-model" \
    "codex-daily --speed fast --json" \
    "codex-daily --speed standard --json" \
    '
import json, os
fast = json.loads(os.environ["RECONCILE_A"])["totals"]["costUSD"]
std  = json.loads(os.environ["RECONCILE_B"])["totals"]["costUSD"]
assert std > 0, f"std={std}"
assert abs(fast - std * 2.0) < 1e-9, f"fast={fast} std*2.0={std*2.0}"
'

# Invariant D1: diff overall window-A cost == Σ daily.totalCost over the same
# date range. The same-length-week fixture's window A spans
# 2026-04-18T19:30Z → 2026-04-25T19:30Z. Seeded entries land on calendar dates
# 2026-04-{20,21,23,24} (no entries on the boundary days 04-18 / 04-25), so
# `daily --since 2026-04-19 --until 2026-04-25` covers exactly the window-A
# entries. Note: only safe because the fixture has no entries on the partial
# boundary days; for arbitrary windows the timestamp-vs-date mismatch makes
# this comparison non-trivial.
INVARIANT_D1_PY='
import json, os
a = json.loads(os.environ["RECONCILE_A"])
d = json.loads(os.environ["RECONCILE_B"])
overall = next(s for s in a["sections"] if s["name"] == "overall")
diff_a_cost = overall["rows"][0]["a"]["cost_usd"]
daily_sum = sum(r["totalCost"] for r in d.get("daily", []))
assert abs(diff_a_cost - daily_sum) < 1e-9, \
    f"diff.overall.a.cost_usd={diff_a_cost} Σdaily.totalCost={daily_sum}"
'
reconcile_invariant "diff_overall_eq_daily_total" \
    "$FIXTURES/diff/same-length-week" \
    "diff --json --a this-week --b last-week" \
    "daily --json --since 2026-04-19 --until 2026-04-25" \
    "$INVARIANT_D1_PY"

# Invariant D2: within a single diff --json output, sum of
# sections[name=models].rows[*].a.cost_usd (excluding null entries from
# asymmetric (new)/(dropped) rows) equals sections[name=overall].rows[0].a.cost_usd.
# This is intra-output reconciliation: both CMD_A and CMD_B run the same
# invocation; we extract two values from a single payload and compare. Same
# rule for window B. Pre-noise-filter aggregate consistency lives in
# DiffResult.raw_totals, but the public JSON under default flags renders
# filtered rows; this fixture has hidden_count=1 on the models section, so
# we compare against the FULL aggregate by re-running with --all.
INVARIANT_D2_PY='
import json, os
a = json.loads(os.environ["RECONCILE_A"])
overall = next(s for s in a["sections"] if s["name"] == "overall")["rows"][0]
models = next(s for s in a["sections"] if s["name"] == "models")["rows"]
# With --all, every aggregated model surfaces; sum across rows.
sum_a = sum(r["a"]["cost_usd"] for r in models if r["a"] is not None)
sum_b = sum(r["b"]["cost_usd"] for r in models if r["b"] is not None)
overall_a = overall["a"]["cost_usd"]
overall_b = overall["b"]["cost_usd"]
assert abs(sum_a - overall_a) < 1e-9, \
    f"Σmodels.a.cost_usd={sum_a} overall.a.cost_usd={overall_a}"
assert abs(sum_b - overall_b) < 1e-9, \
    f"Σmodels.b.cost_usd={sum_b} overall.b.cost_usd={overall_b}"
'
reconcile_invariant "diff_models_sum_eq_overall" \
    "$FIXTURES/diff/same-length-week" \
    "diff --json --a this-week --b last-week --all" \
    "diff --json --a this-week --b last-week --all" \
    "$INVARIANT_D2_PY"

# Invariant D3: same-output reconciliation for projects. Σ projects rows
# (excluding null entries) == overall row for both windows.
INVARIANT_D3_PY='
import json, os
a = json.loads(os.environ["RECONCILE_A"])
overall = next(s for s in a["sections"] if s["name"] == "overall")["rows"][0]
projects = next(s for s in a["sections"] if s["name"] == "projects")["rows"]
sum_a = sum(r["a"]["cost_usd"] for r in projects if r["a"] is not None)
sum_b = sum(r["b"]["cost_usd"] for r in projects if r["b"] is not None)
overall_a = overall["a"]["cost_usd"]
overall_b = overall["b"]["cost_usd"]
assert abs(sum_a - overall_a) < 1e-9, \
    f"Σprojects.a.cost_usd={sum_a} overall.a.cost_usd={overall_a}"
assert abs(sum_b - overall_b) < 1e-9, \
    f"Σprojects.b.cost_usd={sum_b} overall.b.cost_usd={overall_b}"
'
reconcile_invariant "diff_projects_sum_eq_overall" \
    "$FIXTURES/diff/same-length-week" \
    "diff --json --a this-week --b last-week --all" \
    "diff --json --a this-week --b last-week --all" \
    "$INVARIANT_D3_PY"

# ─── Invariant FHB1: per-block totalCost vs range-cost ──────────────────
# For one API-anchored 5h block, block.totalCost (recomputed at every
# record-usage tick by _compute_block_totals) must equal
# range-cost -s <first_observed_at_utc> -e <last_observed_at_utc>
# --total-only within 1e-9 USD. Both paths sum the same per-entry costs;
# the tolerance absorbs IEEE-754 ULP drift across different aggregation
# orders (CLAUDE.md float-tolerance gotcha — never == on cost sums).
#
# This scenario uses its own scratch HOME (no fixture builder needed):
# it seeds session_entries directly into cache.db, inserts a 5h-blocks
# row, then drives `record-usage` to recompute totals.
fhb_perblock_vs_range_cost () {
    local name="fhb-perblock-vs-range-cost"
    local home
    home=$(mktemp -d -t cctally-reconcile-fhb-XXXXXX)

    # Bootstrap stats.db schema (weekly opens stats.db & runs migrations;
    # cache-sync only touches cache.db).
    HOME="$home" TZ=Etc/UTC "$BIN" weekly \
        >"$home/stdout.log" 2>"$home/stderr.log" || true
    # Ensure cache.db schema exists for our seed inserts.
    HOME="$home" TZ=Etc/UTC "$BIN" cache-sync \
        >>"$home/stdout.log" 2>>"$home/stderr.log" || true

    # Seed two session_entries inside one 5h window. We bypass the JSONL
    # ingest path and write directly into cache.db — same approach as
    # cctally-five-hour-blocks-test::seed_session_entry.
    local cache_db="$home/.local/share/cctally/cache.db"
    sqlite3 "$cache_db" <<EOF
INSERT INTO session_files (path, size_bytes, mtime_ns, last_byte_offset,
                           last_ingested_at, session_id, project_path)
VALUES
  ('/scratch/proj-A/01.jsonl', 0, 0, 0, '2026-04-30T11:00:00+00:00',
   NULL, '/scratch/proj-A'),
  ('/scratch/proj-A/02.jsonl', 0, 0, 0, '2026-04-30T13:30:00+00:00',
   NULL, '/scratch/proj-A')
ON CONFLICT(path) DO NOTHING;

INSERT OR IGNORE INTO session_entries
    (source_path, line_offset, timestamp_utc, model,
     msg_id, req_id,
     input_tokens, output_tokens, cache_create_tokens, cache_read_tokens)
VALUES
    ('/scratch/proj-A/01.jsonl', 0, '2026-04-30T11:00:00+00:00',
     'claude-opus-4-7', 'msg_fhb_recon_1', NULL, 1000, 200, 0, 0),
    ('/scratch/proj-A/02.jsonl', 0, '2026-04-30T13:30:00+00:00',
     'claude-opus-4-7', 'msg_fhb_recon_2', NULL, 500, 100, 0, 0);
EOF

    # Insert the block row covering the same [first_observed, last_observed]
    # window the entries land in. _compute_block_totals will recompute
    # totals on the next record-usage tick.
    sqlite3 "$home/.local/share/cctally/stats.db" <<EOF
INSERT INTO five_hour_blocks (
    five_hour_window_key, five_hour_resets_at, block_start_at,
    first_observed_at_utc, last_observed_at_utc,
    final_five_hour_percent, total_cost_usd,
    crossed_seven_day_reset, is_closed,
    created_at_utc, last_updated_at_utc
) VALUES (1777563000, '2026-04-30T15:30:00+00:00', '2026-04-30T10:30:00+00:00',
          '2026-04-30T11:00:00+00:00', '2026-04-30T13:30:00+00:00',
          5.0, 0.0, 0, 1,
          '2026-04-30T11:00:00+00:00', '2026-04-30T13:30:00+00:00');
EOF

    # Drive a record-usage tick so _compute_block_totals fills in the
    # totals on the existing block. We MUST pass --five-hour-resets-at
    # matching the block's window key (1777563000 = 2026-04-30T15:30Z),
    # otherwise maybe_update_five_hour_block bails out (no canonical 5h
    # anchor in the snapshot → nothing to recompute).
    # CCTALLY_AS_OF pins wall-clock to 1h before the block's
    # five_hour_resets_at so the issue #112 plausibility guard accepts
    # both --resets-at (computed from AS_OF) and the seeded 5h epoch.
    HOME="$home" TZ=Etc/UTC CCTALLY_AS_OF="2026-04-30T14:30:00Z" "$BIN" record-usage \
        --percent 1 --resets-at 1777566600 \
        --five-hour-percent 5 --five-hour-resets-at 1777563000 \
        >>"$home/stdout.log" 2>>"$home/stderr.log" || true

    # Read back block.totalCost via --json.
    local block_cost
    block_cost=$(HOME="$home" TZ=Etc/UTC "$BIN" five-hour-blocks --json 2>/dev/null \
                 | python3 -c "import json,sys
d = json.load(sys.stdin)
print(next((b['totalCost'] for b in d['blocks']
            if b['blockStartAt'] == '2026-04-30T10:30:00+00:00'),
           0.0))")

    # range-cost over the exact [first_observed, last_observed] window.
    local rc_cost
    rc_cost=$(HOME="$home" TZ=Etc/UTC "$BIN" range-cost \
                  -s "2026-04-30T11:00:00+00:00" \
                  -e "2026-04-30T13:30:00+00:00" --total-only 2>/dev/null)

    # Compare with 1e-9 tolerance — never == (CLAUDE.md float-tolerance gotcha).
    # Three-way exit: 0 = equal, 1 = mismatch, 2 = both zero (data path broken
    # silently — record-usage didn't fire, JSON parse fell back to default 0,
    # range-cost returned zero on empty cache). The seeded session entries MUST
    # produce a positive cost; both-zero means upstream silently failed.
    local diff
    diff=$(python3 -c "print(abs(${block_cost:-0} - ${rc_cost:-0}))" 2>/dev/null)
    python3 -c "
import sys
b = ${block_cost:-0}
r = ${rc_cost:-0}
if abs(b) < 1e-9 and abs(r) < 1e-9:
    sys.exit(2)
sys.exit(0 if abs(b - r) < 1e-9 else 1)
" 2>/dev/null
    case $? in
        0)
            echo "PASS $name"
            pass_count=$((pass_count + 1))
            rm -rf "$home"
            ;;
        2)
            echo "RECONCILE FAIL $name: both costs are zero — data seeding or record-usage failed silently (scratch=$home)"
            fail_count=$((fail_count + 1))
            ;;
        *)
            echo "RECONCILE FAIL $name: block.totalCost=$block_cost range-cost=$rc_cost diff=$diff (scratch=$home)"
            fail_count=$((fail_count + 1))
            ;;
    esac
}
fhb_perblock_vs_range_cost

# ─── Invariant TZ1: JSON wire timestamps invariant across display.tz ───
# Q3 contract (localize-datetime-display): the persisted display.tz
# preference and the per-call --tz flag affect human-readable rendering
# only — they MUST NOT shift the byte content of `--json` ISO timestamps.
# All wire payloads stay UTC ("...Z" or explicit "+00:00") regardless of
# the resolved display zone. Without this invariant a downstream consumer
# (dashboard, jq pipeline, third-party tool) could see different wire
# bytes depending on which user toggled their personal display.tz pref.
#
# Drives `weekly --json` (a representative bucket-A subcommand: emits
# ISO timestamps in `weekStartAt` / `weekEndAt`) against three settings
# of `display.tz` — local, utc, America/New_York — and asserts byte-
# identical output. The fixture HOME at weekly/multi-week-anchored is
# COPIED into a scratch dir first so `config set` doesn't mutate the
# committed fixture's config.json.
tz_wire_invariant () {
    local name="tz_wire_invariant_weekly_json"
    local src_home="$FIXTURES/weekly/multi-week-anchored"
    local home
    home=$(mktemp -d -t cctally-reconcile-tz-XXXXXX)
    cp -R "$src_home/.local" "$home/"

    local AS_OF=""
    # shellcheck disable=SC1091
    . "$src_home/input.env"

    HOME="$home" TZ=Etc/UTC "$BIN" config set display.tz local >/dev/null
    local out_local
    out_local=$(HOME="$home" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
        "$BIN" weekly --json 2>/dev/null | jq -S .)
    HOME="$home" TZ=Etc/UTC "$BIN" config set display.tz utc >/dev/null
    local out_utc
    out_utc=$(HOME="$home" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
        "$BIN" weekly --json 2>/dev/null | jq -S .)
    HOME="$home" TZ=Etc/UTC "$BIN" config set display.tz America/New_York >/dev/null
    local out_ny
    out_ny=$(HOME="$home" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
        "$BIN" weekly --json 2>/dev/null | jq -S .)
    rm -rf "$home"

    if [ -z "$out_local" ] || [ -z "$out_utc" ] || [ -z "$out_ny" ]; then
        echo "RECONCILE FAIL $name: weekly --json produced empty output under one or more display.tz values"
        fail_count=$((fail_count + 1))
        return 1
    fi
    if [ "$out_local" != "$out_utc" ] || [ "$out_local" != "$out_ny" ]; then
        echo "RECONCILE FAIL $name: weekly --json wire bytes diverged across display.tz {local, utc, America/New_York}"
        fail_count=$((fail_count + 1))
        return 1
    fi
    echo "PASS $name"
    pass_count=$((pass_count + 1))
}
tz_wire_invariant

# ─── Invariant TZ2: report --tz <iana> Week Window cell parses back to ───
# the JSON `weekStartAt` instant. F5 contract: localizing the rendered
# Week Window column must be reversible — a user reading `2026-04-12
# 20:00 EDT` as the start cell must be able to reconstruct the same UTC
# instant carried by JSON `weekStartAt`. Tolerance: 1e-9 seconds (matches
# the existing reconcile-test convention for floating-point comparisons,
# though instants here are integer-valued so the tolerance is just
# defensive).
report_tz_localized_window_reversible () {
    local name="report_tz_localized_window_reversible"
    local fixture_home="$FIXTURES/weekly/multi-week-anchored"
    local AS_OF=""
    # shellcheck disable=SC1091
    . "$fixture_home/input.env"
    local json_out terminal_out
    json_out=$(HOME="$fixture_home" NO_COLOR=1 TZ=Etc/UTC \
        CCTALLY_AS_OF="$AS_OF" \
        "$BIN" report --json --tz America/New_York 2>/dev/null)
    terminal_out=$(HOME="$fixture_home" NO_COLOR=1 TZ=Etc/UTC \
        CCTALLY_AS_OF="$AS_OF" \
        "$BIN" report --tz America/New_York 2>/dev/null)
    if [ -z "$json_out" ] || [ -z "$terminal_out" ]; then
        echo "RECONCILE FAIL $name: report produced empty output"
        fail_count=$((fail_count + 1))
        return 1
    fi
    local result rc_py
    result=$(REPORT_JSON="$json_out" REPORT_TERMINAL="$terminal_out" \
        python3 -c '
import datetime as dt
import json
import os
import re
import sys
from zoneinfo import ZoneInfo

env = json.loads(os.environ["REPORT_JSON"])
current = env["current"]
expected_iso = current["weekStartAt"]
expected = dt.datetime.fromisoformat(expected_iso.replace("Z", "+00:00"))
# Search for the first data row matching the localized window cell.
# Renderer output is "<YYYY-MM-DD HH:MM> <ZONE> -> ...". We do not pin
# on the box-drawing char (varies by terminal style); scanning for the
# datetime + zone tag is sufficient and robust.
terminal = os.environ["REPORT_TERMINAL"]
match = re.search(
    r"(\d{4}-\d{2}-\d{2} \d{2}:\d{2}) ([A-Z+0-9:.\-]+) +->",
    terminal,
)
if match is None:
    sys.exit("could not locate Week Window cell in terminal output")
ts_part = match.group(1)
parsed = dt.datetime.strptime(ts_part, "%Y-%m-%d %H:%M")
zone = ZoneInfo("America/New_York")
parsed = parsed.replace(tzinfo=zone)
parsed_utc = parsed.astimezone(dt.timezone.utc)
expected_utc = expected.astimezone(dt.timezone.utc)
delta = abs((parsed_utc - expected_utc).total_seconds())
if delta > 1e-9:
    sys.exit(
        f"window reverse-parse mismatch: terminal={parsed_utc} "
        f"json={expected_utc} delta={delta}"
    )
' 2>&1); rc_py=$?
    if [ $rc_py -ne 0 ]; then
        echo "RECONCILE FAIL $name: $result"
        fail_count=$((fail_count + 1))
        return 1
    fi
    echo "PASS $name"
    pass_count=$((pass_count + 1))
}
report_tz_localized_window_reversible

# ─── Invariant TZ3: percent-breakdown --tz <iana> Week header parses ───
# back to the JSON `weekStartAt` instant. Same F5 contract as TZ2 but
# for `cmd_percent_breakdown`'s "Week: <start> -> <end>" header (the
# follow-up peer-flaw closed alongside the original F2-F5 fixes in
# commit 87ef15e). Header was previously rendered via _format_ts_compact
# without the resolved tz, dropping the offset suffix even when the
# user passed --tz. Tolerance: 1e-9 seconds (same convention as TZ2).
percent_breakdown_tz_localized_window_reversible () {
    local name="percent_breakdown_tz_localized_window_reversible"
    local fixture_home="$FIXTURES/weekly/multi-week-anchored"
    local AS_OF=""
    # shellcheck disable=SC1091
    . "$fixture_home/input.env"
    local json_out terminal_out
    json_out=$(HOME="$fixture_home" NO_COLOR=1 TZ=Etc/UTC \
        CCTALLY_AS_OF="$AS_OF" \
        "$BIN" percent-breakdown --json --tz America/New_York 2>/dev/null)
    terminal_out=$(HOME="$fixture_home" NO_COLOR=1 TZ=Etc/UTC \
        CCTALLY_AS_OF="$AS_OF" \
        "$BIN" percent-breakdown --tz America/New_York 2>/dev/null)
    if [ -z "$json_out" ] || [ -z "$terminal_out" ]; then
        echo "RECONCILE FAIL $name: percent-breakdown produced empty output"
        fail_count=$((fail_count + 1))
        return 1
    fi
    local result rc_py
    result=$(PB_JSON="$json_out" PB_TERMINAL="$terminal_out" \
        python3 -c '
import datetime as dt
import json
import os
import re
import sys
from zoneinfo import ZoneInfo

env = json.loads(os.environ["PB_JSON"])
expected_iso = env["weekStartAt"]
if not expected_iso:
    sys.exit("JSON weekStartAt missing or null; fixture lacks resolved boundary")
expected = dt.datetime.fromisoformat(expected_iso.replace("Z", "+00:00"))
# Header form: "Week: <YYYY-MM-DD HH:MM> <ZONE> -> ...". Mirror TZ2:
# pin on the datetime + zone tag, not the surrounding chars.
terminal = os.environ["PB_TERMINAL"]
match = re.search(
    r"Week: (\d{4}-\d{2}-\d{2} \d{2}:\d{2}) ([A-Z+0-9:.\-]+) +->",
    terminal,
)
if match is None:
    sys.exit("could not locate Week header cell in terminal output")
ts_part = match.group(1)
parsed = dt.datetime.strptime(ts_part, "%Y-%m-%d %H:%M")
zone = ZoneInfo("America/New_York")
parsed = parsed.replace(tzinfo=zone)
parsed_utc = parsed.astimezone(dt.timezone.utc)
expected_utc = expected.astimezone(dt.timezone.utc)
delta = abs((parsed_utc - expected_utc).total_seconds())
if delta > 1e-9:
    sys.exit(
        f"window reverse-parse mismatch: terminal={parsed_utc} "
        f"json={expected_utc} delta={delta}"
    )
' 2>&1); rc_py=$?
    if [ $rc_py -ne 0 ]; then
        echo "RECONCILE FAIL $name: $result"
        fail_count=$((fail_count + 1))
        return 1
    fi
    echo "PASS $name"
    pass_count=$((pass_count + 1))
}
percent_breakdown_tz_localized_window_reversible

# ─── Invariant TZ4: naive --since / --until parsed in display tz ───
# Locks in P1-1 / P1-2 (cmd_session, cmd_cache_report) plus the prior
# Fix #1 contract for cmd_daily / cmd_monthly: a naive `--since <date>`
# / `--until <date>` is interpreted in the resolved display tz, not host
# local. Regression target: a Jerusalem (+03) host that used to parse
# `--tz utc --since 2026-04-30` as `2026-04-30T00:00 IDT`
# (= 2026-04-29T21:00Z), pulling in entries from the prior UTC day and
# corrupting `daily` / `session` output. After the fix the same flags
# resolve to `2026-04-30T00:00Z`.
#
# Seeds 4 synthetic JSONL entries straddling 2026-04-29T23Z..
# 2026-04-30T01Z under a scratch HOME and runs each subcommand twice
# (negative `--since 2026-04-30 --until 2026-04-30` → no D-1 rows;
# positive `--since 2026-04-29 --until 2026-04-29` → D-1 row exists).
# `TZ=Asia/Jerusalem` is fixed because that's the original Fix #1
# repro environment; any host zone east of UTC where both UTC days
# occur on the same local date would behave identically.
tz_naive_args_localized () {
    local name="tz_naive_args_localized"
    local home
    home=$(mktemp -d -t cctally-reconcile-tz4-XXXXXX)

    # Seed cctally config (display.tz=local so only --tz drives parsing)
    # and a single synthetic Claude JSONL with entries straddling the
    # 2026-04-29 → 2026-04-30 UTC day boundary.
    HOME_FOR_SEED="$home" python3 - <<'PYSEED'
import json
import os
import pathlib

home = pathlib.Path(os.environ["HOME_FOR_SEED"])
app_dir = home / ".local" / "share" / "cctally"
app_dir.mkdir(parents=True, exist_ok=True)
(app_dir / "config.json").write_text(
    json.dumps({"display": {"tz": "local"}}, indent=2) + "\n",
    encoding="utf-8",
)

# JSONL under ~/.claude/projects/<escaped-cwd>/<uuid>.jsonl. Entries
# 1-2 fall on UTC day D-1 (2026-04-29), entries 3-4 on UTC day D
# (2026-04-30). Under TZ=Asia/Jerusalem all four bucket to local
# date 2026-04-30, which is exactly why naive-args-as-host-local is
# wrong: with `--tz utc --since 2026-04-30` the user expects entries
# 3-4 only, but pre-fix the window started at 2026-04-29T21Z (host
# local 2026-04-30T00:00 IDT) and pulled entries 1-2 in.
projects = home / ".claude" / "projects" / "-fixture"
projects.mkdir(parents=True, exist_ok=True)
session_id = "00000000-0000-0000-0000-00000000abcd"
jsonl_path = projects / f"{session_id}.jsonl"

def _line(ts: str) -> str:
    return json.dumps({
        "type": "assistant",
        "timestamp": ts,
        "sessionId": session_id,
        "cwd": "/fixture",
        "message": {
            "id": f"msg_{ts}",
            "model": "claude-sonnet-4-5-20250929",
            "usage": {
                "input_tokens": 100,
                "output_tokens": 100,
                "cache_creation_input_tokens": 0,
                "cache_read_input_tokens": 0,
            },
        },
        "requestId": f"req_{ts}",
    })

with jsonl_path.open("w", encoding="utf-8") as fh:
    for ts in ("2026-04-29T23:00:00.000Z", "2026-04-29T23:55:00.000Z",
               "2026-04-30T00:30:00.000Z", "2026-04-30T01:00:00.000Z"):
        fh.write(_line(ts) + "\n")
PYSEED
    if [ $? -ne 0 ]; then
        echo "RECONCILE FAIL $name: seed step failed (scratch=$home)"
        fail_count=$((fail_count + 1))
        rm -rf "$home"
        return 1
    fi

    # Negative + positive paired runs for daily and session. cache-report
    # is intentionally omitted: its day-bucket key is host-local-derived
    # (independent of display.tz), so the window-edge signal collides
    # with bucketing noise. Daily + session exercise the same parser
    # change end-to-end and are sufficient.
    local rc_py result
    result=$(HOME="$home" TZ=Asia/Jerusalem NO_COLOR=1 \
             RECONCILE_BIN="$BIN" RECONCILE_HOME="$home" \
             python3 - <<'PYCHECK' 2>&1); rc_py=$?
import json
import os
import subprocess
import sys

BIN = os.environ["RECONCILE_BIN"]
ENV = os.environ.copy()

def run(args: list[str]) -> dict:
    proc = subprocess.run(
        [BIN, *args, "--json"],
        capture_output=True, text=True, env=ENV, check=False,
    )
    if proc.returncode != 0:
        raise SystemExit(
            f"{' '.join(args)} exited {proc.returncode}: "
            f"stderr={proc.stderr.strip()}"
        )
    try:
        return json.loads(proc.stdout)
    except json.JSONDecodeError as exc:
        raise SystemExit(
            f"{' '.join(args)} non-JSON stdout: {exc}; "
            f"stdout={proc.stdout[:200]!r}"
        ) from exc

# ── daily: negative ────────────────────────────────────────────────
daily_neg = run([
    "daily", "--tz", "utc",
    "--since", "2026-04-30", "--until", "2026-04-30",
])
neg_dates = [r["date"] for r in daily_neg.get("daily", [])]
if any(d < "2026-04-30" for d in neg_dates):
    raise SystemExit(
        f"daily negative: leaked D-1 row(s) into --since 2026-04-30 "
        f"window: {neg_dates}"
    )
# Positive: same fixture, target D-1, must surface a row.
daily_pos = run([
    "daily", "--tz", "utc",
    "--since", "2026-04-29", "--until", "2026-04-29",
])
pos_dates = [r["date"] for r in daily_pos.get("daily", [])]
if "2026-04-29" not in pos_dates:
    raise SystemExit(
        f"daily positive: --since 2026-04-29 found no D-1 row "
        f"({pos_dates})"
    )

# ── session: negative ──────────────────────────────────────────────
sess_neg = run([
    "session", "--tz", "utc",
    "--since", "2026-04-30", "--until", "2026-04-30",
])
sessions_neg = sess_neg.get("sessions", [])
# `firstActivity` is an ISO string; lex compare against "2026-04-30T00"
# to detect any entry timestamp that landed before D 00:00Z.
for s in sessions_neg:
    fa = s.get("firstActivity")
    if not isinstance(fa, str) or not fa:
        continue
    if fa < "2026-04-30T00:00:00":
        raise SystemExit(
            f"session negative: firstActivity {fa!r} predates "
            f"--since 2026-04-30 window in --tz utc"
        )

# Positive: --since 2026-04-29 must yield at least one session whose
# first activity falls inside D-1.
sess_pos = run([
    "session", "--tz", "utc",
    "--since", "2026-04-29", "--until", "2026-04-29",
])
sessions_pos = sess_pos.get("sessions", [])
hit = any(
    isinstance(s.get("firstActivity"), str)
    and s["firstActivity"].startswith("2026-04-29T")
    for s in sessions_pos
)
if not hit:
    raise SystemExit(
        "session positive: --since 2026-04-29 found no session with "
        "firstActivity on D-1"
    )

print("OK")
PYCHECK

    rm -rf "$home"
    if [ $rc_py -ne 0 ]; then
        echo "RECONCILE FAIL $name: $result"
        fail_count=$((fail_count + 1))
        return 1
    fi
    echo "PASS $name"
    pass_count=$((pass_count + 1))
}
tz_naive_args_localized

# ─── Invariant TZ5: JSON Z-suffixed timestamps byte-identical across ───
# display.tz values: the JSON wire format is unaffected by the
# resolved display tz. TZ1 already asserts overall byte-identity for
# `weekly --json`; TZ5 narrows the assertion to the ISO `…Z` field
# class on a different subcommand surface (`forecast --json`) so a
# regression where any render-time-formatted ISO ever slipped into JSON
# would be caught here.
#
# Plan §Task 5 prescribed `daily --json` as "smallest sufficient
# surface", but `daily --json` emits no Z-suffixed timestamps (only
# date strings + numeric tokens), making the assertion vacuously true.
# `forecast --json` is a different surface than TZ1 (`weekly`) /
# TZ2-3 (`report` / `percent-breakdown` terminal mode), and its
# envelope carries multiple Z-suffixed fields (asOf, weekStartAt,
# weekEndAt, etc.), so the diff is meaningful.
tz_json_byte_stable_across_tz () {
    local name="tz_json_byte_stable_across_tz"
    local src_home="$FIXTURES/weekly/multi-week-anchored"
    local AS_OF=""
    local h
    # shellcheck disable=SC1091
    . "$src_home/input.env"

    local scratch
    scratch=$(mktemp -d -t cctally-reconcile-tz5-XXXXXX)
    local h_local="$scratch/cfg-local"
    local h_utc="$scratch/cfg-utc"
    local h_iana="$scratch/cfg-iana"
    # Fixture seeding is load-bearing: forecast --json on an empty HOME
    # exits 0 with `{"error": "no_current_week_data"}`, which carries no
    # Z-suffixed timestamps and would diff identically across all three
    # display.tz configs (spurious pass). The `[ ! -s ts-local.txt ]`
    # guard below catches that case, but only because error envelopes
    # lack Z-strings — keep the seed step in place.
    for h in "$h_local" "$h_utc" "$h_iana"; do
        mkdir -p "$h/.local/share/cctally"
        cp -R "$src_home/.local/share/cctally/." "$h/.local/share/cctally/"
        if [ -d "$src_home/.claude" ]; then
            cp -R "$src_home/.claude" "$h/" 2>/dev/null
        fi
    done
    echo '{"display":{"tz":"local"}}'              > "$h_local/.local/share/cctally/config.json"
    echo '{"display":{"tz":"utc"}}'                > "$h_utc/.local/share/cctally/config.json"
    echo '{"display":{"tz":"America/New_York"}}'   > "$h_iana/.local/share/cctally/config.json"

    HOME="$h_local" TZ=Etc/UTC NO_COLOR=1 CCTALLY_AS_OF="$AS_OF" \
        "$BIN" forecast --json > "$scratch/out-local.json" 2>/dev/null
    HOME="$h_utc"   TZ=Etc/UTC NO_COLOR=1 CCTALLY_AS_OF="$AS_OF" \
        "$BIN" forecast --json > "$scratch/out-utc.json"   2>/dev/null
    HOME="$h_iana"  TZ=Etc/UTC NO_COLOR=1 CCTALLY_AS_OF="$AS_OF" \
        "$BIN" forecast --json > "$scratch/out-iana.json"  2>/dev/null

    if [ ! -s "$scratch/out-local.json" ] \
       || [ ! -s "$scratch/out-utc.json" ] \
       || [ ! -s "$scratch/out-iana.json" ]; then
        # scratch dir is preserved for diff inspection on FAIL
        echo "RECONCILE FAIL $name: forecast --json produced empty output under one or more display.tz values (scratch=$scratch)"
        fail_count=$((fail_count + 1))
        return 1
    fi

    if command -v jq >/dev/null 2>&1; then
        jq -r '.. | strings | select(test("Z$"))' "$scratch/out-local.json" | sort -u > "$scratch/ts-local.txt"
        jq -r '.. | strings | select(test("Z$"))' "$scratch/out-utc.json"   | sort -u > "$scratch/ts-utc.txt"
        jq -r '.. | strings | select(test("Z$"))' "$scratch/out-iana.json"  | sort -u > "$scratch/ts-iana.txt"
    else
        grep -oE '"[^"]+Z"' "$scratch/out-local.json" | sort -u > "$scratch/ts-local.txt"
        grep -oE '"[^"]+Z"' "$scratch/out-utc.json"   | sort -u > "$scratch/ts-utc.txt"
        grep -oE '"[^"]+Z"' "$scratch/out-iana.json"  | sort -u > "$scratch/ts-iana.txt"
    fi

    if [ ! -s "$scratch/ts-local.txt" ]; then
        # scratch dir is preserved for diff inspection on FAIL
        echo "RECONCILE FAIL $name: no Z-suffixed timestamps found in forecast --json output (would render the assertion vacuous; scratch=$scratch)"
        fail_count=$((fail_count + 1))
        return 1
    fi

    if diff -q "$scratch/ts-local.txt" "$scratch/ts-utc.txt" >/dev/null \
       && diff -q "$scratch/ts-local.txt" "$scratch/ts-iana.txt" >/dev/null; then
        echo "PASS $name"
        pass_count=$((pass_count + 1))
        rm -rf "$scratch"
        return 0
    fi

    echo "RECONCILE FAIL $name:"
    echo "  local vs utc:";  diff "$scratch/ts-local.txt" "$scratch/ts-utc.txt"  | sed 's/^/    /'
    echo "  local vs iana:"; diff "$scratch/ts-local.txt" "$scratch/ts-iana.txt" | sed 's/^/    /'
    fail_count=$((fail_count + 1))
    rm -rf "$scratch"
    return 1
}
tz_json_byte_stable_across_tz

# ─── Invariant SCH1: percent_milestones / five_hour_milestones each ───
# expose an `alerted_at TEXT` column. Locks in the threshold-actions
# T1 schema migration. The column is the write-once
# forward-only marker the alert-dispatch path stamps on milestone-
# INSERT rows whose threshold matches the user's configured alert
# list; NULL means "alerts were disabled at moment of crossing OR
# threshold wasn't in the configured list" — never "delivery failed".
# Schema-only check: opens stats.db and asserts the column exists and
# is TEXT. Spawns a fresh empty HOME and runs `cctally weekly --json`
# to trigger `open_db()` (which applies the inline ALTER migrations);
# stats.db doesn't exist on a never-touched HOME, so we can't PRAGMA
# directly without first booting the schema.
sch1_milestone_alerted_at_columns () {
    local name="sch1_milestone_alerted_at_columns"
    local home
    home=$(mktemp -d -t cctally-reconcile-sch1-XXXXXX)

    # Trigger open_db() against the fresh HOME so stats.db materializes
    # with all schema migrations applied. `weekly --json` is a cheap
    # subcommand that always runs open_db(); on an empty HOME it exits
    # 0 with an empty rollup.
    HOME="$home" TZ=Etc/UTC NO_COLOR=1 \
        "$BIN" weekly --json >/dev/null 2>&1
    local rc_boot=$?
    if [ $rc_boot -ne 0 ]; then
        echo "RECONCILE FAIL $name: cctally weekly --json failed to bootstrap stats.db (rc=$rc_boot, scratch=$home)"
        fail_count=$((fail_count + 1))
        rm -rf "$home"
        return 1
    fi

    local rc_py result
    result=$(SCH1_HOME="$home" python3 - <<'PYCHECK' 2>&1); rc_py=$?
import os
import pathlib
import sqlite3
import sys

home = pathlib.Path(os.environ["SCH1_HOME"])
db_path = home / ".local" / "share" / "cctally" / "stats.db"
if not db_path.exists():
    sys.exit(f"stats.db not created at {db_path}")

conn = sqlite3.connect(str(db_path))
conn.row_factory = sqlite3.Row
try:
    for table in ("percent_milestones", "five_hour_milestones"):
        cols = {r["name"]: r["type"] for r in conn.execute(f"PRAGMA table_info({table})").fetchall()}
        assert "alerted_at" in cols, f"{table} missing alerted_at column"
        assert cols["alerted_at"].upper() == "TEXT", \
            f"{table}.alerted_at should be TEXT, got {cols['alerted_at']}"
finally:
    conn.close()
print("OK")
PYCHECK

    rm -rf "$home"
    if [ $rc_py -ne 0 ]; then
        echo "RECONCILE FAIL $name: $result"
        fail_count=$((fail_count + 1))
        return 1
    fi
    echo "PASS $name"
    pass_count=$((pass_count + 1))
}
sch1_milestone_alerted_at_columns

# ─── Invariants A1 + A2: snapshot envelope alerts array ─────────────────
# A1: every milestone row with `alerted_at IS NOT NULL` satisfies
#     `alerted_at >= captured_at_utc` (no time-travel: dispatch landed at
#     or after the crossing was captured). Applies to BOTH milestone
#     tables. Forward-only semantics (spec §4.3): NULL entries are
#     intentionally invisible — dispatch was off / threshold not in
#     configured list / row predates the alerts feature.
# A2: the snapshot envelope's `alerts` array length equals
#     `min(100, db_count_alerted)` across both milestone tables. The
#     hard cap of 100 is the "single source of truth" contract (panel
#     slices to 10, modal renders all 100 — never two divergent reads).
#
# We bypass `report --json --include-snapshot-envelope` (which doesn't
# exist) and import `_build_alerts_envelope_array` directly via
# SourceFileLoader — the same in-process pattern
# `cctally-alerts-dispatch-test` and `cctally-config-test` use. This is
# a deliberate deviation from the plan's literal subprocess form: adding
# a flag JUST to satisfy the test harness would expand the public CLI
# surface for one off-path consumer, which the project's stdlib-only
# ethos discourages.
a1_a2_alerts_envelope () {
    local name="a1_a2_alerts_envelope"
    local home
    home=$(mktemp -d -t cctally-reconcile-a1a2-XXXXXX)

    # Bootstrap stats.db (open_db() applies all inline ALTERs incl.
    # alerted_at columns from T1) by running any subcommand that
    # opens the DB — `weekly --json` is cheap and exits 0 on empty HOME.
    HOME="$home" TZ=Etc/UTC NO_COLOR=1 \
        "$BIN" weekly --json >/dev/null 2>&1
    local rc_boot=$?
    if [ $rc_boot -ne 0 ]; then
        echo "RECONCILE FAIL $name: cctally weekly --json failed to bootstrap stats.db (rc=$rc_boot, scratch=$home)"
        fail_count=$((fail_count + 1))
        rm -rf "$home"
        return 1
    fi

    local rc_py result
    result=$(REPO_ROOT_RESOLVED="$REPO_ROOT" A1A2_HOME="$home" python3 - <<'PYCHECK' 2>&1); rc_py=$?
import importlib.util
import os
import pathlib
import sqlite3
import sys
from importlib.machinery import SourceFileLoader

# Pin HOME *before* loading cctally so APP_DIR resolves under the
# fixture scratch dir (matches the alerts-dispatch harness pattern).
os.environ["HOME"] = os.environ["A1A2_HOME"]

repo_root = pathlib.Path(os.environ["REPO_ROOT_RESOLVED"])
loader = SourceFileLoader("cctally_mod", str(repo_root / "bin" / "cctally"))
spec = importlib.util.spec_from_loader("cctally_mod", loader)
mod = importlib.util.module_from_spec(spec)
sys.modules["cctally_mod"] = mod
loader.exec_module(mod)

assert str(mod.APP_DIR).startswith(os.environ["HOME"]), (
    f"APP_DIR {mod.APP_DIR} not under HOME={os.environ['HOME']!r}; "
    "harness isolation broken"
)

# Seed a few alerted rows directly so A1 / A2 have something to assert.
# Mix: 2 weekly + 2 five-hour, with one weekly row's alerted_at == captured
# (boundary equality must satisfy A1's >= predicate), and one with
# alerted_at strictly later (~5s after capture, the realistic latency).
conn = mod.open_db()
try:
    # weekly_usage_snapshots / weekly_cost_snapshots rows for the FK-shaped
    # references on percent_milestones. Pricing, week boundary etc. don't
    # matter — A1/A2 only inspect alerted_at + captured_at_utc.
    cur = conn.execute(
        "INSERT INTO weekly_usage_snapshots "
        "(captured_at_utc, week_start_date, week_end_date, "
        " week_start_at, week_end_at, weekly_percent, payload_json) "
        "VALUES (?, ?, ?, ?, ?, ?, ?)",
        ("2026-05-01T12:00:00Z", "2026-04-27", "2026-05-03", None, None, 90.0, "{}"),
    )
    usage_id = int(cur.lastrowid)
    cur = conn.execute(
        "INSERT INTO weekly_cost_snapshots "
        "(captured_at_utc, week_start_date, week_end_date, "
        " week_start_at, week_end_at, cost_usd) "
        "VALUES (?, ?, ?, ?, ?, ?)",
        ("2026-05-01T12:00:00Z", "2026-04-27", "2026-05-03", None, None, 47.32),
    )
    cost_id = int(cur.lastrowid)

    # Two weekly milestones — one alerted (boundary equality), one alerted later.
    conn.execute(
        "INSERT INTO percent_milestones "
        "(captured_at_utc, week_start_date, week_end_date, "
        " percent_threshold, cumulative_cost_usd, marginal_cost_usd, "
        " usage_snapshot_id, cost_snapshot_id, alerted_at) "
        "VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)",
        ("2026-05-01T12:00:00Z", "2026-04-27", "2026-05-03",
         90, 47.32, None, usage_id, cost_id, "2026-05-01T12:00:00Z"),
    )
    conn.execute(
        "INSERT INTO percent_milestones "
        "(captured_at_utc, week_start_date, week_end_date, "
        " percent_threshold, cumulative_cost_usd, marginal_cost_usd, "
        " usage_snapshot_id, cost_snapshot_id, alerted_at) "
        "VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)",
        ("2026-05-01T12:30:00Z", "2026-04-27", "2026-05-03",
         95, 49.55, None, usage_id, cost_id, "2026-05-01T12:30:05Z"),
    )

    # One unalerted weekly milestone (must NOT appear in envelope; A2 cap)
    conn.execute(
        "INSERT INTO percent_milestones "
        "(captured_at_utc, week_start_date, week_end_date, "
        " percent_threshold, cumulative_cost_usd, marginal_cost_usd, "
        " usage_snapshot_id, cost_snapshot_id, alerted_at) "
        "VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)",
        ("2026-05-01T13:00:00Z", "2026-04-27", "2026-05-03",
         80, 42.10, None, usage_id, cost_id, None),
    )

    # five_hour_blocks parent + two five_hour_milestones (one alerted equal,
    # one alerted later). block_id FK is documentation-only (CLAUDE.md
    # gotcha) but we honor it for realism.
    cur = conn.execute(
        "INSERT INTO five_hour_blocks "
        "(five_hour_window_key, five_hour_resets_at, block_start_at, "
        " first_observed_at_utc, last_observed_at_utc, "
        " final_five_hour_percent, "
        " total_input_tokens, total_output_tokens, "
        " total_cache_create_tokens, total_cache_read_tokens, "
        " total_cost_usd, is_closed, created_at_utc, last_updated_at_utc) "
        "VALUES (?, ?, ?, ?, ?, ?, 0, 0, 0, 0, ?, 0, ?, ?)",
        (1714419000, "2026-05-01T15:00:00Z", "2026-05-01T10:00:00Z",
         "2026-05-01T10:00:00Z", "2026-05-01T13:30:00Z", 95.0,
         3.87, "2026-05-01T10:00:00Z", "2026-05-01T13:30:00Z"),
    )
    block_id = int(cur.lastrowid)
    conn.execute(
        "INSERT INTO five_hour_milestones "
        "(block_id, five_hour_window_key, percent_threshold, "
        " captured_at_utc, usage_snapshot_id, "
        " block_input_tokens, block_output_tokens, "
        " block_cache_create_tokens, block_cache_read_tokens, "
        " block_cost_usd, alerted_at) "
        "VALUES (?, ?, ?, ?, ?, 0, 0, 0, 0, ?, ?)",
        (block_id, 1714419000, 90, "2026-05-01T13:00:00Z",
         usage_id, 3.50, "2026-05-01T13:00:00Z"),
    )
    conn.execute(
        "INSERT INTO five_hour_milestones "
        "(block_id, five_hour_window_key, percent_threshold, "
        " captured_at_utc, usage_snapshot_id, "
        " block_input_tokens, block_output_tokens, "
        " block_cache_create_tokens, block_cache_read_tokens, "
        " block_cost_usd, alerted_at) "
        "VALUES (?, ?, ?, ?, ?, 0, 0, 0, 0, ?, ?)",
        (block_id, 1714419000, 95, "2026-05-01T13:30:00Z",
         usage_id, 3.87, "2026-05-01T13:30:08Z"),
    )
    # One unalerted 5h milestone (excluded from envelope)
    conn.execute(
        "INSERT INTO five_hour_milestones "
        "(block_id, five_hour_window_key, percent_threshold, "
        " captured_at_utc, usage_snapshot_id, "
        " block_input_tokens, block_output_tokens, "
        " block_cache_create_tokens, block_cache_read_tokens, "
        " block_cost_usd, alerted_at) "
        "VALUES (?, ?, ?, ?, ?, 0, 0, 0, 0, ?, ?)",
        (block_id, 1714419000, 80, "2026-05-01T12:00:00Z",
         usage_id, 3.20, None),
    )
    conn.commit()

    # ── Invariant A1: alerted_at >= captured_at_utc (no time-travel) ──
    for table, ts_col in (
        ("percent_milestones",   "captured_at_utc"),
        ("five_hour_milestones", "captured_at_utc"),
    ):
        rows = conn.execute(
            f"SELECT alerted_at, {ts_col} FROM {table} "
            f"WHERE alerted_at IS NOT NULL"
        ).fetchall()
        assert rows, f"A1 precondition: {table} has no alerted rows in fixture"
        for r in rows:
            assert r["alerted_at"] >= r[ts_col], (
                f"A1 violation in {table}: alerted_at={r['alerted_at']!r} "
                f"< {ts_col}={r[ts_col]!r}"
            )

    # ── Invariant A2: envelope.alerts length == min(100, db_count) ──
    db_count = conn.execute(
        "SELECT (SELECT COUNT(*) FROM percent_milestones   WHERE alerted_at IS NOT NULL) "
        "     + (SELECT COUNT(*) FROM five_hour_milestones WHERE alerted_at IS NOT NULL)"
    ).fetchone()[0]
    envelope_alerts = mod._build_alerts_envelope_array(conn)
    expected = min(100, db_count)
    assert len(envelope_alerts) == expected, (
        f"A2 violation: envelope.alerts length {len(envelope_alerts)} != "
        f"min(100, {db_count}) = {expected}"
    )

    # Sanity: envelope is sorted newest-first by alerted_at and only
    # includes alerted rows. Catches a regression where the SQL filter
    # is dropped.
    seen_alerted = [a["alerted_at"] for a in envelope_alerts]
    assert seen_alerted == sorted(seen_alerted, reverse=True), (
        f"A2 sort regression: alerted_at order not newest-first: {seen_alerted}"
    )

    # Round-trip a tiny stress check: cap the union at limit=2 and confirm
    # both axes can represent the most-recent rows (so the per-axis SQL
    # LIMIT doesn't pre-drop a winner).
    #
    # The seeded fixture has 4 alerted rows whose alerted_at values, sorted
    # newest-first, are:
    #   2026-05-01T13:30:08Z  (five_hour, threshold 95)
    #   2026-05-01T13:00:00Z  (five_hour, threshold 90)
    #   2026-05-01T12:30:05Z  (weekly,    threshold 95)
    #   2026-05-01T12:00:00Z  (weekly,    threshold 90)
    # A correct merge-sort + slice yields the top two, which are BOTH
    # five_hour. A buggy implementation that skips the union sort and
    # naively concatenates `weekly_rows[:1] + fh_rows[:1]` (or otherwise
    # slices per-axis) would also produce length 2 but with WRONG content:
    # one weekly + one 5h. The IDENTITY assertion below catches that, plus
    # wrong sort direction (oldest-first) and wrong field-name reads.
    capped = mod._build_alerts_envelope_array(conn, limit=2)
    assert len(capped) == 2, f"A2 cap regression: limit=2 yielded {len(capped)} rows"

    expected_top2_alerted_at = ["2026-05-01T13:30:08Z", "2026-05-01T13:00:00Z"]
    got_alerted_at = [a["alerted_at"] for a in capped]
    assert got_alerted_at == expected_top2_alerted_at, (
        f"A2 cap content regression: got {got_alerted_at!r}, "
        f"expected {expected_top2_alerted_at!r} (axis-local slicing or "
        f"wrong sort direction would produce a different identity set)"
    )

    expected_top2_axis = ["five_hour", "five_hour"]
    got_axis = [a["axis"] for a in capped]
    assert got_axis == expected_top2_axis, (
        f"A2 axis order regression: got {got_axis!r}, "
        f"expected {expected_top2_axis!r} (a per-axis LIMIT that pre-drops "
        f"the global newest rows would surface a weekly entry here)"
    )

finally:
    conn.close()

print("OK")
PYCHECK

    rm -rf "$home"
    if [ $rc_py -ne 0 ]; then
        echo "RECONCILE FAIL $name: $result"
        fail_count=$((fail_count + 1))
        return 1
    fi
    echo "PASS $name"
    pass_count=$((pass_count + 1))
}
a1_a2_alerts_envelope

# ── v1.7.2 in-place credit invariants ─────────────────────────────────
# RECON_CREDIT_1: for every week_reset_events row, the MAX(weekly_percent)
# OVER captured_at >= effective_reset_at_utc is within 1e-9 of the latest
# captured_at's weekly_percent for that bucket.
#
# RECON_CREDIT_2: percent_milestones counts per (week, segment) are
# consistent — the post-credit row at threshold T can only exist when
# pre-credit MAX threshold for the same week is >= T (otherwise the
# writer would not have triggered).
#
# Both run against a synthesized DB inside a scratch HOME so the harness
# can be re-run on any clone without requiring a real credited stats.db.
# These complement the existing RECONCILE invariants which compare two
# subcommand outputs — credit invariants live inside one DB so they
# don't fit the reconcile_invariant() shape.

credit_invariants () {
    local name="credit_invariants"
    local home; home="$(mktemp -d -t cctally-reconcile-credit.XXXXXX)"
    local result rc_py
    result=$(REPO_ROOT_RESOLVED="$REPO_ROOT" HOME="$home" TZ=Etc/UTC python3 - <<'PYCRED' 2>&1)
import importlib.util, os, pathlib, sys
from importlib.machinery import SourceFileLoader

repo_root = pathlib.Path(os.environ["REPO_ROOT_RESOLVED"])
loader = SourceFileLoader("cctally_mod", str(repo_root / "bin" / "cctally"))
spec = importlib.util.spec_from_loader("cctally_mod", loader)
mod = importlib.util.module_from_spec(spec); sys.modules["cctally_mod"] = mod
loader.exec_module(mod)
mod.APP_DIR.mkdir(parents=True, exist_ok=True)

end_iso = "2026-05-16T05:00:00+00:00"
effective = "2026-05-15T17:00:00+00:00"
ws = "2026-05-09"

conn = mod.open_db()
try:
    # Seed pre-credit 67% (captured BEFORE effective) and post-credit 2%
    # then 4% (captured AT-OR-AFTER effective).
    conn.executemany(
        "INSERT INTO weekly_usage_snapshots "
        "(captured_at_utc, week_start_date, week_end_date, "
        " week_start_at, week_end_at, weekly_percent, source, payload_json) "
        "VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
        [
            ("2026-05-13T10:00:00Z", ws, "2026-05-16",
             ws + "T05:00:00+00:00", end_iso, 67.0, "test", "{}"),
            ("2026-05-15T18:00:00Z", ws, "2026-05-16",
             ws + "T05:00:00+00:00", end_iso, 2.0, "test", "{}"),
            ("2026-05-15T20:00:00Z", ws, "2026-05-16",
             ws + "T05:00:00+00:00", end_iso, 4.0, "test", "{}"),
        ],
    )
    conn.execute(
        "INSERT INTO week_reset_events "
        "(detected_at_utc, old_week_end_at, new_week_end_at, "
        " effective_reset_at_utc) VALUES (?, ?, ?, ?)",
        ("2026-05-15T19:00:00Z", end_iso, end_iso, effective),
    )
    # Seed pre-credit milestones up to threshold 60 (covers 1..60),
    # and one post-credit milestone at threshold 1.
    for thr in range(1, 61):
        conn.execute(
            "INSERT INTO percent_milestones "
            "(captured_at_utc, week_start_date, week_end_date, "
            " week_start_at, week_end_at, percent_threshold, "
            " cumulative_cost_usd, usage_snapshot_id, cost_snapshot_id, "
            " reset_event_id) "
            "VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)",
            ("2026-05-13T10:00:00Z", ws, "2026-05-16",
             ws + "T05:00:00+00:00", end_iso, thr, 10.0 * thr, 1, 1, 0),
        )
    conn.execute(
        "INSERT INTO percent_milestones "
        "(captured_at_utc, week_start_date, week_end_date, "
        " week_start_at, week_end_at, percent_threshold, "
        " cumulative_cost_usd, usage_snapshot_id, cost_snapshot_id, "
        " reset_event_id) "
        "VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)",
        ("2026-05-15T20:30:00Z", ws, "2026-05-16",
         ws + "T05:00:00+00:00", end_iso, 4, 12.0, 3, 1, 1),
    )
    conn.commit()

    # RECON_CREDIT_1: post-segment MAX equals latest captured_at's
    # weekly_percent in the post-segment window, within 1e-9.
    # Comparison wraps both sides with ``unixepoch()`` so a stored
    # ``effective_reset_at_utc`` with a non-UTC offset (legacy backfill
    # rows from before Bug 3 was fixed) doesn't break the bound under
    # lex string compare — same rule as the production clamp in
    # bin/_cctally_record.py.
    row = conn.execute(
        """
        SELECT MAX(weekly_percent) AS m
          FROM weekly_usage_snapshots
         WHERE week_start_date = ?
           AND unixepoch(captured_at_utc) >= unixepoch(?)
        """,
        (ws, effective),
    ).fetchone()
    latest = conn.execute(
        """
        SELECT weekly_percent
          FROM weekly_usage_snapshots
         WHERE week_start_date = ?
           AND unixepoch(captured_at_utc) >= unixepoch(?)
         ORDER BY captured_at_utc DESC, id DESC LIMIT 1
        """,
        (ws, effective),
    ).fetchone()
    diff1 = abs(float(row["m"]) - float(latest["weekly_percent"]))
    assert diff1 < 1e-9, f"RECON_CREDIT_1 fail: |max - latest| = {diff1}"

    # RECON_CREDIT_2: for each post-credit milestone threshold T, the
    # pre-credit segment's MAX threshold must be >= T. (Otherwise the
    # post-credit segment couldn't have observed the threshold crossing
    # — the writer would not have fired.)
    rows = conn.execute(
        """
        SELECT percent_threshold, reset_event_id
          FROM percent_milestones
         WHERE week_start_date = ? AND reset_event_id != 0
        """,
        (ws,),
    ).fetchall()
    pre_max = conn.execute(
        """
        SELECT MAX(percent_threshold) AS m
          FROM percent_milestones
         WHERE week_start_date = ? AND reset_event_id = 0
        """,
        (ws,),
    ).fetchone()
    pre_max_val = int(pre_max["m"]) if pre_max and pre_max["m"] is not None else 0
    for r in rows:
        t = int(r["percent_threshold"])
        assert t <= pre_max_val, (
            f"RECON_CREDIT_2 fail: post-credit threshold {t} exceeds "
            f"pre-credit MAX {pre_max_val}"
        )

    print("OK")
finally:
    conn.close()
PYCRED
    rc_py=$?
    rm -rf "$home"
    if [ $rc_py -ne 0 ]; then
        echo "RECONCILE FAIL $name: $result"
        fail_count=$((fail_count + 1))
        return 1
    fi
    echo "PASS $name"
    pass_count=$((pass_count + 1))
}
credit_invariants

# ── 5h in-place credit invariants ─────────────────────────────────────
# R-5HC1: every five_hour_reset_events row has prior_percent - post_percent
#         >= _FIVE_HOUR_RESET_PCT_DROP_THRESHOLD (5.0pp) AND
#         prior_percent > post_percent strictly. The threshold is the
#         single bound that distinguishes an Anthropic-issued credit from
#         OAuth jitter (parallel to RECON_CREDIT_* for the weekly axis;
#         the 5h threshold is 5pp because intra-block percents are smaller).
#
# R-5HC2: effective_reset_at_utc falls within the block window keyed by
#         the same five_hour_window_key
#         (block_start_at <= effective_reset_at_utc); unixepoch() on both
#         sides absorbs the +00:00-vs-Z offset mix between stored values
#         (same rule as the production clamp). No row in five_hour_blocks
#         for that key (e.g. heuristic-only history) skips this check
#         gracefully via the LEFT JOIN — there is no body to compare to.
#
# R-5HC3: UNIQUE(five_hour_window_key, effective_reset_at_utc) is enforced
#         at the schema level; this is a belt-and-suspenders runtime
#         check that catches data imported via raw INSERT bypassing the
#         constraint (e.g. operator restore from a pre-UNIQUE backup).
#
# All three run against a synthesized DB inside a scratch HOME so the
# harness can be re-run on any clone without requiring a real credited
# stats.db; this mirrors the credit_invariants() pattern above.

five_hour_credit_invariants () {
    local name="five_hour_credit_invariants"
    local home; home="$(mktemp -d -t cctally-reconcile-5hcredit.XXXXXX)"
    local result rc_py
    result=$(REPO_ROOT_RESOLVED="$REPO_ROOT" HOME="$home" TZ=Etc/UTC python3 - <<'PY5HC' 2>&1)
import importlib.util, os, pathlib, sys
from importlib.machinery import SourceFileLoader

repo_root = pathlib.Path(os.environ["REPO_ROOT_RESOLVED"])
loader = SourceFileLoader("cctally_mod", str(repo_root / "bin" / "cctally"))
spec = importlib.util.spec_from_loader("cctally_mod", loader)
mod = importlib.util.module_from_spec(spec); sys.modules["cctally_mod"] = mod
loader.exec_module(mod)
mod.APP_DIR.mkdir(parents=True, exist_ok=True)

# Block whose 10-min-floored start is 19:30 UTC on 2026-05-16, window key
# floored to 10 min, end at 24:30 (+5h). Effective credit lands at 21:00.
block_start = "2026-05-16T19:30:00+00:00"
window_key = 1779478200  # unixepoch of 2026-05-16T19:30:00+00:00
effective_a = "2026-05-16T21:00:00+00:00"
effective_b = "2026-05-16T21:30:00+00:00"  # distinct 10-min slot, same block

conn = mod.open_db()
try:
    # Seed parent block row so the LEFT JOIN in R-5HC2 has a body. Column
    # names match the ``five_hour_blocks`` DDL at bin/cctally:3905 — the
    # rollup table is open (`is_closed=0`); created/updated timestamps are
    # arbitrary in this harness since R-5HC* don't read them.
    conn.execute(
        "INSERT INTO five_hour_blocks "
        "(five_hour_window_key, five_hour_resets_at, block_start_at, "
        " first_observed_at_utc, last_observed_at_utc, "
        " final_five_hour_percent, total_input_tokens, total_output_tokens, "
        " total_cache_create_tokens, total_cache_read_tokens, "
        " total_cost_usd, is_closed, created_at_utc, last_updated_at_utc) "
        "VALUES (?, ?, ?, ?, ?, 8.0, 100, 200, 300, 400, 12.34, 0, ?, ?)",
        (window_key, "2026-05-17T00:30:00+00:00", block_start,
         "2026-05-16T19:35:00Z", "2026-05-16T22:00:00Z",
         "2026-05-16T19:35:00Z", "2026-05-16T22:00:00Z"),
    )
    # Seed two valid credit events for the same block on distinct 10-min
    # slots — both must satisfy R-5HC1/2/3.
    conn.execute(
        "INSERT INTO five_hour_reset_events "
        "(detected_at_utc, five_hour_window_key, prior_percent, "
        " post_percent, effective_reset_at_utc) VALUES (?, ?, ?, ?, ?)",
        ("2026-05-16T21:00:00Z", window_key, 28.0, 8.0, effective_a),
    )
    conn.execute(
        "INSERT INTO five_hour_reset_events "
        "(detected_at_utc, five_hour_window_key, prior_percent, "
        " post_percent, effective_reset_at_utc) VALUES (?, ?, ?, ?, ?)",
        ("2026-05-16T21:30:00Z", window_key, 15.0, 5.0, effective_b),
    )
    conn.commit()

    # R-5HC1: prior_percent - post_percent >= 5.0 AND prior > post for every row.
    row = conn.execute(
        """
        SELECT COUNT(*) AS c FROM five_hour_reset_events
         WHERE NOT (prior_percent - post_percent >= 5.0
                AND prior_percent > post_percent)
        """,
    ).fetchone()
    assert row["c"] == 0, (
        f"R-5HC1 fail: {row['c']} rows violate the 5.0pp threshold invariant"
    )

    # R-5HC2: effective_reset_at_utc >= block_start_at for every event row
    # whose window_key matches a five_hour_blocks row. unixepoch() on both
    # sides handles the offset mix between stored values (some +00:00, some
    # Z); lex compare would silently misorder on non-UTC hosts.
    row = conn.execute(
        """
        SELECT COUNT(*) AS c FROM five_hour_reset_events e
        LEFT JOIN five_hour_blocks b
          ON b.five_hour_window_key = e.five_hour_window_key
         WHERE b.id IS NOT NULL
           AND unixepoch(e.effective_reset_at_utc) < unixepoch(b.block_start_at)
        """,
    ).fetchone()
    assert row["c"] == 0, (
        f"R-5HC2 fail: {row['c']} events have effective_reset_at_utc "
        f"before block_start_at"
    )

    # R-5HC3: no two five_hour_reset_events rows share
    # (five_hour_window_key, effective_reset_at_utc). The UNIQUE constraint
    # at the schema level handles inserts via the normal path; this catches
    # raw-INSERT imports that bypass UNIQUE (e.g. operator restore).
    row = conn.execute(
        """
        SELECT COUNT(*) AS c FROM (
          SELECT five_hour_window_key, effective_reset_at_utc, COUNT(*) AS n
            FROM five_hour_reset_events
           GROUP BY five_hour_window_key, effective_reset_at_utc
          HAVING n > 1
        )
        """,
    ).fetchone()
    assert row["c"] == 0, (
        f"R-5HC3 fail: {row['c']} duplicate (window_key, effective_iso) pairs"
    )

    print("OK")
finally:
    conn.close()
PY5HC
    rc_py=$?
    rm -rf "$home"
    if [ $rc_py -ne 0 ]; then
        echo "RECONCILE FAIL $name: $result"
        fail_count=$((fail_count + 1))
        return 1
    fi
    echo "PASS $name"
    pass_count=$((pass_count + 1))
}
five_hour_credit_invariants

# ── Projects panel + modal invariants (spec §9.2) ─────────────────────
# R-PROJ1: sum(current_week.rows[].cost_usd) ≈ current_week.total_cost_usd
#          (the panel-row sum equals the row-source total within 1e-9
#          USD). Mirrors the existing "sum-over-visible-rows" structural
#          invariant the dashboard footer reads for every other panel.
#
# R-PROJ2: sum(current_week.rows[].attributed_pct) ≈ weekly_percent
#          (the row sum equals the source weekly snapshot's percent
#          within 1e-9 pp) WHEN a weekly_usage_snapshots row exists for
#          the current week. Skipped silently when no snapshot exists —
#          attributed_pct is None per spec §2.7 and the invariant has
#          nothing to compare against.
#
# R-PROJ3: per project (by bucket_path — the canonical ProjectKey
#          equality key per bin/_cctally_cache.py:188), running
#          _build_projects_envelope twice on the same inputs produces the
#          same sum(weekly_cost) for that project. This is a STABILITY
#          invariant on the trend matrix — both halves call
#          _build_projects_envelope (so it does not cross-validate against
#          a second source; R-PROJ4 is the cross-source check). It exists
#          to detect drift in the bucket_path identity when re-aggregated,
#          and to lock in that the matrix sum is keyed on bucket_path
#          (NOT `cmd_project --project <pattern>` CLI filter — the
#          substring filter does NOT reliably round-trip disambiguated
#          display_keys per Codex F6: filter matches display_key.lower()
#          OR (git_root or bucket_path).lower() — but the disambiguator's
#          parent-dir suffix is appended AFTER display_key, so a query
#          for `foo (repos)` may match unrelated `foo` rows).
#
# R-PROJ4: /api/project/<key>?weeks=N window_cost_usd equals R-PROJ3's
#          sum (the endpoint and the trend matrix agree). This is the
#          genuine cross-source check: the endpoint walks session_entries
#          via _project_detail_for_window independently from the trend's
#          weekly-cost projection.
#
# R-PROJ5: re-running _build_projects_envelope with the same inputs is
#          byte-identical (determinism). The memo cache exercises this
#          implicitly; this is the explicit cross-call regression.
#
# R-PROJ6: per-week arrays (`sessions_per_week`, `first_seen_per_week`,
#          `last_seen_per_week`) — added to support window-scoped
#          Sessions / First seen / Last seen columns in ProjectsModal
#          (issue #71, spec §3.4) — satisfy:
#            (a) length == len(trend.weeks)
#            (b) sessions_per_week[i] >= 0
#            (c) sessions_per_week[i] > 0  ⇔  first_seen_per_week[i] is not None
#            (d) sessions_per_week[i] > 0  ⇔  last_seen_per_week[i] is not None
#            (e) first_seen_per_week[i] <= last_seen_per_week[i] (ISO compare)
#            (f) sum(sessions_per_week) equals the number of (project, week)
#                buckets that produced at least one session for that project
#                — a structural check that the per-week emission cannot
#                drop weeks silently.
#
# All five run against the in-tree fixture `tests/fixtures/projects/`
# (single-conn schema; the harness builders are not regenerated here
# since fixture stability is enforced by the per-fixture .gitignore +
# `register_fixture_db` atexit normalization).
projects_envelope_invariants () {
    local name="projects_envelope_invariants"
    local result rc_py
    result=$(REPO_ROOT_RESOLVED="$REPO_ROOT" TZ=Etc/UTC python3 - <<'PYPROJ' 2>&1)
import importlib.util, os, pathlib, sqlite3, sys, types
from importlib.machinery import SourceFileLoader

repo_root = pathlib.Path(os.environ["REPO_ROOT_RESOLVED"])
# Register the cctally module BEFORE exec so the @dataclass machinery
# can resolve `cls.__module__` -> sys.modules during decoration
# (Python 3.14's dataclass eagerly probes sys.modules; without the
# pre-register the script crashes deep inside dataclass init).
script_path = repo_root / "bin" / "cctally"
mod = types.ModuleType("cctally")
mod.__file__ = str(script_path)
sys.modules["cctally"] = mod
code = compile(script_path.read_text(), str(script_path), "exec")
exec(code, mod.__dict__)

sys.path.insert(0, str(repo_root / "bin"))
import _cctally_dashboard as D

import datetime as dt
NOW = dt.datetime(2026, 5, 19, 12, 0, 0, tzinfo=dt.timezone.utc)
FIXTURE_DIR = repo_root / "tests" / "fixtures" / "projects"


def _open(path):
    return sqlite3.connect(path)


# ---- R-PROJ1 + R-PROJ2 (multi-week + edge-cases) --------------------
def _check_proj1_proj2(label, db_path):
    conn = _open(db_path)
    try:
        D._projects_reset_memo()
        env = D._build_projects_envelope(
            conn, now_utc=NOW, current_week=None, weeks_back=12,
        )
        cw = env["current_week"]
        rows = cw["rows"]
        # R-PROJ1: row sum equals total within 1e-9 USD.
        row_sum = sum(r["cost_usd"] for r in rows)
        diff = abs(row_sum - cw["total_cost_usd"])
        assert diff < 1e-9, (
            f"R-PROJ1 ({label}) fail: row_sum={row_sum} "
            f"total={cw['total_cost_usd']} diff={diff}"
        )

        # R-PROJ2: when a weekly snapshot exists for the current week,
        # sum(attributed_pct) equals the snapshot's weekly_percent.
        week_start_iso = cw["week_start_at"]
        week_date = week_start_iso[:10]
        cur = conn.execute(
            "SELECT MAX(weekly_percent) FROM weekly_usage_snapshots "
            "WHERE week_start_date = ?",
            (week_date,),
        )
        snapshot_pct = cur.fetchone()[0]
        if snapshot_pct is None:
            # No snapshot → attributed_pct must be None everywhere
            # (spec §2.7). Verify the fail-closed shape; nothing to
            # sum-compare against.
            for r in rows:
                assert r["attributed_pct"] is None, (
                    f"R-PROJ2 ({label}) fail: "
                    f"snapshot absent but attributed_pct={r['attributed_pct']!r}"
                )
            return
        valid_pcts = [r["attributed_pct"] for r in rows
                      if r["attributed_pct"] is not None]
        # All-or-nothing: either every row has attribution or none do.
        assert len(valid_pcts) == len(rows), (
            f"R-PROJ2 ({label}) fail: partial attribution — "
            f"{len(valid_pcts)} of {len(rows)} have attributed_pct"
        )
        attr_sum = sum(valid_pcts)
        diff2 = abs(attr_sum - float(snapshot_pct))
        assert diff2 < 1e-9, (
            f"R-PROJ2 ({label}) fail: sum(attributed_pct)={attr_sum} "
            f"snapshot={snapshot_pct} diff={diff2}"
        )
    finally:
        conn.close()


_check_proj1_proj2("multi-week", FIXTURE_DIR / "multi-week.db")
_check_proj1_proj2("edge-cases", FIXTURE_DIR / "edge-cases.db")
_check_proj1_proj2("single-week", FIXTURE_DIR / "single-week.db")


# ---- R-PROJ3 (multi-week, bucket_path identity) ---------------------
# Per project (matched on bucket_path — the canonical ProjectKey
# equality key, NOT the display_key), sum(weekly_cost) across the
# trend matrix equals the same sum when _build_projects_envelope is
# re-run with the same inputs. Spec §9.2 + Codex F6: by bucket_path,
# never via `cmd_project --project` substring filter.
conn = _open(FIXTURE_DIR / "multi-week.db")
try:
    D._projects_reset_memo()
    env_a = D._build_projects_envelope(
        conn, now_utc=NOW, current_week=None, weeks_back=4,
    )
    D._projects_reset_memo()
    env_b = D._build_projects_envelope(
        conn, now_utc=NOW, current_week=None, weeks_back=4,
    )
    map_a = {p["bucket_path"]: sum(p["weekly_cost"]) for p in env_a["trend"]["projects"]}
    map_b = {p["bucket_path"]: sum(p["weekly_cost"]) for p in env_b["trend"]["projects"]}
    assert set(map_a) == set(map_b), (
        f"R-PROJ3 fail: bucket_path set mismatch — "
        f"{set(map_a) ^ set(map_b)}"
    )
    for bp in map_a:
        diff = abs(map_a[bp] - map_b[bp])
        assert diff < 1e-9, (
            f"R-PROJ3 fail (bp={bp}): a={map_a[bp]} b={map_b[bp]} diff={diff}"
        )
finally:
    conn.close()


# ---- R-PROJ4 (endpoint window_cost == trend weekly_cost sum) --------
# /api/project/<key>?weeks=N's `window_cost_usd` equals the sum of
# trend.projects[i].weekly_cost over the same window for the project
# whose bucket_path matches.
conn = _open(FIXTURE_DIR / "multi-week.db")
try:
    D._projects_reset_memo()
    env = D._build_projects_envelope(
        conn, now_utc=NOW, current_week=None, weeks_back=4,
    )
    for tp in env["trend"]["projects"]:
        target_key = tp["key"]
        bp = tp["bucket_path"]
        trend_sum = sum(tp["weekly_cost"])
        D._projects_reset_memo()
        detail = D._project_detail_for_window(
            conn, project_key=target_key, weeks_back=4,
            now_utc=NOW, current_week=None,
        )
        assert detail is not None, f"R-PROJ4 fail: endpoint missed key={target_key}"
        assert detail["bucket_path"] == bp, (
            f"R-PROJ4 fail: bucket_path drift (key={target_key}): "
            f"trend={bp} vs endpoint={detail['bucket_path']}"
        )
        diff = abs(detail["window_cost_usd"] - trend_sum)
        assert diff < 1e-9, (
            f"R-PROJ4 fail (key={target_key}): endpoint={detail['window_cost_usd']} "
            f"trend_sum={trend_sum} diff={diff}"
        )
finally:
    conn.close()


# ---- R-PROJ5 (determinism / byte-identical re-runs) -----------------
import json as _json
conn = _open(FIXTURE_DIR / "multi-week.db")
try:
    D._projects_reset_memo()
    env_a = D._build_projects_envelope(
        conn, now_utc=NOW, current_week=None, weeks_back=12,
    )
    D._projects_reset_memo()
    env_b = D._build_projects_envelope(
        conn, now_utc=NOW, current_week=None, weeks_back=12,
    )
    sa = _json.dumps(env_a, sort_keys=True)
    sb = _json.dumps(env_b, sort_keys=True)
    assert sa == sb, (
        f"R-PROJ5 fail: non-deterministic output across re-runs "
        f"(lens: a={len(sa)} b={len(sb)})"
    )
finally:
    conn.close()


# ---- R-PROJ6 (per-week sessions / first / last shape invariants) ----
# Verifies the issue-#71 envelope addition holds across fixtures.
for label, fixture in (
    ("multi-week", "multi-week.db"),
    ("edge-cases", "edge-cases.db"),
    ("single-week", "single-week.db"),
):
    conn = _open(FIXTURE_DIR / fixture)
    try:
        D._projects_reset_memo()
        env = D._build_projects_envelope(
            conn, now_utc=NOW, current_week=None, weeks_back=12,
        )
        n_weeks = len(env["trend"]["weeks"])
        for tp in env["trend"]["projects"]:
            key = tp["key"]
            sw = tp.get("sessions_per_week")
            fs = tp.get("first_seen_per_week")
            ls = tp.get("last_seen_per_week")
            assert sw is not None and fs is not None and ls is not None, (
                f"R-PROJ6 ({label}, {key}) fail: missing per-week arrays "
                f"(got keys={sorted(tp.keys())})"
            )
            # (a) length matches weeks
            assert len(sw) == n_weeks == len(fs) == len(ls), (
                f"R-PROJ6 ({label}, {key}) fail: per-week length mismatch — "
                f"weeks={n_weeks} sessions={len(sw)} first={len(fs)} last={len(ls)}"
            )
            sum_active_weeks = 0
            for i, (s, f, l) in enumerate(zip(sw, fs, ls)):
                # (b) non-negative count
                assert isinstance(s, int) and s >= 0, (
                    f"R-PROJ6 ({label}, {key}) fail: sessions_per_week[{i}]={s!r}"
                )
                # (c)+(d) presence parity with first/last seen
                if s > 0:
                    assert f is not None and l is not None, (
                        f"R-PROJ6 ({label}, {key}) fail: week[{i}] has "
                        f"{s} sessions but first/last is None "
                        f"(first={f!r} last={l!r})"
                    )
                    sum_active_weeks += 1
                else:
                    assert f is None and l is None, (
                        f"R-PROJ6 ({label}, {key}) fail: week[{i}] has 0 "
                        f"sessions but first/last is non-None "
                        f"(first={f!r} last={l!r})"
                    )
                # (e) first <= last on weeks that have activity
                if f is not None and l is not None:
                    assert f <= l, (
                        f"R-PROJ6 ({label}, {key}) fail: first_seen_per_week[{i}]={f!r} "
                        f">  last_seen_per_week[{i}]={l!r}"
                    )
            # (f) Each project has at least one week with sessions — the
            # bucket-loop only emits projects that have at least one
            # nonzero week.
            assert sum_active_weeks >= 1, (
                f"R-PROJ6 ({label}, {key}) fail: project emitted but no "
                f"week recorded any sessions"
            )
    finally:
        conn.close()


print("OK")
PYPROJ
    rc_py=$?
    if [ $rc_py -ne 0 ]; then
        echo "RECONCILE FAIL $name: $result"
        fail_count=$((fail_count + 1))
        return 1
    fi
    echo "PASS $name"
    pass_count=$((pass_count + 1))
}
projects_envelope_invariants

# ── ccusage-parity dedup invariants (R-DEDUP1/2/3/4/5) ────────────────
# R-DEDUP1: for every (msg_id, req_id) key that appears in >=2 assistant
#           emissions across the user's JSONL, `session_entries` holds
#           exactly one row whose token total equals the MAX over all
#           emissions for that key — the "highest-wins" contract from
#           Task 1's `_should_replace`. Exact integer equality (no
#           tolerance — token totals are integers; any divergence is a
#           dedup bug, not float drift).
#
# R-DEDUP2: for every `mode='auto' AND project IS NULL` row in
#           `weekly_cost_snapshots` whose `range_*_iso` columns are
#           populated, the stored `cost_usd` equals re-running
#           `_calculate_entry_cost` over `session_entries` across the
#           same `[range_start_iso, range_end_iso]` window. Tolerance
#           1e-9 USD (IEEE-754 ULP drift across two independent
#           summations — same rule as every other USD invariant in this
#           harness). Matches the PRODUCTION writer's predicate
#           (`compute_week_cost` -> `iter_entries`: closed lex
#           `timestamp_utc >= ? AND <= ?` on UTC-normalized ISO).
#           Migration 008's body is now SYMMETRIC with this predicate
#           (V1 fix: `unixepoch(timestamp_utc) <= unixepoch(?)`); a row
#           whose `timestamp_utc` exactly equals `range_end_iso` is
#           included by both the one-shot recompute and every
#           subsequent `sync-week` write, so the invariant holds even
#           for snapshots whose `range_end_iso` lands on a real entry's
#           timestamp (e.g. an entry written exactly on the
#           subscription-week reset instant). Skip guards (both, mirroring
#           R-DEDUP4/5): recency exclusion (`range_end_iso` >1 day old)
#           AND cache-drift (a session file tail-ingested after migration
#           008's applied_at). The cache-drift guard is what stops the
#           CURRENT in-progress week from flaking on an active install
#           (#95) — its `range_end` is recent, so recency alone never
#           skips it, yet that's exactly when live ingests land in-window.
#
# R-DEDUP3: regression guard on the "`five_hour_blocks` totals recompute
#           every tick from `session_entries`" contract (CLAUDE.md 5-hour
#           windows section). For the active 5h block — the most recent
#           row whose start+5h is still in the future — the stored
#           `total_cost_usd` equals the recompute over
#           `[block_start_at, captured_at_utc]`. Same 1e-9 USD tolerance
#           rationale; same interval semantics as
#           `get_claude_session_entries` (lex `timestamp_utc >= ?
#           AND timestamp_utc <= ?` on ISO strings, NOT unixepoch —
#           production reads use lex compare here).
#
# R-DEDUP4: extends R-DEDUP3 to CLOSED historical `five_hour_blocks`
#           rows. The live writer only recomputes the active block;
#           migration 009 fills the gap by recomputing every row's
#           `total_*` from the corrected `session_entries`. Recency
#           exclusion (1d) + cache-drift skip mirror R-DEDUP2/3. Caps
#           at 50 rows to keep the harness bounded on heavy histories.
#
# R-DEDUP5: `percent_milestones.cumulative_cost_usd` must equal the
#           recompute over `[week_start_at_or_date_midnight,
#           captured_at_utc]` after migration 010 applies. Pre-fix the
#           milestone rows captured the pre-dedup inflated cumulative
#           cost at the moment of crossing; 010 rewrites them. Recency
#           exclusion (1d) + cache-drift skip + 100-row cap.
#
# All five read the user's real production DBs (`stats.db` + `cache.db`)
# so they exercise the actual ccusage-parity dedup wiring end-to-end. On
# a fresh clone with no production data (CI, brand-new dev box) each
# invariant skips gracefully — the python block prints "OK (skipped:
# ...)" and the harness still reports PASS. The cache rebuild from
# cache-migration 001 + stats-migration 008 populates the data that
# makes these invariants meaningful; skip is the right outcome until
# then.

dedup_invariants () {
    local name="dedup_invariants"
    local result rc_py
    result=$(REPO_ROOT_RESOLVED="$REPO_ROOT" TZ=Etc/UTC python3 - <<'PYDEDUP' 2>&1)
import datetime as dt
import json
import os
import pathlib
import sqlite3
import sys
from collections import defaultdict

repo_root = pathlib.Path(os.environ["REPO_ROOT_RESOLVED"])
sys.path.insert(0, str(repo_root / "bin"))
from _lib_pricing import _calculate_entry_cost

home = pathlib.Path.home()
stats_db = home / ".local/share/cctally/stats.db"
cache_db = home / ".local/share/cctally/cache.db"
claude_projects = home / ".claude" / "projects"

# Track sub-invariant status so a skip in one doesn't mask a fail in
# another. Final stdout summarises each — "OK" + sub-status lines so the
# bash wrapper still reports PASS while the operator can see what ran.
sub_status: list[str] = []


def _open_ro(label: str, *paths: pathlib.Path):
    """Open one or more DBs read-only, returning the connections in order.

    A concurrent cctally writer (hook-tick / sync_cache) can leave a
    DB file momentarily un-openable even when the path exists, so a
    `mode=ro` connect can raise `sqlite3.OperationalError: unable to
    open database file`. Treat that as a SKIP for this invariant rather
    than a hard fail — the live-host reconcile path stays meaningful
    without flaking under normal active use. On failure, appends a skip
    line to `sub_status`, closes any already-opened connections, and
    returns None so the caller can short-circuit.
    """
    conns: list[sqlite3.Connection] = []
    for p in paths:
        try:
            conns.append(sqlite3.connect(f"file:{p}?mode=ro", uri=True))
        except sqlite3.OperationalError as exc:
            for c in conns:
                c.close()
            sub_status.append(
                f"{label}: skipped ({p.name} not openable — concurrent "
                f"writer? {exc})"
            )
            return None
    return conns[0] if len(conns) == 1 else tuple(conns)

# ─── R-DEDUP1 ──────────────────────────────────────────────────────────
if not claude_projects.exists():
    sub_status.append("R-DEDUP1: skipped (no ~/.claude/projects on host)")
elif not cache_db.exists():
    sub_status.append("R-DEDUP1: skipped (no cache.db on host)")
else:
    # Gather all (msg_id, req_id) keys with multiple emissions, recording
    # the MAX assistant-message token total per key. Bounds: walking every
    # JSONL is unavoidable (we need the raw emissions, not the deduped
    # cache) — heavy users have ~10MB of JSONL which scans in <1s.
    max_totals: dict[tuple[str, str], int] = defaultdict(int)
    emission_counts: dict[tuple[str, str], int] = defaultdict(int)
    for fp in claude_projects.glob("**/*.jsonl"):
        try:
            fh = fp.open()
        except OSError:
            continue
        with fh:
            for line in fh:
                try:
                    obj = json.loads(line)
                except Exception:
                    continue
                if obj.get("type") != "assistant":
                    continue
                msg = obj.get("message") or {}
                usage = msg.get("usage") or {}
                # Mirror the ingest path's `<synthetic>` drop
                # (_parse_usage_entries / _iter_jsonl_entries_with_offsets
                # in _lib_jsonl.py — matches ccusage claude_loader.rs:454).
                # session_entries never holds these rows, so including
                # them in max_totals here would report a false dedup
                # regression whenever a synthetic emission shares a
                # (msg_id, req_id) with — or out-totals — a real row.
                model = msg.get("model") or obj.get("model")
                if isinstance(model, str) and model.strip() == "<synthetic>":
                    continue
                msg_id = msg.get("id")
                req_id = obj.get("requestId")
                if not msg_id or not req_id:
                    continue
                total = (
                    usage.get("input_tokens", 0)
                    + usage.get("output_tokens", 0)
                    + usage.get("cache_creation_input_tokens", 0)
                    + usage.get("cache_read_input_tokens", 0)
                )
                key = (msg_id, req_id)
                emission_counts[key] += 1
                if total > max_totals[key]:
                    max_totals[key] = total

    multi_emission_keys = [k for k, c in emission_counts.items() if c >= 2]
    if not multi_emission_keys:
        sub_status.append(
            "R-DEDUP1: skipped (no multi-emission (msg_id, req_id) pairs)"
        )
    else:
        # Sample bound at 100 keys per the plan — keeps runtime sane on
        # heavy histories. The bound is enough to surface a regression
        # in `_should_replace` (any single multi-emission key with a
        # below-max cached row would fail).
        conn = _open_ro("R-DEDUP1", cache_db)
        if conn is not None:
            try:
                sampled = multi_emission_keys[:100]
                checked = 0
                for msg_id, req_id in sampled:
                    row = conn.execute(
                        "SELECT input_tokens + output_tokens "
                        "       + cache_create_tokens + cache_read_tokens "
                        "  FROM session_entries "
                        " WHERE msg_id = ? AND req_id = ?",
                        (msg_id, req_id),
                    ).fetchone()
                    # Missing row is treated as a skip-condition (key may
                    # belong to a JSONL file the cache hasn't ingested
                    # yet, e.g. mid-write). Not a fail.
                    if row is None:
                        continue
                    cached_total = row[0]
                    expected = max_totals[(msg_id, req_id)]
                    assert cached_total == expected, (
                        f"R-DEDUP1 violated: ({msg_id}, {req_id}) cache "
                        f"holds {cached_total} tokens, max emission was "
                        f"{expected}"
                    )
                    checked += 1
                sub_status.append(
                    f"R-DEDUP1: ok ({checked}/{len(sampled)} keys checked, "
                    f"{len(multi_emission_keys)} multi-emission keys total)"
                )
            finally:
                conn.close()

# ─── R-DEDUP2 ──────────────────────────────────────────────────────────
if not stats_db.exists() or not cache_db.exists():
    sub_status.append(
        "R-DEDUP2: skipped (production stats.db/cache.db not present)"
    )
else:
    _conns = _open_ro("R-DEDUP2", stats_db, cache_db)
    if _conns is not None:
        stats, cache = _conns
        try:
            # Migration-008 scope: mode='auto' AND project IS NULL AND
            # range_*_iso both non-NULL. The migration's own SELECT mirrors
            # this — any divergence here means the migration ran but the
            # stored values drifted from session_entries afterwards (e.g.
            # cache rebuilt without re-running 008).
            #
            # Recency exclusion: skip snapshots whose `range_end_iso` is
            # less than 1 day old. Those rows are by definition
            # snapshots-of-an-active-tail: the same subscription week can
            # keep accumulating new `session_entries` until its week
            # boundary closes, and each new ingest may dedup-replace
            # existing rows under the highest-tokens-wins UPSERT (Task 1),
            # which can shift the recomputed cost (e.g. a 2nd assistant
            # emission with HIGHER token total but DIFFERENT cache_creation
            # vs cache_read mix renders cheaper or pricier than the row it
            # replaced). The snapshot captured cost-at-write-instant; once
            # the source set changes underneath, the equality cannot hold
            # by design. An earlier 1-hour boundary was too narrow — the
            # in-progress week kept absorbing UPSERTs hours after capture
            # (e.g. snapshot 4205 stored $1624.94 vs $1624.85 recompute,
            # Δ -$0.088 about ~1h20min post-capture). 1 day is conservative
            # against the typical hours-not-days ingestion catch-up: by the
            # next day all activity for prior days has landed, and any
            # later JSONL touches would only affect newer snapshots.
            # Resolve migration 008's applied_at_utc once. The cache-drift
            # skip in the loop gates on `session_files.last_ingested_at >
            # 008.applied` (the recompute baseline) rather than per-row
            # `captured_at`: cache 001 wipes + re-ingests every session row at
            # a timestamp far past historical snapshots' capture instant, so a
            # per-row `captured_at` baseline would make every historical
            # snapshot skip. 008 recomputed `cost_usd` against the post-001
            # cache; only ingests AFTER 008 could diverge stored from the
            # current cache. If 008 isn't applied yet, fall back to the
            # conservative per-row `captured_at_utc`. Same shape as R-DEDUP4/5.
            mig_row = stats.execute(
                "SELECT applied_at_utc FROM schema_migrations "
                "WHERE name = '008_recompute_weekly_cost_snapshots_dedup_fix'"
            ).fetchone()
            m008_applied = mig_row[0] if mig_row else None

            rows = stats.execute(
                "SELECT id, range_start_iso, range_end_iso, cost_usd, "
                "       captured_at_utc "
                "  FROM weekly_cost_snapshots "
                " WHERE mode = 'auto' AND project IS NULL "
                "   AND range_start_iso IS NOT NULL "
                "   AND range_end_iso IS NOT NULL "
                "   AND unixepoch(range_end_iso) "
                "       < unixepoch('now', '-1 day')"
            ).fetchall()
            if not rows:
                sub_status.append(
                    "R-DEDUP2: skipped (no eligible weekly_cost_snapshots rows)"
                )
            else:
                checked = 0
                for snap_id, start_iso, end_iso, stored, captured_at_utc in rows:
                    # Cache-drift guard (mirrors R-DEDUP3/4/5): if any session
                    # file was tail-ingested after the recompute baseline, a
                    # row inside [range_start, range_end] may have been
                    # INSERTed or REPLACEd (highest-tokens-wins UPSERT, Task 1)
                    # since the snapshot was written, so the recompute would
                    # diverge through no fault of the writer. This is the guard
                    # R-DEDUP2 was missing (#95): the recency exclusion alone
                    # never skips the CURRENT in-progress week (its `range_end`
                    # is recent, not >1 day old), which is exactly when live
                    # ingests land in-window and the race fires. Skip rather
                    # than report a spurious fail.
                    drift_baseline = m008_applied or captured_at_utc
                    stale_row = cache.execute(
                        "SELECT 1 FROM session_files "
                        " WHERE last_ingested_at > ? LIMIT 1",
                        (drift_baseline,),
                    ).fetchone()
                    if stale_row is not None:
                        continue
                    # Match the PRODUCTION writer's predicate exactly:
                    # `iter_entries` converts the input datetimes to UTC ISO
                    # and then runs the closed-interval lex compare
                    # `timestamp_utc >= ? AND timestamp_utc <= ?` against
                    # `session_entries.timestamp_utc` (which is stored in
                    # UTC). Normalizing the stored `range_*_iso` (which
                    # may carry a host offset like `+03:00`) to UTC ISO
                    # here mirrors that one-shot conversion and keeps the
                    # row set identical to what `compute_week_cost`
                    # walked at write time.
                    start_utc = dt.datetime.fromisoformat(start_iso).astimezone(
                        dt.timezone.utc).isoformat()
                    end_utc = dt.datetime.fromisoformat(end_iso).astimezone(
                        dt.timezone.utc).isoformat()
                    entries = cache.execute(
                        "SELECT model, input_tokens, output_tokens, "
                        "       cache_create_tokens, cache_read_tokens, "
                        "       usage_extra_json, cost_usd_raw "
                        "  FROM session_entries "
                        " WHERE timestamp_utc >= ? "
                        "   AND timestamp_utc <= ?",
                        (start_utc, end_utc),
                    ).fetchall()
                    computed = 0.0
                    for model, i, o, cc, cr, extras_json, raw in entries:
                        usage = {
                            "input_tokens": i,
                            "output_tokens": o,
                            "cache_creation_input_tokens": cc,
                            "cache_read_input_tokens": cr,
                        }
                        if extras_json:
                            usage.update(json.loads(extras_json))
                        computed += _calculate_entry_cost(
                            model, usage, mode="auto", cost_usd=raw,
                        )
                    assert abs(stored - computed) < 1e-9, (
                        f"R-DEDUP2 violated: snapshot id={snap_id} "
                        f"stored=${stored:.9f} computed=${computed:.9f} "
                        f"range=[{start_iso}, {end_iso}]"
                    )
                    checked += 1
                if checked == 0:
                    sub_status.append(
                        "R-DEDUP2: skipped (every eligible snapshot had a "
                        "post-capture cache ingest)"
                    )
                else:
                    sub_status.append(
                        f"R-DEDUP2: ok ({checked} weekly_cost_snapshots rows)"
                    )
        finally:
            stats.close()
            cache.close()

# ─── R-DEDUP3 ──────────────────────────────────────────────────────────
if not stats_db.exists() or not cache_db.exists():
    sub_status.append(
        "R-DEDUP3: skipped (production stats.db/cache.db not present)"
    )
else:
    _conns = _open_ro("R-DEDUP3", stats_db, cache_db)
    if _conns is not None:
        stats, cache = _conns
        try:
            # Active block = the most recent five_hour_blocks row whose
            # block_start_at + 5h is still in the future. Mirrors the same
            # "is this block still live?" predicate the dashboard / TUI use
            # for the ACTIVE row. unixepoch() on both sides keeps the
            # comparison offset-agnostic (block_start_at may carry host
            # offset; `now_utc_iso` is +00:00).
            now_utc_iso = dt.datetime.now(dt.timezone.utc).isoformat()
            active = stats.execute(
                "SELECT block_start_at, last_observed_at_utc, total_cost_usd "
                "  FROM five_hour_blocks "
                " WHERE unixepoch(block_start_at) + 5 * 3600 "
                "       > unixepoch(?) "
                " ORDER BY block_start_at DESC LIMIT 1",
                (now_utc_iso,),
            ).fetchone()
            if active is None:
                sub_status.append(
                    "R-DEDUP3: skipped (no active 5h block on host)"
                )
            else:
                block_start_at, last_observed_at_utc, stored_cost = active
                # Match `iter_entries` interval semantics: lex
                # `timestamp_utc >= ? AND <= ?` on ISO strings AFTER
                # normalizing both bounds to UTC. `block_start_at` is stored
                # with the host's display offset (e.g. `+03:00`) per
                # `parse_iso_datetime`'s host-local fallback (CLAUDE.md
                # "Cross-reset flag is interval-based" note); raw lex compare
                # against UTC-keyed `timestamp_utc` would silently miss every
                # entry on a non-UTC host. Normalizing here mirrors the
                # one-shot `astimezone(utc).isoformat()` `iter_entries` does
                # at write time, keeping the row set identical to what
                # `_compute_block_totals` walked.
                block_start_utc = dt.datetime.fromisoformat(
                    block_start_at).astimezone(dt.timezone.utc).isoformat()
                last_obs_utc = dt.datetime.fromisoformat(
                    last_observed_at_utc.replace("Z", "+00:00")
                ).astimezone(dt.timezone.utc).isoformat()
                # Cache-drift guard: if `session_entries` has rows with
                # `timestamp_utc` inside the block window that were INSERTed
                # or REPLACEd (highest-wins) AFTER the rollup's last
                # `record-usage` tick, the rollup is stale by design — the
                # recompute would diverge through no fault of the writer.
                # We can't read a per-row `last_modified`, but the cache's
                # `session_files.last_ingested_at` is a sound proxy: any
                # file whose tail-ingest landed after `last_obs_utc` may
                # have changed a row in our window. Skip in that case
                # rather than report a spurious fail.
                stale_row = cache.execute(
                    "SELECT 1 FROM session_files "
                    " WHERE last_ingested_at > ? LIMIT 1",
                    (last_obs_utc,),
                ).fetchone()
                if stale_row is not None:
                    sub_status.append(
                        f"R-DEDUP3: skipped (active block at "
                        f"{block_start_at} — cache ingested after last "
                        f"record-usage tick)"
                    )
                else:
                    entries = cache.execute(
                        "SELECT model, input_tokens, output_tokens, "
                        "       cache_create_tokens, cache_read_tokens, "
                        "       usage_extra_json, cost_usd_raw "
                        "  FROM session_entries "
                        " WHERE timestamp_utc >= ? "
                        "   AND timestamp_utc <= ?",
                        (block_start_utc, last_obs_utc),
                    ).fetchall()
                    computed_cost = 0.0
                    for model, i, o, cc, cr, extras_json, raw in entries:
                        usage = {
                            "input_tokens": i,
                            "output_tokens": o,
                            "cache_creation_input_tokens": cc,
                            "cache_read_input_tokens": cr,
                        }
                        if extras_json:
                            usage.update(json.loads(extras_json))
                        computed_cost += _calculate_entry_cost(
                            model, usage, mode="auto", cost_usd=raw,
                        )
                    assert abs(stored_cost - computed_cost) < 1e-9, (
                        f"R-DEDUP3 violated: active block "
                        f"block_start_at={block_start_at} "
                        f"stored=${stored_cost:.9f} "
                        f"computed=${computed_cost:.9f}"
                    )
                    sub_status.append(
                        f"R-DEDUP3: ok (active block at {block_start_at})"
                    )
        finally:
            stats.close()
            cache.close()

# ─── R-DEDUP4 ──────────────────────────────────────────────────────────
# Closed historical `five_hour_blocks` totals must equal the recompute
# over `[block_start_at, last_observed_at_utc]` after migration 009
# applies. Pre-migration the live writer (`maybe_update_five_hour_block`)
# only recomputes the currently active block; closed blocks kept their
# pre-dedup totals forever absent the one-shot migration.
#
# Scope: closed blocks only. Active block has its own invariant
# (R-DEDUP3); covering it here would duplicate the same recompute path
# without adding signal.
#
# Recency exclusion: skip blocks whose `last_observed_at_utc` is less
# than 1 day old. Same rationale as R-DEDUP2 — the cache can keep
# absorbing UPSERTs after a block closes (e.g. a JSONL file's tail
# arrived late), which shifts the recomputed cost without the stored
# total being able to track it. 1 day is conservative against
# typical hours-not-days ingestion catch-up.
#
# Tolerance: 1e-9 USD (same float-ULP rule as R-DEDUP2/3).
if not stats_db.exists() or not cache_db.exists():
    sub_status.append(
        "R-DEDUP4: skipped (production stats.db/cache.db not present)"
    )
else:
    _conns = _open_ro("R-DEDUP4", stats_db, cache_db)
    if _conns is not None:
        stats, cache = _conns
        try:
            # Resolve migration 009's applied_at_utc once. The cache-drift
            # skip below probes `session_files.last_ingested_at > 009.applied_at`
            # rather than `> last_observed_at_utc` (which would make every
            # closed-historical block skip, since cache 001 wipes + re-ingests
            # every session row at a timestamp far past any historical block's
            # last_observed). The right semantics: migration 009 recomputed
            # block totals against the post-001 cache snapshot at 009.applied;
            # only ingests AFTER 009 could diverge the stored values from the
            # current cache state. If 009 isn't applied yet, fall back to the
            # conservative per-block guard.
            mig_row = stats.execute(
                "SELECT applied_at_utc FROM schema_migrations "
                "WHERE name = '009_recompute_five_hour_blocks_dedup_fix'"
            ).fetchone()
            m009_applied = mig_row[0] if mig_row else None

            rows = stats.execute(
                "SELECT id, block_start_at, last_observed_at_utc, "
                "       total_cost_usd "
                "  FROM five_hour_blocks "
                " WHERE is_closed = 1 "
                "   AND unixepoch(last_observed_at_utc) "
                "       < unixepoch('now', '-1 day') "
                " ORDER BY block_start_at DESC LIMIT 50"
            ).fetchall()
            if not rows:
                sub_status.append(
                    "R-DEDUP4: skipped (no eligible closed 5h blocks)"
                )
            else:
                checked = 0
                for (
                    block_id, block_start_at, last_observed_at_utc,
                    stored_cost,
                ) in rows:
                    # Same UTC normalization as R-DEDUP3 — `block_start_at`
                    # may carry host offset.
                    block_start_utc = dt.datetime.fromisoformat(
                        block_start_at
                    ).astimezone(dt.timezone.utc).isoformat()
                    last_obs_utc = dt.datetime.fromisoformat(
                        last_observed_at_utc.replace("Z", "+00:00")
                    ).astimezone(dt.timezone.utc).isoformat()
                    # Cache-drift guard. Gate on 009's applied_at when
                    # present (recompute baseline); fall back to
                    # last_obs_utc when 009 hasn't run (conservative,
                    # mirrors R-DEDUP3's posture for the active block).
                    drift_baseline = m009_applied or last_obs_utc
                    stale_row = cache.execute(
                        "SELECT 1 FROM session_files "
                        " WHERE last_ingested_at > ? LIMIT 1",
                        (drift_baseline,),
                    ).fetchone()
                    if stale_row is not None:
                        continue
                    entries = cache.execute(
                        "SELECT model, input_tokens, output_tokens, "
                        "       cache_create_tokens, cache_read_tokens, "
                        "       usage_extra_json, cost_usd_raw "
                        "  FROM session_entries "
                        " WHERE timestamp_utc >= ? "
                        "   AND timestamp_utc <= ?",
                        (block_start_utc, last_obs_utc),
                    ).fetchall()
                    computed_cost = 0.0
                    for model, i, o, cc, cr, extras_json, raw in entries:
                        usage = {
                            "input_tokens": i,
                            "output_tokens": o,
                            "cache_creation_input_tokens": cc,
                            "cache_read_input_tokens": cr,
                        }
                        if extras_json:
                            usage.update(json.loads(extras_json))
                        computed_cost += _calculate_entry_cost(
                            model, usage, mode="auto", cost_usd=raw,
                        )
                    assert abs(stored_cost - computed_cost) < 1e-9, (
                        f"R-DEDUP4 violated: block id={block_id} "
                        f"block_start_at={block_start_at} "
                        f"stored=${stored_cost:.9f} "
                        f"computed=${computed_cost:.9f}"
                    )
                    checked += 1
                if checked == 0:
                    sub_status.append(
                        "R-DEDUP4: skipped (every eligible block had a "
                        "post-close cache ingest)"
                    )
                else:
                    sub_status.append(
                        f"R-DEDUP4: ok ({checked} closed 5h blocks "
                        f"reconciled)"
                    )
        finally:
            stats.close()
            cache.close()

# ─── R-DEDUP5 ──────────────────────────────────────────────────────────
# `percent_milestones.cumulative_cost_usd` must equal the recompute over
# `[week_start_at_or_date_midnight, captured_at_utc]` after migration
# 010 applies. Pre-migration the milestones were write-once at the
# moment of crossing using a `latest_cost` SELECT against the
# (then-stale) `weekly_cost_snapshots` row — so the historical values
# carried the pre-dedup inflated factor that 008/010 unwind.
#
# Scope: rows with `week_start_at` non-NULL OR `week_start_date`
# parseable. Legacy rows missing both are skipped (migration 010 skips
# them too — leaves them at pre-fix value).
#
# Recency exclusion: skip milestones whose `captured_at_utc` is less
# than 1 day old. Same rationale as R-DEDUP2/4.
#
# Tolerance: 1e-9 USD.
if not stats_db.exists() or not cache_db.exists():
    sub_status.append(
        "R-DEDUP5: skipped (production stats.db/cache.db not present)"
    )
else:
    _conns = _open_ro("R-DEDUP5", stats_db, cache_db)
    if _conns is not None:
        stats, cache = _conns
        try:
            # Mirror R-DEDUP4: gate cache-drift skip on migration 010's
            # applied_at when present; fall back to per-row captured_at.
            mig_row = stats.execute(
                "SELECT applied_at_utc FROM schema_migrations "
                "WHERE name = '010_recompute_percent_milestones_dedup_fix'"
            ).fetchone()
            m010_applied = mig_row[0] if mig_row else None

            rows = stats.execute(
                "SELECT id, week_start_date, week_start_at, "
                "       captured_at_utc, cumulative_cost_usd "
                "  FROM percent_milestones "
                " WHERE unixepoch(captured_at_utc) "
                "       < unixepoch('now', '-1 day') "
                " ORDER BY captured_at_utc DESC LIMIT 100"
            ).fetchall()
            if not rows:
                sub_status.append(
                    "R-DEDUP5: skipped (no eligible percent_milestones)"
                )
            else:
                checked = 0
                for (
                    mid, week_start_date, week_start_at,
                    captured_at_utc, stored_cum,
                ) in rows:
                    # Migration 010's lower-bound fallback rule: prefer
                    # week_start_at, else week_start_date at midnight UTC.
                    if week_start_at:
                        range_start_iso = week_start_at
                    elif week_start_date:
                        range_start_iso = (
                            f"{week_start_date}T00:00:00+00:00"
                        )
                    else:
                        continue
                    start_utc = dt.datetime.fromisoformat(
                        range_start_iso
                    ).astimezone(dt.timezone.utc).isoformat()
                    end_utc = dt.datetime.fromisoformat(
                        captured_at_utc.replace("Z", "+00:00")
                    ).astimezone(dt.timezone.utc).isoformat()
                    # Cache-drift guard: gate on 010's applied_at when
                    # present (recompute baseline); fall back to
                    # captured_at_utc when 010 hasn't run.
                    drift_baseline = m010_applied or captured_at_utc
                    stale_row = cache.execute(
                        "SELECT 1 FROM session_files "
                        " WHERE last_ingested_at > ? LIMIT 1",
                        (drift_baseline,),
                    ).fetchone()
                    if stale_row is not None:
                        continue
                    entries = cache.execute(
                        "SELECT model, input_tokens, output_tokens, "
                        "       cache_create_tokens, cache_read_tokens, "
                        "       usage_extra_json, cost_usd_raw "
                        "  FROM session_entries "
                        " WHERE timestamp_utc >= ? "
                        "   AND timestamp_utc <= ?",
                        (start_utc, end_utc),
                    ).fetchall()
                    computed = 0.0
                    for model, i, o, cc, cr, extras_json, raw in entries:
                        usage = {
                            "input_tokens": i,
                            "output_tokens": o,
                            "cache_creation_input_tokens": cc,
                            "cache_read_input_tokens": cr,
                        }
                        if extras_json:
                            usage.update(json.loads(extras_json))
                        computed += _calculate_entry_cost(
                            model, usage, mode="auto", cost_usd=raw,
                        )
                    assert abs(stored_cum - computed) < 1e-9, (
                        f"R-DEDUP5 violated: milestone id={mid} "
                        f"week={week_start_date} "
                        f"captured={captured_at_utc} "
                        f"stored=${stored_cum:.9f} "
                        f"computed=${computed:.9f}"
                    )
                    checked += 1
                if checked == 0:
                    sub_status.append(
                        "R-DEDUP5: skipped (every eligible milestone had a "
                        "post-capture cache ingest)"
                    )
                else:
                    sub_status.append(
                        f"R-DEDUP5: ok ({checked} percent_milestones "
                        f"reconciled)"
                    )
        finally:
            stats.close()
            cache.close()

print("OK")
for s in sub_status:
    print(f"  {s}")
PYDEDUP
    rc_py=$?
    if [ $rc_py -ne 0 ]; then
        echo "RECONCILE FAIL $name: $result"
        fail_count=$((fail_count + 1))
        return 1
    fi
    echo "PASS $name"
    # Surface the per-invariant sub-status lines so operators can see
    # which of R-DEDUP1/2/3 actually ran vs skipped on this host.
    echo "$result" | tail -n +2
    pass_count=$((pass_count + 1))
}
dedup_invariants

# ─── Invariant MODE-*: -m/--mode cost-source cross-command equality + ───
# kernel identities (issue #86 Session C, spec §4.1).
#
# Fixture: tests/fixtures/mode/mixed-cost — one subscription week, two
# days, two models; each day mixes one entry WITH a recorded costUSD
# (cache.db session_entries.cost_usd_raw, deliberately != computed) and
# one entry WITHOUT (NULL). The three modes therefore visibly diverge:
#   auto      = recorded-when-present, else computed
#   calculate = always computed from embedded pricing (ignores recorded)
#   display   = recorded-only ($0 when absent)
#
# MODE-A/B/C (per mode): Σ(daily.totalCost) == Σ(monthly.totalCost) ==
#   Σ(weekly.totalCost) == Σ(session.totalCost) == range-cost.totalCostUSD
#   over the same window, within 1e-9 USD. Catches any of the five
#   recompute-from-entries commands silently NOT threading mode (they would
#   disagree). The session leg is the critical one: `session` was the lone
#   pre-Session-C aggregator that ignored recorded costUSD, so its auto-mode
#   total used to UNDER/OVER-count vs daily on this mixed fixture.
# MODE-KERNEL: auto Σ > display Σ (display drops the NULL-cost entries to
#   $0) AND auto Σ != calculate Σ (recorded != computed on the WITH-cost
#   entries). These are the kernel identities that prove the modes are
#   semantically distinct over this fixture, not just plumbed.

MODE_FX="$FIXTURES/mode/mixed-cost"

# daily Σ == monthly Σ (per mode).
INVARIANT_MODE_DAILY_EQ_MONTHLY_PY='
import json, os
a = json.loads(os.environ["RECONCILE_A"])
b = json.loads(os.environ["RECONCILE_B"])
sum_daily = sum(r["totalCost"] for r in a.get("daily", []))
sum_monthly = sum(r["totalCost"] for r in b.get("monthly", []))
assert abs(sum_daily - sum_monthly) < 1e-9, \
    f"Σdaily.totalCost={sum_daily} Σmonthly.totalCost={sum_monthly}"
'
# daily Σ == weekly Σ (per mode).
INVARIANT_MODE_DAILY_EQ_WEEKLY_PY='
import json, os
a = json.loads(os.environ["RECONCILE_A"])
b = json.loads(os.environ["RECONCILE_B"])
sum_daily = sum(r["totalCost"] for r in a.get("daily", []))
sum_weekly = sum(r["totalCost"] for r in b.get("weekly", []))
assert abs(sum_daily - sum_weekly) < 1e-9, \
    f"Σdaily.totalCost={sum_daily} Σweekly.totalCost={sum_weekly}"
'
# daily Σ == range-cost.totalCostUSD over the same week window (per mode).
INVARIANT_MODE_DAILY_EQ_RANGE_COST_PY='
import json, os
a = json.loads(os.environ["RECONCILE_A"])
b = json.loads(os.environ["RECONCILE_B"])
sum_daily = sum(r["totalCost"] for r in a.get("daily", []))
range_total = b["totalCostUSD"]
assert abs(sum_daily - range_total) < 1e-9, \
    f"Σdaily.totalCost={sum_daily} range-cost.totalCostUSD={range_total}"
'
# daily Σ == session Σ (per mode). `_aggregate_claude_sessions` was the lone
# pre-Session-C aggregator that ignored recorded costUSD (it passed no
# cost_usd, so auto collapsed to calculate). This leg proves it now threads
# mode like every sibling — i.e. on costUSD-bearing data `session` default
# (auto) totals match `daily`, and `--mode calculate|display` track too. The
# session/ goldens carry no costUSD, so ONLY this mixed-cost fixture exercises
# the divergence (spec §4.1).
INVARIANT_MODE_DAILY_EQ_SESSION_PY='
import json, os
a = json.loads(os.environ["RECONCILE_A"])
b = json.loads(os.environ["RECONCILE_B"])
sum_daily = sum(r["totalCost"] for r in a.get("daily", []))
sum_session = sum(r["totalCost"] for r in b.get("sessions", []))
assert abs(sum_daily - sum_session) < 1e-9, \
    f"Σdaily.totalCost={sum_daily} Σsession.totalCost={sum_session}"
'

# The mixed-cost week spans 2026-04-20 → 2026-04-27; range-cost is given
# the same window so it sums exactly the seeded entries.
MODE_RANGE_START="2026-04-20T00:00:00Z"
MODE_RANGE_END="2026-04-27T00:00:00Z"

for mode in auto calculate display; do
    reconcile_invariant "mode_${mode}_daily_eq_monthly" "$MODE_FX" \
        "daily --json --mode $mode" \
        "monthly --json --mode $mode" \
        "$INVARIANT_MODE_DAILY_EQ_MONTHLY_PY"
    reconcile_invariant "mode_${mode}_daily_eq_weekly" "$MODE_FX" \
        "daily --json --mode $mode" \
        "weekly --json --mode $mode" \
        "$INVARIANT_MODE_DAILY_EQ_WEEKLY_PY"
    reconcile_invariant "mode_${mode}_daily_eq_range_cost" "$MODE_FX" \
        "daily --json --mode $mode" \
        "range-cost -s $MODE_RANGE_START -e $MODE_RANGE_END --mode $mode --json" \
        "$INVARIANT_MODE_DAILY_EQ_RANGE_COST_PY"
    reconcile_invariant "mode_${mode}_daily_eq_session" "$MODE_FX" \
        "daily --json --mode $mode" \
        "session --json --mode $mode" \
        "$INVARIANT_MODE_DAILY_EQ_SESSION_PY"
done

# Kernel identity: auto Σ > display Σ (NULL-cost entries drop to $0).
INVARIANT_MODE_AUTO_GT_DISPLAY_PY='
import json, os
a = json.loads(os.environ["RECONCILE_A"])
b = json.loads(os.environ["RECONCILE_B"])
sum_auto = sum(r["totalCost"] for r in a.get("daily", []))
sum_display = sum(r["totalCost"] for r in b.get("daily", []))
assert sum_auto > sum_display + 1e-9, \
    f"expected auto Σ > display Σ; auto={sum_auto} display={sum_display}"
'
reconcile_invariant "mode_kernel_auto_gt_display" "$MODE_FX" \
    "daily --json --mode auto" \
    "daily --json --mode display" \
    "$INVARIANT_MODE_AUTO_GT_DISPLAY_PY"

# Kernel identity: auto Σ != calculate Σ (recorded != computed on the
# WITH-cost entries, so auto reuses recorded while calculate recomputes).
INVARIANT_MODE_AUTO_NE_CALCULATE_PY='
import json, os
a = json.loads(os.environ["RECONCILE_A"])
b = json.loads(os.environ["RECONCILE_B"])
sum_auto = sum(r["totalCost"] for r in a.get("daily", []))
sum_calc = sum(r["totalCost"] for r in b.get("daily", []))
assert abs(sum_auto - sum_calc) > 1e-9, \
    f"expected auto Σ != calculate Σ; auto={sum_auto} calculate={sum_calc}"
'
reconcile_invariant "mode_kernel_auto_ne_calculate" "$MODE_FX" \
    "daily --json --mode auto" \
    "daily --json --mode calculate" \
    "$INVARIANT_MODE_AUTO_NE_CALCULATE_PY"

# ── Statusline invariants (issue #86 Session G — spec §5.2) ───────────
# Six cross-command invariants binding `cctally statusline` segments to
# their canonical-command counterparts. Each invariant seeds a single
# fixture HOME (cache.db + stats.db), runs `cctally statusline` with a
# hand-crafted stdin payload, parses the resulting line via regex to
# extract the relevant dollar amount / percentage, then compares against
# `cctally session/daily/blocks/...` JSON output for the same window.
# Tolerance 1e-9 USD / 0.5 pp for percent-rounding (statusline rounds
# ints; the sibling command emits a float). Mirrors the established
# pattern of running both sides under the same fixture HOME + AS_OF +
# extracting both values to Python via env vars.
STATUSLINE_FIXTURE_HOME="$SCRATCH_DIR/statusline-reconcile"
STATUSLINE_AS_OF="2026-05-28T12:00:00Z"
STATUSLINE_SID="reconcile-sid"
STATUSLINE_SOURCE_PATH="/cache/reconcile.jsonl"

# Build the fixture HOME (cache.db with one session entry attributed to
# STATUSLINE_SID; stats.db with one weekly_usage_snapshots row carrying
# 5h/7d percentages anchored to the AS_OF window). Run once via Python
# to keep DDL out of the harness shell.
mkdir -p "$STATUSLINE_FIXTURE_HOME/.local/share/cctally"
PYTHONPATH="$REPO_ROOT/bin" python3 - <<PY >/dev/null
import pathlib, sqlite3
import _fixture_builders as fb

home = pathlib.Path(r"$STATUSLINE_FIXTURE_HOME/.local/share/cctally")
home.mkdir(parents=True, exist_ok=True)

cache_db = home / "cache.db"
fb.create_cache_db(cache_db)
with sqlite3.connect(cache_db) as c:
    c.execute(
        "INSERT OR IGNORE INTO session_files "
        "(path, size_bytes, mtime_ns, last_byte_offset, "
        " last_ingested_at, session_id, project_path) "
        "VALUES (?, 0, 0, 0, ?, ?, NULL)",
        (r"$STATUSLINE_SOURCE_PATH", fb.FIXED_LAST_INGESTED_AT, r"$STATUSLINE_SID"),
    )
    # 200_000 input + 20_000 output → \$0.90 cost from CLAUDE_MODEL_PRICING
    # (3e-06 input + 1.5e-05 output for claude-sonnet-4-5).
    fb.seed_session_entry(
        c,
        source_path=r"$STATUSLINE_SOURCE_PATH",
        line_offset=1,
        timestamp_utc="2026-05-28T11:30:00Z",
        model="claude-sonnet-4-5",
        input_tokens=200_000,
        output_tokens=20_000,
        msg_id="msg-reconcile",
        req_id="req-reconcile",
    )

stats_db = home / "stats.db"
fb.create_stats_db(stats_db)
with sqlite3.connect(stats_db) as c:
    # 5h_resets=1779981720 → canonical key floored to 1779981600.
    fb.seed_weekly_usage_snapshot(
        c,
        captured_at_utc="2026-05-28T11:50:00Z",
        week_start_date="2026-05-28",
        week_end_date="2026-06-04",
        week_start_at="2026-05-28T02:00:00Z",
        week_end_at="2026-06-04T02:00:00Z",
        weekly_percent=42.0,
        five_hour_percent=34.0,
        five_hour_resets_at="2026-05-28T15:22:00Z",
        five_hour_window_key=1779981600,
        source="reconcile-fixture",
    )
PY

# Stdin payload for statusline. Same shape as the basic fixture but
# pointed at the reconcile session_id + source_path.
STATUSLINE_STDIN='{"session_id":"'"$STATUSLINE_SID"'","model":{"id":"claude-sonnet-4-5","display_name":"Sonnet 4.5"},"workspace":{"current_dir":"/tmp"},"transcript_path":"'"$STATUSLINE_SOURCE_PATH"'","rate_limits":{"five_hour":{"used_percentage":34.0,"resets_at":1779981720},"seven_day":{"used_percentage":42.0,"resets_at":1780538400}},"cost":{"total_cost_usd":1.99}}'

# Run statusline (cctally-side cost source) and capture the line.
SL_LINE=$(HOME="$STATUSLINE_FIXTURE_HOME" \
          CCTALLY_DATA_DIR="$STATUSLINE_FIXTURE_HOME/.local/share/cctally" \
          TZ=Etc/UTC NO_COLOR=1 CCTALLY_AS_OF="$STATUSLINE_AS_OF" \
          "$BIN" statusline --cost-source cctally <<< "$STATUSLINE_STDIN")
SL_RC=$?
if [ "$SL_RC" -ne 0 ]; then
    echo "RECONCILE FAIL statusline_setup: cctally statusline exited $SL_RC"
    fail_count=$((fail_count + 1))
fi

# Common reconcile runner for statusline invariants.
# Args: NAME REGEX_TO_EXTRACT EXPECTED_VALUE_EXPR ASSERTION_PY
statusline_reconcile () {
    local name="$1" extracted="$2" expected="$3"
    local diff
    diff=$(awk -v a="$extracted" -v b="$expected" 'BEGIN{d=a-b; if(d<0)d=-d; print d}')
    if awk -v d="$diff" 'BEGIN{exit !(d < 1e-9)}'; then
        echo "PASS $name statusline/reconcile"
        pass_count=$((pass_count + 1))
    else
        echo "RECONCILE FAIL $name statusline/reconcile: " \
             "extracted=$extracted expected=$expected diff=$diff"
        fail_count=$((fail_count + 1))
    fi
}

# Helper: regex out a dollar amount from the statusline line.
extract_money () {
    # Args: full line, prefix-after-dollar (regex anchor)
    # Example: extract_money "$SL_LINE" '([0-9.]+) session' → 0.90
    local line="$1" pattern="$2"
    printf '%s\n' "$line" | sed -nE "s/.*${pattern}.*/\\1/p" | head -1
}

# Invariant 1: statusline_session_eq_cctally_session.
# `cctally session -i <sid> --json` exposes the merged-session total.
SL_SESSION=$(printf '%s\n' "$SL_LINE" | sed -nE 's/.*💰 \$([0-9.]+) session.*/\1/p')
SESS_JSON=$(HOME="$STATUSLINE_FIXTURE_HOME" \
            CCTALLY_DATA_DIR="$STATUSLINE_FIXTURE_HOME/.local/share/cctally" \
            TZ=Etc/UTC NO_COLOR=1 CCTALLY_AS_OF="$STATUSLINE_AS_OF" \
            "$BIN" session --json 2>/dev/null)
SESS_COST=$(printf '%s' "$SESS_JSON" | python3 -c "
import json, sys
data = json.load(sys.stdin)
for s in data.get('sessions', []):
    if s.get('sessionId') == '$STATUSLINE_SID':
        print(s['totalCost'])
        break
else:
    print('0')
")
statusline_reconcile "statusline_session_eq_cctally_session" \
    "$SL_SESSION" "$SESS_COST"

# Invariant 2: statusline_today_eq_daily. The today bucket (UTC) matches
# `daily` aggregated over the AS_OF date.
SL_TODAY=$(printf '%s\n' "$SL_LINE" | sed -nE 's/.*\/ \$([0-9.]+) today.*/\1/p')
DAILY_JSON=$(HOME="$STATUSLINE_FIXTURE_HOME" \
             CCTALLY_DATA_DIR="$STATUSLINE_FIXTURE_HOME/.local/share/cctally" \
             TZ=Etc/UTC NO_COLOR=1 CCTALLY_AS_OF="$STATUSLINE_AS_OF" \
             "$BIN" daily --json --since 2026-05-28 --until 2026-05-28 2>/dev/null)
DAILY_TODAY=$(printf '%s' "$DAILY_JSON" | python3 -c "
import json, sys
data = json.load(sys.stdin)
total = sum(r['totalCost'] for r in data.get('daily', []))
print(total)
")
statusline_reconcile "statusline_today_eq_daily" \
    "$SL_TODAY" "$DAILY_TODAY"

# Invariant 3: statusline_block_eq_blocks_active. The block-cost slot
# matches the cost of the active 5h block (cctally blocks -a --json).
SL_BLOCK=$(printf '%s\n' "$SL_LINE" | sed -nE 's/.*\/ \$([0-9.]+) block.*/\1/p')
BLOCKS_JSON=$(HOME="$STATUSLINE_FIXTURE_HOME" \
              CCTALLY_DATA_DIR="$STATUSLINE_FIXTURE_HOME/.local/share/cctally" \
              TZ=Etc/UTC NO_COLOR=1 CCTALLY_AS_OF="$STATUSLINE_AS_OF" \
              "$BIN" blocks -a --json 2>/dev/null)
BLOCKS_ACTIVE_COST=$(printf '%s' "$BLOCKS_JSON" | python3 -c "
import json, sys
data = json.load(sys.stdin)
blocks = data.get('blocks', [])
active = [b for b in blocks if b.get('isActive')]
print(active[0]['costUSD'] if active else 0)
")
statusline_reconcile "statusline_block_eq_blocks_active" \
    "$SL_BLOCK" "$BLOCKS_ACTIVE_COST"

# Invariant 4: statusline_burn_rate_eq_blocks_active. Same source data,
# burn formula (cost / elapsed_seconds * 3600).
SL_BURN=$(printf '%s\n' "$SL_LINE" | sed -nE 's/.*🔥 \$([0-9.]+)\/hr.*/\1/p')
EXPECTED_BURN=$(printf '%s' "$BLOCKS_JSON" | python3 -c "
import json, sys, datetime as dt
data = json.load(sys.stdin)
blocks = data.get('blocks', [])
active = [b for b in blocks if b.get('isActive')]
if not active:
    print(0)
else:
    b = active[0]
    start = dt.datetime.fromisoformat(b['startTime'].replace('Z', '+00:00'))
    now = dt.datetime.fromisoformat('$STATUSLINE_AS_OF'.replace('Z', '+00:00'))
    elapsed_s = max(int((now - start).total_seconds()), 1)
    cost = b.get('costUSD', 0)
    burn = cost / elapsed_s * 3600.0
    print(f'{burn:.2f}')
")
statusline_reconcile "statusline_burn_rate_eq_blocks_active" \
    "$SL_BURN" "$EXPECTED_BURN"

# Invariant 5: statusline_5h_eq_record_usage_latest. The rendered 5h %
# matches the latest weekly_usage_snapshots.five_hour_percent for the
# canonical window (post HWM clamp). Stdin already carries 34.0%, no
# higher HWM stored → renders 34%.
SL_5H=$(printf '%s\n' "$SL_LINE" | sed -nE 's/.*5h ([0-9]+)%.*/\1/p')
EXPECTED_5H=$(sqlite3 "$STATUSLINE_FIXTURE_HOME/.local/share/cctally/stats.db" \
    "SELECT five_hour_percent FROM weekly_usage_snapshots ORDER BY captured_at_utc DESC LIMIT 1" \
    2>/dev/null)
EXPECTED_5H_ROUNDED=$(awk -v p="$EXPECTED_5H" 'BEGIN{print int(p + 0.5)}')
statusline_reconcile "statusline_5h_eq_record_usage_latest" \
    "$SL_5H" "$EXPECTED_5H_ROUNDED"

# Invariant 6: statusline_7d_eq_record_usage_latest. Same shape.
SL_7D=$(printf '%s\n' "$SL_LINE" | sed -nE 's/.*7d ([0-9]+)%.*/\1/p')
EXPECTED_7D=$(sqlite3 "$STATUSLINE_FIXTURE_HOME/.local/share/cctally/stats.db" \
    "SELECT weekly_percent FROM weekly_usage_snapshots ORDER BY captured_at_utc DESC LIMIT 1" \
    2>/dev/null)
EXPECTED_7D_ROUNDED=$(awk -v p="$EXPECTED_7D" 'BEGIN{print int(p + 0.5)}')
statusline_reconcile "statusline_7d_eq_record_usage_latest" \
    "$SL_7D" "$EXPECTED_7D_ROUNDED"

# ─── Invariant BUDGET1: budget.spent_usd == independent raw re-derivation ──
# (F3, spec §6) `cctally budget --json .spent_usd` must equal an INDEPENDENT
# raw re-derivation of the same window's live cost within 1e-9 USD. The
# re-derivation scans the fixture's cache.db `session_entries` directly and
# reimplements the per-token cost formula from _lib_pricing.CLAUDE_MODEL_PRICING
# inline — it never calls `_sum_cost_for_range`, so the invariant stays
# non-vacuous (a different code path + summation order than budget's, exactly
# like the reconciliation-testing project memory prescribes). Pinned to the
# LIVE path (budget calls `_sum_cost_for_range`, the same helper `weekly`/
# `forecast` use), NOT snapshot-based `report`.
BUDGET1_PY='
import json, os, sqlite3, sys, datetime as dt
sys.path.insert(0, os.environ["BUDGET_BIN_DIR"])
import _lib_pricing as P

budget = json.loads(os.environ["RECONCILE_A"])
spent_budget = budget["spent_usd"]
week_start = dt.datetime.fromisoformat(budget["week_start_at"].replace("Z", "+00:00"))
as_of = dt.datetime.fromisoformat(budget["as_of"].replace("Z", "+00:00"))

# Independent raw scan: sum cost over session_entries in [week_start, as_of],
# reimplementing the per-token formula from the embedded pricing dict. This is
# deliberately NOT _sum_cost_for_range / _calculate_entry_cost.
conn = sqlite3.connect(os.environ["BUDGET_CACHE_DB"])
rows = conn.execute(
    "SELECT timestamp_utc, model, input_tokens, output_tokens, "
    "cache_create_tokens, cache_read_tokens, cost_usd_raw FROM session_entries"
).fetchall()
conn.close()

def rate(pricing, key):
    return pricing.get(key, 0.0)

total = 0.0
counted = 0
for ts_s, model, it, ot, cc, cr, cost_raw in rows:
    ts = dt.datetime.fromisoformat(ts_s.replace("Z", "+00:00"))
    if ts.tzinfo is None:
        ts = ts.replace(tzinfo=dt.timezone.utc)
    if not (week_start <= ts <= as_of):
        continue
    counted += 1
    # mode="auto": if a materialized cost is present, use it; else compute.
    if cost_raw is not None:
        total += float(cost_raw)
        continue
    pricing = P.CLAUDE_MODEL_PRICING.get(model)
    if pricing is None:
        # fixtures use known-priced models; a None here is a fixture bug.
        raise SystemExit(f"unpriced model in fixture: {model!r}")
    total += (
        (it or 0) * rate(pricing, "input_cost_per_token")
        + (ot or 0) * rate(pricing, "output_cost_per_token")
        + (cc or 0) * rate(pricing, "cache_creation_input_token_cost")
        + (cr or 0) * rate(pricing, "cache_read_input_token_cost")
    )

# Non-vacuity: a window that summed zero entries would make the equality
# trivially true. Assert the independent scan actually counted spend.
assert counted > 0, "BUDGET1 vacuous: no session_entries fell in the window"
assert total > 0.0, "BUDGET1 vacuous: independent re-derivation summed $0"
assert abs(spent_budget - total) < 1e-9, (
    f"budget.spent_usd={spent_budget} independent_raw_sum={total} "
    f"(counted {counted} entries in [{week_start}, {as_of}])"
)
'
for fx in under warn over; do
    fixture_home="$FIXTURES/budget/$fx"
    [ -f "$fixture_home/input.env" ] || continue
    AS_OF=""
    # shellcheck disable=SC1091
    . "$fixture_home/input.env"
    budget_json=$(HOME="$fixture_home" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
        "$BIN" budget --json 2>/dev/null); rc_b=$?
    if [ $rc_b -ne 0 ]; then
        echo "RECONCILE FAIL budget_spent_eq_raw_scan budget/$fx: budget --json rc=$rc_b"
        fail_count=$((fail_count + 1))
        continue
    fi
    result=$(RECONCILE_A="$budget_json" \
        BUDGET_BIN_DIR="$REPO_ROOT/bin" \
        BUDGET_CACHE_DB="$fixture_home/.local/share/cctally/cache.db" \
        python3 -c "$BUDGET1_PY" 2>&1); rc_py=$?
    if [ $rc_py -ne 0 ]; then
        echo "RECONCILE FAIL budget_spent_eq_raw_scan budget/$fx: $result"
        fail_count=$((fail_count + 1))
        continue
    fi
    echo "PASS budget_spent_eq_raw_scan budget/$fx"
    pass_count=$((pass_count + 1))
done

# ─── Invariant PROJECTED1: projected-pace alert == displayed week-avg field ──
# NAMESPACE NOTE: `PROJECTED*` invariants here are the projected-pace ALERT
# axis (#121). They are unrelated to the `R-PROJ1..R-PROJ6` family above
# (~line 1936), which reconciles the projects PANEL aggregation. Both
# abbreviate to "PROJ" under a casual grep — the prefixes are deliberately
# distinct (`PROJECTED` vs `R-PROJ`); keep them that way.
# (#121, spec §4 "Reconcile invariant") The projected-pace alert axis fires on
# the WEEK-AVERAGE projection — `p_now + r_avg*remaining` (weekly_pct) and
# `spent + rate_avg*remaining` (budget_usd). That SAME number is surfaced as the
# additive `week_avg_projection_pct` (forecast --json) / `week_avg_projection_usd`
# (budget --json) output fields. This invariant pins the two together within
# 1e-9 so neither call path can drift from the other.
#
# Binding choice (load-bearing for non-vacuity):
#   1. The "alert value" side is the ACTUAL detector projection path, not a
#      re-derivation: we import bin/cctally and call
#      `_weekly_pct_week_avg_projection(conn, now)` (the exact helper
#      `maybe_record_projected_alert`'s weekly leg fires on) and the budget
#      detector path `_build_budget_status_inputs(..., skip_sync=True)` →
#      `compute_budget_status(...).week_avg_projection_usd` (the exact value its
#      budget leg fires on). So the assertion binds the firing value, not a
#      look-alike formula.
#   2. The "displayed field" side is the REAL emitted JSON key, parsed straight
#      out of `forecast --json` / `budget --json`.
#   3. Non-vacuity guard (the core of spec §4): both fixtures are deliberately
#      recent≠average, so the DISPLAYED VERDICT HIGH END diverges from the
#      week-average — forecast `projected-cap` has final_percent_high (178.6) >
#      week_avg_projection_pct (122.5); budget `recent-hot` has
#      projected_eow_high_usd (324) > week_avg_projection_usd (252). The
#      invariant asserts the bound value equals the week-average AND is strictly
#      NOT the high end, so a regression that wired the alert (or the output
#      field) to the displayed high-end verdict band fails here rather than
#      passing by accident. (The 1e-9 equality alone would be vacuous if the two
#      week-average numbers were the same by construction with no distinct
#      high-end to mis-bind to — these fixtures supply that distinct high end.)

# ── Weekly_pct leg: forecast --json week_avg_projection_pct ↔ detector ──
PROJECTED1_WEEKLY_PY='
import json, os, sys, importlib.util
from importlib.machinery import SourceFileLoader

fc = json.loads(os.environ["RECONCILE_A"])
emitted = fc["forecast"]["week_avg_projection_pct"]   # JSON-rounded to 3 dp
high_end = fc["forecast"]["final_percent_high"]

# Bind to the ACTUAL detector helper the projected weekly leg fires on
# (full precision; the JSON field is round(detector_value, 3)).
bin_dir = os.environ["PROJECTED_BIN_DIR"]
sys.path.insert(0, bin_dir)
loader = SourceFileLoader("cctally", os.path.join(bin_dir, "cctally"))
spec = importlib.util.spec_from_loader("cctally", loader)
c = importlib.util.module_from_spec(spec); sys.modules["cctally"] = c
loader.exec_module(c)
conn = c.open_db()
now = c._command_as_of()
proj = c._weekly_pct_week_avg_projection(conn, now)
assert proj is not None, "PROJECTED1 weekly: detector returned None (no current-week snapshot)"
detector_value, low_conf = proj
assert not low_conf, "PROJECTED1 weekly: fixture is LOW CONF (detector would not fire here)"

# Reconcile contract: the emitted forecast field is the detector value, rounded
# to the JSON surface precision (3 dp) — equal within 1e-9 of that round().
# This is THE bind: the alert and forecast --json share the week-average number.
assert abs(emitted - round(detector_value, 3)) < 1e-9, (
    f"forecast week_avg_projection_pct={emitted} != round(detector,3)="
    f"{round(detector_value, 3)} (detector full value {detector_value}; the "
    f"value maybe_record_projected_alert weekly leg fires on)"
)

# Independent cross-check from forecast --json'\''s OWN published rates/window
# (a path that does not touch the detector): p_now + r_avg*remaining. The
# published rate is rounded to 6 dp, so this is a coarse sanity bound (not the
# 1e-9 contract above), guarding against a grossly wrong formula.
p_now = fc["current"]["weekly_percent"]
r_avg = fc["rates"]["week_average_pct_per_hour"]
remaining_h = fc["week"]["remaining_hours"]
rederived = p_now + r_avg * remaining_h
assert abs(emitted - rederived) < 1e-3, (
    f"forecast week_avg_projection_pct={emitted} far from published-rate "
    f"re-derivation {rederived}"
)

# Non-vacuity: the displayed verdict high end must DIFFER from the week-average,
# so binding to final_percent_high (the band the verdict keys off) would fail.
assert abs(high_end - emitted) > 1.0, (
    f"PROJECTED1 weekly VACUOUS: final_percent_high={high_end} ~= "
    f"week_avg_projection_pct={emitted}; fixture is not recent!=average so a "
    f"wrong binding to the displayed high end could pass by accident"
)
'
fc_home="$FIXTURES/forecast/projected-cap"
if [ -f "$fc_home/input.env" ]; then
    AS_OF=""
    # shellcheck disable=SC1091
    . "$fc_home/input.env"
    fc_json=$(HOME="$fc_home" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
        "$BIN" forecast --json 2>/dev/null); rc_f=$?
    if [ $rc_f -ne 0 ]; then
        echo "RECONCILE FAIL projected_alert_eq_displayed_week_avg forecast/projected-cap: forecast --json rc=$rc_f"
        fail_count=$((fail_count + 1))
    else
        result=$(RECONCILE_A="$fc_json" \
            PROJECTED_BIN_DIR="$REPO_ROOT/bin" \
            HOME="$fc_home" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
            CCTALLY_DISABLE_DEV_AUTODETECT=1 \
            python3 -c "$PROJECTED1_WEEKLY_PY" 2>&1); rc_py=$?
        if [ $rc_py -ne 0 ]; then
            echo "RECONCILE FAIL projected_alert_eq_displayed_week_avg forecast/projected-cap: $result"
            fail_count=$((fail_count + 1))
        else
            echo "PASS projected_alert_eq_displayed_week_avg forecast/projected-cap"
            pass_count=$((pass_count + 1))
        fi
    fi
else
    echo "RECONCILE FAIL projected_alert_eq_displayed_week_avg forecast/projected-cap: fixture missing"
    fail_count=$((fail_count + 1))
fi

# ── Budget_usd leg: budget --json week_avg_projection_usd ↔ detector ──
PROJECTED1_BUDGET_PY='
import json, os, sys, importlib.util, datetime as dt
from importlib.machinery import SourceFileLoader

b = json.loads(os.environ["RECONCILE_B"])
emitted = b["week_avg_projection_usd"]
high_end = b["projected_eow_high_usd"]
target = b["weekly_usd"]
spent = b["spent_usd"]

# Re-derive from budget --json'\''s own published spend/window (independent of the
# kernel): rate_avg = spent/elapsed_hours; week_avg = spent + rate_avg*remaining.
ws = dt.datetime.fromisoformat(b["week_start_at"].replace("Z", "+00:00"))
we = dt.datetime.fromisoformat(b["week_end_at"].replace("Z", "+00:00"))
now = dt.datetime.fromisoformat(b["as_of"].replace("Z", "+00:00"))
total_s = (we - ws).total_seconds()
elapsed_s = max(0.0, min((now - ws).total_seconds(), total_s))
remaining_h = max(0.0, (total_s - elapsed_s)) / 3600.0
elapsed_h = elapsed_s / 3600.0
rate_avg = (spent / elapsed_h) if elapsed_h > 0 else 0.0
rederived = spent + rate_avg * remaining_h

# Bind to the ACTUAL detector path the projected budget leg fires on.
bin_dir = os.environ["PROJECTED_BIN_DIR"]
sys.path.insert(0, bin_dir)
loader = SourceFileLoader("cctally", os.path.join(bin_dir, "cctally"))
spec = importlib.util.spec_from_loader("cctally", loader)
c = importlib.util.module_from_spec(spec); sys.modules["cctally"] = c
loader.exec_module(c)
conn = c.open_db()
now_dt = c._command_as_of()
inputs = c._build_budget_status_inputs(
    conn, target_usd=target, now_utc=now_dt,
    alert_thresholds=(90, 100), skip_sync=True,
)
assert inputs is not None, "PROJECTED1 budget: _build_budget_status_inputs returned None"
status = c.compute_budget_status(inputs)
assert not status.low_confidence, "PROJECTED1 budget: fixture is low-confidence (detector would not fire)"
detector_value = status.week_avg_projection_usd

# Equality (the reconcile contract): emitted == re-derivation == detector.
assert abs(emitted - rederived) < 1e-9, (
    f"budget week_avg_projection_usd={emitted} != rederived {rederived}"
)
assert abs(emitted - detector_value) < 1e-9, (
    f"budget week_avg_projection_usd={emitted} != detector {detector_value} "
    f"(the value maybe_record_projected_alert budget leg fires on)"
)

# Non-vacuity: displayed verdict high end must DIFFER from the week-average.
assert abs(high_end - emitted) > 1.0, (
    f"PROJECTED1 budget VACUOUS: projected_eow_high_usd={high_end} ~= "
    f"week_avg_projection_usd={emitted}; fixture is not recent!=average so a "
    f"wrong binding to the displayed high end could pass by accident"
)
'
b_home="$FIXTURES/budget/recent-hot"
if [ -f "$b_home/input.env" ]; then
    AS_OF=""
    # shellcheck disable=SC1091
    . "$b_home/input.env"
    b_json=$(HOME="$b_home" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
        "$BIN" budget --json 2>/dev/null); rc_b=$?
    if [ $rc_b -ne 0 ]; then
        echo "RECONCILE FAIL projected_alert_eq_displayed_week_avg budget/recent-hot: budget --json rc=$rc_b"
        fail_count=$((fail_count + 1))
    else
        result=$(RECONCILE_B="$b_json" \
            PROJECTED_BIN_DIR="$REPO_ROOT/bin" \
            HOME="$b_home" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
            CCTALLY_DISABLE_DEV_AUTODETECT=1 \
            python3 -c "$PROJECTED1_BUDGET_PY" 2>&1); rc_py=$?
        if [ $rc_py -ne 0 ]; then
            echo "RECONCILE FAIL projected_alert_eq_displayed_week_avg budget/recent-hot: $result"
            fail_count=$((fail_count + 1))
        else
            echo "PASS projected_alert_eq_displayed_week_avg budget/recent-hot"
            pass_count=$((pass_count + 1))
        fi
    fi
else
    echo "RECONCILE FAIL projected_alert_eq_displayed_week_avg budget/recent-hot: fixture missing"
    fail_count=$((fail_count + 1))
fi

# ── PROJECTED2 (calendar-month Claude) + PROJECTED3 (Codex) — #135 ──────────
# The #135 generalization extends the projected-pace axis to ANY Claude period
# (calendar-week / calendar-month) and to Codex. Both fired budget legs now
# route through the SAME `_build_vendor_budget_inputs` + `compute_budget_status`
# factory that `cmd_budget` renders from, so the fired projected value
# reconciles to `budget --json`'s `week_avg_projection_usd` (top-level for the
# Claude leg; `.codex.week_avg_projection_usd` for the Codex leg) within 1e-9.
#
# Tz contract (R3): the firing path resolves CONFIG tz (`Namespace(tz=None)`),
# so these invariants bind to the DEFAULT/config-tz `budget --json` with the
# SAME `now` (NO `--tz` on the invocation). The fixtures pin `display.tz=utc`,
# so the config-tz period start is deterministic.
#
# Non-vacuity: the "fired value" side is the REAL detector factory path (NOT a
# re-derivation) — `_build_vendor_budget_inputs(vendor=..., skip_sync=False)` →
# `compute_budget_status(...).week_avg_projection_usd`, the exact value the
# `maybe_record_projected_alert` budget/codex legs fire on — so the equality
# binds the firing value to the displayed field by construction, not a
# look-alike formula. An independent re-derivation from the JSON's OWN published
# spend/window adds a coarse formula guard. (Distinct from the PROJECTED1
# recent≠average high-end guard: these calendar fixtures are pace-stable, so the
# separate skip_sync non-vacuity proof lives in the cold-cache pytest.)
PROJECTED_CALENDAR_PY='
import json, os, sys, importlib.util, argparse, datetime as dt
from importlib.machinery import SourceFileLoader

raw = json.loads(os.environ["RECONCILE_A"])
sub = os.environ.get("RECONCILE_SUBKEY", "")
b = raw[sub] if sub else raw
emitted = b["week_avg_projection_usd"]
target = b["amount_usd"] if sub else b["weekly_usd"]
spent = b["spent_usd"]
vendor = os.environ["RECONCILE_VENDOR"]

# Re-derive from budget --json'\''s OWN published spend/window (independent of the
# kernel): rate_avg = spent/elapsed_hours; week_avg = spent + rate_avg*remaining.
ws_key = "period_start_at" if sub else "week_start_at"
we_key = "period_end_at" if sub else "week_end_at"
ws = dt.datetime.fromisoformat(b[ws_key].replace("Z", "+00:00"))
we = dt.datetime.fromisoformat(b[we_key].replace("Z", "+00:00"))
now = dt.datetime.fromisoformat(b["as_of"].replace("Z", "+00:00"))
total_s = (we - ws).total_seconds()
elapsed_s = max(0.0, min((now - ws).total_seconds(), total_s))
remaining_h = max(0.0, (total_s - elapsed_s)) / 3600.0
elapsed_h = elapsed_s / 3600.0
rate_avg = (spent / elapsed_h) if elapsed_h > 0 else 0.0
rederived = spent + rate_avg * remaining_h

# Bind to the ACTUAL detector factory the projected leg fires on.
bin_dir = os.environ["PROJECTED_BIN_DIR"]
sys.path.insert(0, bin_dir)
loader = SourceFileLoader("cctally", os.path.join(bin_dir, "cctally"))
spec = importlib.util.spec_from_loader("cctally", loader)
c = importlib.util.module_from_spec(spec); sys.modules["cctally"] = c
loader.exec_module(c)
config = c.load_config()
tz = c.resolve_display_tz(argparse.Namespace(tz=None), config)   # CONFIG tz (R3)
now_dt = c._command_as_of()
inputs = c._build_vendor_budget_inputs(
    vendor=vendor, period="calendar-month", target_usd=target,
    alert_thresholds=(90, 100), now_utc=now_dt, config=config, tz=tz,
    skip_sync=False,
)
assert inputs is not None, "calendar projected: _build_vendor_budget_inputs returned None"
status = c.compute_budget_status(inputs)
assert not status.low_confidence, "calendar projected: fixture is low-confidence (detector would not fire)"
detector_value = status.week_avg_projection_usd

# Equality (the reconcile contract): emitted == re-derivation == detector.
assert abs(emitted - rederived) < 1e-9, (
    f"{vendor} week_avg_projection_usd={emitted} != rederived {rederived}"
)
assert abs(emitted - detector_value) < 1e-9, (
    f"{vendor} week_avg_projection_usd={emitted} != detector {detector_value} "
    f"(the value maybe_record_projected_alert {vendor} leg fires on)"
)
'
# PROJECTED2: calendar-month Claude budget --period month --json
cm_home="$FIXTURES/budget/claude-calendar-month"
if [ -f "$cm_home/input.env" ]; then
    AS_OF=""
    # shellcheck disable=SC1091
    . "$cm_home/input.env"
    cm_json=$(HOME="$cm_home" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
        "$BIN" budget --period month --json 2>/dev/null); rc_cm=$?
    if [ $rc_cm -ne 0 ]; then
        echo "RECONCILE FAIL projected_calendar_claude_eq_displayed budget/claude-calendar-month: budget --period month --json rc=$rc_cm"
        fail_count=$((fail_count + 1))
    else
        result=$(RECONCILE_A="$cm_json" RECONCILE_VENDOR="claude" RECONCILE_SUBKEY="" \
            PROJECTED_BIN_DIR="$REPO_ROOT/bin" \
            HOME="$cm_home" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
            CCTALLY_DISABLE_DEV_AUTODETECT=1 \
            python3 -c "$PROJECTED_CALENDAR_PY" 2>&1); rc_py=$?
        if [ $rc_py -ne 0 ]; then
            echo "RECONCILE FAIL projected_calendar_claude_eq_displayed budget/claude-calendar-month: $result"
            fail_count=$((fail_count + 1))
        else
            echo "PASS projected_calendar_claude_eq_displayed budget/claude-calendar-month"
            pass_count=$((pass_count + 1))
        fi
    fi
else
    echo "RECONCILE FAIL projected_calendar_claude_eq_displayed budget/claude-calendar-month: fixture missing"
    fail_count=$((fail_count + 1))
fi

# PROJECTED3: Codex budget --vendor codex --json (nested .codex)
cx_home="$FIXTURES/budget/codex-only"
if [ -f "$cx_home/input.env" ]; then
    AS_OF=""
    # shellcheck disable=SC1091
    . "$cx_home/input.env"
    cx_json=$(HOME="$cx_home" NO_COLOR=1 TZ=Etc/UTC CCTALLY_AS_OF="$AS_OF" \
