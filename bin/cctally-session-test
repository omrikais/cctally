#!/usr/bin/env bash
# Fixture-based validation harness for `cctally session`.
#
# Rebuilds fixtures, then walks each fixture dir under
# tests/fixtures/session/ and runs each output mode through the
# shared run_mode helper (bin/_lib-fixture-harness.sh). Modes:
#   * terminal    — default (no extra flags)
#   * json        — --json
#   * desc        — --order desc  (ONLY for fixtures with golden-desc.txt;
#                   opt-in via file presence, not hardcoded per scenario).
# Exits 0 on all-pass, non-zero on any diff/missing golden.

set -uo pipefail

REPO_ROOT=$(cd "$(dirname "$0")/.." && pwd)

HARNESS_SUBCOMMAND="session"
HARNESS_FIXTURES_DIR="$REPO_ROOT/tests/fixtures/session"
HARNESS_BIN="$REPO_ROOT/bin/cctally"

# Per-run scratch dir for the regenerated fixture DBs and any test-process
# SQLite writes. Keeps the in-tree fixture .db files byte-stable across
# harness runs (the builder is host-deterministic but produces different
# bytes on different hosts/sqlite versions). HARNESS_FAKE_HOME_BASE
# redirects FAKE_HOME in _lib-fixture-harness.sh; input.env / golden-*.txt
# are still read from the in-tree HARNESS_FIXTURES_DIR.
SCRATCH_DIR=$(mktemp -d -t cctally-session-fixtures-XXXXXX)
trap 'rm -rf "$SCRATCH_DIR"' EXIT
export HARNESS_FAKE_HOME_BASE="$SCRATCH_DIR"

# Regenerate seeded fixture DBs into the scratch dir so goldens always
# check against reproducible state without dirtying the tree.
. "$REPO_ROOT/bin/_lib-fixture-cache.sh"
build_fixtures_cached "$REPO_ROOT/bin/build-session-fixtures.py" "$SCRATCH_DIR" || {
    echo "FAIL: build-session-fixtures.py crashed (exit $?)" >&2
    exit 1
}

# Source the shared run_mode helper.
# shellcheck disable=SC1091
. "$REPO_ROOT/bin/_lib-fixture-harness.sh"

pass_count=0
fail_count=0

for dir in "$HARNESS_FIXTURES_DIR"/*/; do
    name=$(basename "$dir")
    run_mode "$name" "terminal" ""       "terminal"
    run_mode "$name" "json"     "--json" "json"
    # Opt-in per-fixture descending-order mode: only fixtures whose
    # golden-desc.txt exists are expected to assert the --order desc output.
    if [ -f "$dir/golden-desc.txt" ]; then
        run_mode "$name" "desc" "--order desc" "desc"
    fi
    # Opt-in per-fixture --breakdown mode (issue #104): asserts the
    # per-model sub-row Total Tokens column sums all four components
    # (input + output + cache). Only fixtures with golden-breakdown.txt.
    if [ -f "$dir/golden-breakdown.txt" ]; then
        run_mode "$name" "breakdown" "--breakdown" "breakdown"
    fi
    # Session C (issue #86): -m/--mode cost-source coverage. These
    # fixtures carry NO recorded costUSD (cache.db session_entries.
    # cost_usd_raw is all NULL), so the three modes split cleanly:
    #   * --mode calculate ≡ default auto (every cost is computed from
    #     pricing either way) → reuse golden-terminal.txt byte-for-byte.
    #     Proves the command threads mode without altering computed totals.
    #   * --mode display drops every (cost-less) entry to $0 → a distinct
    #     golden-mode-display.txt where all Cost (USD) cells zero. Proves
    #     the flag actually reaches the per-entry cost path.
    run_mode "$name" "mode-calculate" "--mode calculate" "terminal"
    run_mode "$name" "mode-display"   "--mode display"   "mode-display"
done

echo "----"
echo "passed: $pass_count   failed: $fail_count"
[ "$fail_count" -eq 0 ]
