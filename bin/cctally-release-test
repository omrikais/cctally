#!/usr/bin/env bash
# Fixture-based harness for `cctally release` (cmd_release).
#
# Each scenario under tests/fixtures/release/<name>/ exists as:
#   - setup.sh                  : builds an isolated git layout under
#                                 $work/ (private working clone +
#                                 private.git bare + public working
#                                 clone + public.git bare); seeds
#                                 CHANGELOG.md per-scenario.
#   - run.sh                    : invokes `cctally release ...` from
#                                 inside private/ and writes deterministic
#                                 artifacts to $work/_artifacts/ for the
#                                 harness to compare against goldens.
#   - golden-exit.txt           : single integer; required.
#   - golden-stdout-substr.txt  : required, may be empty.
#   - golden-stderr-substr.txt  : required, may be empty.
#   - golden-changelog.md       : optional — exact post-release CHANGELOG.md.
#   - golden-commit-msg.txt     : optional — `git log -1 --format=%B` of the
#                                 stamp commit, with `<SHA7>` placeholders.
#   - golden-tag-annotation.txt : optional — release-tag annotation body.
#   - golden-package-json.json  : optional — exact post-stamp package.json
#                                 contents (Task 15: Phase 1 co-stamp).
#
# Pattern: builder regenerates setup.sh + run.sh into a scratch tree.
# Harness copies them per-scenario into $work/, runs setup.sh, then
# `(cd private && bash ../run.sh "$REPO_ROOT")`. The release script
# resolves CHANGELOG_PATH via __file__.parent.parent inside private/,
# so it reads/writes the scratch CHANGELOG.md (NOT cctally-dev's own).
#
# The summary line MUST end with `passed: N   failed: M` (two spaces) so
# the cctally-test-all aggregator's awk parser picks up the counts.

set -uo pipefail

REPO_ROOT=$(cd "$(dirname "$0")/.." && pwd)
FIXTURES_DIR="$REPO_ROOT/tests/fixtures/release"

# Default the Phase 6 brew-archive override for every scenario (issue #29).
# Phase 6 (`_release_compute_brew_sha256`) downloads the GitHub auto-archive
# unless `CCTALLY_RELEASE_BREW_ARCHIVE_URL` is set, and the synthetic v0.1.1
# tag doesn't exist on the public mirror — workstations that resolve the URL
# get HTTP 404, the self-hosted runner happens not to. Exporting here makes
# the harness the single source of truth; setup.sh + run.sh inherit it via
# normal shell env propagation. Scenarios that explicitly want the
# un-overridden path (none today) can `unset` it in their own scaffold.
export CCTALLY_RELEASE_BREW_ARCHIVE_URL="file://$REPO_ROOT/tests/fixtures/release/_assets/fake-archive-v1.0.1.tar.gz"

# Isolate from host git config (issue #29 — same robustness goal as the
# brew-archive override). Without this, host-level config like
# `release.brewClone` leaks into scenarios via global ~/.gitconfig and
# tricks Phase 6's discovery into entering the formula-render path on
# scenarios that don't seed a fake brew tap. The self-hosted runner
# happened to lack this config, so CI was green while workstations that
# do `release.brewClone = …` for their real homebrew clone failed
# locally. /dev/null is the documented git-supported sentinel for
# "skip this config layer." Applies to every git invocation issued by
# setup.sh, run.sh, and the cctally release subprocess they fork.
export GIT_CONFIG_GLOBAL=/dev/null
export GIT_CONFIG_NOSYSTEM=1

# Default Phase 5's npm-poll timing for every scenario. Phase 5 polls
# `npm view cctally@<v>` (production: 5-min timeout while a public-repo
# OIDC GHA workflow publishes). The fake-npm in fixtures returns exit 0
# with empty stdout for `view` by default, which `_release_phase_npm_done`
# treats as "not yet published" — without an override, every happy-path
# fixture would burn the full 300s timeout. Override globally to ~2s so
# scenarios that don't explicitly mock view-as-success still bail fast
# (returning 0 from Phase 5, matching their existing expected_exit=0).
# Per-fixture overrides via `_run_release_with_npm_env` (e.g.
# phase5-poll-timeout=1, phase5-poll-success=10) take precedence because
# they re-export inside run.sh after this harness-level export.
export CCTALLY_RELEASE_NPM_POLL_TIMEOUT_S="${CCTALLY_RELEASE_NPM_POLL_TIMEOUT_S:-2}"
export CCTALLY_RELEASE_NPM_POLL_INTERVAL_S="${CCTALLY_RELEASE_NPM_POLL_INTERVAL_S:-0.1}"

SCRATCH_DIR=$(mktemp -d -t cctally-release-XXXXXX)
trap 'rm -rf "$SCRATCH_DIR"' EXIT

# Regenerate fixtures into a scratch built/ tree so the harness always
# picks up the latest builder output without dirtying the in-tree goldens.
"$REPO_ROOT/bin/build-release-fixtures.py" --out "$SCRATCH_DIR/built" >/dev/null || {
    echo "FAIL: build-release-fixtures.py crashed (exit $?)" >&2
    exit 1
}

pass_count=0
fail_count=0

for dir in "$FIXTURES_DIR"/*/; do
    name=$(basename "$dir")
    # Skip underscore-prefixed dirs (e.g. `_assets/` for shared
    # tarball/binary fixtures consumed by Phase 5/6 scenarios).
    case "$name" in
        _*) continue ;;
    esac
    # Optional single-scenario filter. Used by
    # bin/cctally-release-harness-isolation-test to exercise just one
    # leak-prone scenario without paying the full-suite cost.
    if [ -n "${CCTALLY_RELEASE_TEST_SCENARIO:-}" ] \
       && [ "$name" != "${CCTALLY_RELEASE_TEST_SCENARIO}" ]; then
        continue
    fi
    expected_exit=$(cat "$dir/golden-exit.txt" | tr -d '\n')
    expected_stdout=$(cat "$dir/golden-stdout-substr.txt" | tr -d '\n')
    expected_stderr=$(cat "$dir/golden-stderr-substr.txt" | tr -d '\n')

    work="$SCRATCH_DIR/run/$name"
    mkdir -p "$work"
    cp "$SCRATCH_DIR/built/$name/setup.sh" "$work/setup.sh"
    cp "$SCRATCH_DIR/built/$name/run.sh" "$work/run.sh"

    setup_log="$work/_setup.log"
    if ! (cd "$work" && bash setup.sh "$REPO_ROOT") >"$setup_log" 2>&1; then
        echo "FAIL [$name]: setup.sh exited non-zero"
        echo "  setup output:"
        sed 's/^/    /' "$setup_log"
        fail_count=$((fail_count + 1))
        continue
    fi

    # Run from inside private/. The release script's __file__ is
    # $work/private/bin/cctally; CHANGELOG_PATH thus resolves to
    # $work/private/CHANGELOG.md.
    run_log="$work/_run.log"
    (cd "$work/private" && bash ../run.sh "$REPO_ROOT") >"$run_log" 2>&1
    actual_exit=$?

    # Normalize artifacts (run.sh wrote them under $work/_artifacts/).
    artifact_dir="$work/_artifacts"
    actual_stdout=""
    actual_stderr=""
    if [ -f "$artifact_dir/stdout.txt" ]; then
        actual_stdout=$(cat "$artifact_dir/stdout.txt")
    fi
    if [ -f "$artifact_dir/stderr.txt" ]; then
        actual_stderr=$(cat "$artifact_dir/stderr.txt")
    fi
    if [ -f "$artifact_dir/exit.txt" ]; then
        # run.sh wrote the inner-process exit code (the release script's
        # exit code) to exit.txt. Use that for the comparison so the
        # harness sees the actual cctally release exit, not the wrapper's
        # bash exit (which can differ if run.sh has its own assertions
        # before exiting).
        actual_exit=$(cat "$artifact_dir/exit.txt" | tr -d '\n')
    fi

    pass=true
    fail_reasons=()

    if [ "$actual_exit" != "$expected_exit" ]; then
        pass=false
        fail_reasons+=("exit=$actual_exit (expected $expected_exit)")
    fi

    if [ -n "$expected_stdout" ] && ! grep -qF -- "$expected_stdout" "$artifact_dir/stdout.txt" 2>/dev/null; then
        pass=false
        fail_reasons+=("stdout substring '$expected_stdout' not found")
    fi

    if [ -n "$expected_stderr" ] && ! grep -qF -- "$expected_stderr" "$artifact_dir/stderr.txt" 2>/dev/null; then
        pass=false
        fail_reasons+=("stderr substring '$expected_stderr' not found")
    fi

    # Optional byte-exact CHANGELOG check.
    cl_golden="$dir/golden-changelog.md"
    if [ -f "$cl_golden" ] && [ -f "$artifact_dir/changelog.md" ]; then
        if ! diff -u "$cl_golden" "$artifact_dir/changelog.md" >/dev/null; then
            pass=false
            fail_reasons+=("changelog mismatch")
        fi
    fi

    # Optional byte-exact commit-msg check (with <SHA7> normalization
    # already applied by run.sh).
    cm_golden="$dir/golden-commit-msg.txt"
    if [ -f "$cm_golden" ] && [ -f "$artifact_dir/commit-msg.txt" ]; then
        if ! diff -u "$cm_golden" "$artifact_dir/commit-msg.txt" >/dev/null; then
            pass=false
            fail_reasons+=("commit-msg mismatch")
        fi
    fi

    # Optional tag-annotation check.
    ta_golden="$dir/golden-tag-annotation.txt"
    if [ -f "$ta_golden" ] && [ -f "$artifact_dir/tag-annotation.txt" ]; then
        if ! diff -u "$ta_golden" "$artifact_dir/tag-annotation.txt" >/dev/null; then
            pass=false
            fail_reasons+=("tag-annotation mismatch")
        fi
    fi

    # Optional byte-exact package.json check (post-stamp). Phase 1
    # co-stamps package.json; this golden pins the exact stamped bytes.
    pj_golden="$dir/golden-package-json.json"
    if [ -f "$pj_golden" ] && [ -f "$artifact_dir/package.json" ]; then
        if ! diff -u "$pj_golden" "$artifact_dir/package.json" >/dev/null; then
            pass=false
            fail_reasons+=("package-json mismatch")
        fi
    fi

    # Optional body-canonical-three-sources check. The run.sh writes
    # `body-equal.txt` containing "1" or "0"; the golden pins "1" so a
    # silent shape change in any of the three body sources fails fast.
    be_golden="$dir/golden-body-equal.txt"
    if [ -f "$be_golden" ] && [ -f "$artifact_dir/body-equal.txt" ]; then
        if ! diff -u "$be_golden" "$artifact_dir/body-equal.txt" >/dev/null; then
            pass=false
            fail_reasons+=("body-equal mismatch")
        fi
    fi

    # Optional gh-argv check (for gh phase scenarios). The run.sh
    # captures `gh-argv.log` from $work/gh-argv.log; the golden pins
    # the exact recorded sequence with paths/PIDs normalized.
    ga_golden="$dir/golden-gh-argv.txt"
    if [ -f "$ga_golden" ] && [ -f "$artifact_dir/gh-argv.log" ]; then
        # Normalize paths under the harness scratch tree so the golden is
        # byte-stable across runs (mktemp paths differ; PIDs differ).
        sed -E \
            -e "s|/.+/cctally-release-[A-Za-z0-9]+/run/[^/]+|<WORK>|g" \
            -e "s|/tmp/release-notes-v[0-9.-]+(-[0-9]+)?\.md|<NOTES>|g" \
            "$artifact_dir/gh-argv.log" > "$artifact_dir/gh-argv.normalized.txt"
        if ! diff -u "$ga_golden" "$artifact_dir/gh-argv.normalized.txt" >/dev/null; then
            pass=false
            fail_reasons+=("gh-argv mismatch")
        fi
    fi

    # Optional npm-invocations check (Phase 5 scenarios). The run.sh
    # captures `npm-invocations.log` (the fake-npm's argv recording, one
    # invocation per line, in order). Golden pins the exact call shape.
    ni_golden="$dir/golden-npm-invocations.txt"
    if [ -f "$ni_golden" ] && [ -f "$artifact_dir/npm-invocations.log" ]; then
        if ! diff -u "$ni_golden" "$artifact_dir/npm-invocations.log" >/dev/null; then
            pass=false
            fail_reasons+=("npm-invocations mismatch")
        fi
    fi

    # Optional rendered-formula substring check (Phase 6 scenarios).
    # The run.sh captures `formula.rb` from the brew tap clone after the
    # release. Golden is a substring (multi-line OK) — covers the
    # `url "..."` + `sha256 "..."` lines without pinning the entire
    # template render.
    fs_golden="$dir/golden-formula-substr.txt"
    if [ -f "$fs_golden" ]; then
        actual_formula=""
        if [ -f "$artifact_dir/formula.rb" ]; then
            actual_formula=$(cat "$artifact_dir/formula.rb")
        fi
        expected_formula=$(cat "$fs_golden")
        if ! grep -qF -- "$expected_formula" <<<"$actual_formula"; then
            pass=false
            fail_reasons+=("formula-substr mismatch")
        fi
    fi

    if $pass; then
        echo "PASS [$name]"
        pass_count=$((pass_count + 1))
    else
        echo "FAIL [$name]: ${fail_reasons[*]}"
        echo "  actual exit:   $actual_exit"
        echo "  actual stdout:"
        sed 's/^/    /' "$artifact_dir/stdout.txt" 2>/dev/null || echo "    (missing)"
        echo "  actual stderr:"
        sed 's/^/    /' "$artifact_dir/stderr.txt" 2>/dev/null || echo "    (missing)"
        # On diff failures, surface the actual vs golden for the
        # mismatching artifact so the failure message is actionable.
        for reason in "${fail_reasons[@]}"; do
            case "$reason" in
                "changelog mismatch")
                    echo "  changelog diff (golden vs actual):"
                    diff -u "$cl_golden" "$artifact_dir/changelog.md" 2>/dev/null \
                        | head -60 | sed 's/^/    /'
                    ;;
                "commit-msg mismatch")
                    echo "  commit-msg diff (golden vs actual):"
                    diff -u "$cm_golden" "$artifact_dir/commit-msg.txt" 2>/dev/null \
                        | head -60 | sed 's/^/    /'
                    ;;
                "tag-annotation mismatch")
                    echo "  tag-annotation diff (golden vs actual):"
                    diff -u "$ta_golden" "$artifact_dir/tag-annotation.txt" 2>/dev/null \
                        | head -60 | sed 's/^/    /'
                    ;;
                "package-json mismatch")
                    echo "  package.json diff (golden vs actual):"
                    diff -u "$pj_golden" "$artifact_dir/package.json" 2>/dev/null \
                        | head -60 | sed 's/^/    /'
                    ;;
                "body-equal mismatch")
                    echo "  body-equal diff (golden vs actual):"
                    diff -u "$be_golden" "$artifact_dir/body-equal.txt" 2>/dev/null \
                        | head -10 | sed 's/^/    /'
                    echo "  body-from-commit:"
                    sed 's/^/    /' "$artifact_dir/body-from-commit.txt" 2>/dev/null | head -20
                    echo "  body-from-tag:"
                    sed 's/^/    /' "$artifact_dir/body-from-tag.txt" 2>/dev/null | head -20
                    echo "  body-from-gh:"
                    sed 's/^/    /' "$artifact_dir/body-from-gh.txt" 2>/dev/null | head -20
                    ;;
                "gh-argv mismatch")
                    echo "  gh-argv diff (golden vs actual):"
                    diff -u "$ga_golden" "$artifact_dir/gh-argv.normalized.txt" 2>/dev/null \
                        | head -60 | sed 's/^/    /'
                    ;;
                "npm-invocations mismatch")
                    echo "  npm-invocations diff (golden vs actual):"
                    diff -u "$ni_golden" "$artifact_dir/npm-invocations.log" 2>/dev/null \
                        | head -60 | sed 's/^/    /'
                    ;;
                "formula-substr mismatch")
                    echo "  expected substring not found in formula.rb"
                    echo "  expected:"
                    sed 's/^/    /' "$fs_golden" 2>/dev/null | head -20
                    echo "  actual formula.rb:"
                    sed 's/^/    /' "$artifact_dir/formula.rb" 2>/dev/null | head -40
                    ;;
            esac
        done
        fail_count=$((fail_count + 1))
    fi
done

echo "----"
echo "passed: $pass_count   failed: $fail_count"
[ "$fail_count" -eq 0 ]
