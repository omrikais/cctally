#!/usr/bin/env bash
# Regression harness for the dedup self-heal in cmd_record_usage.
#
# Reproduces the 2026-05-08 CC-self-update kill-window race:
#   - snapshot at N% inserted, milestone N recorded normally
#   - snapshot at (N+1)% inserted, but the in-flight record-usage call
#     is killed before maybe_record_milestone / maybe_update_five_hour_block
#     get a chance to run (simulated by inserting the snapshot directly
#     and skipping the maybe-* calls)
#   - subsequent record-usage call observes the same (N+1)% and hits
#     the dedup short-circuit
#   - PRE-FIX: dedup returns immediately, milestone (N+1) and
#     five_hour_blocks row stay missing forever
#   - POST-FIX: dedup runs the self-heal, calls maybe_record_milestone
#     and maybe_update_five_hour_block on the latest existing snapshot,
#     and milestone (N+1) + the 5h block both materialize
#
# Pattern: dynamic-import of bin/cctally (matches
# bin/cctally-percent-milestone-idempotency-test). HARNESS_FAKE_HOME
# scratch dir keeps it isolated from real ~/.local/share/cctally.
#
# Asserts:
#   - exactly one percent_milestones row at threshold N+1 after dedup tick
#   - exactly one five_hour_blocks row for the simulated 5h window after dedup tick
#   - the dedup tick itself exited 0 (no error path taken)

set -uo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

pass_count=0
fail_count=0

assert_eq () {
    local label="$1" expected="$2" actual="$3"
    if [ "$expected" = "$actual" ]; then
        echo "PASS $label"
        pass_count=$((pass_count + 1))
    else
        echo "FAIL $label"
        printf '  expected: %s\n  actual:   %s\n' "$expected" "$actual"
        fail_count=$((fail_count + 1))
    fi
}

SCRATCH="$(mktemp -d -t cctally-selfheal.XXXXXX)"
trap 'rm -rf "$SCRATCH"' EXIT

out=$(REPO_ROOT_RESOLVED="$REPO_ROOT" HOME="$SCRATCH" TZ=Etc/UTC python3 - <<'PY'
import importlib.util
import os
import pathlib
import sys
import argparse
import datetime as dt

from importlib.machinery import SourceFileLoader

repo_root = pathlib.Path(os.environ["REPO_ROOT_RESOLVED"])
loader = SourceFileLoader("cctally_mod", str(repo_root / "bin" / "cctally"))
spec = importlib.util.spec_from_loader("cctally_mod", loader)
mod = importlib.util.module_from_spec(spec)
sys.modules["cctally_mod"] = mod
loader.exec_module(mod)

assert str(mod.APP_DIR).startswith(os.environ["HOME"]), (
    f"APP_DIR {mod.APP_DIR} did not land under HOME={os.environ['HOME']!r}; "
    "harness isolation broken"
)
mod.APP_DIR.mkdir(parents=True, exist_ok=True)

# Pin reset epochs so the test is deterministic.
# week:    2026-05-02 00:00:00 UTC -> 2026-05-09 00:00:00 UTC
# 5h:      2026-05-08 20:00:00 UTC -> 2026-05-09 01:00:00 UTC
WEEK_END_EPOCH = int(dt.datetime(2026, 5, 9, 0, 0, 0, tzinfo=dt.timezone.utc).timestamp())
FIVE_H_END_EPOCH = int(dt.datetime(2026, 5, 9, 1, 0, 0, tzinfo=dt.timezone.utc).timestamp())

def call_record(weekly_pct: float, five_hour_pct: float = 0.0) -> int:
    ns = argparse.Namespace(
        percent=weekly_pct,
        resets_at=WEEK_END_EPOCH,
        five_hour_percent=five_hour_pct,
        five_hour_resets_at=FIVE_H_END_EPOCH,
        week_start_name=None,
    )
    return mod.cmd_record_usage(ns)

# Tick 1: weekly=80%, five_hour=0% — clean path. Milestone 80 written;
# 5h block row created (the upsert runs whenever fiveHourPercent is not
# None, even at 0.0); but NO 5h milestone (current_floor < 1).
rc1 = call_record(80.0, 0.0)

conn = mod.open_db()
try:
    snap1 = conn.execute(
        "SELECT id, weekly_percent FROM weekly_usage_snapshots "
        "ORDER BY id DESC LIMIT 1"
    ).fetchone()
    m80 = conn.execute(
        "SELECT COUNT(*) AS n FROM percent_milestones WHERE percent_threshold=80"
    ).fetchone()["n"]
    blocks_after_tick1 = conn.execute(
        "SELECT COUNT(*) AS n FROM five_hour_blocks"
    ).fetchone()["n"]
finally:
    conn.close()

print(f"rc1={rc1}")
print(f"snap1_pct={snap1['weekly_percent']}")
print(f"milestone_80_after_tick1={m80}")
print(f"blocks_after_tick1={blocks_after_tick1}")

# Tick 2: weekly=81%, five_hour=1% — simulate killed run by inserting
# the snapshot directly, bypassing maybe_record_milestone and
# maybe_update_five_hour_block. Replicates the real-world kill window
# (CC self-update on 2026-05-08). Both surfaces are now genuinely owed
# a heal: percent_milestone 81 missing AND five_hour_milestone 1
# missing AND the block's last_observed_at_utc is stale.
#
# Pin capturedAt 60s later than tick 1 so the block's last_observed_at_utc
# (set by tick 1's maybe_update_five_hour_block call) is strictly older
# than tick 2's snapshot — mirroring the real-world cadence (~30s status-
# line ticks). Without the explicit offset, now_utc_iso() rounds to
# seconds and tick 1 / tick 2 collide in the same second, masking the
# probe-2 staleness check.
later = (dt.datetime.now(dt.timezone.utc) + dt.timedelta(seconds=60)).replace(
    microsecond=0
).isoformat().replace("+00:00", "Z")
saved = mod.insert_usage_snapshot(
    {
        "source": "statusline",
        "capturedAt": later,
        "weeklyPercent": 81.0,
        "weekStartDate": "2026-05-02",
        "weekEndDate": "2026-05-09",
        "weekStartAt": dt.datetime.fromtimestamp(
            WEEK_END_EPOCH - 7 * 86400, tz=dt.timezone.utc
        ).isoformat(timespec="seconds"),
        "weekEndAt": dt.datetime.fromtimestamp(
            WEEK_END_EPOCH, tz=dt.timezone.utc
        ).isoformat(timespec="seconds"),
        "fiveHourPercent": 1.0,
        "fiveHourResetsAt": dt.datetime.fromtimestamp(
            FIVE_H_END_EPOCH, tz=dt.timezone.utc
        ).isoformat(timespec="seconds"),
        "fiveHourWindowKey": mod._canonical_5h_window_key(FIVE_H_END_EPOCH),
    },
    "monday",
)

conn = mod.open_db()
try:
    m81_before_heal = conn.execute(
        "SELECT COUNT(*) AS n FROM percent_milestones WHERE percent_threshold=81"
    ).fetchone()["n"]
    fhm1_before_heal = conn.execute(
        "SELECT COUNT(*) AS n FROM five_hour_milestones WHERE percent_threshold=1"
    ).fetchone()["n"]
finally:
    conn.close()
print(f"milestone_81_before_heal={m81_before_heal}")
print(f"five_hour_milestone_1_before_heal={fhm1_before_heal}")

# Tick 3: weekly=81%, five_hour=1% — dedup short-circuit. PRE-FIX:
# returns 0 with milestone_81 AND five_hour_milestone 1 still missing.
# POST-FIX (round 1): self-heal triggers both helpers; round 2's
# pre-probe layer detects the missing percent milestone (probe 1) and
# the stale block last_observed_at_utc (probe 2), and materializes
# both milestones.
rc3 = call_record(81.0, 1.0)

conn = mod.open_db()
try:
    m81_after_heal = conn.execute(
        "SELECT COUNT(*) AS n FROM percent_milestones WHERE percent_threshold=81"
    ).fetchone()["n"]
    blocks_after_heal = conn.execute(
        "SELECT COUNT(*) AS n FROM five_hour_blocks"
    ).fetchone()["n"]
    fhm1_after_heal = conn.execute(
        "SELECT COUNT(*) AS n FROM five_hour_milestones WHERE percent_threshold=1"
    ).fetchone()["n"]
    snap_count = conn.execute(
        "SELECT COUNT(*) AS n FROM weekly_usage_snapshots"
    ).fetchone()["n"]
finally:
    conn.close()

print(f"rc3={rc3}")
print(f"milestone_81_after_heal={m81_after_heal}")
print(f"blocks_after_heal={blocks_after_heal}")
print(f"five_hour_milestone_1_after_heal={fhm1_after_heal}")
print(f"snap_count={snap_count}")
PY
)
ec=$?

if [ $ec -ne 0 ]; then
    echo "FAIL python harness exited with $ec"
    printf '%s\n' "$out"
    fail_count=$((fail_count + 1))
    echo "passed: $pass_count   failed: $fail_count"
    exit 1
fi

rc1=$(printf '%s\n' "$out" | awk -F= '/^rc1=/{print $2}')
snap1_pct=$(printf '%s\n' "$out" | awk -F= '/^snap1_pct=/{print $2}')
m80=$(printf '%s\n' "$out" | awk -F= '/^milestone_80_after_tick1=/{print $2}')
blocks_after_tick1=$(printf '%s\n' "$out" | awk -F= '/^blocks_after_tick1=/{print $2}')
m81b=$(printf '%s\n' "$out" | awk -F= '/^milestone_81_before_heal=/{print $2}')
fhm1b=$(printf '%s\n' "$out" | awk -F= '/^five_hour_milestone_1_before_heal=/{print $2}')
rc3=$(printf '%s\n' "$out" | awk -F= '/^rc3=/{print $2}')
m81a=$(printf '%s\n' "$out" | awk -F= '/^milestone_81_after_heal=/{print $2}')
blocks_after_heal=$(printf '%s\n' "$out" | awk -F= '/^blocks_after_heal=/{print $2}')
fhm1a=$(printf '%s\n' "$out" | awk -F= '/^five_hour_milestone_1_after_heal=/{print $2}')
snap_count=$(printf '%s\n' "$out" | awk -F= '/^snap_count=/{print $2}')

assert_eq "tick1 record-usage exit code" "0" "$rc1"
assert_eq "tick1 weekly_percent" "80.0" "$snap1_pct"
assert_eq "milestone 80 after clean tick" "1" "$m80"
assert_eq "5h block created at tick 1 even with five_hour=0%" "1" "$blocks_after_tick1"
assert_eq "milestone 81 missing after killed-run sim" "0" "$m81b"
assert_eq "five_hour_milestone 1 missing after killed-run sim" "0" "$fhm1b"
assert_eq "dedup tick exit code" "0" "$rc3"
assert_eq "milestone 81 self-healed by dedup tick" "1" "$m81a"
assert_eq "five_hour_blocks self-healed" "1" "$blocks_after_heal"
assert_eq "five_hour_milestone 1 self-healed" "1" "$fhm1a"
assert_eq "snapshot count unchanged by dedup tick" "2" "$snap_count"

# ── v1.7.2 in-place credit detection scenarios ────────────────────────
# 3 sub-scenarios isolated under fresh scratch dirs so the prior week's
# state can't leak into the credit-fires assertions. Each tests one
# branch of the live record-usage path's new credit logic + the
# downstream self-heal probe (Task 8).

run_credit_scenario () {
    # $1 = label, $2 = inline python.
    local label="$1"
    local pycode="$2"
    local scratch
    scratch="$(mktemp -d -t cctally-selfheal-credit.XXXXXX)"
    local out2
    out2=$(REPO_ROOT_RESOLVED="$REPO_ROOT" HOME="$scratch" TZ=Etc/UTC python3 -c "$pycode")
    local ec2=$?
    rm -rf "$scratch"
    if [ $ec2 -ne 0 ]; then
        echo "FAIL $label (python exit $ec2)"
        printf '%s\n' "$out2"
        fail_count=$((fail_count + 1))
        return
    fi
    if printf '%s\n' "$out2" | grep -q '^OK$'; then
        echo "PASS $label"
        pass_count=$((pass_count + 1))
    else
        echo "FAIL $label"
        printf '%s\n' "$out2"
        fail_count=$((fail_count + 1))
    fi
}

# Scenario A: in-place credit fires on first observation of the drop.
# Seed prior 67% on a FUTURE week_end (so prior_end_dt > now_utc holds);
# drive record-usage at 2% with the same end_at. Assert: one
# week_reset_events row keyed on old==new==end_at, one new snapshot row
# at 2% via the reset-aware clamp, hwm-7d force-written to 2.0.
run_credit_scenario "credit-fires" "$(cat <<'PY'
import importlib.util, os, pathlib, sys, argparse, datetime as dt
from importlib.machinery import SourceFileLoader
repo_root = pathlib.Path(os.environ["REPO_ROOT_RESOLVED"])
loader = SourceFileLoader("cctally_mod", str(repo_root / "bin" / "cctally"))
spec = importlib.util.spec_from_loader("cctally_mod", loader)
mod = importlib.util.module_from_spec(spec); sys.modules["cctally_mod"] = mod
loader.exec_module(mod)
mod.APP_DIR.mkdir(parents=True, exist_ok=True)
future = (dt.datetime.now(dt.timezone.utc) + dt.timedelta(days=3)).replace(
    minute=0, second=0, microsecond=0
)
end_iso = future.isoformat(timespec="seconds"); end_epoch = int(future.timestamp())
ws = (future - dt.timedelta(days=7)).date().isoformat()
conn = mod.open_db()
try:
    conn.execute(
        "INSERT INTO weekly_usage_snapshots "
        "(captured_at_utc, week_start_date, week_end_date, week_start_at, "
        " week_end_at, weekly_percent, source, payload_json) "
        "VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
        ("2026-05-14T10:00:00Z", ws, ws,
         ws + "T00:00:00+00:00", end_iso, 67.0, "test", "{}"),
    )
    conn.commit()
finally:
    conn.close()
(mod.APP_DIR / "hwm-7d").write_text(f"{ws} 67.0\n")
rc = mod.cmd_record_usage(argparse.Namespace(
    percent=2.0, resets_at=end_epoch,
    five_hour_percent=None, five_hour_resets_at=None,
    week_start_name=None,
))
assert rc == 0, f"rc={rc}"
conn = mod.open_db()
try:
    events = conn.execute(
        "SELECT old_week_end_at, new_week_end_at, effective_reset_at_utc "
        "FROM week_reset_events"
    ).fetchall()
    assert len(events) == 1, f"events={list(events)}"
    assert events[0]["new_week_end_at"] == end_iso
    # In-place credit row shape (post-Bug-1 fix): old == effective,
    # new == cur_end (DISTINCT). The old==new shape collapsed the
    # credited week to a zero-width window in
    # _apply_reset_events_to_weekrefs.
    assert events[0]["old_week_end_at"] == events[0]["effective_reset_at_utc"]
    assert events[0]["old_week_end_at"] != events[0]["new_week_end_at"]
    cnt = conn.execute(
        "SELECT COUNT(*) FROM weekly_usage_snapshots WHERE weekly_percent = 2.0"
    ).fetchone()[0]
    assert cnt == 1, f"2pct snapshots={cnt}"
finally:
    conn.close()
parts = (mod.APP_DIR / "hwm-7d").read_text().strip().split()
assert parts == [ws, "2.0"], f"hwm-7d={parts}"
print("OK")
PY
)"

# Scenario B: second record-usage call with same end_at + 3% is a no-op
# for the event row (prior is now 2%, drop is +1 not >= 25pp).
run_credit_scenario "credit-second-call-no-op" "$(cat <<'PY'
import importlib.util, os, pathlib, sys, argparse, datetime as dt
from importlib.machinery import SourceFileLoader
repo_root = pathlib.Path(os.environ["REPO_ROOT_RESOLVED"])
loader = SourceFileLoader("cctally_mod", str(repo_root / "bin" / "cctally"))
spec = importlib.util.spec_from_loader("cctally_mod", loader)
mod = importlib.util.module_from_spec(spec); sys.modules["cctally_mod"] = mod
loader.exec_module(mod)
mod.APP_DIR.mkdir(parents=True, exist_ok=True)
future = (dt.datetime.now(dt.timezone.utc) + dt.timedelta(days=3)).replace(
    minute=0, second=0, microsecond=0
)
end_iso = future.isoformat(timespec="seconds"); end_epoch = int(future.timestamp())
ws = (future - dt.timedelta(days=7)).date().isoformat()
conn = mod.open_db()
try:
    conn.execute(
        "INSERT INTO weekly_usage_snapshots "
        "(captured_at_utc, week_start_date, week_end_date, week_start_at, "
        " week_end_at, weekly_percent, source, payload_json) "
        "VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
        ("2026-05-14T10:00:00Z", ws, ws,
         ws + "T00:00:00+00:00", end_iso, 67.0, "test", "{}"),
    )
    conn.commit()
finally:
    conn.close()
ns = lambda pct: argparse.Namespace(
    percent=pct, resets_at=end_epoch,
    five_hour_percent=None, five_hour_resets_at=None,
    week_start_name=None,
)
mod.cmd_record_usage(ns(2.0))  # fires detection
mod.cmd_record_usage(ns(3.0))  # should NOT fire detection again
conn = mod.open_db()
try:
    n = conn.execute("SELECT COUNT(*) FROM week_reset_events").fetchone()[0]
    assert n == 1, f"events={n}"
finally:
    conn.close()
print("OK")
PY
)"

# Scenario C: credit fires, then post-credit usage climbs. Assert
# the reset-aware clamp lets 3% land (since post-segment MAX is 2%).
run_credit_scenario "credit-then-rising" "$(cat <<'PY'
import importlib.util, os, pathlib, sys, argparse, datetime as dt
from importlib.machinery import SourceFileLoader
repo_root = pathlib.Path(os.environ["REPO_ROOT_RESOLVED"])
loader = SourceFileLoader("cctally_mod", str(repo_root / "bin" / "cctally"))
spec = importlib.util.spec_from_loader("cctally_mod", loader)
mod = importlib.util.module_from_spec(spec); sys.modules["cctally_mod"] = mod
loader.exec_module(mod)
mod.APP_DIR.mkdir(parents=True, exist_ok=True)
future = (dt.datetime.now(dt.timezone.utc) + dt.timedelta(days=3)).replace(
    minute=0, second=0, microsecond=0
)
end_iso = future.isoformat(timespec="seconds"); end_epoch = int(future.timestamp())
ws = (future - dt.timedelta(days=7)).date().isoformat()
conn = mod.open_db()
try:
    conn.execute(
        "INSERT INTO weekly_usage_snapshots "
        "(captured_at_utc, week_start_date, week_end_date, week_start_at, "
        " week_end_at, weekly_percent, source, payload_json) "
        "VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
        ("2026-05-14T10:00:00Z", ws, ws,
         ws + "T00:00:00+00:00", end_iso, 67.0, "test", "{}"),
    )
    conn.commit()
finally:
    conn.close()
ns = lambda pct: argparse.Namespace(
    percent=pct, resets_at=end_epoch,
    five_hour_percent=None, five_hour_resets_at=None,
    week_start_name=None,
)
mod.cmd_record_usage(ns(2.0))  # credit fires, seeds 2%
mod.cmd_record_usage(ns(3.0))  # rises in post-credit segment
conn = mod.open_db()
try:
    n3 = conn.execute(
        "SELECT COUNT(*) FROM weekly_usage_snapshots WHERE weekly_percent = 3.0"
    ).fetchone()[0]
    assert n3 == 1, f"3pct snapshots={n3}"
finally:
    conn.close()
print("OK")
PY
)"

echo "passed: $pass_count   failed: $fail_count"
[ "$fail_count" -eq 0 ]
