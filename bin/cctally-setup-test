#!/usr/bin/env bash
# Fixture harness for `cctally setup`.
#
# Pattern: scratch HOME per scenario, run `cctally setup` (or a variant
# from cmd.txt), diff the resulting stdout/stderr against
# golden-stdout.txt, and (when goldens are present) diff the produced
# settings.json and ~/.local/bin/ symlink listing.
#
# OAuth / keychain stubbing: macOS `security` lookup would otherwise
# return the developer's real Claude Code token. We shadow `security`
# with a stub at $fake/.fake-bin/security that exits non-zero, and
# prepend that dir to PATH. With no $HOME/.claude/.credentials.json
# either, `_resolve_oauth_token` returns None deterministically.
#
# Symlink listing: `ls -la` differs across BSD/GNU and is locale/TZ
# sensitive. We render the listing via a Python one-liner that emits
# only the stable bits (name + symlink target), normalize the repo-root
# path to /REPO, and diff that. macOS-only listings are NOT used.
#
# Per-scenario input.env knobs (all optional):
#   INCLUDE_LOCAL_BIN=1   prepend $fake/.local/bin to PATH (so
#                         _setup_path_includes_local_bin returns True)
#   INCLUDE_BREW_PREFIX_BIN=1
#                         prepend $fake/opt/homebrew/bin to PATH (issue #119).
#                         Brew scenarios put the formula's stable
#                         <prefix>/bin on PATH so `_reachable_elsewhere`
#                         (shutil.which over PATH minus ~/.local/bin)
#                         resolves deterministically. A scenario that wants
#                         the pinned-only-path case (<prefix>/bin OFF PATH)
#                         simply leaves this unset.
#
# Brew keg layout (issue #119): a brew install must run a REAL COPY of the
# binary from a fake Homebrew keg — `_setup_resolve_repo_root()` calls
# `Path(__file__).resolve()`, so a symlink would resolve back to the live
# source checkout and brew detection (`/Cellar/cctally/` in repo_root)
# would never fire. The existing `presetup.sh` + repo-scratch + launcher
# swap path is the extension point: a presetup.sh reshapes the scratch
# `bin/` copy into `$fake/opt/homebrew/Cellar/cctally/<ver>/libexec/bin/`
# and writes the keg's `cctally` path to a `$REPO_SCRATCH/.harness-launcher`
# sentinel that this harness honors (overriding the default launcher). The
# scenario also drops the formula's stable `<prefix>/bin/cctally` symlink so
# the brew hook target resolves to a fixture-stable path. Goldens normalize
# `$fake` (and its `/private/var` realpath form on macOS) to /FAKE.

set -uo pipefail

# Regenerate goldens: CCTALLY_SETUP_REGENERATE=1 bin/cctally-setup-test
# (rewrites each scenario's golden-stdout.txt from the current normalized
# output; settings.json / symlinks / exit goldens are left as-is and still
# verified, so a regen surfaces any unexpected drift there). Mirrors the
# CCTALLY_DOCTOR_REGENERATE seam in bin/cctally-doctor-test.
REGENERATE="${CCTALLY_SETUP_REGENERATE:-}"

# Dev-instance isolation: force prod data-dir layout under fake HOME.
. "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_lib-harness-env.sh"

HARNESS_BIN="$(cd "$(dirname "$0")" && pwd)/cctally"
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd -P)"
FIXTURES_DIR="$REPO_ROOT/tests/fixtures/setup"
pass_count=0
fail_count=0

# Robust golden comparison (issue #106/#107): ONE `diff` over real files
# drives both the verdict and the displayed bytes — no `<(process
# substitution)`, whose transient /dev/fd setup failure under heavy
# parallel CI load made `diff` exit 2 and the old `diff …>/dev/null`
# detection swallow it as a phantom FAIL with no diff to show.
# shellcheck source=bin/_lib-golden-diff.sh
. "$REPO_ROOT/bin/_lib-golden-diff.sh"

# Cross-platform, locale-stable listing of ~/.local/bin/ contents.
# Emits one line per entry: "<name> -> <target>" for symlinks,
# "<name> [file]" for regular files, "<name> [dir]" otherwise.
list_local_bin () {
    local dir="$1"
    python3 -c '
import os, sys
d = sys.argv[1]
if not os.path.isdir(d):
    sys.exit(0)
rows = []
for name in sorted(os.listdir(d)):
    p = os.path.join(d, name)
    if os.path.islink(p):
        rows.append(f"{name} -> {os.readlink(p)}")
    elif os.path.isfile(p):
        rows.append(f"{name} [file]")
    elif os.path.isdir(p):
        rows.append(f"{name} [dir]")
    else:
        rows.append(f"{name} [other]")
print("\n".join(rows))
' "$dir"
}

run_scenario () {
    local name="$1"
    local dir="$FIXTURES_DIR/$name"
    [ -d "$dir" ] || return 0
    [ -f "$dir/cmd.txt" ] || { echo "SKIP $name: no cmd.txt"; return 0; }

    local fake; fake=$(mktemp -d)
    # Temp compare files for the golden-diff helpers land in the scratch
    # HOME, cleaned with the `rm -rf "$fake"` at scenario end.
    local GOLDEN_DIFF_TMPDIR="$fake"
    if [ -d "$dir/input" ]; then
        cp -R "$dir/input/." "$fake/"
    fi
    mkdir -p "$fake/.claude" "$fake/.local/bin" "$fake/.fake-bin"
    cat > "$fake/.fake-bin/security" <<'STUB'
#!/bin/sh
# cctally-setup-test: shadow real `security` so the keychain check
# returns no token deterministically.
exit 1
STUB
    chmod +x "$fake/.fake-bin/security"
    # Provide python3 in .fake-bin (issue #114). _setup_compute_symlink_state
    # is now shutil.which-aware, so the scrubbed PATH must keep python3
    # reachable WITHOUT exposing the real `cctally` that lives in the same
    # Homebrew/npm bin as the ambient python3 (which `${py3_dir}` would have
    # leaked, flipping a "0/13"/--status slot to "available"). A python3
    # symlink here lets the CLI run while .fake-bin stays cctally-free.
    ln -sf "$(command -v python3)" "$fake/.fake-bin/python3"

    # Per-scenario knobs.
    local INCLUDE_LOCAL_BIN=""
    local INCLUDE_BREW_PREFIX_BIN=""
    # Fixture command processes must never see the maintainer's live
    # CODEX_HOME. A scenario may explicitly export its own fake-home list.
    unset CODEX_HOME
    if [ -f "$dir/input.env" ]; then
        # shellcheck disable=SC1091
        . "$dir/input.env"
    fi
    local codex_home_env="${CODEX_HOME:-}"
    local path_pre=""
    if [ "$INCLUDE_LOCAL_BIN" = "1" ]; then
        path_pre="$fake/.local/bin:"
    fi
    # Issue #119: a brew scenario opts in to the formula's stable
    # <prefix>/bin on PATH so `_reachable_elsewhere` resolves the keg copy
    # deterministically. Leaving this unset models the pathological
    # pinned-only-path box (<prefix>/bin off PATH).
    if [ "$INCLUDE_BREW_PREFIX_BIN" = "1" ]; then
        path_pre="${path_pre}$fake/opt/homebrew/bin:"
    fi

    # Template-expand /REPO -> actual REPO_ROOT in copied provider JSON.
    # Both Claude settings and Codex hooks pin the exact current binary path,
    # which cannot be hardcoded at fixture-creation time.
    find "$fake" -type f -name '*.json' 2>/dev/null \
        | while read -r f; do
            python3 -c "import sys; p=sys.argv[1]; r=sys.argv[2]; \
import pathlib; t=pathlib.Path(p).read_text(); \
pathlib.Path(p).write_text(t.replace('/REPO', r))" "$f" "$REPO_ROOT"
        done

    # The cctally shebang is `/usr/bin/env python3`; we want the harness's
    # ambient `python3` (tied to the test runner / Python 3.11+ on CI),
    # not the macOS system python3 in /usr/bin (3.9, below cctally's floor).
    # Exposed via the `python3` symlink in `$fake/.fake-bin` (already first
    # on PATH below) rather than the raw `dirname python3` — see issue #114
    # note at the .fake-bin python3 symlink: a Homebrew/npm bin holding the
    # ambient python3 also holds a real `cctally`, which the now
    # shutil.which-aware symlink check would otherwise pick up.

    # Per-scenario scratch repo: when `presetup.sh` exists, copy the
    # repo's `bin/` into `$fake/repo-scratch/bin/` and let the scenario
    # mutate it before the main `cctally` invocation. This lets a
    # scenario simulate layouts where the script's resolved location
    # differs from the live source checkout — e.g. reshaping the tree
    # into a `node_modules/cctally/` layout to exercise the npm-only
    # gate in `_setup_resolve_symlink_source`, or removing
    # `bin/cctally-npm-shim.js` from that npm layout to exercise the
    # inner shim-missing fallback. The launcher swaps from
    # `$HARNESS_BIN` (live `bin/cctally`) to the scratch copy so
    # `_setup_resolve_repo_root` (derived from `__file__.resolve()`)
    # lands inside the scratch.
    local launcher="$HARNESS_BIN"
    local repo_scratch=""
    if [ -f "$dir/presetup.sh" ]; then
        repo_scratch="$fake/repo-scratch"
        mkdir -p "$repo_scratch/bin"
        # cp -R preserves symlink targets and the +x bit; both matter:
        # the scratch must be a self-sufficient checkout for `bin/cctally`
        # to run, and bash wrappers / shim file need their exec bit.
        cp -R "$REPO_ROOT/bin/." "$repo_scratch/bin/"
        REPO_SCRATCH="$repo_scratch" FAKE_HOME="$fake" bash "$dir/presetup.sh"
        launcher="$repo_scratch/bin/cctally"
        # Issue #119 (brew): a presetup.sh that reshapes the scratch into a
        # Homebrew keg writes the keg's `cctally` path to this sentinel so
        # the launcher resolves (`__file__.resolve()`) INTO the keg, firing
        # brew detection. Absent sentinel = default repo-scratch launcher
        # (every pre-#119 presetup scenario unchanged).
        if [ -f "$repo_scratch/.harness-launcher" ]; then
            launcher="$(cat "$repo_scratch/.harness-launcher")"
        fi
        # `_setup_resolve_repo_root` calls `pathlib.Path(__file__).resolve()`;
        # on macOS that resolves `/var/folders/...` to `/private/var/...`.
        # Use the realpath form for sed substitution so symlink targets
        # (which the kernel records using the resolved root) normalize
        # cleanly to /REPO. We keep the unresolved form too so any
        # output that didn't go through `realpath` still substitutes.
        repo_scratch="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$repo_scratch")"
    fi

    # Pre-run hook: if pre-cmd.txt exists, run it once to materialize
    # post-install state (symlinks, etc.) that we can't ship in git.
    if [ -f "$dir/pre-cmd.txt" ]; then
        local pre; pre=$(cat "$dir/pre-cmd.txt")
        # CCTALLY_DISABLE_UPDATE_CHECK: a `setup` install otherwise fires a
        # DETACHED background `_update-check` worker (main()'s post-command
        # hook) that mkdir's APP_DIR to write update-state.json — racing a
        # later cmd that wipes/asserts on APP_DIR (the uninstall-purge
        # "data dir gone" post-check flaked ~50-75% on Linux 3.12/3.13 from
        # exactly this). The seam keeps every scenario deterministic.
        # shellcheck disable=SC2086
        HOME="$fake" CODEX_HOME="$codex_home_env" TZ=Etc/UTC SHELL=/bin/zsh CCTALLY_DISABLE_UPDATE_CHECK=1 \
            PATH="${path_pre}$fake/.fake-bin:/usr/bin:/bin" \
            "$launcher" $pre >/dev/null 2>&1 || true
    fi

    local cmd; cmd=$(cat "$dir/cmd.txt")
    local raw
    # Forward CCTALLY_AS_OF (when set, e.g. by an `input.env` file or the
    # ambient shell) so scenarios that exercise wall-clock-derived names
    # (e.g. the timestamped `cctally-legacy-hook-backup-<UTC ts>/` dir)
    # can produce deterministic goldens. The `${VAR:-}` form keeps every
    # existing scenario unaffected when the var is unset.
    if [ -f "$dir/stdin.txt" ]; then
        # Optional sibling `stdin.txt`: feeds its bytes verbatim to the
        # CLI's stdin, enabling fixture coverage of TTY-prompt paths
        # (e.g. legacy-hook migration `[Y/n]`). Absent file = no
        # behavior change — backward-compatible for every existing
        # scenario.
        # shellcheck disable=SC2086
        raw=$(HOME="$fake" CODEX_HOME="$codex_home_env" TZ=Etc/UTC SHELL=/bin/zsh CCTALLY_AS_OF="${CCTALLY_AS_OF:-}" \
              CCTALLY_DISABLE_UPDATE_CHECK=1 CCTALLY_SETUP_PROGRESS=0 \
              PATH="${path_pre}$fake/.fake-bin:/usr/bin:/bin" \
              "$launcher" $cmd < "$dir/stdin.txt" 2>&1; echo "EXIT=$?")
    else
        # shellcheck disable=SC2086
        raw=$(HOME="$fake" CODEX_HOME="$codex_home_env" TZ=Etc/UTC SHELL=/bin/zsh CCTALLY_AS_OF="${CCTALLY_AS_OF:-}" \
              CCTALLY_DISABLE_UPDATE_CHECK=1 CCTALLY_SETUP_PROGRESS=0 \
              PATH="${path_pre}$fake/.fake-bin:/usr/bin:/bin" \
              "$launcher" $cmd 2>&1; echo "EXIT=$?")
    fi
    local rc=${raw##*EXIT=}
    rc=${rc%$'\n'}
    local out=${raw%EXIT=*}

    # Normalize: paths, sizes (KB/MB/GB), entry counts, fetch ages.
    # Strip transient cache migration banner — fires once per fresh
    # data dir; goldens shouldn't depend on it.
    # Order matters: when a scenario uses a scratch repo, $repo_scratch
    # is a subpath of $fake; substituting $repo_scratch → /REPO must
    # happen FIRST so the parent $fake → /FAKE rule doesn't shadow it.
    local scratch_sed=""
    if [ -n "$repo_scratch" ]; then
        scratch_sed="-e s|$repo_scratch|/REPO|g"
    fi
    # Issue #119 (brew): the brew hook target is derived from the
    # `.resolve()`d keg repo_root, so on macOS it carries the `/private/var`
    # realpath form of $fake (e.g. the stable <prefix>/bin/cctally hook
    # command). Substitute the realpath form FIRST — it is a superstring of
    # the bare $fake (`/private/var/...` contains `/var/...`), so the
    # `$fake → /FAKE` rule must not run before it. Harmless no-op when
    # $fake_real == $fake (host without /private symlink).
    local fake_real; fake_real=$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$fake")
    local fake_real_sed=""
    if [ "$fake_real" != "$fake" ]; then
        fake_real_sed="-e s|$fake_real|/FAKE|g"
    fi
    local norm
    norm=$(printf '%s' "$out" \
        | grep -v '^\[cache\] migrated' \
        | sed -E \
            $scratch_sed \
            $fake_real_sed \
            -e "s|$fake|/FAKE|g" \
            -e "s|$REPO_ROOT|/REPO|g" \
            -e 's/\(([0-9]+) newly created\)/(N newly created)/g' \
            -e 's/[0-9]+\.[0-9]+ (B|KB|MB|GB|TB)/SIZE/g' \
            -e 's/\(([0-9]+) new entries\)/(N new entries)/g' \
            -e 's/Last fetch     [0-9]+s ago/Last fetch     Ns ago/g' \
            -e 's/cctally-legacy-hook-backup-[0-9]{8}-[0-9]{6}/cctally-legacy-hook-backup-TIMESTAMP/g')

    # Per-root identity keys are deliberately hashes of the random fixture
    # home. For the Codex-hook JSON fixtures, pin the state contract rather
    # than incidental hashes, and make a mixed-root golden deterministic
    # without changing the CLI's required source-root-key sort order.
    if [ -f "$dir/normalize-codex-hooks-json" ]; then
        norm=$(printf '%s' "$norm" | python3 -c '
import json, sys
payload = json.load(sys.stdin)
for row in payload.get("codex_hooks", {}).get("roots", []):
    row["source_root_key"] = "ROOT_KEY"
payload.get("codex_hooks", {}).get("roots", []).sort(key=lambda row: row["codex_home"])
print(json.dumps(payload, indent=2))
')
    fi

    local fail_local=0

    if [ -n "$REGENERATE" ]; then
        # $norm carries NO trailing newline; write the golden the same way
        # the comparison materializes the actual side (printf '%s').
        printf '%s' "$norm" > "$dir/golden-stdout.txt"
        echo "REGEN setup/$name/golden-stdout.txt"
    elif [ -f "$dir/golden-stdout.txt" ]; then
        # $norm and golden-stdout.txt both carry NO trailing newline (the
        # harness has always compared via `printf '%s'`), so materialize
        # $norm the same way and diff the two real files — byte-exact.
        local stdout_tmp; stdout_tmp=$(mktemp "$GOLDEN_DIFF_TMPDIR/golden-diff-stdout.XXXXXX")
        printf '%s' "$norm" > "$stdout_tmp"
        _golden_diff_files "stdout" "$dir/golden-stdout.txt" "$stdout_tmp" 60 || fail_local=1
        rm -f "$stdout_tmp"
    else
        # Missing goldens are FAILURES, not auto-blessed. The test-all
        # aggregator greps for `^MISSING GOLDEN` to surface failures —
        # auto-writing here would silently sail through CI.
        echo "MISSING GOLDEN setup/$name/golden-stdout.txt"
        fail_local=1
    fi

    if [ -f "$dir/golden-exit.txt" ]; then
        local expected_rc; expected_rc=$(cat "$dir/golden-exit.txt")
        if [ "$rc" != "$expected_rc" ]; then
            echo "exit mismatch for $name: got $rc want $expected_rc"
            fail_local=1
        fi
    else
        echo "MISSING GOLDEN setup/$name/golden-exit.txt"
        fail_local=1
    fi

    if [ -f "$dir/golden-settings.json" ]; then
        if [ -f "$fake/.claude/settings.json" ]; then
            local actual_settings
            # Issue #119 (brew): the recorded hook command is the stable
            # <prefix>/bin/cctally, derived from the .resolve()d keg root, so
            # it carries the /private/var realpath form of $fake on macOS.
            # Normalize $fake_real FIRST (superstring of bare $fake), then the
            # bare $fake, alongside the existing repo/REPO substitutions.
            actual_settings=$(sed -E \
                $scratch_sed \
                $fake_real_sed \
                -e "s|$fake|/FAKE|g" \
                -e "s|$REPO_ROOT|/REPO|g" \
                -e 's|cctally-legacy-hook-backup-[0-9]{8}-[0-9]{6}|cctally-legacy-hook-backup-TIMESTAMP|g' \
                "$fake/.claude/settings.json")
            # golden-settings.json ends in \n; _golden_diff_str materializes
            # the actual via `printf '%s\n'`, matching the old comparison.
            _golden_diff_str "settings.json" "$dir/golden-settings.json" "$actual_settings" 50 || fail_local=1
        else
            echo "settings.json missing; expected golden present ($name)"
            fail_local=1
        fi
    fi

    if [ -f "$dir/golden-symlinks.txt" ]; then
        local listing; listing=$(list_local_bin "$fake/.local/bin")
        local norm_listing
        # $fake_real/$fake normalization (issue #119): a pinned-only-path
        # brew fixture seeds a ~/.local/bin/cctally link whose target is the
        # keg under $fake; normalize it like the stdout/settings paths.
        norm_listing=$(printf '%s' "$listing" | sed -E \
            $scratch_sed \
            $fake_real_sed \
            -e "s|$fake|/FAKE|g" \
            -e "s|$REPO_ROOT|/REPO|g")
        if [ -n "$REGENERATE" ]; then
            # golden-symlinks.txt ends in \n; materialize the actual side the
            # same way the comparison does (printf '%s\n'). Regenerating this
            # golden alongside golden-stdout keeps a SETUP_SYMLINK_NAMES change
            # (e.g. #279 S1 F2 adding cctally-budget) re-blessable in one pass.
            printf '%s\n' "$norm_listing" > "$dir/golden-symlinks.txt"
            echo "REGEN setup/$name/golden-symlinks.txt"
        else
            # golden-symlinks.txt ends in \n; _golden_diff_str materializes the
            # actual via `printf '%s\n'`, matching the old comparison.
            _golden_diff_str "symlinks" "$dir/golden-symlinks.txt" "$norm_listing" 50 || fail_local=1
        fi
    fi

    # Scenario-specific post-run checks (e.g. data dir absence after purge).
    if [ -f "$dir/post-check.sh" ]; then
        if ! bash "$dir/post-check.sh" "$fake" "$REPO_ROOT" >/dev/null 2>&1; then
            echo "post-check.sh failed for $name"
            bash "$dir/post-check.sh" "$fake" "$REPO_ROOT" | head -20
            fail_local=1
        fi
    fi

    if [ "$fail_local" = 0 ]; then
        echo "PASS $name"
        pass_count=$((pass_count + 1))
    else
        echo "FAIL $name"
        fail_count=$((fail_count + 1))
    fi
    rm -rf "$fake"
}

for d in "$FIXTURES_DIR"/*/; do
    [ -d "$d" ] || continue
    run_scenario "$(basename "$d")"
done
echo "----"
echo "passed: $pass_count   failed: $fail_count"
[ "$fail_count" -eq 0 ]
