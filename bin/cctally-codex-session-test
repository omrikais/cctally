#!/usr/bin/env bash
# Fixture-based validation harness for `cctally codex-session`.
# Modes:
#   * terminal — default (no extra flags)
#   * json     — --json
#   * desc     — --order desc  (ONLY for fixtures with golden-desc.txt;
#                 opt-in via file presence, not hardcoded per scenario).
# Exits 0 on all-pass, non-zero on any diff/missing golden.

set -uo pipefail

REPO_ROOT=$(cd "$(dirname "$0")/.." && pwd)

HARNESS_SUBCOMMAND="codex-session"
HARNESS_FIXTURES_DIR="$REPO_ROOT/tests/fixtures/codex-session"
HARNESS_BIN="$REPO_ROOT/bin/cctally"

# Per-run scratch dir for the regenerated fixture DBs and any test-process
# SQLite writes. Keeps the in-tree fixture .db files byte-stable across
# harness runs (the builder is host-deterministic but produces different
# bytes on different hosts/sqlite versions). The shared Codex builder
# writes four sub-trees (codex-{daily,monthly,weekly,session}/) under
# $SCRATCH_DIR; HARNESS_FAKE_HOME_BASE points at the codex-session/ subtree
# so _lib-fixture-harness.sh resolves FAKE_HOME=$SCRATCH_DIR/codex-session/<scenario>.
# input.env / golden-*.txt (incl. opt-in golden-desc.txt) are still read
# from the in-tree HARNESS_FIXTURES_DIR.
SCRATCH_DIR=$(mktemp -d -t cctally-codex-session-fixtures-XXXXXX)
trap 'rm -rf "$SCRATCH_DIR"' EXIT
export HARNESS_FAKE_HOME_BASE="$SCRATCH_DIR/codex-session"

"$REPO_ROOT/bin/build-codex-fixtures.py" --out "$SCRATCH_DIR" >/dev/null || {
    echo "FAIL: build-codex-fixtures.py crashed (exit $?)" >&2
    exit 1
}

# shellcheck disable=SC1091
. "$REPO_ROOT/bin/_lib-fixture-harness.sh"

pass_count=0
fail_count=0

for dir in "$HARNESS_FIXTURES_DIR"/*/; do
    name=$(basename "$dir")
    run_mode "$name" "terminal" ""       "terminal"
    run_mode "$name" "json"     "--json" "json"
    # Opt-in per-fixture descending-order mode: only fixtures whose
    # golden-desc.txt exists are expected to assert the --order desc output.
    if [ -f "$dir/golden-desc.txt" ]; then
        run_mode "$name" "desc" "--order desc" "desc"
    fi
done

echo "----"
echo "passed: $pass_count   failed: $fail_count"
[ "$fail_count" -eq 0 ]
