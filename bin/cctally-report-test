#!/usr/bin/env bash
# Fixture-based validation harness for `cctally report` (dollar-per-percent)
# (#279 S7 W6). report joins weekly_usage_snapshots + weekly_cost_snapshots for
# the $/1% trend table; the builder stamps all stats migrations (render-fixture
# rule) so the recompute gate can't zero the seeded snapshots. Modes: terminal + json.
set -uo pipefail

REPO_ROOT=$(cd "$(dirname "$0")/.." && pwd)

HARNESS_SUBCOMMAND="report"
HARNESS_FIXTURES_DIR="$REPO_ROOT/tests/fixtures/report"
HARNESS_BIN="$REPO_ROOT/bin/cctally"

SCRATCH_DIR=$(mktemp -d -t cctally-report-fixtures-XXXXXX)
trap 'rm -rf "$SCRATCH_DIR"' EXIT
export HARNESS_FAKE_HOME_BASE="$SCRATCH_DIR"

. "$REPO_ROOT/bin/_lib-fixture-cache.sh"
build_fixtures_cached "$REPO_ROOT/bin/build-report-fixtures.py" "$SCRATCH_DIR" || {
    echo "FAIL: build-report-fixtures.py crashed (exit $?)" >&2
    exit 1
}

# shellcheck disable=SC1091
. "$REPO_ROOT/bin/_lib-fixture-harness.sh"

pass_count=0
fail_count=0

for dir in "$HARNESS_FIXTURES_DIR"/*/; do
    name=$(basename "$dir")
    run_mode "$name" "terminal" ""       "terminal"
    run_mode "$name" "json"     "--json" "json"
done

echo "----"
echo "passed: $pass_count   failed: $fail_count"
[ "$fail_count" -eq 0 ]
