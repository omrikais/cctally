# ─── Scenario fhb-breakdown-crossed-reset: ⚡ suffix + suppressed delta ─
fhb_breakdown_crossed_reset () {
    local name="fhb-breakdown-crossed-reset"
    begin_scenario "$name"

    run_cctally "$home" weekly >/dev/null 2>&1 || true

    sql "$home" "
INSERT INTO five_hour_blocks (
    five_hour_window_key, five_hour_resets_at, block_start_at,
    first_observed_at_utc, last_observed_at_utc,
    final_five_hour_percent, total_cost_usd,
    seven_day_pct_at_block_start, seven_day_pct_at_block_end,
    crossed_seven_day_reset, is_closed,
    created_at_utc, last_updated_at_utc
) VALUES (1777563000, '2026-04-30T15:30:00+00:00', '2026-04-30T10:30:00+00:00',
          '2026-04-30T10:30:00+00:00', '2026-04-30T15:30:00+00:00',
          50.0, 30.00, 95.0, 5.0, 1, 1,
          '2026-04-30T10:30:00+00:00', '2026-04-30T15:30:00+00:00');

INSERT INTO five_hour_milestones (
    block_id, five_hour_window_key, percent_threshold,
    captured_at_utc, usage_snapshot_id,
    block_cost_usd, marginal_cost_usd, seven_day_pct_at_crossing
) VALUES (1, 1777563000, 1, '2026-04-30T11:00:00+00:00', 0, 6.00, NULL, 95.5);
"
    local out
    out=$(HOME="$home" TZ=Etc/UTC "$BIN" five-hour-breakdown 2>&1)

    case "$out" in
        *"⚡ crossed weekly reset"*) ;;
        *) _err="${_err:+$_err; }crossed-reset missing suffix" ;;
    esac
    # When crossed_seven_day_reset=1 the delta is suppressed: the renderer
    # emits a bare em-dash in parens "(—)" instead of "(Δ +Xpp)".
    case "$out" in
        *"(—)"*) ;;
        *) _err="${_err:+$_err; }crossed-reset delta not suppressed" ;;
    esac

    finish_scenario "$name"
}
fhb_breakdown_crossed_reset

# ─── Scenario fhb-invalid-tz: --tz typo exits 2 with a clear stderr ─
# Regression for the silent-fallback bug where `_format_block_start`
# rendered UTC digits with the user's invalid suffix appended verbatim
# (e.g. `2026-04-30 14:00 America/New_Yorkk`). The unified `_argparse_tz`
# `type=` callable refuses the bad value up front via argparse's standard
# error-and-exit-2 path.
fhb_invalid_tz () {
    local name="fhb-invalid-tz"
    begin_scenario "$name"

    # No DB seeding required — the gate fires before open_db().
    local out rc
    out=$(HOME="$home" TZ=Etc/UTC "$BIN" five-hour-blocks --tz America/New_Yorkk 2>&1)
    rc=$?

    assert_eq "$rc" "2" "five-hour-blocks invalid-tz exit"
    case "$out" in
        *"argument --tz: invalid timezone 'America/New_Yorkk' -- expected 'local', 'utc', or an IANA name"*) ;;
        *) _err="${_err:+$_err; }five-hour-blocks invalid-tz stderr message" ;;
    esac

    out=$(HOME="$home" TZ=Etc/UTC "$BIN" five-hour-breakdown --tz Not/A/Zone 2>&1)
    rc=$?
    assert_eq "$rc" "2" "five-hour-breakdown invalid-tz exit"
    case "$out" in
        *"argument --tz: invalid timezone 'Not/A/Zone' -- expected 'local', 'utc', or an IANA name"*) ;;
        *) _err="${_err:+$_err; }five-hour-breakdown invalid-tz stderr message" ;;
    esac

    finish_scenario "$name"
}
fhb_invalid_tz

# ─── Scenario fhb-dedup-migration: merge_5h_block_duplicates_v1 ───────
# Regression for the F5/duplicate-block fix. Anthropic's status line
# reported `rate_limits.5h.resets_at` jittered by 1 s across a 600-second
# floor boundary (`09:49:59` ↔ `09:50:00`), and an earlier bug in the
# prior-anchor lookup let the second value fork into a NEW
# five_hour_window_key (e.g. ids 61 + 69 in the user's prod DB pointing
# at the same physical 5h window). The one-shot migration in
# `_migration_merge_5h_block_duplicates_v1` heals existing forked rows
# on the next open_db() call.
#
# Seeds two rows whose five_hour_resets_at differ by 1 second across
# the 09:50:00 boundary (BOUND_NEAR=09:49:59, BOUND_PAST=09:50:00),
# triggers any cctally subcommand (which calls open_db() → the
# migration), then asserts the rows collapsed to a single canonical
# parent and the migration marker is recorded.
fhb_dedup_migration () {
    local name="fhb-dedup-migration"
    begin_scenario "$name"

    # Open the DB by running a no-op subcommand (creates schema +
    # populates schema_migrations marker as if migration already ran on
    # an empty table — we DELETE that marker right after so the
    # follow-up subcommand re-fires the migration on the seeded data).
    run_cctally "$home" weekly >/dev/null 2>&1 || true
    # Reset user_version to 2 so the dispatcher re-runs migration #3 only
    # (under the framework, fast-path triggers on user_version == registry-len;
    # DELETE'ing the marker alone leaves user_version=3 and the migration
    # never re-fires).
    sqlite3 "$home/.local/share/cctally/stats.db" <<EOF
DELETE FROM schema_migrations WHERE name = '003_merge_5h_block_duplicates_v1';
PRAGMA user_version = 2;
EOF

    # Seed two parent rows representing the same physical 5h window
    # but stored under distinct (forked) window keys. Mirrors the
    # production incident: id=61 stored 1777629000 (09:50:00 floored)
    # and id=69 stored 1777628400 (09:40:00 from the 09:49:59 sample).
    sql "$home" "
INSERT INTO five_hour_blocks (
    id, five_hour_window_key, five_hour_resets_at, block_start_at,
    first_observed_at_utc, last_observed_at_utc,
    final_five_hour_percent, total_cost_usd,
    seven_day_pct_at_block_start, seven_day_pct_at_block_end,
    crossed_seven_day_reset, is_closed,
    created_at_utc, last_updated_at_utc
) VALUES
  (61, 1777629000, '2026-04-30T09:50:00+00:00', '2026-04-30T04:50:00+00:00',
   '2026-04-30T04:50:00+00:00', '2026-04-30T08:00:00+00:00',
   4.0, 1.20, 70.0, 71.0, 0, 0,
   '2026-04-30T04:50:00+00:00', '2026-04-30T08:00:00+00:00'),
  (69, 1777628400, '2026-04-30T09:49:59+00:00', '2026-04-30T08:30:00+00:00',
   '2026-04-30T08:30:00+00:00', '2026-04-30T09:30:00+00:00',
   19.0, 4.50, 71.0, 72.0, 0, 0,
   '2026-04-30T08:30:00+00:00', '2026-04-30T09:30:00+00:00');

INSERT INTO weekly_usage_snapshots (
    captured_at_utc, weekly_percent,
    week_start_date, week_end_date, payload_json,
    five_hour_percent, five_hour_resets_at, five_hour_window_key
) VALUES
  ('2026-04-30T08:00:00+00:00', 71.0,
   '2026-04-28', '2026-05-05', '{}',
   4.0, '2026-04-30T09:50:00+00:00', 1777629000),
  ('2026-04-30T09:30:00+00:00', 72.0,
   '2026-04-28', '2026-05-05', '{}',
   19.0, '2026-04-30T09:49:59+00:00', 1777628400);
"

    pre_count=$(sql "$home" "SELECT COUNT(*) FROM five_hour_blocks;")
    assert_eq "$pre_count" "2" "pre-migration block count"

    # Trigger open_db() again to fire the migration. `weekly` opens
    # stats.db without writing any 5h-block rows.
    run_cctally "$home" weekly >/dev/null 2>&1 || true

    post_count=$(sql "$home" "SELECT COUNT(*) FROM five_hour_blocks;")
    assert_eq "$post_count" "1" "post-migration block count (merged to canonical)"

    # Canonical = earliest first_observed_at_utc → id 61 wins.
    canonical_id=$(sql "$home" "SELECT id FROM five_hour_blocks;")
    assert_eq "$canonical_id" "61" "canonical block id"

    # Both snapshots' five_hour_window_key now point to the canonical key
    # (1777629000), so the latest-snapshot lookup resolves cleanly.
    distinct_snap_keys=$(sql "$home" \
        "SELECT COUNT(DISTINCT five_hour_window_key) FROM weekly_usage_snapshots;")
    assert_eq "$distinct_snap_keys" "1" "snapshot keys collapsed"
    snap_key=$(sql "$home" \
        "SELECT DISTINCT five_hour_window_key FROM weekly_usage_snapshots;")
    assert_eq "$snap_key" "1777629000" "snapshot keys point at canonical"

    # Migration marker is set so the next open_db() doesn't re-run.
    marker=$(sql "$home" \
        "SELECT name FROM schema_migrations WHERE name = '003_merge_5h_block_duplicates_v1';")
    assert_eq "$marker" "003_merge_5h_block_duplicates_v1" "migration marker recorded"

    # Group-wide merge: canonical (id=61) inherits the latest-observed
    # row's aggregates (id=69's last_observed='09:30', final_pct=19.0,
    # seven_day_pct_at_block_end=72.0, total_cost=4.50). Without the
    # merge, closed/historical duplicate groups would freeze canonical
    # at the earliest-observation slice forever (no future tick fires).
    last_observed=$(sql "$home" \
        "SELECT last_observed_at_utc FROM five_hour_blocks WHERE id = 61;")
    assert_eq "$last_observed" "2026-04-30T09:30:00+00:00" \
        "canonical merged last_observed_at_utc"
    final_pct=$(sql "$home" \
        "SELECT final_five_hour_percent FROM five_hour_blocks WHERE id = 61;")
    assert_eq "$final_pct" "19.0" "canonical merged final_five_hour_percent"
    p_end=$(sql "$home" \
        "SELECT seven_day_pct_at_block_end FROM five_hour_blocks WHERE id = 61;")
    assert_eq "$p_end" "72.0" "canonical merged seven_day_pct_at_block_end"
    cost=$(sql "$home" \
        "SELECT total_cost_usd FROM five_hour_blocks WHERE id = 61;")
    assert_eq "$cost" "4.5" "canonical merged total_cost_usd"

    # Idempotency: running open_db() again is a no-op.
    run_cctally "$home" weekly >/dev/null 2>&1 || true
    post_count2=$(sql "$home" "SELECT COUNT(*) FROM five_hour_blocks;")
    assert_eq "$post_count2" "1" "second open_db() leaves canonical row alone"

    finish_scenario "$name"
}
fhb_dedup_migration

# ─── Scenario fhb-dedup-milestone-collision: UNIQUE collision regression ──
# Regression for the milestone-rekey ordering bug. When canonical and a
# dropped block both hold a milestone for the SAME percent_threshold and
# the dropped row's milestone is the EARLIER keeper, the migration must
# DELETE non-keepers before UPDATEing keepers — otherwise the keeper
# UPDATE collides with canonical's still-present non-keeper milestone on
# UNIQUE(five_hour_window_key, percent_threshold), rolling the migration
# back forever.
fhb_dedup_milestone_collision () {
    local name="fhb-dedup-milestone-collision"
    begin_scenario "$name"

    run_cctally "$home" weekly >/dev/null 2>&1 || true
    # Reset user_version to 2 so the dispatcher re-runs migration #3 only
    # (see fhb-dedup-migration comment for rationale).
    sqlite3 "$home/.local/share/cctally/stats.db" <<EOF
DELETE FROM schema_migrations WHERE name = '003_merge_5h_block_duplicates_v1';
PRAGMA user_version = 2;
EOF

    # Two parent rows for the same physical 5h window + a milestone on
    # threshold=10 in EACH. Canonical (id=61) milestone captured at
    # 08:30; dropped (id=69) milestone captured at 08:00 — earlier ⇒
    # the dropped row's milestone wins the per-threshold dedup and gets
    # rekeyed onto canonical. The DELETE-first ordering keeps the
    # UNIQUE(five_hour_window_key, percent_threshold) constraint
    # satisfied throughout.
    sql "$home" "
INSERT INTO five_hour_blocks (
    id, five_hour_window_key, five_hour_resets_at, block_start_at,
    first_observed_at_utc, last_observed_at_utc,
    final_five_hour_percent, total_cost_usd,
    seven_day_pct_at_block_start, seven_day_pct_at_block_end,
    crossed_seven_day_reset, is_closed,
    created_at_utc, last_updated_at_utc
) VALUES
  (61, 1777629000, '2026-04-30T09:50:00+00:00', '2026-04-30T04:50:00+00:00',
   '2026-04-30T04:50:00+00:00', '2026-04-30T08:30:00+00:00',
   10.0, 1.20, 70.0, 71.0, 0, 0,
   '2026-04-30T04:50:00+00:00', '2026-04-30T08:30:00+00:00'),
  (69, 1777628400, '2026-04-30T09:49:59+00:00', '2026-04-30T08:30:00+00:00',
   '2026-04-30T08:30:00+00:00', '2026-04-30T09:30:00+00:00',
   12.0, 4.50, 71.0, 72.0, 0, 0,
   '2026-04-30T08:30:00+00:00', '2026-04-30T09:30:00+00:00');

INSERT INTO weekly_usage_snapshots (
    id, captured_at_utc, weekly_percent,
    week_start_date, week_end_date, payload_json,
    five_hour_percent, five_hour_resets_at, five_hour_window_key
) VALUES
  (101, '2026-04-30T08:30:00+00:00', 71.0,
   '2026-04-28', '2026-05-05', '{}',
   10.0, '2026-04-30T09:50:00+00:00', 1777629000),
  (102, '2026-04-30T08:00:00+00:00', 70.5,
   '2026-04-28', '2026-05-05', '{}',
   10.0, '2026-04-30T09:49:59+00:00', 1777628400);

INSERT INTO five_hour_milestones (
    block_id, five_hour_window_key, percent_threshold, captured_at_utc,
    usage_snapshot_id
) VALUES
  (61, 1777629000, 10, '2026-04-30T08:30:00+00:00', 101),
  (69, 1777628400, 10, '2026-04-30T08:00:00+00:00', 102);
"

    # Trigger the migration.
    run_cctally "$home" weekly >/dev/null 2>&1 || true

    # Migration must complete (marker present) — failure mode would be
    # a rollback leaving the marker absent and the duplicates intact.
    marker=$(sql "$home" \
        "SELECT name FROM schema_migrations WHERE name = '003_merge_5h_block_duplicates_v1';")
    assert_eq "$marker" "003_merge_5h_block_duplicates_v1" \
        "migration marker recorded (no rollback)"

    post_count=$(sql "$home" "SELECT COUNT(*) FROM five_hour_blocks;")
    assert_eq "$post_count" "1" "blocks collapsed to canonical"

    # Exactly one milestone survives per threshold, FK'd to canonical.
    ms_count=$(sql "$home" \
        "SELECT COUNT(*) FROM five_hour_milestones WHERE percent_threshold = 10;")
    assert_eq "$ms_count" "1" "single milestone per threshold survives"
    ms_block=$(sql "$home" \
        "SELECT block_id FROM five_hour_milestones WHERE percent_threshold = 10;")
    assert_eq "$ms_block" "61" "surviving milestone FK'd to canonical"
    ms_key=$(sql "$home" \
        "SELECT five_hour_window_key FROM five_hour_milestones WHERE percent_threshold = 10;")
    assert_eq "$ms_key" "1777629000" "surviving milestone keyed to canonical"
    # Earlier captured_at wins (write-once milestone semantics).
    ms_captured=$(sql "$home" \
        "SELECT captured_at_utc FROM five_hour_milestones WHERE percent_threshold = 10;")
    assert_eq "$ms_captured" "2026-04-30T08:00:00+00:00" \
        "earliest captured_at wins per-threshold dedup"

    finish_scenario "$name"
}
fhb_dedup_milestone_collision

# ─── Scenario fhb-banner-shown: migration error banner UX ──────────────
# Regression for the G1 fix. Pre-seeds a migration-errors.log entry under
# the fixture HOME, then asserts:
#   1. Non-JSON command renders the banner on STDOUT (first line).
#   2. --json command renders the banner on STDERR and keeps STDOUT a
#      parseable JSON document.
# The banner format anchors on the "⚠ cctally: migration `<name>` failed"
# substring so a future copy edit doesn't silently break the assertion.
fhb_banner_shown () {
    local name="fhb-banner-shown"
    begin_scenario "$name"

    # Bootstrap the DB so the dispatcher stamps user_version = 3 and the
    # second open is a fast-path no-op (otherwise the dispatcher would run
    # migration handlers, succeed on the no-data path, and the post-handler
    # _clear_migration_error_log_entries(qualified_name) would silently
    # unlink the seeded log entry).
    run_cctally "$home" weekly >/dev/null 2>&1 || true

    # Pre-seed sentinel log under the fixture HOME (no migration ran). The
    # name uses a unique sentinel string that doesn't match any registered
    # migration's qualified name — that way even if a migration handler
    # were to run, the success-side log clear wouldn't drop this entry.
    local log_dir="$home/.local/share/cctally/logs"
    mkdir -p "$log_dir"
    local log_path="$log_dir/migration-errors.log"
    printf '[2026-04-30T12:00:00Z] stats.db:099_test_banner_sentinel\n  seeded test failure\n  Traceback line 1\n  Traceback line 2\n\n' > "$log_path"

    # 1. Non-JSON: banner on STDOUT, normal output follows.
    HOME="$home" TZ=Etc/UTC "$BIN" five-hour-blocks \
        > "$home/text-stdout.log" 2> "$home/text-stderr.log" || true
    local first_line
    first_line=$(head -n 1 "$home/text-stdout.log")
    case "$first_line" in
        "⚠ cctally: migration \`stats.db:099_test_banner_sentinel\` failed"*)
            ;;  # ok
        *)
            _err="${_err:+$_err; }non-json banner missing on stdout (got: $first_line)" ;;
    esac
    # Stderr should NOT carry the banner in non-json mode.
    if grep -q '⚠ cctally: migration' "$home/text-stderr.log"; then
        _err="${_err:+$_err; }non-json banner leaked to stderr"
    fi

    # 2. JSON: banner on STDERR, JSON parses cleanly from STDOUT.
    HOME="$home" TZ=Etc/UTC "$BIN" five-hour-blocks --json \
        > "$home/json-stdout.log" 2> "$home/json-stderr.log" || true
    if ! python3 -c "import json,sys; json.load(open(sys.argv[1]))" \
            "$home/json-stdout.log" 2>/dev/null; then
        _err="${_err:+$_err; }json mode stdout is not parseable JSON"
    fi
    if ! grep -q '⚠ cctally: migration `stats.db:099_test_banner_sentinel` failed' \
            "$home/json-stderr.log"; then
        _err="${_err:+$_err; }json mode banner missing on stderr"
    fi

    finish_scenario "$name"
}
fhb_banner_shown

# ─── Scenario fhb-banner-autoclear: auto-clear on migration success ────
# Regression for the G1(c) auto-clear behavior. Seeds the same kind of
# duplicate blocks as fhb-dedup-migration so the merge migration runs to
# success, AND seeds a sentinel log entry tagged with that migration's
# name. After the run the log file should be unlinked (last entry was
# the migration that just succeeded). Prevents stale banners persisting
# after a transient migration failure self-heals on the next open.
fhb_banner_autoclear () {
    local name="fhb-banner-autoclear"
    begin_scenario "$name"

    # Open the DB to create schema (also drops the pre-fired marker so the
    # migration runs again on the seeded data — same trick as
    # fhb-dedup-migration uses). Reset user_version to 2 so migration #3
    # re-fires (see fhb-dedup-migration comment for rationale).
    run_cctally "$home" weekly >/dev/null 2>&1 || true
    sqlite3 "$home/.local/share/cctally/stats.db" <<EOF
DELETE FROM schema_migrations WHERE name = '003_merge_5h_block_duplicates_v1';
PRAGMA user_version = 2;
EOF

    # Seed two duplicate parent blocks (boundary-jitter fork).
    sql "$home" "
INSERT INTO five_hour_blocks (
    id, five_hour_window_key, five_hour_resets_at, block_start_at,
    first_observed_at_utc, last_observed_at_utc,
    final_five_hour_percent, total_cost_usd,
    seven_day_pct_at_block_start, seven_day_pct_at_block_end,
    crossed_seven_day_reset, is_closed,
    created_at_utc, last_updated_at_utc
) VALUES
  (61, 1777629000, '2026-04-30T09:50:00+00:00', '2026-04-30T04:50:00+00:00',
   '2026-04-30T04:50:00+00:00', '2026-04-30T08:00:00+00:00',
   4.0, 1.20, 70.0, 71.0, 0, 0,
   '2026-04-30T04:50:00+00:00', '2026-04-30T08:00:00+00:00'),
  (69, 1777628400, '2026-04-30T09:49:59+00:00', '2026-04-30T08:30:00+00:00',
   '2026-04-30T08:30:00+00:00', '2026-04-30T09:30:00+00:00',
   19.0, 4.50, 71.0, 72.0, 0, 0,
   '2026-04-30T08:30:00+00:00', '2026-04-30T09:30:00+00:00');
"

    # Seed a sentinel log entry whose name matches the migration.
    local log_dir="$home/.local/share/cctally/logs"
    mkdir -p "$log_dir"
    local log_path="$log_dir/migration-errors.log"
    # Use the framework-qualified name so the dispatcher's success-side
    # _clear_migration_error_log_entries(qualified_name) matches and unlinks.
    printf '[2026-04-30T11:59:00Z] stats.db:003_merge_5h_block_duplicates_v1\n  prior failure - to be cleared\n  fake traceback\n\n' > "$log_path"

    # Trigger open_db() — migration runs successfully and auto-clears.
    run_cctally "$home" weekly >/dev/null 2>&1 || true

    # Confirm migration succeeded (canonical row remains).
    post_count=$(sql "$home" "SELECT COUNT(*) FROM five_hour_blocks;")
    assert_eq "$post_count" "1" "post-migration block count (autoclear scenario)"

    # Auto-clear: the log file should be unlinked because the last entry
    # was tagged with the migration that just succeeded.
    if [ -e "$log_path" ]; then
        local remaining
        remaining=$(cat "$log_path")
        _err="${_err:+$_err; }migration-errors.log not unlinked after success (contents: $remaining)"
    fi

    finish_scenario "$name"
}
fhb_banner_autoclear

# ─── Scenario fhb-banner-diff-json-routing: diff --json keeps stdout clean ────
# Regression for a P1 bug: `diff` declares --json with dest="emit_json"
# (not the default dest="json"), so the banner-routing fallback to
# getattr(args, "json", False) was returning False and the banner was
# being printed to STDOUT — corrupting the JSON envelope. The fix
# introduces _args_emit_json() which checks BOTH dest names.
#
# Uses a date-range diff (`last-7d prev-7d`) so we don't depend on the
# subscription-week anchor (no record-usage seed needed); the banner-
# routing logic runs the same way regardless of the diff body.
fhb_banner_diff_json_routing () {
    local name="fhb-banner-diff-json-routing"
    begin_scenario "$name"

    # Pre-seed the migration-errors.log so the banner has something to render.
    local log_dir="$home/.local/share/cctally/logs"
    mkdir -p "$log_dir"
    local log_path="$log_dir/migration-errors.log"
    # Use the framework-qualified name so bootstrap doesn't clear the entry.
    printf '[2026-04-30T12:00:00Z] stats.db:003_merge_5h_block_duplicates_v1\n  seeded test failure\n  Traceback line 1\n  Traceback line 2\n\n' > "$log_path"

    # Run `diff --json` with a non-week range (no anchor needed).
    HOME="$home" TZ=Etc/UTC "$BIN" diff --a last-7d --b prev-7d --json \
        > "$home/diff-json-stdout.log" 2> "$home/diff-json-stderr.log" || true

    # STDOUT must be parseable JSON — the banner must not have leaked into it.
    if ! python3 -c "import json,sys; json.load(open(sys.argv[1]))" \
            "$home/diff-json-stdout.log" 2>/dev/null; then
        _err="${_err:+$_err; }diff --json stdout is not parseable JSON (banner likely leaked)"
    fi

    # STDOUT must NOT contain the banner substring.
    if grep -q '⚠ cctally: migration' "$home/diff-json-stdout.log"; then
        _err="${_err:+$_err; }banner leaked to diff --json stdout"
    fi

    # Banner MUST appear on STDERR.
    if ! grep -q '⚠ cctally: migration `stats.db:003_merge_5h_block_duplicates_v1` failed' \
            "$home/diff-json-stderr.log"; then
        _err="${_err:+$_err; }diff --json banner missing on stderr"
    fi

    finish_scenario "$name"
}
fhb_banner_diff_json_routing

# ─── Scenario fhb-banner-status-line-suppressed: forecast --status-line clean ──
# Regression for a P1 bug: `forecast --status-line` is consumed via
# `$(cctally forecast --status-line --no-sync 2>/dev/null)` for shell
# prompt embedding (see forecast docstring). Both stdout and stderr are
# unsafe surfaces — stdout is shell-substituted into the user's prompt,
# stderr is discarded. The banner must be suppressed entirely.
#
# Seeds a current-week weekly_usage_snapshots row so forecast has data
# to render (otherwise --status-line emits an empty silent segment and
# the test can't distinguish "banner suppressed" from "nothing happened").
fhb_banner_status_line_suppressed () {
    local name="fhb-banner-status-line-suppressed"
    begin_scenario "$name"

    # Bootstrap schema.
    run_cctally "$home" weekly >/dev/null 2>&1 || true

    # Seed a current-week snapshot so _load_forecast_inputs returns non-None.
    sql "$home" "
INSERT INTO weekly_usage_snapshots (
    captured_at_utc, week_start_date, week_end_date,
    week_start_at, week_end_at, weekly_percent, source, payload_json,
    five_hour_percent, five_hour_resets_at, five_hour_window_key
) VALUES (
    '2026-04-30T12:45:00+00:00', '2026-04-27', '2026-05-04',
    '2026-04-27T00:00:00+00:00', '2026-05-04T00:00:00+00:00',
    42.0, 'fixture', '{}', 42.0,
    '2026-04-30T15:30:00+00:00', 1777563000
);
"

    # Pre-seed the migration-errors.log.
    local log_dir="$home/.local/share/cctally/logs"
    mkdir -p "$log_dir"
    local log_path="$log_dir/migration-errors.log"
    # Use the framework-qualified name so bootstrap doesn't clear the entry.
    printf '[2026-04-30T12:00:00Z] stats.db:003_merge_5h_block_duplicates_v1\n  seeded test failure\n  Traceback line 1\n  Traceback line 2\n\n' > "$log_path"

    # Pin "now" so forecast renders deterministically.
    CCTALLY_AS_OF=2026-04-30T12:45:00Z HOME="$home" TZ=Etc/UTC \
        "$BIN" forecast --status-line --no-sync \
        > "$home/sl-stdout.log" 2> "$home/sl-stderr.log" || true

    # STDOUT must NOT contain the banner — it's shell-substituted into the
    # user's prompt and would corrupt the rendered prompt.
    if grep -q '⚠ cctally: migration' "$home/sl-stdout.log"; then
        _err="${_err:+$_err; }banner leaked to status-line stdout (would corrupt user's shell prompt)"
    fi

    # STDOUT must be at most one line (status-line contract).
    local line_count
    line_count=$(wc -l < "$home/sl-stdout.log" | tr -d ' ')
    if [ "$line_count" -gt 1 ]; then
        _err="${_err:+$_err; }status-line stdout has $line_count lines (expected 0 or 1)"
    fi

    # STDERR must NOT contain the banner — `2>/dev/null` discards it
    # anyway and we want zero noise from this code path.
    if grep -q '⚠ cctally: migration' "$home/sl-stderr.log"; then
        _err="${_err:+$_err; }banner leaked to status-line stderr (status-line discards stderr — surfacing here is misleading)"
    fi

    finish_scenario "$name"
}
fhb_banner_status_line_suppressed

echo
echo "passed: $pass_count   failed: $fail_count"
exit $fail_count
