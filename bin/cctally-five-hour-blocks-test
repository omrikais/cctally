    created_at_utc, last_updated_at_utc
) VALUES
  (1777545000, '2026-04-30T10:30:00+00:00', '2026-04-30T05:30:00+00:00',
   '2026-04-30T05:30:00+00:00', '2026-04-30T10:30:00+00:00',
   30.0, 8.00, 0, 1,
   '2026-04-30T05:30:00+00:00', '2026-04-30T10:30:00+00:00'),
