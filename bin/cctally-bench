#!/usr/bin/env python3
"""In-process backend benchmark runner (issue #276, M3 / Session B).

Times the backend hot paths against a deterministic synthetic fixture and
prints a human table / ``--json``; ``--compare``/``--gate`` diff a run against
the committed advisory baseline. A dev / maintainer tool (like
``bin/cctally-release``), NOT a ``cctally`` subcommand — it never ships to npm
and is never wired into ``cctally-test-all`` (the self-test
``bin/cctally-bench-test`` is; it asserts structure only, never timings).

Six benchmark families (14 benchmarks) exercise the #268-#275 perf wins:
  1. snapshot spine  — _tui_build_snapshot cold / warm / idle (precompute_envelope)
  2. ingest          — sync_cache no-op over many files + a one-file delta
  3. conversations   — list_conversations page1 / sorted / filtered
  4. search / find   — search_conversations cross-session + find_in_conversation
  5. payload/outline — _assemble_session + get_conversation_outline (measure-only)
  6. warm reconciles — projects-envelope + cache-report reconcile helpers

The runner is a PURE CONSUMER: every call is the real read/build path against
the isolated fixture. It adds no timing hooks inside the modules (Session A's
M2 phase collector already did that) and changes no semantics of the code
under test. ``--trace`` flips the M2 collector on per body and captures its
phase sub-tree, so the bench and /api/debug/backend speak one phase vocabulary.
"""
from __future__ import annotations

import argparse
import importlib.machinery
import importlib.util
import json
import os
import pathlib
import platform
import statistics
import sys
import time

# ── Tunable constants (documented in bench/README.md; tune after first run) ──
BENCH_TOLERANCE_PCT = 0.15        # proportional regression tolerance
BENCH_TOLERANCE_FLOOR_MS = 15.0   # absolute floor (same-machine run-to-run noise)
DEFAULT_ITERATIONS = 5            # first discarded as warmup, median of the rest
DEFAULT_SEED = 42
DEFAULT_SCALE = "large"
SCHEMA_VERSION = 1

_BIN_DIR = pathlib.Path(__file__).resolve().parent
BASELINE_PATH = _BIN_DIR.parent / "bench" / "baselines" / "backend.json"

# ── Session C (M5): the --assembly-scan mode ─────────────────────────────────
# The visibility budget used by the threshold analysis in docs/backend-
# performance.md: the msg_count at which whole-session assembly crosses this is
# the "materialize?" trigger. Tunable (see bench/README.md).
ASSEMBLY_VISIBLE_MS = 100.0
# The committed evidence baseline lives at bench/baselines/assembly.json (Codex
# F7 — a separate file from the default suite's backend.json); it is written by
# the maintainer via `--assembly-scan --json > …`, not programmatically here.
# The per-rung columns that are DETERMINISTIC (goldenable) — everything else is
# a machine-variant *_ms timing (recorded, never asserted). The self-test drops
# the timing keys and byte-compares the rest across two runs.
_ASSEMBLY_STRUCTURAL_KEYS = (
    "turn_count", "msg_count", "item_count", "assembled_items_bytes",
    "page_bytes_200", "page_bytes_500", "page_bytes_1000", "outline_bytes",
)

# Process-local accelerator caches reset for a COLD snapshot build — the set
# the production self-heal path (_dashboard_self_heal_orphans) resets.
_COLD_RESETS = (
    "reset_dispatch_state",
    "reset_group_a_state",
    "reset_group_a_current_state",
    "reset_session_cache_state",
    "reset_doctor_memo",
    "reset_weekref_cost_state",
    "reset_projects_env_state",
    "reset_projects_env_current_state",
    "reset_bugk_segment_state",
    "reset_cache_report_state",
)


# ── loaders ──────────────────────────────────────────────────────────────

def _load_gen():
    """Path-load the sibling generator (hyphenated filename)."""
    path = _BIN_DIR / "build-bench-fixtures.py"
    loader = importlib.machinery.SourceFileLoader("build_bench_fixtures", str(path))
    spec = importlib.util.spec_from_loader("build_bench_fixtures", loader)
    mod = importlib.util.module_from_spec(spec)
    loader.exec_module(mod)
    return mod


def _pin_and_import(data_dir, claude_dir):
    """Pin BOTH env axes before loading cctally (paths captured at import), then
    re-resolve the path globals so the process targets THIS scratch dir."""
    os.environ["CCTALLY_DATA_DIR"] = str(data_dir)
    os.environ["CLAUDE_CONFIG_DIR"] = str(claude_dir)
    os.environ.setdefault("CCTALLY_DISABLE_DEV_AUTODETECT", "1")
    if str(_BIN_DIR) not in sys.path:
        sys.path.insert(0, str(_BIN_DIR))
    # Reuse the generator's extensionless-cctally loader so both halves share
    # ONE sys.modules["cctally"] instance.
    cctally = _load_gen().load_cctally()
    cctally._cctally_core._init_paths_from_env()
    perf = cctally._load_sibling("_lib_perf")
    return cctally, perf


# ── timing loop ──────────────────────────────────────────────────────────

def time_body(fn, iterations):
    """Run ``fn`` ``iterations + 1`` times, discard the first (warmup), and
    return ``(median_ms, min_ms, max_ms, last_return)``."""
    samples = []
    last = None
    for i in range(iterations + 1):
        t0 = time.perf_counter()
        last = fn()
        dt_ms = (time.perf_counter() - t0) * 1000.0
        if i > 0:
            samples.append(dt_ms)
    return statistics.median(samples), min(samples), max(samples), last


def _time_median(fn, iterations):
    """Median-of-N wall-clock ms for ``fn`` (warmup discarded)."""
    return time_body(fn, iterations)[0]


def _reset_perf(perf):
    perf.set_enabled(False)
    perf.reset_thread()
    perf._LAST_BACKEND_PERF = None


def _capture_phases(name, body, perf, has_own_root):
    """Run ``body`` once with the M2 collector on and return its phase tree.

    Bodies with their own root phase (``_tui_build_snapshot`` opens ``snapshot``
    and calls ``reset_thread`` itself) run bare; the rest are wrapped in an
    outer ``perf.phase(name)`` so a direct ``sync_cache`` / query call still
    produces a captured tree (spec §4.2 tracing mechanics)."""
    perf.set_enabled(True)
    perf.reset_thread()
    try:
        if has_own_root:
            body()
        else:
            with perf.phase(name):
                body()
        root = perf.current_root()
        return root.to_dict() if root is not None else None
    finally:
        _reset_perf(perf)


# ── benchmark registry ───────────────────────────────────────────────────

def _make_benchmarks(cctally, perf):
    """Build the registry. Returns ``(benchmarks, cleanup)`` where each
    benchmark is ``(name, body, has_own_root, count_of)`` and ``cleanup`` closes
    the shared read connection."""
    sc = cctally._load_sibling("_lib_snapshot_cache")
    cr = cctally._load_sibling("_lib_cache_report")
    cq = cctally._load_sibling("_lib_conversation_query")

    # Shared read connection for the query families (read-only; reused across
    # iterations to isolate query cost from connection-open cost).
    read_conn = cctally.open_conversations_db()

    def _scalar(sql, params=()):
        row = read_conn.execute(sql, params).fetchone()
        return row[0] if row else None

    large_sid = _scalar(
        "SELECT session_id FROM conversation_sessions "
        "ORDER BY msg_count DESC, session_id LIMIT 1"
    )
    proj_label = _scalar(
        "SELECT project_label FROM conversation_sessions "
        "WHERE project_label IS NOT NULL AND project_label != '' "
        "ORDER BY session_id LIMIT 1"
    )
    delta_path = _scalar(
        "SELECT path FROM cache_db.session_files "
        "ORDER BY size_bytes ASC, path LIMIT 1"
    )
    num_files = _scalar("SELECT COUNT(*) FROM cache_db.session_files") or 0

    # ── family 1: snapshot spine ──
    def _snapshot():
        return cctally._tui_build_snapshot(
            skip_sync=True, precompute_envelope=True, runtime_bind=None
        )

    def _reset_cold():
        sc.bump_generation()
        for fn_name in _COLD_RESETS:
            getattr(sc, fn_name)()

    def snapshot_cold():
        _reset_cold()
        return _snapshot()

    def snapshot_warm():
        sc.bump_generation()            # move the signature → full rebuild
        return _snapshot()

    def snapshot_idle():
        return _snapshot()              # unchanged signature → reuse (near-zero)

    # ── family 2: ingest ──
    def sync_noop():
        conn = cctally.open_cache_db()
        try:
            return cctally.sync_cache(conn)
        finally:
            conn.close()

    def sync_delta():
        conn = cctally.open_cache_db()
        try:
            if delta_path:
                # Reset the file's ingest cursor so this one file re-ingests
                # from offset 0 each call (idempotent UPSERT — no duplication,
                # semantic content stable); measures single-file delta cost.
                conn.execute("DELETE FROM session_files WHERE path=?", (delta_path,))
                conn.commit()
                return cctally.sync_cache(conn, only_paths={delta_path})
            return cctally.sync_cache(conn)
        finally:
            conn.close()

    # ── family 3: conversations rail ──
    def conv_page1():
        return cq.list_conversations(read_conn, sort="recent", limit=50, offset=0)

    def conv_sorted():
        return cq.list_conversations(read_conn, sort="cost", limit=50, offset=0)

    def conv_filtered():
        return cq.list_conversations(
            read_conn, sort="recent", limit=50, offset=0,
            projects=[proj_label] if proj_label else None,
            date_from="2025-01-01",
        )

    # ── family 4: search / find ──
    def search_cross():
        return cq.search_conversations(read_conn, "benchmark", limit=50)

    def find_in_conv():
        return cq.find_in_conversation(read_conn, large_sid, "benchmark")

    # ── family 5: payload / outline (measurement-only) ──
    def payload_assemble():
        return cq._assemble_session(read_conn, large_sid)

    def outline_build():
        return cq.get_conversation_outline(read_conn, large_sid)

    # #278 Theme B: the memo-HIT rung. Measures the WARM path only — a single
    # indexed watermark SELECT + LRU hit (sub-ms). time_body discards the first
    # (warmup) call, which primes the memo on a miss, so every MEASURED iteration
    # is a pure hit; the callable must NOT clear/prime per-iteration (that would
    # fold a cold assemble into every sample). The cold payload.assemble /
    # outline.build rungs above stay UNCHANGED as the baseline.
    cq._assemble_memo_clear()
    cq._assemble_session_memoized(read_conn, large_sid)   # prime once (untimed)

    def outline_memo():
        return cq._assemble_session_memoized(read_conn, large_sid)   # measured: hit

    # ── family 6: warm reconciles ──
    raw_config = cctally.load_config()
    display_tz = cctally._resolve_display_tz_obj(
        cctally._apply_display_tz_override(raw_config, None)
    )
    bucket_tz = cr._resolve_bucket_tz(display_tz)
    tz_key = str(display_tz)

    def _dispatch_sig():
        stats_conn = cctally.open_db()
        try:
            return cctally._cctally_tui._tui_compute_dispatch_signature(stats_conn)
        finally:
            stats_conn.close()

    # Prime the two reconcile caches cold once (untimed) so the warmup call is
    # the cold-record path and the measured iterations are warm/idempotent.
    sc.reset_projects_env_state()
    sc.reset_projects_env_current_state()
    sc.reset_cache_report_state()

    def reconcile_projects_env():
        sig = _dispatch_sig()
        conn = cctally.open_cache_db()
        try:
            sc.reconcile_projects_env_cache(
                conn,
                max_entry_id=sig.max_entry_id,
                max_mutation_seq=sig.entry_mutation_seq,
                max_wus_id=sig.max_wus_id,
                sf_sig=sc.session_files_sig(conn),
            )
        finally:
            conn.close()

    def reconcile_cache_report():
        sig = _dispatch_sig()
        conn = cctally.open_cache_db()
        try:
            sc.reconcile_cache_report_cache(
                conn,
                max_entry_id=sig.max_entry_id,
                max_mutation_seq=sig.entry_mutation_seq,
                reset_sig=sig.reset_sig,
                sf_sig=sc.session_files_sig(conn),
                bucket_tz=bucket_tz,
                tz_key=tz_key,
            )
        finally:
            conn.close()

    def _len_conversations(r):
        return len(r["conversations"]) if isinstance(r, dict) else None

    def _total(r):
        return r.get("total") if isinstance(r, dict) else None

    benchmarks = [
        ("snapshot.cold", snapshot_cold, True, None),
        ("snapshot.warm", snapshot_warm, True, None),
        ("snapshot.idle", snapshot_idle, True, None),
        ("sync.noop", sync_noop, False, lambda r: num_files),
        ("sync.delta", sync_delta, False, lambda r: 1 if delta_path else 0),
        ("conversations.page1", conv_page1, False, _len_conversations),
        ("conversations.sorted", conv_sorted, False, _len_conversations),
        ("conversations.filtered", conv_filtered, False, _len_conversations),
        ("search.cross_session", search_cross, False, _total),
        ("find.in_conversation", find_in_conv, False,
         lambda r: (r or {}).get("total")),
        ("payload.assemble", payload_assemble, False, None),
        ("outline.build", outline_build, False, None),
        ("payload.assemble_memo_hit", outline_memo, False, None),
        ("reconcile.cache_report", reconcile_cache_report, False, None),
        ("reconcile.projects_env", reconcile_projects_env, False, None),
    ]

    def cleanup():
        try:
            read_conn.close()
        except Exception:
            pass

    return benchmarks, cleanup


def _machine_label():
    return f"{platform.system()}-{platform.machine()}".lower()


def _bench_version(cctally):
    try:
        v = cctally._share_resolve_version()
        if v:
            return v
    except Exception:
        pass
    return "unknown"


def run_all(*, scale, seed, iterations, trace, root=None,
            data_dir=None, claude_dir=None):
    """Build/reuse the fixture (or use the operator-supplied realism roots),
    time every registered benchmark, and return the ``--json`` result dict."""
    gen = _load_gen()
    if (data_dir is None) != (claude_dir is None):
        raise ValueError(
            "realism mode needs BOTH --data-dir and --claude-dir — the "
            "cache/stats dir and the JSONL source are independent axes; "
            "passing only one would silently fall back to the synthetic fixture")
    if data_dir is not None and claude_dir is not None:
        data_dir = pathlib.Path(data_dir)
        claude_dir = pathlib.Path(claude_dir)
    else:
        if root is None:
            raise ValueError("run_all requires root= unless data_dir+claude_dir given")
        data_dir = gen.build_fixture(scale=scale, seed=seed, root=root)
        claude_dir = pathlib.Path(root) / "claude"

    cctally, perf = _pin_and_import(data_dir, claude_dir)

    conn = cctally.open_conversations_db()
    try:
        dcounts = gen.dataset_counts(conn)
    finally:
        conn.close()

    benchmarks, cleanup = _make_benchmarks(cctally, perf)
    results = {}
    try:
        for name, body, has_own_root, count_of in benchmarks:
            _reset_perf(perf)
            median, mn, mx, last = time_body(body, iterations)
            count = None
            if count_of is not None:
                try:
                    count = count_of(last)
                except Exception:
                    count = None
            entry = {
                "median_ms": round(median, 4),
                "min_ms": round(mn, 4),
                "max_ms": round(mx, 4),
                "count": count,
                "bytes": None,
                "phases": None,
            }
            if trace:
                entry["phases"] = _capture_phases(name, body, perf, has_own_root)
            results[name] = entry
    finally:
        _reset_perf(perf)
        cleanup()

    return {
        "schemaVersion": SCHEMA_VERSION,
        "cctally_version": _bench_version(cctally),
        "machine_label": _machine_label(),
        "scale": scale,
        "seed": seed,
        "dataset_counts": dcounts,
        "benchmarks": results,
    }


# ── --assembly-scan mode (Session C / M5) ─────────────────────────────────

def run_assembly_scan(*, ladder_scale="small", iterations=DEFAULT_ITERATIONS,
                      root=None, data_dir=None, claude_dir=None):
    """Sweep the conversation-assembly cost across a size ladder — one session
    per rung — and return a per-rung report (spec §3).

    ``ladder_scale`` selects the ladder: ``small`` → the fast ``assembly-small``
    scale (``ASSEMBLY_TURN_LADDER_SMALL``), ``large`` → the full ``assembly``
    scale (``ASSEMBLY_TURN_LADDER``). Uses the ``assembly`` fixture INTERNALLY
    (Codex F7) — never the default ``--scale`` corpus — under a pinned scratch
    ``CCTALLY_DATA_DIR`` + ``CLAUDE_CONFIG_DIR`` (the B/M3 dual-env isolation).

    Per rung it records deterministic counts + payload bytes (goldenable) and
    median-of-N wall-clock timings (advisory — the repeated-reassembly paths
    ``detail_*``/``outline``/``find_hit``/``open_pair`` that drive the
    materialization decision, since pagination caps payload bytes but NOT
    assembly cost). Structural columns are stable run-to-run; timings are not.
    """
    gen = _load_gen()
    scale = "assembly" if ladder_scale == "large" else "assembly-small"
    if data_dir is not None or claude_dir is not None:
        # Optional realism cross-check (advisory, non-committed): scan an
        # operator-copied cache. Both axes required, same XOR guard as run_all.
        if data_dir is None or claude_dir is None:
            raise ValueError(
                "realism mode needs BOTH --data-dir and --claude-dir")
        data_dir = pathlib.Path(data_dir)
        claude_dir = pathlib.Path(claude_dir)
        ladder = None                     # bucket real sessions by size instead
    else:
        if root is None:
            raise ValueError("run_assembly_scan requires root= unless "
                             "data_dir+claude_dir given")
        data_dir = gen.build_fixture(scale=scale, seed=DEFAULT_SEED, root=root)
        claude_dir = pathlib.Path(root) / "claude"
        ladder = (gen.ASSEMBLY_TURN_LADDER if scale == "assembly"
                  else gen.ASSEMBLY_TURN_LADDER_SMALL)

    cctally, perf = _pin_and_import(data_dir, claude_dir)
    cq = cctally._load_sibling("_lib_conversation_query")
    token = gen._SEARCH_TOKEN

    conn = cctally.open_conversations_db()
    try:
        dcounts = gen.dataset_counts(conn)
        if ladder is not None:
            sids = [f"sess-{i}" for i in range(len(ladder))]
            turn_of = {f"sess-{i}": t for i, t in enumerate(ladder)}
        else:
            # Realism: the largest session per size bucket (advisory).
            sids = [r[0] for r in conn.execute(
                "SELECT session_id FROM conversation_sessions "
                "ORDER BY msg_count DESC, session_id LIMIT 6").fetchall()]
            turn_of = {}

        rungs = []
        for sid in sids:
            msg_count = conn.execute(
                "SELECT msg_count FROM conversation_sessions WHERE session_id=?",
                (sid,)).fetchone()[0]

            asm = cq._assemble_session(conn, sid)
            item_count = len(asm["items"])
            # A vacuous find would measure the cheap early-out probe, not the
            # assembly-backed path. The SYNTHETIC fixture stamps the token into
            # every message, so a miss there is a real bug → hard-fail (a plain
            # `raise`, not a bare `assert` that `python -O` would strip). Real
            # operator sessions (realism mode, ladder is None) may legitimately
            # lack the token, so there the find stays advisory (no assert).
            fr = cq.find_in_conversation(conn, sid, token)
            if ladder is not None and not (fr is not None and fr.get("total", 0) > 0):
                raise RuntimeError(f"{sid}: find on {token!r} was vacuous")

            # Deterministic payload bytes (materialization-footprint proxy +
            # real endpoint page bytes). json.dumps in the SAME wire form.
            # Reuse the `asm` assembled above — it is deterministic, so a second
            # _assemble_session would only burn a whole-session assemble per rung.
            assembled_items_bytes = len(json.dumps(asm["items"]).encode())
            page_bytes = {}
            for L in (200, 500, 1000):
                page_bytes[L] = len(json.dumps(
                    cq.get_conversation(conn, sid, tail=True, limit=L)).encode())
            outline_bytes = len(json.dumps(
                cq.get_conversation_outline(conn, sid)).encode())

            # Advisory timings (median-of-N, warmup discarded). Bind sid per
            # loop via a default arg so the lambda captures THIS rung.
            assemble_ms = _time_median(
                lambda s=sid: cq._assemble_session(conn, s), iterations)
            detail_tail_ms = _time_median(
                lambda s=sid: cq.get_conversation(conn, s, tail=True, limit=200),
                iterations)
            detail_page_ms = _time_median(
                lambda s=sid: cq.get_conversation(conn, s, tail=True, limit=500),
                iterations)
            outline_ms = _time_median(
                lambda s=sid: cq.get_conversation_outline(conn, s), iterations)
            find_hit_ms = _time_median(
                lambda s=sid: cq.find_in_conversation(conn, s, token), iterations)
            open_pair_ms = detail_tail_ms + outline_ms

            rungs.append({
                "turn_count": turn_of.get(sid),
                "msg_count": msg_count,
                "item_count": item_count,
                "assemble_ms": round(assemble_ms, 4),
                "detail_tail_ms": round(detail_tail_ms, 4),
                "detail_page_ms": round(detail_page_ms, 4),
                "outline_ms": round(outline_ms, 4),
                "find_hit_ms": round(find_hit_ms, 4),
                "open_pair_ms": round(open_pair_ms, 4),
                "assembled_items_bytes": assembled_items_bytes,
                "page_bytes_200": page_bytes[200],
                "page_bytes_500": page_bytes[500],
                "page_bytes_1000": page_bytes[1000],
                "outline_bytes": outline_bytes,
            })
    finally:
        conn.close()

    return {
        "schemaVersion": SCHEMA_VERSION,
        "cctally_version": _bench_version(cctally),
        "machine_label": _machine_label(),
        "ladder_scale": ladder_scale,
        "visible_ms": ASSEMBLY_VISIBLE_MS,
        "dataset_counts": dcounts,
        "rungs": rungs,
    }


def render_assembly_table(result) -> str:
    lines = []
    dc = result["dataset_counts"]
    lines.append(
        f"assembly scan · cctally {result['cctally_version']} · "
        f"ladder={result['ladder_scale']} · machine={result['machine_label']} · "
        f"visible={result['visible_ms']:.0f}ms"
    )
    lines.append(
        f"dataset: {dc['sessions']:,} sessions · {dc['entries']:,} entries · "
        f"{dc['messages']:,} messages"
    )
    lines.append("─" * 96)
    lines.append(
        f"{'turns':>7}{'msgs':>8}{'items':>7}{'assemble':>10}{'outline':>9}"
        f"{'find':>9}{'open_pair':>11}{'items_b':>10}{'page1k_b':>10}"
    )
    for r in result["rungs"]:
        tc = "—" if r["turn_count"] is None else f"{r['turn_count']:,}"
        lines.append(
            f"{tc:>7}{r['msg_count']:>8,}{r['item_count']:>7,}"
            f"{_fmt_ms(r['assemble_ms']):>10}{_fmt_ms(r['outline_ms']):>9}"
            f"{_fmt_ms(r['find_hit_ms']):>9}{_fmt_ms(r['open_pair_ms']):>11}"
            f"{r['assembled_items_bytes']:>10,}{r['page_bytes_1000']:>10,}"
        )
    return "\n".join(lines)


# ── output ───────────────────────────────────────────────────────────────

def _fmt_ms(v):
    return f"{v:.1f}ms"


def render_table(result) -> str:
    lines = []
    dc = result["dataset_counts"]
    lines.append(
        f"backend bench · cctally {result['cctally_version']} · "
        f"scale={result['scale']} · seed={result['seed']} · "
        f"machine={result['machine_label']}"
    )
    lines.append(
        f"dataset: {dc['sessions']:,} sessions · {dc['entries']:,} entries · "
        f"{dc['messages']:,} messages"
    )
    lines.append("─" * 62)
    lines.append(f"{'benchmark':<26}{'median':>10}  {'range':>16}  {'count':>8}")
    for name, b in result["benchmarks"].items():
        rng = f"{b['min_ms']:.1f}–{b['max_ms']:.1f}ms"
        count = "—" if b["count"] is None else f"{b['count']:,}"
        lines.append(f"{name:<26}{_fmt_ms(b['median_ms']):>10}  {rng:>16}  {count:>8}")
    return "\n".join(lines)


# ── compare / gate ───────────────────────────────────────────────────────

def classify(baseline, current, *, pct, floor_ms):
    """Total per-benchmark status taxonomy (spec §4.3). Returns a dict keyed by
    benchmark name plus a ``_meta`` entry. Statuses: ``OK`` / ``REGRESSED`` /
    ``MISSING`` (in baseline, absent from current) / ``NEW`` (in current, absent
    from baseline). ``REGRESSED`` iff ``current - baseline > max(pct*baseline,
    floor_ms)`` — the floor stops sub-ms benches flapping and cleanly handles a
    zero/near-zero baseline. A non-dict / keyless baseline is ``malformed``."""
    if not isinstance(baseline, dict) or "benchmarks" not in baseline:
        return {"_meta": {"malformed": True, "machine_mismatch": False}}
    b = baseline["benchmarks"]
    c = current["benchmarks"]
    out = {"_meta": {
        "malformed": False,
        "machine_mismatch": baseline.get("machine_label") != current.get("machine_label"),
    }}
    for name, bv in b.items():
        if name not in c:
            out[name] = {"status": "MISSING", "baseline_ms": bv["median_ms"],
                         "current_ms": None, "delta_ms": None}
            continue
        base_ms = bv["median_ms"]
        cur_ms = c[name]["median_ms"]
        delta = cur_ms - base_ms
        tol = max(pct * base_ms, floor_ms)
        out[name] = {
            "status": "REGRESSED" if delta > tol else "OK",
            "baseline_ms": base_ms, "current_ms": cur_ms, "delta_ms": delta,
        }
    for name in c:
        if name not in b:
            out[name] = {"status": "NEW", "baseline_ms": None,
                         "current_ms": c[name]["median_ms"], "delta_ms": None}
    return out


def gate_exit(classified, *, allow_cross_machine=True):
    """Exit code for ``--gate``: 2 if the baseline is malformed; 0 on a
    cross-machine compare (when ``allow_cross_machine``) since those numbers are
    advisory-only; 1 if any benchmark is ``REGRESSED`` or ``MISSING``; else 0."""
    meta = classified.get("_meta", {})
    if meta.get("malformed"):
        return 2
    if meta.get("machine_mismatch") and allow_cross_machine:
        return 0
    for name, r in classified.items():
        if name == "_meta":
            continue
        if r["status"] in ("REGRESSED", "MISSING"):
            return 1
    return 0


def _load_baseline():
    try:
        return json.loads(BASELINE_PATH.read_text())
    except (OSError, json.JSONDecodeError):
        return None


def render_compare(classified) -> str:
    """Δ table + per-benchmark verdicts (advisory). Loud banner on a malformed
    baseline or a cross-machine compare."""
    meta = classified.get("_meta", {})
    lines = []
    if meta.get("malformed"):
        return (f"!! baseline {BASELINE_PATH} is missing or malformed — cannot "
                f"compare. Run `cctally-bench --update-baseline`.")
    if meta.get("machine_mismatch"):
        lines.append(
            "!! machine-label mismatch — this comparison is CROSS-MACHINE and "
            "advisory only; --gate will not fail on these numbers alone."
        )
    lines.append(f"{'benchmark':<26}{'baseline':>10}{'current':>10}"
                 f"{'delta':>10}  status")
    for name, r in classified.items():
        if name == "_meta":
            continue
        base = "—" if r["baseline_ms"] is None else _fmt_ms(r["baseline_ms"])
        cur = "—" if r["current_ms"] is None else _fmt_ms(r["current_ms"])
        delta = "—" if r["delta_ms"] is None else f"{r['delta_ms']:+.1f}ms"
        lines.append(f"{name:<26}{base:>10}{cur:>10}{delta:>10}  {r['status']}")
    return "\n".join(lines)


def _write_baseline(result):
    BASELINE_PATH.parent.mkdir(parents=True, exist_ok=True)
    BASELINE_PATH.write_text(json.dumps(result, indent=2, sort_keys=True) + "\n")


def _resolve_root(args):
    if args.root:
        return pathlib.Path(args.root).expanduser()
    env_data = os.environ.get("CCTALLY_DATA_DIR", "").strip()
    if env_data:
        return pathlib.Path(env_data).expanduser().parent
    import tempfile
    return (pathlib.Path(tempfile.gettempdir()) / "cctally-bench"
            / f"{args.scale}-seed{args.seed}")


def _resolve_assembly_root(args):
    """A DEDICATED scratch root for --assembly-scan, keyed by the assembly scale
    so the ladder fixture NEVER shares a dir with Session B's small/large corpus
    (a marker mismatch would otherwise rebuild-over one of them). An explicit
    --root is respected (the operator then owns isolation)."""
    if args.root:
        return pathlib.Path(args.root).expanduser()
    import tempfile
    scale = "assembly" if args.assembly_ladder_scale == "large" else "assembly-small"
    return (pathlib.Path(tempfile.gettempdir()) / "cctally-bench"
            / f"{scale}-seed{DEFAULT_SEED}")


def _build_parser():
    ap = argparse.ArgumentParser(
        description="In-process backend benchmark runner (issue #276, M3)."
    )
    ap.add_argument("--scale", choices=("small", "large"), default=DEFAULT_SCALE)
    ap.add_argument("--seed", type=int, default=DEFAULT_SEED)
    ap.add_argument("--iterations", type=int, default=DEFAULT_ITERATIONS)
    ap.add_argument("--trace", action="store_true",
                    help="capture the M2 phase sub-tree per benchmark.")
    ap.add_argument("--json", action="store_true", dest="as_json")
    ap.add_argument("--root", default=None,
                    help="scratch root for the synthetic fixture.")
    ap.add_argument("--data-dir", default=None,
                    help="realism mode: an operator-COPIED CCTALLY_DATA_DIR.")
    ap.add_argument("--claude-dir", default=None,
                    help="realism mode: an operator-COPIED Claude root.")
    ap.add_argument("--compare", action="store_true",
                    help="diff against the committed baseline (advisory, exit 0).")
    ap.add_argument("--gate", action="store_true",
                    help="like --compare but exit non-zero on regression/missing.")
    ap.add_argument("--update-baseline", action="store_true", dest="update_baseline",
                    help="rerun and overwrite bench/baselines/backend.json.")
    ap.add_argument("--assembly-scan", action="store_true", dest="assembly_scan",
                    help="Session C (M5) mode: sweep conversation-assembly cost "
                         "across a size ladder. Uses its own baseline "
                         "(bench/baselines/assembly.json); incompatible with "
                         "--compare/--gate/--update-baseline (backend.json).")
    ap.add_argument("--assembly-ladder-scale", choices=("small", "large"),
                    default="small", dest="assembly_ladder_scale",
                    help="ladder size for --assembly-scan (default: small).")
    return ap


def main(argv=None) -> int:
    parser = _build_parser()
    args = parser.parse_args(argv)
    if args.assembly_scan:
        if args.compare or args.gate or args.update_baseline:
            parser.error(
                "--assembly-scan uses its own baseline (bench/baselines/"
                "assembly.json) and is incompatible with "
                "--compare/--gate/--update-baseline (which target backend.json).")
        result = run_assembly_scan(
            ladder_scale=args.assembly_ladder_scale, iterations=args.iterations,
            root=_resolve_assembly_root(args),
            data_dir=args.data_dir, claude_dir=args.claude_dir)
        if args.as_json:
            print(json.dumps(result, indent=2, sort_keys=True))
        else:
            print(render_assembly_table(result))
        return 0
    root = _resolve_root(args)
    result = run_all(
        scale=args.scale, seed=args.seed, iterations=args.iterations,
        trace=args.trace, root=root,
        data_dir=args.data_dir, claude_dir=args.claude_dir,
    )
    if args.update_baseline:
        _write_baseline(result)
        print(f"wrote baseline: {BASELINE_PATH}")
        print(render_table(result))
        return 0
    if args.compare or args.gate:
        classified = classify(
            _load_baseline(), result,
            pct=BENCH_TOLERANCE_PCT, floor_ms=BENCH_TOLERANCE_FLOOR_MS,
        )
        print(render_compare(classified))
        return gate_exit(classified) if args.gate else 0
    if args.as_json:
        print(json.dumps(result, indent=2))
    else:
        print(render_table(result))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
