#!/usr/bin/env bash
# Golden-file harness for the conversation-viewer endpoints (Plan 2, §3 / §6.8).
#
# Boots `cctally dashboard` against the seeded fixture cache.db and drives the
# three conversation GET routes + the loopback/Host privacy gate end-to-end:
#
#   - Rebuilds the fixture (cache.db + stats.db) via build-conversation-fixtures.
#   - Starts the server on an ephemeral port (--port 0) with --no-sync
#     --no-browser, pinned to HOME=<scratch> and a LOOPBACK bind (127.0.0.1).
#   - GET /api/conversations (loopback Host)         → all-history rail, >=2
#     sessions; pagination probe `?limit=1&offset=0` → has_more:true + a
#     next_offset.
#   - GET /api/conversation/s1 (loopback Host)        → resume-merged, deduped
#     items, the (m1,r1) turn ONCE with cost ONCE, sum(items.cost)==cost_usd,
#     cursor shape present.
#   - GET /api/conversation/search?q=token (loopback) → the prose-fragment hit
#     deduped across the replay to ONE, (session_id,uuid) anchor present, the
#     multi-fragment turn resolves to a single turn item.
#   - GET /api/conversation/s5/outline (loopback)     → #177 S5 full-session
#     skeleton + stats; turns/stats keys present, stats.cost_usd == the reader's
#     header cost_usd (shared assembly pass).
#   - GATE: the SAME GET /api/conversations but with a LAN-hostname `Host`
#     header (expose unset → default false) → 403 (the anti-DNS-rebinding gate
#     rejects a hostname Host even on a loopback bind). A default (loopback
#     Host) request to the same route returns 200 — proving the 403 is the Host
#     gate, not a broken route.
#
# Each JSON body is normalized (wall-clock fields → sentinels) and diffed
# against tests/fixtures/conversation/<scenario>/golden-*.json. First run writes
# each golden; steady-state is a byte-stable diff. Every compare routes through
# bin/_lib-golden-diff.sh (NEVER inline `diff -u <(…)` — #106/#107). A trap
# kills any stray server PID on exit / Ctrl-C.
#
# Single scenario, run sequentially (the gate truth-table is driven by Host
# headers, not by separate fixture trees), so no xargs fan-out here.

set -uo pipefail

# Dev-instance isolation: force prod data-dir layout under fake HOME.
. "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_lib-harness-env.sh"

REPO_ROOT=$(cd "$(dirname "$0")/.." && pwd)
BIN="$REPO_ROOT/bin/cctally"
FIX_DIR="$REPO_ROOT/tests/fixtures/conversation"

# Robust golden comparison (#106/#107): ONE `diff` over real files drives both
# the verdict and the displayed bytes — no `<(process substitution)`.
# shellcheck source=bin/_lib-golden-diff.sh
. "$REPO_ROOT/bin/_lib-golden-diff.sh"

# Bounded server teardown (issue #153): SIGTERM -> grace poll -> SIGKILL, so a
# dropped single SIGTERM (CPython signal/Event lost-wakeup race) can't hang the
# suite on an unbounded `wait`. shellcheck source=bin/_lib-kill-server.sh
. "$REPO_ROOT/bin/_lib-kill-server.sh"

# Per-run scratch root. The scenario's HOME is a clone of the in-tree fixture's
# .local tree, so the dashboard server's startup writes (e.g. SQLite WAL) never
# dirty the committed fixture.
SCRATCH_ROOT=$(mktemp -d -t cctally-conversation-test.XXXXXX)
GOLDEN_DIFF_TMPDIR="$SCRATCH_ROOT"

pass_count=0
fail_count=0

declare -a BG_PIDS=()
cleanup () {
    for p in "${BG_PIDS[@]:-}"; do
        [ -n "$p" ] && kill_server_bounded "$p"
    done
    rm -rf "$SCRATCH_ROOT"
}
trap cleanup EXIT INT TERM

echo ">> rebuilding fixtures"
"$REPO_ROOT/bin/build-conversation-fixtures.py" >/dev/null || {
    echo "FAIL: build-conversation-fixtures.py crashed (exit $?)" >&2
    exit 1
}

# The search golden's `mode:"fts"` + bracketed `[token]` snippet are FTS5-
# specific (SQLite's snippet()); on a build lacking FTS5 the kernel falls back
# to LIKE + a manual snippet, so the byte-exact search-golden diff would
# diverge. Probe once and gate ONLY the search-golden byte-compare on FTS5 —
# the structural search asserts (dedup-to-one / anchor / cost) are mode-agnostic
# and always run. Mirrors tests/test_conversation_query.py's FTS5 skip.
FTS5_AVAILABLE=$(python3 -c '
import sqlite3
c = sqlite3.connect(":memory:")
try:
    c.execute("CREATE VIRTUAL TABLE _p USING fts5(x)")
    print("1")
except sqlite3.OperationalError:
    print("0")
')

# Normalize a conversation JSON body so re-runs are byte-stable. The payloads
# are already wall-clock-independent (every timestamp is fixture-pinned and
# anchor ids are deterministic insert order), but normalize defensively the
# same way bin/cctally-dashboard-test does, so a future field addition that
# leaks wall time into the golden trips here instead of flaking. Stdin: raw
# JSON. Stdout: sorted-key, 2-space-indent JSON.
normalize_json () {
    python3 -c '
import json, sys
body = json.load(sys.stdin)
# No wall-clock fields exist in the conversation payloads today; re-serialize
# with sorted keys + 2-space indent so the golden is canonical and stable.
print(json.dumps(body, indent=2, sort_keys=True))
'
}

fail () {
    echo "FAIL ${name:-?}: $1"
    ok=0
}

# fetch_and_diff <label> <golden-basename> <url> [extra curl args...]
#   GET the url, normalize, diff against the named golden (writing it on first
#   run). Marks `ok=0` on any failure. Uses the golden-diff chokepoint.
fetch_and_diff () {
    local label="$1" golden_base="$2" url="$3"; shift 3
    local golden="$dir/$golden_base"
    local raw actual
    raw=$(curl -s --max-time 5 "$@" "$url")
    if [ -z "$raw" ]; then
        fail "$label: empty body ($url)"
        return
    fi
    actual=$(printf '%s' "$raw" | normalize_json)
    if [ $? -ne 0 ] || [ -z "$actual" ]; then
        fail "$label: JSON could not be normalized (raw: $raw)"
        return
    fi
    if [ ! -f "$golden" ]; then
        printf '%s\n' "$actual" > "$golden"
        echo "WROTE $name golden: $golden"
    else
        _golden_diff_str "$label" "$golden" "$actual" 5000 || ok=0
    fi
}

run_scenario () {
    name="$1"
    dir="$FIX_DIR/$name"
    ok=1

    if [ ! -f "$dir/input.env" ]; then
        fail "no input.env at $dir/input.env"
        return 1
    fi

    local loopback_host lan_host search_q
    loopback_host=$(grep '^LOOPBACK_HOST=' "$dir/input.env" | head -1 | cut -d= -f2-)
    lan_host=$(grep '^LAN_HOSTNAME_HOST=' "$dir/input.env" | head -1 | cut -d= -f2-)
    search_q=$(grep '^SEARCH_QUERY=' "$dir/input.env" | head -1 | cut -d= -f2-)
    : "${loopback_host:=127.0.0.1}"
    : "${lan_host:=lan-host.example.com}"
    : "${search_q:=token}"

    # Clone the in-tree fixture's .local tree into scratch HOME so server
    # startup writes (SQLite WAL etc.) can't dirty the committed fixture.
    local scratch_home="$SCRATCH_ROOT/$name"
    mkdir -p "$scratch_home"
    cp -R "$dir/.local" "$scratch_home/"

    local log="$scratch_home/server.log"
    # Loopback bind + default expose (unset → false). The gate's 403 leg below
    # rejects a LAN-hostname Host even on this loopback bind.
    HOME="$scratch_home" TZ=Etc/UTC \
        "$BIN" dashboard --port 0 --no-browser --no-sync \
        --sync-interval 9999 --host 127.0.0.1 >"$log" 2>&1 &
    local pid=$!
    BG_PIDS+=("$pid")

    # Discover the ephemeral port from the banner (up to ~15s for cold runners).
    local port="" tries=0
    while [ $tries -lt 150 ]; do
        if [ -s "$log" ]; then
            port=$(grep -Eo 'http://(127\.0\.0\.1|localhost):[0-9]+' "$log" | head -1 | sed 's#.*:##')
            [ -n "$port" ] && break
        fi
        if ! kill -0 "$pid" 2>/dev/null; then
            break
        fi
        sleep 0.1
        tries=$((tries + 1))
    done

    if [ -z "$port" ]; then
        fail "could not discover port (log: $log)"
        sed 's/^/    /' "$log" 2>/dev/null || true
        kill_server_bounded "$pid"
        return 1
    fi

    local base="http://127.0.0.1:$port"
    # Loopback Host header pinned on the 200-path requests. (curl's default Host
    # would be 127.0.0.1:<port> — a loopback IP literal, which the gate also
    # allows — but pin it explicitly so the contract is legible.)
    local LOOP=(-H "Host: ${loopback_host}:${port}")

    # --- 1) Rail: full page + pagination probe ---------------------------
    fetch_and_diff "GET /api/conversations" "golden-conversations.json" \
        "$base/api/conversations" "${LOOP[@]}"

    # Pagination: limit=1&offset=0 must page (>=2 sessions seeded).
    local page_raw page_check
    page_raw=$(curl -s --max-time 5 "${LOOP[@]}" "$base/api/conversations?limit=1&offset=0")
    page_check=$(printf '%s' "$page_raw" | python3 -c '
import json, sys
d = json.load(sys.stdin)
errs = []
convs = d.get("conversations")
if not isinstance(convs, list) or len(convs) != 1:
    errs.append("limit=1 did not return exactly 1 conversation: %r" % (convs,))
page = d.get("page") or {}
if page.get("has_more") is not True:
    errs.append("page.has_more != True under limit=1: %r" % (page.get("has_more"),))
if page.get("next_offset") != 1:
    errs.append("page.next_offset != 1: %r" % (page.get("next_offset"),))
if errs:
    sys.exit("; ".join(errs))
print("ok")
' 2>&1)
    if [ "$page_check" != "ok" ]; then
        fail "rail pagination: $page_check (raw: $page_raw)"
    fi

    # --- 2) Reader: resume-merged, deduped, cost-once --------------------
    fetch_and_diff "GET /api/conversation/s1" "golden-conversation-s1.json" \
        "$base/api/conversation/s1" "${LOOP[@]}"

    # Non-golden structural asserts: the (m1,r1) turn appears ONCE, cost ONCE,
    # sum(items.cost)==header cost_usd, cursor shape present. Plus #164: the
    # tool_result FOLDS into the turn's tool_call (no standalone tool_result
    # item) and its uuid joins the turn's member_uuids. Plus skill-content
    # nesting: the PAIRED skill body (sk1, source_tool_use_id=toolu_FX) folds
    # INTO the Skill tool_call (skill_body/skill_name set, result null, sk1
    # joined to member_uuids) and its standalone item DISAPPEARS, while the
    # UNPAIRED skill body (sk2, no link) survives as the lone standalone pill.
    local reader_raw reader_check
    reader_raw=$(curl -s --max-time 5 "${LOOP[@]}" "$base/api/conversation/s1")
    reader_check=$(printf '%s' "$reader_raw" | python3 -c '
import json, sys
d = json.load(sys.stdin)
errs = []
items = d.get("items") or []
kinds = [it.get("kind") for it in items]
# #164: the tool_result FOLDED into the turn, so there is no standalone
# tool_result item — only [human, assistant]. The PAIRED skill body folded into
# the Skill chip (dropped as an item); the UNPAIRED skill body (sk2) is the lone
# trailing `meta` item (NEVER a "human"/"You" prompt).
if kinds != ["human", "assistant", "meta"]:
    errs.append("items kinds != [human, assistant, meta] (replay/fragments/result/skill-fold not applied): %r" % (kinds,))
if any(k == "tool_result" for k in kinds):
    errs.append("a standalone tool_result item survived folding: %r" % (kinds,))
# The lone surviving meta item is the UNPAIRED skill (sk2), not the folded sk1.
metas = [it for it in items if it.get("kind") == "meta"]
if len(metas) != 1:
    errs.append("expected ONE standalone meta item (the UNPAIRED skill body), got %d" % (len(metas),))
else:
    meta = metas[0]
    if meta.get("anchor", {}).get("uuid") != "sk2":
        errs.append("standalone meta is not the UNPAIRED sk2 (paired sk1 should have folded away): %r" % (meta.get("anchor"),))
    if meta.get("meta_kind") != "skill":
        errs.append("meta_kind != skill: %r" % (meta.get("meta_kind"),))
    if meta.get("skill_name") != "using-superpowers":
        errs.append("standalone skill_name != using-superpowers: %r" % (meta.get("skill_name"),))
    if "Using Superpowers" not in (meta.get("text") or ""):
        errs.append("standalone meta render text missing the unpaired skill body: %r" % (meta.get("text"),))
# The PAIRED skill body (sk1) must NOT survive as a standalone item anywhere.
if any(it.get("anchor", {}).get("uuid") == "sk1" for it in items):
    errs.append("the PAIRED skill body sk1 survived as a standalone item (should have folded into the Skill chip)")
assistants = [it for it in items if it.get("kind") == "assistant"]
if len(assistants) != 1:
    errs.append("turn not collapsed to ONE assistant item: %d" % (len(assistants),))
else:
    turn = assistants[0]
    # #164/#160: every folded uuid joins member_uuids (the jump anchor) — the two
    # prose/seed fragments (a1a, a1b), the Read tool_result (tr1, Phase 2), the
    # "Launching skill" tool_result (tr_fx, Phase 2 — folded BEFORE its result is
    # superseded), and the skill body (sk1, Phase 4b).
    if set(turn.get("member_uuids") or []) != {"a1a", "a1b", "tr1", "tr_fx", "sk1"}:
        errs.append("member_uuids != {a1a,a1b,tr1,tr_fx,sk1}: %r" % (turn.get("member_uuids"),))
    anc = turn.get("anchor") or {}
    if anc.get("session_id") != "s1" or anc.get("uuid") != "a1b":
        errs.append("turn anchor != (s1, a1b): %r" % (anc,))
    if not (turn.get("cost_usd", 0.0) > 0):
        errs.append("turn cost_usd not > 0: %r" % (turn.get("cost_usd"),))
    # #164: the tool_use became a tool_call carrying the paired result; no bare
    # tool_use block survives the Phase-3 sweep.
    blocks = turn.get("blocks") or []
    if any(b.get("kind") == "tool_use" for b in blocks):
        errs.append("a bare tool_use block survived the sweep: %r" % (blocks,))
    calls = [b for b in blocks if b.get("kind") == "tool_call"]
    # TWO tool_calls now: the Read (toolu_s1a) + the Skill (toolu_FX).
    if len(calls) != 2:
        errs.append("expected TWO tool_call blocks (Read + Skill), got %d" % (len(calls),))
    by_id = {c.get("tool_use_id"): c for c in calls}
    read_call = by_id.get("toolu_s1a")
    if read_call is None:
        errs.append("the Read tool_call (toolu_s1a) is missing")
    else:
        if read_call.get("preview") != "/home/u/proj/resets.py":
            errs.append("Read tool_call.preview wrong: %r" % (read_call.get("preview"),))
        res = read_call.get("result") or {}
        if res.get("text") != "def reset(): ...":
            errs.append("Read tool_call.result.text wrong: %r" % (res.get("text"),))
        if "skill_body" in read_call:
            errs.append("the Read tool_call wrongly carries a skill_body: %r" % (read_call.get("skill_body"),))
    # Skill-content nesting: the Skill tool_call carries the folded body and a
    # cleared result; the "Launching skill" tool_result was superseded.
    skill_call = by_id.get("toolu_FX")
    if skill_call is None:
        errs.append("the Skill tool_call (toolu_FX) is missing")
    else:
        if skill_call.get("name") != "Skill":
            errs.append("Skill tool_call.name != Skill: %r" % (skill_call.get("name"),))
        if skill_call.get("skill_name") != "brainstorming":
            errs.append("Skill tool_call.skill_name != brainstorming: %r" % (skill_call.get("skill_name"),))
        if "Brainstorming Ideas" not in (skill_call.get("skill_body") or ""):
            errs.append("Skill tool_call.skill_body missing the folded body: %r" % (skill_call.get("skill_body"),))
        if skill_call.get("result") is not None:
            errs.append("Skill tool_call.result not cleared on fold: %r" % (skill_call.get("result"),))
# Cost counted exactly once despite the cross-file replay.
s = sum(it.get("cost_usd", 0.0) for it in items)
if abs(s - d.get("cost_usd", 0.0)) >= 1e-9:
    errs.append("sum(items.cost_usd)=%r != header cost_usd=%r" % (s, d.get("cost_usd")))
page = d.get("page") or {}
if "next_after" not in page or "has_more" not in page:
    errs.append("cursor shape missing (next_after/has_more): %r" % (page,))
if errs:
    sys.exit("; ".join(errs))
print("ok")
' 2>&1)
    if [ "$reader_check" != "ok" ]; then
        fail "reader dedup/cost-once: $reader_check (raw: $reader_raw)"
    fi

    # --- 2b) Reader: sidechain payload (#155) ----------------------------
    fetch_and_diff "GET /api/conversation/s3" "golden-conversation-s3.json" \
        "$base/api/conversation/s3" "${LOOP[@]}"

    local sc_raw sc_check
    sc_raw=$(curl -s --max-time 5 "${LOOP[@]}" "$base/api/conversation/s3")
    sc_check=$(printf '%s' "$sc_raw" | python3 -c '
import json, sys
d = json.load(sys.stdin)
errs = []
items = d.get("items") or []
by = {it["anchor"]["uuid"]: it for it in items}
# NEGATIVE privacy guarantee: no raw source_path on ANY item; both new fields present.
for it in items:
    if "source_path" in it:
        errs.append("source_path leaked on item %r" % (it["anchor"].get("uuid"),))
    if "subagent_key" not in it or "parent_uuid" not in it:
        errs.append("missing subagent_key/parent_uuid on %r" % (it["anchor"].get("uuid"),))
# main items -> subagent_key None; agent items -> derived hash.
if by.get("s3h1", {}).get("subagent_key") is not None:
    errs.append("main item s3h1 subagent_key != None: %r" % (by.get("s3h1", {}).get("subagent_key"),))
if by.get("a1", {}).get("subagent_key") != "aaaa1111":
    errs.append("a1 subagent_key != aaaa1111: %r" % (by.get("a1", {}).get("subagent_key"),))
if by.get("b1", {}).get("subagent_key") != "bbbb2222":
    errs.append("b1 subagent_key != bbbb2222: %r" % (by.get("b1", {}).get("subagent_key"),))
# the multi-fragment subagent-C turn (anchor c2) carries the SEED parent (s3a1),
# NOT the intra-turn prose parent (c1).
cturn = by.get("c2") or {}
if cturn.get("subagent_key") != "cccc3333":
    errs.append("c-turn subagent_key != cccc3333: %r" % (cturn.get("subagent_key"),))
if cturn.get("parent_uuid") != "s3a1":
    errs.append("c-turn parent_uuid != s3a1 (seed): %r" % (cturn.get("parent_uuid"),))
if set(cturn.get("member_uuids") or []) != {"c1", "c2"}:
    errs.append("c-turn member_uuids != {c1,c2}: %r" % (cturn.get("member_uuids"),))
if errs:
    sys.exit("; ".join(errs))
print("ok")
' 2>&1)
    if [ "$sc_check" != "ok" ]; then
        fail "reader sidechain payload (#155): $sc_check (raw: $sc_raw)"
    fi

    # --- 2c) Reader: enriched data contract (#177) -----------------------
    # The s5 turn pins every #177 surface in one payload: per-turn tokens drawn
    # from the SAME session_entries row as cost, a vendor cost_usd_raw override
    # (so cost != f(tokens)), stop_reason + skill/plugin attribution, structured
    # input + input_truncated on the tool_call, and result.full_length on the
    # truncated tool result.
    fetch_and_diff "GET /api/conversation/s5" "golden-conversation-s5.json" \
        "$base/api/conversation/s5" "${LOOP[@]}"

    local enr_raw enr_check
    enr_raw=$(curl -s --max-time 5 "${LOOP[@]}" "$base/api/conversation/s5")
    enr_check=$(printf '%s' "$enr_raw" | python3 -c '
import json, sys
d = json.load(sys.stdin)
errs = []
items = d.get("items") or []
turn = next((it for it in items if it["kind"] == "assistant"), None)
if turn is None:
    sys.exit("no assistant turn on s5")
# tokens from the same source row as cost.
tok = turn.get("tokens")
if tok != {"input": 1000, "output": 500, "cache_creation": 0, "cache_read": 0}:
    errs.append("tokens wrong/absent: %r" % (tok,))
# cost is the raw override ($0.99), NOT token-derived ($0.0175) — same source
# row, NOT same arithmetic.
if turn.get("cost_usd") != 0.99:
    errs.append("cost_usd != raw override 0.99: %r" % (turn.get("cost_usd"),))
if turn.get("stop_reason") != "tool_use":
    errs.append("stop_reason wrong: %r" % (turn.get("stop_reason"),))
if turn.get("attribution_skill") != "superpowers:test-driven-development":
    errs.append("attribution_skill wrong: %r" % (turn.get("attribution_skill"),))
if turn.get("attribution_plugin") != "superpowers":
    errs.append("attribution_plugin wrong: %r" % (turn.get("attribution_plugin"),))
call = next((b for b in turn["blocks"] if b.get("kind") == "tool_call"), None)
if call is None:
    errs.append("no tool_call block on s5 turn")
else:
    if call.get("input") != {"file_path": "/home/u/proj/resolve.py", "old_string": "clipped-leaf…"}:
        errs.append("input did not survive to tool_call: %r" % (call.get("input"),))
    if call.get("input_truncated") is not True:
        errs.append("input_truncated wrong: %r" % (call.get("input_truncated"),))
    # #198: the ingest-stamped true edit stat survives the tool_use -> tool_call fold.
    if call.get("edit_stat") != {"add": 412, "del": 87}:
        errs.append("edit_stat did not survive to tool_call: %r" % (call.get("edit_stat"),))
    res = call.get("result") or {}
    if res.get("full_length") != 48213:
        errs.append("result.full_length wrong/absent: %r" % (res.get("full_length"),))
    if res.get("truncated") is not True:
        errs.append("result.truncated wrong: %r" % (res.get("truncated"),))
if errs:
    sys.exit("; ".join(errs))
print("ok")
' 2>&1)
    if [ "$enr_check" != "ok" ]; then
        fail "reader enriched data contract (#177): $enr_check (raw: $enr_raw)"
    fi

    # --- 2d) Outline: full-session skeleton + stats (#177 S5) -------------
    # The /outline route shares get_conversation's assembly pass, so its
    # stats.cost_usd MUST equal the reader's header cost_usd byte-for-byte.
    fetch_and_diff "GET /api/conversation/s5/outline" "golden-conversation-s5-outline.json" \
        "$base/api/conversation/s5/outline" "${LOOP[@]}"

    local outline_raw reader_s5_raw outline_check
    outline_raw=$(curl -s --max-time 5 "${LOOP[@]}" "$base/api/conversation/s5/outline")
    reader_s5_raw=$(curl -s --max-time 5 "${LOOP[@]}" "$base/api/conversation/s5")
    outline_check=$(O="$outline_raw" R="$reader_s5_raw" python3 -c '
import json, os, sys
o = json.loads(os.environ["O"])
r = json.loads(os.environ["R"])
errs = []
for key in ("session_id", "stats", "turns"):
    if key not in o:
        errs.append("outline missing %r key: %r" % (key, sorted(o)))
turns = o.get("turns")
if not isinstance(turns, list) or not turns:
    errs.append("outline turns not a non-empty list: %r" % (turns,))
stats = o.get("stats") or {}
if stats.get("cost_usd") != r.get("cost_usd"):
    errs.append("outline stats.cost_usd=%r != reader cost_usd=%r"
                % (stats.get("cost_usd"), r.get("cost_usd")))
if errs:
    sys.exit("; ".join(errs))
print("ok")
' 2>&1)
    if [ "$outline_check" != "ok" ]; then
        fail "outline route (#177 S5): $outline_check (raw: $outline_raw)"
    fi

    # --- 2e) Reader: #186 command-marker fold + read-time ANSI strip ------
    # s6's FIRST user line is a PRE-FIX slash-command stdout echo carrying SGR
    # styling (stored entry_type='human'). The reader must (a) fold it to
    # kind='meta'/meta_kind='command' (System-marker pill, not a "YOU" turn),
    # (b) strip the raw `\x1b` from the folded command <pre> body, and (c) the
    # rail title must be the REAL second prompt, clean of plumbing + ANSI.
    fetch_and_diff "GET /api/conversation/s6" "golden-conversation-s6.json" \
        "$base/api/conversation/s6" "${LOOP[@]}"

    local s6_raw s6_check rail_raw
    s6_raw=$(curl -s --max-time 5 "${LOOP[@]}" "$base/api/conversation/s6")
    rail_raw=$(curl -s --max-time 5 "${LOOP[@]}" "$base/api/conversations")
    s6_check=$(D="$s6_raw" RAIL="$rail_raw" python3 -c '
import json, os, sys
d = json.loads(os.environ["D"])
rail = json.loads(os.environ["RAIL"])
errs = []
raw = os.environ["D"]
if "\\u001b" in raw or "\x1b" in raw:
    errs.append("raw ESC survived into the s6 reader payload")
items = d.get("items") or []
by = {it["anchor"]["uuid"]: it for it in items}
echo = by.get("s6m")
if echo is None:
    errs.append("s6m item missing")
else:
    if echo.get("kind") != "meta" or echo.get("meta_kind") != "command":
        errs.append("s6m not folded to meta/command: kind=%r meta_kind=%r"
                    % (echo.get("kind"), echo.get("meta_kind")))
    if "\x1b" in (echo.get("text") or ""):
        errs.append("s6m command body still carries ESC: %r" % (echo.get("text"),))
    if "Fable 5" not in (echo.get("text") or ""):
        errs.append("s6m command body lost its text: %r" % (echo.get("text"),))
real = by.get("s6h")
if real is None or real.get("kind") != "human":
    errs.append("s6h real prompt missing/not human: %r" % (real,))
conv = next((c for c in rail.get("conversations", []) if c.get("session_id") == "s6"), None)
if conv is None:
    errs.append("s6 absent from rail")
elif conv.get("title") != "complete Session 6 — Search depth from issue #177":
    errs.append("s6 rail title not the clean real prompt: %r" % (conv.get("title"),))
if errs:
    sys.exit("; ".join(errs))
print("ok")
' 2>&1)
    if [ "$s6_check" != "ok" ]; then
        fail "reader command-marker fold + ANSI strip (#186): $s6_check (raw: $s6_raw)"
    fi

    # --- 2f) Reader + outline: cache-failure markers (spec §1/§2) ---------
    # s7 seeds a first-prime turn + a healthy turn + one MAIN-thread failure +
    # one SUBAGENT-thread failure. The kernel recomputes the flag per read inside
    # _assemble_session, so the reader carries `cache_failure` on exactly the two
    # failing turns and the outline carries the matching flag + a session-level
    # stats.cache_failures aggregate. Byte-stable goldens lock both payloads; the
    # structural asserts below pin the load-bearing fields independent of FTS5.
    fetch_and_diff "GET /api/conversation/s7" "golden-conversation-s7.json" \
        "$base/api/conversation/s7" "${LOOP[@]}"
    fetch_and_diff "GET /api/conversation/s7/outline" "golden-conversation-s7-outline.json" \
        "$base/api/conversation/s7/outline" "${LOOP[@]}"

    local s7_raw s7_outline_raw s7_check
    s7_raw=$(curl -s --max-time 5 "${LOOP[@]}" "$base/api/conversation/s7")
    s7_outline_raw=$(curl -s --max-time 5 "${LOOP[@]}" "$base/api/conversation/s7/outline")
    s7_check=$(D="$s7_raw" O="$s7_outline_raw" python3 -c '
import json, os, sys
d = json.loads(os.environ["D"])
o = json.loads(os.environ["O"])
errs = []
by = {it["anchor"]["uuid"]: it for it in (d.get("items") or [])}
# First prime + healthy turns are NOT flagged (absent, not zero).
for clean in ("s7a1", "s7a2", "s7g1"):
    if clean not in by:
        errs.append("missing item %r" % (clean,))
    elif "cache_failure" in by[clean]:
        errs.append("%r should NOT carry cache_failure" % (clean,))
# Main-thread failure on s7a3: lost = min(134000, 130000-0) = 130000.
m = by.get("s7a3", {})
mf = m.get("cache_failure")
if mf is None:
    errs.append("s7a3 missing cache_failure")
else:
    if mf.get("prev_cached") != 130000:
        errs.append("s7a3 prev_cached=%r != 130000" % (mf.get("prev_cached"),))
    if mf.get("tokens_recreated") != 130000:
        errs.append("s7a3 tokens_recreated=%r != 130000" % (mf.get("tokens_recreated"),))
    if not (mf.get("est_wasted_usd", 0.0) > 0):
        errs.append("s7a3 est_wasted_usd not > 0: %r" % (mf.get("est_wasted_usd"),))
# Subagent-thread failure on s7g2: keyed independently, lost=min(120000,80000-5000)=75000.
g = by.get("s7g2", {})
gf = g.get("cache_failure")
if gf is None:
    errs.append("s7g2 missing cache_failure")
else:
    if gf.get("prev_cached") != 80000:
        errs.append("s7g2 prev_cached=%r != 80000" % (gf.get("prev_cached"),))
    if gf.get("tokens_recreated") != 75000:
        errs.append("s7g2 tokens_recreated=%r != 75000" % (gf.get("tokens_recreated"),))
# Outline aggregate: exactly two failures, summed tokens + usd.
agg = (o.get("stats") or {}).get("cache_failures")
if agg is None:
    errs.append("outline stats.cache_failures missing")
else:
    if agg.get("count") != 2:
        errs.append("outline cache_failures.count=%r != 2" % (agg.get("count"),))
    if agg.get("tokens_recreated") != 205000:   # 130000 + 75000
        errs.append("outline cache_failures.tokens_recreated=%r != 205000"
                    % (agg.get("tokens_recreated"),))
    if not (agg.get("est_wasted_usd", 0.0) > 0):
        errs.append("outline cache_failures.est_wasted_usd not > 0: %r"
                    % (agg.get("est_wasted_usd"),))
# Outline turns copy the flag onto the matching turns.
ot = {t["uuid"]: t for t in (o.get("turns") or [])}
for fid in ("s7a3", "s7g2"):
    if "cache_failure" not in ot.get(fid, {}):
        errs.append("outline turn %r missing cache_failure" % (fid,))
if errs:
    sys.exit("; ".join(errs))
print("ok")
' 2>&1)
    if [ "$s7_check" != "ok" ]; then
        fail "cache-failure markers (spec §1/§2): $s7_check (raw: $s7_raw)"
    fi

    # --- 2g) Reader + outline: subagent viewer (spec §4 1a/1b/1c) ---------
    # s8 exercises the new Claude Code subagent format:
    #   * cc110001 — SYNC child (structured totals; regression — no totals_derived)
    #   * ace20002 — nested GRANDCHILD (1a: string-content result parsed for
    #     authoritative <usage> totals; 1b: parent_subagent_key == the child)
    #   * a55c0003 — ASYNC child (1c: status flips async_launched -> completed via
    #     the <task-notification> join; derived totals with totals_derived)
    #   * b0c40004 — truncated-(i) (1a links via agentId; <usage> clipped -> 1c
    #     derives totals with totals_derived)
    #   * toolu_trunc2 — truncated-(ii) (agentId clipped -> NO subagent_meta entry,
    #     no crash, the spawn stays a flat tool_call chip)
    # subagent_meta is shared by get_conversation + the outline, so the byte
    # goldens lock BOTH; the structural asserts pin the load-bearing fields.
    fetch_and_diff "GET /api/conversation/s8" "golden-conversation-s8.json" \
        "$base/api/conversation/s8" "${LOOP[@]}"
    fetch_and_diff "GET /api/conversation/s8/outline" "golden-conversation-s8-outline.json" \
        "$base/api/conversation/s8/outline" "${LOOP[@]}"

    local s8_raw s8_outline_raw s8_check
    s8_raw=$(curl -s --max-time 5 "${LOOP[@]}" "$base/api/conversation/s8")
    s8_outline_raw=$(curl -s --max-time 5 "${LOOP[@]}" "$base/api/conversation/s8/outline")
    s8_check=$(D="$s8_raw" O="$s8_outline_raw" python3 -c '
import json, os, sys
d = json.loads(os.environ["D"])
o = json.loads(os.environ["O"])
errs = []
sm = d.get("subagent_meta") or {}

# (1a + 1b) NESTED GRANDCHILD: parsed authoritative <usage> totals + parent
# linkage pointing at the CHILD (cross-file: parent_subagent_key == the child
# hash, spawn_uuid == the child item holding the spawn). NOT totals_derived
# (the <usage> wrapper survived the clip, so totals are authoritative).
gc = sm.get("ace20002")
if gc is None:
    errs.append("grandchild ace20002 missing from subagent_meta (1a parse failed)")
else:
    if gc.get("kind") != "grounding":
        errs.append("grandchild kind != grounding: %r" % (gc.get("kind"),))
    if gc.get("total_tokens") != 8400:
        errs.append("grandchild total_tokens != 8400: %r" % (gc.get("total_tokens"),))
    if gc.get("total_tool_use_count") != 5:
        errs.append("grandchild total_tool_use_count != 5: %r" % (gc.get("total_tool_use_count"),))
    if gc.get("total_duration_ms") != 9100:
        errs.append("grandchild total_duration_ms != 9100: %r" % (gc.get("total_duration_ms"),))
    if gc.get("status") != "completed":
        errs.append("grandchild status != completed: %r" % (gc.get("status"),))
    if gc.get("parent_subagent_key") != "cc110001":
        errs.append("grandchild parent_subagent_key != cc110001 (the child): %r"
                    % (gc.get("parent_subagent_key"),))
    if gc.get("spawn_tool_use_id") != "toolu_gc":
        errs.append("grandchild spawn_tool_use_id != toolu_gc: %r" % (gc.get("spawn_tool_use_id"),))
    if gc.get("spawn_uuid") != "ch_a1":
        errs.append("grandchild spawn_uuid != ch_a1 (holding item): %r" % (gc.get("spawn_uuid"),))
    if gc.get("totals_derived"):
        errs.append("grandchild wrongly marked totals_derived (parse was authoritative)")

# (1c) ASYNC child: status flips async_launched -> completed via the
# <task-notification> join; totals derived from its own thread + totals_derived.
ac = sm.get("a55c0003")
if ac is None:
    errs.append("async a55c0003 missing from subagent_meta")
else:
    if ac.get("status") != "completed":
        errs.append("async status did NOT flip to completed (1c notification join): %r"
                    % (ac.get("status"),))
    for f in ("total_tokens", "total_duration_ms", "total_tool_use_count"):
        if ac.get(f) is None:
            errs.append("async missing derived %s" % (f,))
    if ac.get("totals_derived") is not True:
        errs.append("async totals_derived != True: %r" % (ac.get("totals_derived"),))
    if ac.get("parent_subagent_key") is not None:
        errs.append("async parent_subagent_key != None (main): %r" % (ac.get("parent_subagent_key"),))
    if ac.get("spawn_uuid") != "s8a1":
        errs.append("async spawn_uuid != s8a1: %r" % (ac.get("spawn_uuid"),))
    if ac.get("spawn_tool_use_id") != "toolu_async":
        errs.append("async spawn_tool_use_id != toolu_async: %r" % (ac.get("spawn_tool_use_id"),))

# SYNC child (regression): authoritative totals, NO totals_derived; 1b linkage.
sc = sm.get("cc110001")
if sc is None:
    errs.append("sync child cc110001 missing from subagent_meta")
else:
    if sc.get("total_tokens") != 12000:
        errs.append("sync child total_tokens != 12000: %r" % (sc.get("total_tokens"),))
    if sc.get("status") != "completed":
        errs.append("sync child status != completed: %r" % (sc.get("status"),))
    if "totals_derived" in sc:
        errs.append("sync child wrongly carries totals_derived (authoritative totals)")
    if sc.get("spawn_tool_use_id") != "toolu_child":
        errs.append("sync child spawn_tool_use_id != toolu_child: %r" % (sc.get("spawn_tool_use_id"),))
    if sc.get("parent_subagent_key") is not None:
        errs.append("sync child parent_subagent_key != None: %r" % (sc.get("parent_subagent_key"),))

# (1a degrade) TRUNCATED-(i): agentId present, <usage> clipped -> links + derived.
tr1 = sm.get("b0c40004")
if tr1 is None:
    errs.append("truncated-(i) b0c40004 missing (agentId-present clip should still link)")
else:
    if tr1.get("totals_derived") is not True:
        errs.append("truncated-(i) totals_derived != True: %r" % (tr1.get("totals_derived"),))
    for f in ("total_tokens", "total_duration_ms", "total_tool_use_count"):
        if tr1.get(f) is None:
            errs.append("truncated-(i) missing derived %s" % (f,))
    if tr1.get("spawn_tool_use_id") != "toolu_trunc1":
        errs.append("truncated-(i) spawn_tool_use_id != toolu_trunc1: %r" % (tr1.get("spawn_tool_use_id"),))

# (1a degrade) TRUNCATED-(ii): agentId clipped -> NO subagent_meta entry (no
# mis-link, no crash). No meta references toolu_trunc2; the spawn stays a flat
# tool_call chip on s8a1 (NOT suppressed, since no nested card exists for it).
if any(m.get("spawn_tool_use_id") == "toolu_trunc2" for m in sm.values()):
    errs.append("truncated-(ii) toolu_trunc2 wrongly produced a subagent_meta entry")
by = {it["anchor"]["uuid"]: it for it in (d.get("items") or [])}
s8a1 = by.get("s8a1") or {}
spawn_calls = {b.get("tool_use_id") for b in (s8a1.get("blocks") or [])
               if b.get("kind") == "tool_call"}
if "toolu_trunc2" not in spawn_calls:
    errs.append("truncated-(ii) flat tool_call chip toolu_trunc2 missing from s8a1: %r"
                % (sorted(spawn_calls),))
if any(b.get("kind") == "tool_use" for b in (s8a1.get("blocks") or [])):
    errs.append("a bare tool_use survived the sweep on s8a1")

# No parser-only block keys (agent_id / subagent_meta) leak into any block.
for it in (d.get("items") or []):
    for b in it.get("blocks") or []:
        for leak in ("agent_id", "subagent_meta"):
            if leak in b:
                errs.append("block-shape leak: %r on %r" % (leak, it["anchor"].get("uuid")))

# The outline shares the SAME subagent_meta (no extra wiring) — every reader key
# is present on the outline byte-for-byte.
osm = o.get("subagent_meta") or {}
if osm != sm:
    errs.append("outline subagent_meta != reader subagent_meta (shared assembly broke)")

if errs:
    sys.exit("; ".join(errs))
print("ok")
' 2>&1)
    if [ "$s8_check" != "ok" ]; then
        fail "subagent viewer (spec §4 1a/1b/1c): $s8_check (raw: $s8_raw)"
    fi

    # --- 3) Search: deduped across replay to ONE hit ---------------------
    # Byte-exact golden only when FTS5 is present (the golden is FTS-shaped);
    # the structural asserts below run unconditionally.
    if [ "$FTS5_AVAILABLE" = "1" ]; then
        fetch_and_diff "GET /api/conversation/search" "golden-search.json" \
            "$base/api/conversation/search?q=$search_q" "${LOOP[@]}"
    else
        echo "SKIP $name search golden-diff: sqlite build lacks FTS5 (structural asserts still run)"
    fi

    local search_raw search_check
    search_raw=$(curl -s --max-time 5 "${LOOP[@]}" "$base/api/conversation/search?q=$search_q")
    search_check=$(printf '%s' "$search_raw" | python3 -c '
import json, sys
d = json.load(sys.stdin)
errs = []
hits = d.get("hits") or []
# The prose fragment is replayed across two source_paths — the multi-fragment
# turn must resolve to exactly ONE hit on (session_id, uuid).
if len(hits) != 1:
    errs.append("replay not deduped to ONE hit: %d" % (len(hits),))
else:
    h = hits[0]
    if h.get("session_id") != "s1" or h.get("uuid") != "a1b":
        errs.append("hit anchor != (s1, a1b): %r" % ((h.get("session_id"), h.get("uuid")),))
    if not (h.get("cost_usd", 0.0) > 0):
        errs.append("hit cost_usd not > 0: %r" % (h.get("cost_usd"),))
if d.get("total") != 1:
    errs.append("total != 1: %r" % (d.get("total"),))
if errs:
    sys.exit("; ".join(errs))
print("ok")
' 2>&1)
    if [ "$search_check" != "ok" ]; then
        fail "search dedup: $search_check (raw: $search_raw)"
    fi

    # --- 4) Gate: LAN-hostname Host → 403 on a loopback bind -------------
    # Default request (loopback Host) returns 200 — proving the route works and
    # the 403 below is the Host gate, not a broken route.
    local loop_code
    loop_code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 5 \
        "${LOOP[@]}" "$base/api/conversations")
    if [ "$loop_code" != "200" ]; then
        fail "gate: loopback-Host /api/conversations returned $loop_code (expected 200)"
    fi
    # LAN-hostname Host with expose unset (default false) → anti-DNS-rebinding
    # gate rejects with 403 EVEN on a loopback bind.
    local lan_code
    lan_code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 5 \
        -H "Host: $lan_host" "$base/api/conversations")
    if [ "$lan_code" != "403" ]; then
        fail "gate: LAN-hostname Host /api/conversations returned $lan_code (expected 403)"
    fi
    # The 403 body is the JSON gate shape, not a route 404.
    local lan_body lan_body_check
    lan_body=$(curl -s --max-time 5 -H "Host: $lan_host" "$base/api/conversations")
    lan_body_check=$(printf '%s' "$lan_body" | python3 -c '
import json, sys
try:
    d = json.load(sys.stdin)
except Exception as exc:
    sys.exit("403 body not JSON: %s" % (exc,))
if "error" not in d:
    sys.exit("403 body missing error key: %r" % (d,))
print("ok")
' 2>&1)
    if [ "$lan_body_check" != "ok" ]; then
        fail "gate: 403 body shape: $lan_body_check (raw: $lan_body)"
    fi

    # The gate also covers the reader + search routes (same _require helper).
    local lan_reader_code lan_search_code
    lan_reader_code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 5 \
        -H "Host: $lan_host" "$base/api/conversation/s1")
    if [ "$lan_reader_code" != "403" ]; then
        fail "gate: LAN-hostname Host /api/conversation/s1 returned $lan_reader_code (expected 403)"
    fi
    lan_search_code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 5 \
        -H "Host: $lan_host" "$base/api/conversation/search?q=$search_q")
    if [ "$lan_search_code" != "403" ]; then
        fail "gate: LAN-hostname Host /api/conversation/search returned $lan_search_code (expected 403)"
    fi
    # #177 S5: the /outline route shares the same _require_transcripts_allowed gate.
    local lan_outline_code
    lan_outline_code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 5 \
        -H "Host: $lan_host" "$base/api/conversation/s5/outline")
    if [ "$lan_outline_code" != "403" ]; then
        fail "gate: LAN-hostname Host /api/conversation/s5/outline returned $lan_outline_code (expected 403)"
    fi

    kill_server_bounded "$pid"

    if [ "$ok" = "1" ]; then
        echo "PASS $name"
        return 0
    fi
    return 1
}

# Single scenario, sequential.
for scenario in all-history; do
    if run_scenario "$scenario"; then
        pass_count=$((pass_count + 1))
    else
        fail_count=$((fail_count + 1))
    fi
done

echo
echo "passed: $pass_count   failed: $fail_count"
[ "$fail_count" = "0" ]
