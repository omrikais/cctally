#!/usr/bin/env bash
# Fixture-based validation harness for `blocks`.
#
# Walks tests/fixtures/blocks/*/input.env, runs two output
# modes (default terminal and --json) via the shared run_mode helper
# (bin/_lib-fixture-harness.sh), and diffs each against the corresponding
# golden file. Exits 0 on all-pass, 1 on any diff.
#
# Uses CCTALLY_AS_OF (via the shared lib's TZ=Etc/UTC env block) to pin
# "now" for deterministic output. The shared lib injects NO_COLOR=1 and
# TZ=Etc/UTC on every invocation.

set -uo pipefail

REPO_ROOT=$(cd "$(dirname "$0")/.." && pwd)

HARNESS_SUBCOMMAND="blocks"
HARNESS_FIXTURES_DIR="$REPO_ROOT/tests/fixtures/blocks"
HARNESS_BIN="$REPO_ROOT/bin/cctally"

# Per-run scratch dir for the regenerated fixture DBs and any test-process
# SQLite writes. Keeps the in-tree fixture .db files byte-stable across
# harness runs (the builder is host-deterministic but produces different
# bytes on different hosts/sqlite versions). HARNESS_FAKE_HOME_BASE
# redirects FAKE_HOME in _lib-fixture-harness.sh; input.env / golden-*.txt
# are still read from the in-tree HARNESS_FIXTURES_DIR.
SCRATCH_DIR=$(mktemp -d -t cctally-blocks-fixtures-XXXXXX)
trap 'rm -rf "$SCRATCH_DIR"' EXIT
export HARNESS_FAKE_HOME_BASE="$SCRATCH_DIR"

# Regenerate seeded fixture DBs into the scratch dir so goldens always
# check against reproducible state without dirtying the tree.
"$REPO_ROOT/bin/build-blocks-fixtures.py" --out "$SCRATCH_DIR" >/dev/null || {
    echo "FAIL: build-blocks-fixtures.py crashed (exit $?)" >&2
    exit 1
}

# shellcheck disable=SC1091
. "$REPO_ROOT/bin/_lib-fixture-harness.sh"

pass_count=0
fail_count=0

for dir in "$HARNESS_FIXTURES_DIR"/*/; do
    name=$(basename "$dir")
    run_mode "$name" "terminal" ""       "terminal"
    run_mode "$name" "json"     "--json" "json"
done

echo "----"
echo "passed: $pass_count   failed: $fail_count"
[ "$fail_count" -eq 0 ]
