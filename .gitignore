.DS_Store
*.log
.idea/
__pycache__/
.worktrees/
.superpowers/
.agents/
# Ignore everything in .claude/ EXCEPT the project-scoped skills + agents trees
# (which are tracked so skill/agent definitions survive fresh clones / propagate
# to CI). Use `.claude/*` rather than `.claude/` so git still traverses
# into the directory; a bare `.claude/` would prevent the re-include.
# __pycache__ and .DS_Store stay ignored via the top-of-file rules.
.claude/*
!.claude/skills/
!.claude/agents/
# Re-include fixture scaffolding under setup test fixtures (gitignore '.claude/' matches anywhere)
!tests/fixtures/setup/*/input/.claude/
!tests/fixtures/setup/*/input/.claude/**

# Fixture runtime artifacts — the lock file, config, logs, and SQLite WAL/SHM
# sidecars regenerate on every harness run and are never committed. (The
# consumed-from-tree dashboard/share/migrations/doctor/projects fixtures DO
# commit their stats.db/cache.db; the scratch-rebuild suites do not — see the
# block below and #97.)
cache.db*.lock
cache.db-wal
cache.db-shm
stats.db-wal
stats.db-shm
tests/fixtures/*/*/.local/share/ccusage-subscription/config.json
tests/fixtures/*/*/.local/share/ccusage-subscription/logs/
tests/fixtures/*/*/.local/share/cctally/config.json
tests/fixtures/*/*/.local/share/cctally/logs/

# Scratch-rebuild harness suites: their {stats,cache}.db are NEVER read — the
# harness rebuilds fresh into a `--out <scratch>` dir on every run (see #97), so
# committed copies drift silently to stale schemas with no test catching it.
# Don't track them; `bin/build-<cmd>-fixtures.py` regenerates on demand. The
# consumed-from-tree fixtures (dashboard, share, migrations + per-migration
# goldens, doctor, projects) are deliberately absent here — their committed
# .db ARE the test input and stay tracked.
tests/fixtures/alerts/*/.local/share/cctally/*.db
tests/fixtures/blocks/*/.local/share/cctally/*.db
tests/fixtures/cache-report/*/.local/share/cctally/*.db
tests/fixtures/codex-daily/*/.local/share/cctally/*.db
tests/fixtures/codex-monthly/*/.local/share/cctally/*.db
tests/fixtures/codex-session/*/.local/share/cctally/*.db
tests/fixtures/codex-weekly/*/.local/share/cctally/*.db
tests/fixtures/diff/*/.local/share/cctally/*.db
tests/fixtures/forecast/*/.local/share/cctally/*.db
tests/fixtures/project/*/.local/share/cctally/*.db
tests/fixtures/session/*/.local/share/cctally/*.db
tests/fixtures/weekly/*/.local/share/cctally/*.db

# === npm root install pollution ===
# `package.json` at the repo root is the npm-publish sentinel; npm's natural
# workflow puts `node_modules/` and `package-lock.json` next to it on any
# `npm install <pkg>` from root. Anchor to root so dashboard/web's legitimate
# Vite/React deps (handled by dashboard/web/.gitignore) stay untouched.
/node_modules
/package-lock.json

# === Browser-MCP / manual-smoke artifacts ===
# Playwright MCP writes a page snapshot + console log to .playwright-mcp/
# on every browser interaction during share-v2 smoke passes (M1.20+).
# Tool-generated; regenerated every session.
.playwright-mcp/
# Ad-hoc smoke screenshots saved at the repo root during manual share-v2
# smoke testing (M1.20 + follow-up passes). `smoke*` matches both the
# first-pass `share-v2-smoke-N-...` and second-pass `share-v2-smoke2-N-...`
# naming. Anchored to root so an intentional asset elsewhere (e.g.,
# docs/) isn't accidentally dropped.
/share-v2-smoke*.png
baseline/
