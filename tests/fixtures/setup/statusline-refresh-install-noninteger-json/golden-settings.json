{
  "statusLine": {
    "type": "command",
    "command": "cctally statusline",
    "refreshInterval": "fast"
  },
  "hooks": {
    "PostToolBatch": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/REPO/bin/cctally hook-tick"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/REPO/bin/cctally hook-tick"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/REPO/bin/cctally hook-tick"
          }
        ]
      }
    ]
  }
}
