{
  "hooks": {
    "PostToolBatch": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/FAKE/opt/homebrew/bin/cctally hook-tick"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/FAKE/opt/homebrew/bin/cctally hook-tick"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/FAKE/opt/homebrew/bin/cctally hook-tick"
          }
        ]
      }
    ]
  }
}
